import { BodyEditorPanel } from "body_panel.slint";
import { KeyValueTableRow } from "types.slint";

export component RequestBodyTabHost inherits BodyEditorPanel {
    in-out property <string> workspace_body_mode;
    in-out property <string> workspace_raw_body_subtype;
    in-out property <string> workspace_request_body;
    in-out property <[KeyValueTableRow]> workspace_body_field_rows;
    in-out property <string> workspace_form_file_field;
    in-out property <string> workspace_form_file_path;
    in-out property <string> workspace_graphql_variables;
    in property <bool> workspace_busy;
    callback workspace_body_mode_changed(string);
    callback workspace_add_body_field();
    callback workspace_add_body_file_field(string, string);
    callback workspace_pick_form_file();
    callback workspace_update_body_field_row(int, string, string);
    callback workspace_delete_body_field_row(int);
    callback workspace_apply_graphql_template(string);

    body_mode <=> root.workspace_body_mode;
    raw_body_subtype <=> root.workspace_raw_body_subtype;
    request_body <=> root.workspace_request_body;
    body_field_rows <=> root.workspace_body_field_rows;
    form_file_field <=> root.workspace_form_file_field;
    form_file_path <=> root.workspace_form_file_path;
    graphql_variables <=> root.workspace_graphql_variables;
    busy: root.workspace_busy;
    body_mode_changed(mode) => {
        root.workspace_body_mode_changed(mode);
    }
    add_body_field => {
        root.workspace_add_body_field();
    }
    add_body_file_field(field, path) => {
        root.workspace_add_body_file_field(field, path);
    }
    pick_form_file => {
        root.workspace_pick_form_file();
    }
    update_body_field_row(row_id, key, value) => {
        root.workspace_update_body_field_row(row_id, key, value);
    }
    delete_body_field_row(row_id) => {
        root.workspace_delete_body_field_row(row_id);
    }
    apply_graphql_template(template) => {
        root.workspace_apply_graphql_template(template);
    }
}
