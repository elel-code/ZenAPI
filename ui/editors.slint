import { ScrollView } from "std-widgets.slint";
import { Theme } from "theme.slint";
import { UiText } from "widgets.slint";

export component CodePane inherits Rectangle {
    in-out property <string> text;
    in property <bool> read_only;
    callback selection_changed(int, int);

    horizontal-stretch: 1;
    vertical-stretch: 1;
    border-radius: 8px;
    border-width: 1px;
    border-color: Theme.outline_variant;
    background: Theme.surface_container_lowest;

    ScrollView {
        x: 1px;
        y: 1px;
        width: parent.width - 2px;
        height: parent.height - 2px;
        viewport-width: max(self.visible-width, code_input.preferred-width + 28px);
        viewport-height: max(self.visible-height, code_input.preferred-height + 24px);
        vertical-scrollbar-policy: ScrollBarPolicy.as-needed;
        horizontal-scrollbar-policy: ScrollBarPolicy.as-needed;

        code_input := TextInput {
            x: 14px;
            y: 12px;
            width: max(parent.visible-width - 28px, self.preferred-width);
            height: max(parent.visible-height - 24px, self.preferred-height);
            text <=> root.text;
            read-only: root.read_only;
            single-line: false;
            wrap: word-wrap;
            font-family: "JetBrains Mono";
            font-size: 13px;
            font-weight: 400;
            letter-spacing: 0px;
            color: Theme.on_surface;
            selection-background-color: Theme.primary_container;
            selection-foreground-color: Theme.on_surface;
            text-cursor-width: root.read_only ? 0px : 2px;
            cursor-position-changed(_) => {
                root.selection_changed(code_input.anchor-position-byte-offset, code_input.cursor-position_byte-offset);
            }
        }
    }
}

export component ReadOnlyCodeBlock inherits Rectangle {
    in property <string> text;

    horizontal-stretch: 1;
    vertical-stretch: 1;
    border-radius: 8px;
    border-width: 1px;
    border-color: Theme.outline_variant;
    background: Theme.surface_container_lowest;

    ScrollView {
        x: 1px;
        y: 1px;
        width: parent.width - 2px;
        height: parent.height - 2px;
        viewport-width: max(self.visible-width, code_text.preferred-width + 28px);
        viewport-height: max(self.visible-height, code_text.preferred-height + 24px);
        vertical-scrollbar-policy: ScrollBarPolicy.as-needed;
        horizontal-scrollbar-policy: ScrollBarPolicy.as-needed;

        code_text := UiText {
            x: 14px;
            y: 12px;
            width: max(parent.visible-width - 28px, self.preferred-width);
            height: max(parent.visible-height - 24px, self.preferred-height);
            text: root.text;
            font-family: "JetBrains Mono";
            font-size: 13px;
            font-weight: 400;
            letter-spacing: 0px;
            color: Theme.on_surface;
            wrap: word-wrap;
            vertical-alignment: top;
        }
    }
}

export component LabeledEditor inherits Rectangle {
    in-out property <string> text;
    in property <string> label;
    in property <bool> read_only: false;

    horizontal-stretch: 1;
    vertical-stretch: 1;
    background: transparent;

    VerticalLayout {
        padding: 0px;
        spacing: 6px;

        UiText {
            text: root.label;
            height: 20px;
            horizontal-stretch: 1;
            color: Theme.on_surface_variant;
            font-size: 12px;
            font-weight: 800;
            vertical-alignment: center;
            overflow: elide;
        }

        CodePane {
            text <=> root.text;
            read_only: root.read_only;
        }
    }
}
