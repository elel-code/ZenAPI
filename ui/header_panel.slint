import { KeyValueTablePanel } from "key_value_table_panel.slint";
import { Theme } from "theme.slint";
import { KeyValueTableRow } from "types.slint";
import { ActionButton, TextField, UiText } from "widgets.slint";

export component HeaderEditorPanel inherits Rectangle {
    in-out property <string> request_headers;
    in-out property <[KeyValueTableRow]> header_rows;
    in-out property <string> header_import_path;
    in property <bool> busy;
    callback apply_header_preset(string);
    callback add_header();
    callback paste_headers();
    callback import_headers(string);
    callback pick_header_import_file();
    callback update_header_row(int, string, string);
    callback delete_header_row(int);
    callback copy_headers();

    horizontal-stretch: 1;
    vertical-stretch: 1;
    background: transparent;

    VerticalLayout {
        padding: 0px;
        spacing: 6px;

        HorizontalLayout {
            height: 22px;
            spacing: 6px;
            alignment: center;

            UiText {
                text: "Headers";
                horizontal-stretch: 1;
                height: parent.height;
                color: Theme.on_surface_variant;
                font-size: 12px;
                font-weight: 800;
                vertical-alignment: center;
                overflow: elide;
            }

            ActionButton {
                text: "Accept";
                button_width: 58px;
                enabled: !root.busy;
                clicked => {
                    root.apply_header_preset("accept-json");
                }
            }

            ActionButton {
                text: "Content";
                button_width: 64px;
                enabled: !root.busy;
                clicked => {
                    root.apply_header_preset("content-json");
                }
            }

            ActionButton {
                text: "Bearer";
                button_width: 60px;
                enabled: !root.busy;
                clicked => {
                    root.apply_header_preset("bearer-token");
                }
            }

            ActionButton {
                text: "Copy";
                button_width: 54px;
                enabled: root.request_headers != "";
                clicked => {
                    root.copy_headers();
                }
            }

            ActionButton {
                text: "Paste";
                button_width: 58px;
                enabled: !root.busy;
                clicked => {
                    root.paste_headers();
                }
            }
        }

        HorizontalLayout {
            height: 34px;
            spacing: 8px;

            TextField {
                text <=> root.header_import_path;
                placeholder: "header file path";
                mono: true;
                enabled: !root.busy;
            }

            ActionButton {
                text: "Open";
                button_width: 54px;
                enabled: !root.busy;
                clicked => {
                    root.pick_header_import_file();
                }
            }

            ActionButton {
                text: "Import";
                button_width: 68px;
                enabled: !root.busy && root.header_import_path != "";
                clicked => {
                    root.import_headers(root.header_import_path);
                }
            }
        }

        KeyValueTablePanel {
            rows <=> root.header_rows;
            title: "";
            key_header: "Header";
            value_header: "Value";
            helper: "Stored as Header=value lines; presets update common headers.";
            busy: root.busy;
            add_row => {
                root.add_header();
            }
            update_row(row_id, key, value) => {
                root.update_header_row(row_id, key, value);
            }
            delete_row(row_id) => {
                root.delete_header_row(row_id);
            }
        }
    }
}
