import { Theme } from "theme.slint";
import { TextField } from "text_field.slint";
import { ActionButton } from "action_button.slint";

export component TestAssertionLine inherits Rectangle {
    in property <int> row_id;
    in-out property <string> kind;
    in-out property <string> target;
    in-out property <string> expected;
    in property <bool> enabled: true;
    callback edited(int, string, string, string);
    callback cycle_kind_requested(int, string);
    callback delete_requested(int);

    height: 44px;
    horizontal-stretch: 1;
    border-radius: 6px;
    border-width: 1px;
    border-color: Theme.outline_variant;
    background: row_touch.has-hover ? Theme.surface_container_high : Theme.surface_container_low;

    row_touch := TouchArea {}

    ActionButton {
        x: 10px;
        y: 5px;
        text: "Kind";
        button_width: 52px;
        enabled: root.enabled;
        clicked => {
            root.cycle_kind_requested(root.row_id, root.kind);
        }
    }

    TextField {
        x: 70px;
        y: 5px;
        width: 116px;
        height: 34px;
        text <=> root.kind;
        placeholder: "status_equals";
        mono: true;
        enabled: root.enabled;
        edited => {
            root.edited(root.row_id, root.kind, root.target, root.expected);
        }
    }

    TextField {
        x: 198px;
        y: 5px;
        width: 118px;
        height: 34px;
        text <=> root.target;
        placeholder: "target";
        mono: true;
        enabled: root.enabled;
        edited => {
            root.edited(root.row_id, root.kind, root.target, root.expected);
        }
    }

    TextField {
        x: 328px;
        y: 5px;
        width: parent.width - 392px;
        height: 34px;
        text <=> root.expected;
        placeholder: "expected";
        mono: true;
        enabled: root.enabled;
        edited => {
            root.edited(root.row_id, root.kind, root.target, root.expected);
        }
    }

    ActionButton {
        x: parent.width - 54px;
        y: 5px;
        text: "Del";
        button_width: 44px;
        warning: true;
        enabled: root.enabled;
        clicked => {
            root.delete_requested(root.row_id);
        }
    }
}
