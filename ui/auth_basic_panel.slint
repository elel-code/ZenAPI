import { Theme } from "theme.slint";
import { TextField } from "text_field.slint";
import { UiText } from "widgets.slint";

export component AuthBasicPanel inherits Rectangle {
    in-out property <string> username;
    in-out property <string> password;
    in property <bool> busy;
    callback update_basic_auth(string, string);

    height: 98px;
    horizontal-stretch: 1;
    background: transparent;

    VerticalLayout {
        padding: 0px;
        spacing: 8px;

        UiText {
            text: "Basic Credentials";
            height: 20px;
            horizontal-stretch: 1;
            color: Theme.on_surface_variant;
            font-size: 12px;
            font-weight: 800;
            vertical-alignment: center;
            overflow: elide;
        }

        HorizontalLayout {
            height: 36px;
            spacing: 10px;

            TextField {
                text <=> root.username;
                placeholder: "username";
                mono: true;
                enabled: !root.busy;
                edited => {
                    root.update_basic_auth(root.username, root.password);
                }
                accepted => {
                    root.update_basic_auth(root.username, root.password);
                }
            }

            TextField {
                text <=> root.password;
                placeholder: "password";
                mono: true;
                enabled: !root.busy;
                edited => {
                    root.update_basic_auth(root.username, root.password);
                }
                accepted => {
                    root.update_basic_auth(root.username, root.password);
                }
            }
        }

        UiText {
            text: "Saved as username:password and base64 encoded before sending.";
            height: 18px;
            horizontal-stretch: 1;
            color: Theme.outline;
            font-size: 12px;
            vertical-alignment: center;
            overflow: elide;
        }
    }
}
