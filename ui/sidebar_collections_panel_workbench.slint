import { Theme } from "theme.slint";
import { ActionButton } from "action_button.slint";
import { CollectionRow, RouteRow } from "types.slint";
import { UiText } from "widgets.slint";
import { SidebarFolderRow } from "sidebar_rows.slint";
import { SidebarCollectionFilePanel } from "sidebar_collection_file_panel.slint";
import { SidebarCollectionFolderControls } from "sidebar_collection_folder_controls.slint";
import { SidebarCollectionRequestControls } from "sidebar_collection_request_controls.slint";
import { SidebarCollectionTree } from "sidebar_collection_tree.slint";

export component SidebarCollectionsPanelWorkbench inherits Rectangle {
    in property <[RouteRow]> routes;
    in property <[CollectionRow]> collection_rows;
    in-out property <int> selected_route;
    in-out property <int> selected_collection_request;
    in-out property <string> selected_collection_folder;
    in-out property <string> collection_move_target_label;
    in-out property <string> collection_request_name;
    in-out property <string> collection_folder_name;
    in-out property <string> collection_name;
    in-out property <string> collection_path;
    in property <string> collection_status;
    in property <int> total_route_count;
    in property <bool> busy;
    callback select_route(int);
    callback select_collection_request(int);
    callback rename_collection_request(int, string);
    callback duplicate_collection_request(int);
    callback delete_collection_request(int);
    callback move_collection_request(int, string);
    callback reorder_collection_request(int, int);
    callback import_collection(string);
    callback add_collection_folder(string);
    callback rename_collection_folder(string, string);
    callback delete_collection_folder(string);
    callback reorder_collection_folder(string, int);
    callback save_current_request();
    callback pick_collection_import_file();
    callback pick_collection_save_path();
    callback pick_postman_collection_path();

    horizontal-stretch: 1;
    vertical-stretch: 1;
    background: transparent;

    VerticalLayout {
        padding: 0px;
        spacing: 8px;

        HorizontalLayout {
            height: 24px;
            spacing: 8px;
            alignment: center;

            UiText {
                text: "COLLECTIONS";
                horizontal-stretch: 1;
                height: parent.height;
                color: Theme.on_surface_variant;
                font-size: 12px;
                font-weight: 800;
                vertical-alignment: center;
                overflow: elide;
            }

            ActionButton {
                text: "+";
                button_width: 30px;
                enabled: !root.busy;
                clicked => {
                    root.save_current_request();
                }
            }
        }

        SidebarFolderRow {
            label: root.collection_name == "" ? "Collection" : root.collection_name;
            selected: root.selected_collection_folder == "" && root.selected_collection_request < 0;
            interactive: true;
            picked => {
                root.selected_collection_folder = "";
                root.collection_move_target_label = root.collection_name == "" ? "Collection" : root.collection_name;
                root.selected_collection_request = -1;
                root.collection_request_name = "";
            }
        }

        SidebarCollectionFilePanel {
            collection_path <=> root.collection_path;
            collection_status: root.collection_status;
            busy: root.busy;
            import_collection(path) => {
                root.import_collection(path);
            }
            pick_collection_import_file => {
                root.pick_collection_import_file();
            }
            pick_collection_save_path => {
                root.pick_collection_save_path();
            }
            pick_postman_collection_path => {
                root.pick_postman_collection_path();
            }
        }

        SidebarCollectionFolderControls {
            selected_collection_folder <=> root.selected_collection_folder;
            collection_move_target_label <=> root.collection_move_target_label;
            collection_folder_name <=> root.collection_folder_name;
            busy: root.busy;
            add_collection_folder(name) => {
                root.add_collection_folder(name);
            }
            rename_collection_folder(folder_path, name) => {
                root.rename_collection_folder(folder_path, name);
            }
            delete_collection_folder(folder_path) => {
                root.delete_collection_folder(folder_path);
            }
            reorder_collection_folder(folder_path, delta) => {
                root.reorder_collection_folder(folder_path, delta);
            }
        }

        SidebarCollectionTree {
            routes: root.routes;
            collection_rows: root.collection_rows;
            selected_route <=> root.selected_route;
            selected_collection_request <=> root.selected_collection_request;
            selected_collection_folder <=> root.selected_collection_folder;
            collection_move_target_label <=> root.collection_move_target_label;
            collection_request_name <=> root.collection_request_name;
            total_route_count: root.total_route_count;
            select_route(index) => {
                root.select_route(index);
            }
            select_collection_request(id) => {
                root.select_collection_request(id);
            }
        }

        SidebarCollectionRequestControls {
            selected_collection_request <=> root.selected_collection_request;
            selected_collection_folder <=> root.selected_collection_folder;
            collection_move_target_label <=> root.collection_move_target_label;
            collection_request_name <=> root.collection_request_name;
            busy: root.busy;
            rename_collection_request(row_id, name) => {
                root.rename_collection_request(row_id, name);
            }
            duplicate_collection_request(row_id) => {
                root.duplicate_collection_request(row_id);
            }
            delete_collection_request(row_id) => {
                root.delete_collection_request(row_id);
            }
            move_collection_request(row_id, folder_path) => {
                root.move_collection_request(row_id, folder_path);
            }
            reorder_collection_request(row_id, delta) => {
                root.reorder_collection_request(row_id, delta);
            }
        }
    }
}
