import { Theme } from "theme.slint";
import { ResponseTab } from "tab_controls.slint";

export component ResponseTabStrip inherits Rectangle {
    in-out property <string> active_tab;
    callback picked(string);

    height: 44px;
    horizontal-stretch: 1;
    background: Theme.surface_container_low;

    HorizontalLayout {
        padding-left: 12px;
        padding-right: 12px;
        spacing: 8px;
        alignment: center;

        for item in [
            { mode: "pretty", label: "Pretty" },
            { mode: "raw", label: "Raw" },
            { mode: "headers", label: "Headers" },
            { mode: "cookies", label: "Cookies" },
        ]: ResponseTab {
            mode: item.mode;
            label: item.label;
            selected: root.active_tab == item.mode;
            picked(mode) => {
                root.active_tab = mode;
                root.picked(mode);
            }
        }
    }
}
