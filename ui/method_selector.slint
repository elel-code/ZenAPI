import { MethodChip } from "status_components.slint";
import { Theme } from "theme.slint";

component MethodOption inherits Rectangle {
    in property <string> value;
    in property <bool> selected;
    callback picked(string);

    height: 32px;
    horizontal-stretch: 1;
    border-radius: 6px;
    background: root.selected ? Theme.surface_variant : option_touch.has-hover ? Theme.surface_container_high : Theme.surface_container;

    option_touch := TouchArea {
        mouse-cursor: pointer;
        clicked => {
            root.picked(root.value);
        }
    }

    MethodChip {
        x: 8px;
        y: 5px;
        method: root.value;
    }
}

export component MethodSelector inherits Rectangle {
    in-out property <string> method;
    in property <bool> enabled: true;

    width: 100px;
    height: 38px;
    background: root.enabled && touch.has-hover ? Theme.surface_container_high : Theme.surface_container_lowest;

    touch := TouchArea {
        enabled: root.enabled;
        mouse-cursor: root.enabled ? pointer : default;
        clicked => {
            method_popup.show();
        }
    }

    MethodChip {
        x: 12px;
        y: 8px;
        method: root.method;
    }

    Text {
        x: parent.width - 26px;
        text: "v";
        width: 14px;
        height: parent.height;
        color: Theme.outline;
        font-family: "Inter";
        font-size: 13px;
        font-weight: 500;
        horizontal-alignment: center;
        vertical-alignment: center;
        letter-spacing: 0px;
    }

    Rectangle {
        x: parent.width - 1px;
        width: 1px;
        height: parent.height;
        background: Theme.outline_variant;
    }

    method_popup := PopupWindow {
        x: 0px;
        y: root.height + 6px;
        width: root.width;
        height: 236px;
        close-policy: close-on-click-outside;

        Rectangle {
            width: parent.width;
            height: parent.height;
            background: Theme.surface_container;
            border-radius: 8px;
            border-width: 1px;
            border-color: Theme.outline_variant;
            clip: true;

            VerticalLayout {
                padding: 6px;
                spacing: 2px;

                for name in ["GET", "POST", "PUT", "PATCH", "DELETE", "HEAD", "OPTIONS"]: MethodOption {
                    value: name;
                    selected: root.method == name;
                    picked(value) => {
                        root.method = value;
                        method_popup.close();
                    }
                }
            }
        }
    }
}
