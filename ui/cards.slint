import { Theme } from "theme.slint";
import { MethodChip } from "status_components.slint";
import { UiText } from "widgets.slint";

export component MetricCard inherits Rectangle {
    in property <string> label;
    in property <string> value;
    in property <string> detail;

    height: 104px;
    horizontal-stretch: 1;
    border-radius: 8px;
    border-width: 1px;
    border-color: Theme.outline_variant;
    background: Theme.surface_container;

    VerticalLayout {
        padding: 16px;
        spacing: 8px;

        UiText {
            text: root.label;
            height: 16px;
            horizontal-stretch: 1;
            color: Theme.on_surface_variant;
            font-size: 11px;
            font-weight: 800;
            vertical-alignment: center;
            overflow: elide;
        }

        UiText {
            text: root.value;
            height: 34px;
            horizontal-stretch: 1;
            color: Theme.on_surface;
            font-size: 28px;
            font-weight: 800;
            vertical-alignment: center;
            overflow: elide;
        }

        UiText {
            text: root.detail;
            height: 18px;
            horizontal-stretch: 1;
            color: Theme.outline;
            font-size: 12px;
            vertical-alignment: center;
            overflow: elide;
        }
    }
}

export component DataPanel inherits Rectangle {
    in property <string> title;
    in property <string> body;

    horizontal-stretch: 1;
    vertical-stretch: 1;
    border-radius: 8px;
    border-width: 1px;
    border-color: Theme.outline_variant;
    background: Theme.surface_container;

    VerticalLayout {
        padding: 16px;
        spacing: 10px;

        UiText {
            text: root.title;
            height: 24px;
            horizontal-stretch: 1;
            color: Theme.on_surface;
            font-size: 15px;
            font-weight: 800;
            vertical-alignment: center;
            overflow: elide;
        }

        UiText {
            text: root.body;
            horizontal-stretch: 1;
            vertical-stretch: 1;
            color: Theme.on_surface_variant;
            font-family: "JetBrains Mono";
            font-size: 12px;
            vertical-alignment: top;
            overflow: elide;
        }
    }
}

export component MockLogLine inherits Rectangle {
    in property <string> method;
    in property <string> path;
    in property <string> status;

    height: 38px;
    horizontal-stretch: 1;
    background: touch.has-hover ? Theme.surface_container_high : transparent;
    border-radius: 6px;

    touch := TouchArea {}

    UiText {
        x: 10px;
        text: root.status;
        width: 34px;
        height: parent.height;
        font-family: "JetBrains Mono";
        font-size: 11px;
        font-weight: 800;
        color: root.status == "500" || root.status == "404" || root.status == "401" ? Theme.error : Theme.secondary;
        vertical-alignment: center;
        overflow: elide;
    }

    MethodChip {
        x: 52px;
        y: 8px;
        method: root.method;
    }

    UiText {
        x: 122px;
        text: root.path;
        width: parent.width - 132px;
        height: parent.height;
        font-family: "JetBrains Mono";
        font-size: 12px;
        color: Theme.on_surface_variant;
        vertical-alignment: center;
        overflow: elide;
    }
}
