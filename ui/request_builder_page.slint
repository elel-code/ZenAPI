        Rectangle {
            width: root.divider_width;
            background: Theme.outline_variant;
        }

        ResponsePanel {
            width: root.response_width;
            response_body <=> root.response_body;
            response_raw_body <=> root.response_raw_body;
            response_headers <=> root.response_headers;
            response_cookies <=> root.response_cookies;
            folded_response_body <=> root.folded_response_body;
            folded_response_raw_body <=> root.folded_response_raw_body;
            folded_response_headers <=> root.folded_response_headers;
            folded_response_cookies <=> root.folded_response_cookies;
            codegen_language <=> root.codegen_language;
            codegen_output <=> root.codegen_output;
            codegen_path <=> root.codegen_path;
            runner_rows <=> root.runner_rows;
            runner_summary <=> root.runner_summary;
            runner_delay_ms <=> root.runner_delay_ms;
            runner_report_path <=> root.runner_report_path;
            runner_report_format <=> root.runner_report_format;
            runner_stop_on_failure <=> root.runner_stop_on_failure;
