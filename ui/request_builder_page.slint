            response_meta: root.response_meta;
            response_time: root.response_time;
            response_size: root.response_size;
            response_tone: root.response_tone;
            busy: root.busy;
            generate_code => {
                root.generate_code();
            }
            save_codegen(path) => {
                root.save_codegen(path);
            }
            pick_codegen_path => {
                root.pick_codegen_path();
            }
            run_collection => {
                root.run_collection();
            }
            cancel_collection_run => {
                root.cancel_collection_run();
            }
            save_runner_report(path) => {
                root.save_runner_report(path);
            }
            pick_runner_report_path => {
                root.pick_runner_report_path();
            }
            copy_response(tab, text, anchor, cursor) => {
                root.copy_response(tab, text, anchor, cursor);
            }
            format_response(tab) => {
                root.format_response(tab);
            }
            summarize_graphql_schema(tab, text) => {
                root.summarize_graphql_schema(tab, text);
            }
        }
    }
