import { Theme } from "theme.slint";
import { RouteRow } from "types.slint";
import { DocumentationDetailPanel } from "documentation_detail_panel.slint";
import { DocumentationSidebarPanel } from "documentation_sidebar_panel.slint";
import { DocumentationTryItPanel } from "documentation_try_it_panel.slint";

export component DocumentationPage inherits Rectangle {
    in property <[RouteRow]> routes;
    in-out property <int> selected_route;
    in property <string> method;
    in-out property <string> url;
    in property <string> auth_mode;
    in property <bool> busy;
    callback select_route(int);
    callback send_request();

    horizontal-stretch: 1;
    vertical-stretch: 1;
    background: Theme.background;

    HorizontalLayout {
        spacing: 0px;

        DocumentationSidebarPanel {
            routes: root.routes;
            selected_route <=> root.selected_route;
            select_route(index) => {
                root.select_route(index);
            }
        }

        Rectangle {
            width: 1px;
            background: Theme.outline_variant;
        }

        DocumentationDetailPanel {
            route_count: root.routes.length;
            method: root.method;
            url: root.url;
        }

        DocumentationTryItPanel {
            route_count: root.routes.length;
            method: root.method;
            url <=> root.url;
            auth_mode: root.auth_mode;
            busy: root.busy;
            send_request => {
                root.send_request();
            }
        }
    }
}
