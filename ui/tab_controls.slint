    tab_touch := TouchArea {
        mouse-cursor: pointer;
        clicked => {
            root.picked(root.mode);
        }
    }

    Text {
        text: root.label;
        width: parent.width;
        height: parent.height - 2px;
        color: root.selected ? Theme.primary : (tab_touch.has-hover ? Theme.on_surface : Theme.on_surface_variant);
        font-family: "Inter";
        font-size: 13px;
        font-weight: root.selected ? 800 : 600;
        horizontal-alignment: center;
        vertical-alignment: center;
        overflow: elide;
        letter-spacing: 0px;
    }

    Rectangle {
