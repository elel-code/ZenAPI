import { DataPanel } from "cards.slint";
import { KeyValueTableRow } from "types.slint";
import { AuthApiKeyPanel } from "auth_api_key_panel.slint";
import { AuthBasicPanel } from "auth_basic_panel.slint";
import { AuthModeToolbar } from "auth_mode_toolbar.slint";
import { AuthOAuth2Panel } from "auth_oauth2_panel.slint";
import { AuthTokenPanel } from "auth_token_panel.slint";

export component AuthEditorPanel inherits Rectangle {
    in-out property <string> auth_mode;
    in-out property <string> auth_config;
    in-out property <string> auth_basic_username;
    in-out property <string> auth_basic_password;
    in-out property <[KeyValueTableRow]> auth_key_rows;
    in property <bool> busy;
    callback auth_mode_changed(string);
    callback update_basic_auth(string, string);
    callback add_auth_key();
    callback update_auth_key_row(int, string, string);
    callback delete_auth_key_row(int);
    callback fetch_oauth2_token();

    horizontal-stretch: 1;
    vertical-stretch: 1;
    background: transparent;

    VerticalLayout {
        padding: 0px;
        spacing: 12px;

        AuthModeToolbar {
            auth_mode <=> root.auth_mode;
            busy: root.busy;
            auth_mode_changed(mode) => {
                root.auth_mode_changed(mode);
            }
        }

        if root.auth_mode == "none": DataPanel {
            title: "No Authentication";
            body: "Requests are sent without generated Authorization headers or API key query parameters.";
        }

        if root.auth_mode == "bearer": AuthTokenPanel {
            label: "Bearer Token";
            token <=> root.auth_config;
            placeholder: "token or {{token}}";
            helper: "Sends Authorization: Bearer <token>.";
            busy: root.busy;
        }

        if root.auth_mode == "jwt": AuthTokenPanel {
            label: "JWT";
            token <=> root.auth_config;
            placeholder: "eyJhbGciOi...";
            helper: "JWT is sent as Authorization: Bearer <token>.";
            busy: root.busy;
        }

        if root.auth_mode == "oauth2": AuthOAuth2Panel {
            config <=> root.auth_config;
            busy: root.busy;
            fetch_oauth2_token => {
                root.fetch_oauth2_token();
            }
        }

        if root.auth_mode == "basic": AuthBasicPanel {
            username <=> root.auth_basic_username;
            password <=> root.auth_basic_password;
            busy: root.busy;
            update_basic_auth(username, password) => {
                root.update_basic_auth(username, password);
            }
        }

        if root.auth_mode == "api-header": AuthApiKeyPanel {
            rows <=> root.auth_key_rows;
            title: "API Key Header";
            key_header: "Header";
            helper: "Stored as key=value lines, for example x-api-key={{apiKey}}.";
            busy: root.busy;
            add_auth_key => {
                root.add_auth_key();
            }
            update_auth_key_row(row_id, key, value) => {
                root.update_auth_key_row(row_id, key, value);
            }
            delete_auth_key_row(row_id) => {
                root.delete_auth_key_row(row_id);
            }
        }

        if root.auth_mode == "api-query": AuthApiKeyPanel {
            rows <=> root.auth_key_rows;
            title: "API Key Query";
            key_header: "Param";
            helper: "Stored as key=value lines, for example api_key={{apiKey}}.";
            busy: root.busy;
            add_auth_key => {
                root.add_auth_key();
            }
            update_auth_key_row(row_id, key, value) => {
                root.update_auth_key_row(row_id, key, value);
            }
            delete_auth_key_row(row_id) => {
                root.delete_auth_key_row(row_id);
            }
        }
    }
}
