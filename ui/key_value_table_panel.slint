import { ListView } from "std-widgets.slint";
import { Theme } from "theme.slint";
import { KeyValueTableRow } from "types.slint";
import { UiText } from "widgets.slint";
import { KeyValueTableControls } from "key_value_table_controls.slint";
import { KeyValueTableLine } from "key_value_table_row.slint";

export component KeyValueTablePanel inherits Rectangle {
    in-out property <[KeyValueTableRow]> rows;
    in property <string> title;
    in property <string> key_header: "Key";
    in property <string> value_header: "Value";
    in property <string> helper: "";
    in property <bool> busy: false;
    in property <bool> show_paste: false;
    in property <bool> show_import: false;
    in-out property <string> import_path;
    in property <bool> show_file_attach: false;
    in-out property <string> file_field;
    in-out property <string> file_path;
    callback add_row();
    callback paste_rows();
    callback import_rows(string);
    callback pick_import_file();
    callback add_file_row(string, string);
    callback pick_file();
    callback update_row(int, string, string);
    callback delete_row(int);

    horizontal-stretch: 1;
    vertical-stretch: 1;
    background: transparent;

    VerticalLayout {
        padding: 0px;
        spacing: 8px;

        KeyValueTableControls {
            title: root.title;
            busy: root.busy;
            show_paste: root.show_paste;
            show_import: root.show_import;
            import_path <=> root.import_path;
            show_file_attach: root.show_file_attach;
            file_field <=> root.file_field;
            file_path <=> root.file_path;
            add_row => {
                root.add_row();
            }
            paste_rows => {
                root.paste_rows();
            }
            import_rows(path) => {
                root.import_rows(path);
            }
            pick_import_file => {
                root.pick_import_file();
            }
            add_file_row(field, path) => {
                root.add_file_row(field, path);
            }
            pick_file => {
                root.pick_file();
            }
        }

        Rectangle {
            height: 30px;
            horizontal-stretch: 1;
            border-radius: 6px;
            border-width: 1px;
            border-color: Theme.outline_variant;
            background: Theme.surface_container;

            UiText {
                x: 14px;
                text: root.key_header;
                width: 150px;
                height: parent.height;
                color: Theme.on_surface_variant;
                font-size: 12px;
                font-weight: 800;
                vertical-alignment: center;
                overflow: elide;
            }

            Rectangle {
                x: 172px;
                y: 6px;
                width: 1px;
                height: parent.height - 12px;
                background: Theme.outline_variant;
            }

            UiText {
                x: 184px;
                text: root.value_header;
                width: parent.width - 244px;
                height: parent.height;
                color: Theme.on_surface_variant;
                font-size: 12px;
                font-weight: 800;
                vertical-alignment: center;
                overflow: elide;
            }
        }

        Rectangle {
            horizontal-stretch: 1;
            vertical-stretch: 1;
            background: transparent;

            if root.rows.length == 0: UiText {
                text: "No rows";
                width: parent.width;
                height: 32px;
                color: Theme.outline;
                font-size: 12px;
                vertical-alignment: center;
                overflow: elide;
            }

            if root.rows.length != 0: ListView {
                width: parent.width;
                height: parent.height;
                vertical-scrollbar-policy: ScrollBarPolicy.as-needed;
                horizontal-scrollbar-policy: ScrollBarPolicy.as-needed;

                for row in root.rows: KeyValueTableLine {
                    row_id: row.row_id;
                    key: row.key;
                    value: row.value;
                    enabled: !root.busy;
                    edited(row_id, key, value) => {
                        root.update_row(row_id, key, value);
                    }
                    delete_requested(row_id) => {
                        root.delete_row(row_id);
                    }
                }
            }
        }

        if root.helper != "": UiText {
            text: root.helper;
            height: 18px;
            horizontal-stretch: 1;
            color: Theme.outline;
            font-size: 12px;
            vertical-alignment: center;
            overflow: elide;
        }
    }
}
