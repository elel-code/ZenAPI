import { Theme } from "theme.slint";
import { UiText } from "widgets.slint";

export component ResponseHeader inherits Rectangle {
    in property <string> response_status;
    in property <string> response_time;
    in property <string> response_size;
    in property <string> response_tone;

    height: 112px;
    horizontal-stretch: 1;
    background: Theme.surface_container_low;

    UiText {
        x: 20px;
        y: 14px;
        text: "Response";
        width: 180px;
        height: 30px;
        color: Theme.on_surface;
        font-size: 24px;
        font-weight: 800;
        overflow: elide;
        vertical-alignment: center;
    }

    Rectangle {
        x: parent.width - 148px;
        y: 15px;
        width: 128px;
        height: 30px;
        border-radius: 4px;
        border-width: 1px;
        border-color: root.response_tone == "error" ? Theme.error : #00a572;
        background: transparent;

        UiText {
            x: 7px;
            text: root.response_status;
            width: parent.width - 14px;
            height: parent.height;
            color: root.response_tone == "error" ? Theme.error : #00a572;
            font-family: "JetBrains Mono";
            font-size: 13px;
            horizontal-alignment: center;
            vertical-alignment: center;
            overflow: elide;
        }
    }

    UiText {
        x: 20px;
        y: 60px;
        text: "TIME";
        width: 80px;
        height: 18px;
        color: Theme.on_surface_variant;
        font-size: 11px;
        font-weight: 800;
        vertical-alignment: center;
        overflow: elide;
    }

    UiText {
        x: 150px;
        y: 60px;
        text: "SIZE";
        width: 80px;
        height: 18px;
        color: Theme.on_surface_variant;
        font-size: 11px;
        font-weight: 800;
        vertical-alignment: center;
        overflow: elide;
    }

    UiText {
        x: 20px;
        y: 80px;
        text: root.response_time == "" ? "--" : root.response_time;
        width: 116px;
        height: 20px;
        color: Theme.on_surface;
        font-family: "JetBrains Mono";
        font-size: 13px;
        vertical-alignment: center;
        overflow: elide;
    }

    UiText {
        x: 150px;
        y: 80px;
        text: root.response_size == "" ? "--" : root.response_size;
        width: parent.width - 170px;
        height: 22px;
        color: Theme.on_surface;
        font-family: "JetBrains Mono";
        font-size: 13px;
        vertical-alignment: center;
        overflow: elide;
    }
}
