                            }
                            copy_response(tab, text) => {
                                root.copy_response(tab, text);
                            }
                            format_response(tab) => {
                                root.format_response(tab);
                            }
                        }
                    }
                }

                ScrollView {
                    visible: root.active_page_index == 0;
                    width: parent.width;
                    height: parent.height;
                    viewport-width: max(self.visible-width, 1040px);
                    viewport-height: max(self.visible-height, 680px);
                    vertical-scrollbar-policy: ScrollBarPolicy.as-needed;
                    horizontal-scrollbar-policy: ScrollBarPolicy.as-needed;

                    DashboardPage {
                        width: max(parent.visible-width, 1040px);
                        height: max(parent.visible-height, 680px);
                        route_count: root.total_route_count;
                        history_count: root.history_rows.length;
                        mock_count: root.mock_logs.length;
                        runner_summary: root.runner_summary;
                        server_running: root.server_running;
                        server_status: root.server_status;
                        response_status: root.response_status;
                        open_page(page_index) => {
                            root.navigate_page(page_index);
                        }
                    }
                }

                ScrollView {
                    visible: root.active_page_index == 2;
                    width: parent.width;
                    height: parent.height;
                    viewport-width: max(self.visible-width, 1160px);
                    viewport-height: max(self.visible-height, 620px);
                    vertical-scrollbar-policy: ScrollBarPolicy.as-needed;
                    horizontal-scrollbar-policy: ScrollBarPolicy.as-needed;

                    MockManagerPage {
                        width: max(parent.visible-width, 1160px);
                        height: max(parent.visible-height, 620px);
                        routes <=> root.routes;
                        mock_logs <=> root.mock_logs;
                        selected_route <=> root.selected_route;
                        mock_log_filter <=> root.mock_log_filter;
                        mock_log_path <=> root.mock_log_path;
                        selected_mock_method: root.selected_mock_method;
                        selected_mock_path: root.selected_mock_path;
                        selected_mock_summary: root.selected_mock_summary;
                        selected_mock_body <=> root.selected_mock_body;
                        busy: root.busy;
                        server_running: root.server_running;
                        server_status: root.server_status;
                        select_route(index) => {
                            root.select_route(index);
                        }
                        toggle_server => {
                            root.toggle_server();
                        }
                        save_mock_response(body) => {
                            root.save_mock_response(body);
                        }
                        filter_mock_logs(query) => {
                            root.filter_mock_logs(query);
                        }
                        save_mock_logs(path) => {
                            root.save_mock_logs(path);
                        }
                        clear_mock_logs => {
                            root.clear_mock_logs();
                        }
                    }
                }

                ScrollView {
                    visible: root.active_page_index == 4;
                    width: parent.width;
                    height: parent.height;
                    viewport-width: max(self.visible-width, 1180px);
                    viewport-height: max(self.visible-height, 620px);
                    vertical-scrollbar-policy: ScrollBarPolicy.as-needed;
                    horizontal-scrollbar-policy: ScrollBarPolicy.as-needed;

                    EnvironmentPage {
                        width: max(parent.visible-width, 1180px);
                        height: max(parent.visible-height, 620px);
                        variable_rows <=> root.variable_rows;
                        global_variables <=> root.global_variables;
                        environment_name <=> root.environment_name;
                        environment_variables <=> root.environment_variables;
                        variables_json_preview <=> root.variables_json_preview;
                        busy: root.busy;
                        select_environment(name) => {
                            root.select_environment(name);
                        }
                        environment_name_changed(name) => {
                            root.environment_name_changed(name);
                        }
                        update_variable_row(row_id, scope, name, value) => {
                            root.update_variable_row(row_id, scope, name, value);
                        }
                        add_variable(scope) => {
                            root.add_variable(scope);
                        }
                        delete_variable_row(row_id, scope) => {
                            root.delete_variable_row(row_id, scope);
                        }
                    }
                }

                ScrollView {
                    visible: root.active_page_index == 3;
                    width: parent.width;
                    height: parent.height;
                    viewport-width: max(self.visible-width, 1040px);
                    viewport-height: max(self.visible-height, 620px);
                    vertical-scrollbar-policy: ScrollBarPolicy.as-needed;
                    horizontal-scrollbar-policy: ScrollBarPolicy.as-needed;

                    RunnerPage {
                        width: max(parent.visible-width, 1040px);
                        height: max(parent.visible-height, 620px);
                        collection_rows <=> root.collection_rows;
                        runner_rows <=> root.runner_rows;
                        runner_summary <=> root.runner_summary;
                        runner_delay_ms <=> root.runner_delay_ms;
                        runner_report_path <=> root.runner_report_path;
                        runner_report_format <=> root.runner_report_format;
                        runner_stop_on_failure <=> root.runner_stop_on_failure;
                        runner_active <=> root.runner_active;
                        busy: root.busy;
                        run_collection => {
                            root.run_collection();
                        }
                        cancel_collection_run => {
                            root.cancel_collection_run();
                        }
                        save_runner_report(path) => {
                            root.save_runner_report(path);
                        }
                    }
                }

                ScrollView {
                    visible: root.active_page_index == 10;
                    width: parent.width;
                    height: parent.height;
                    viewport-width: max(self.visible-width, 840px);
                    viewport-height: max(self.visible-height, 620px);
                    vertical-scrollbar-policy: ScrollBarPolicy.as-needed;
                    horizontal-scrollbar-policy: ScrollBarPolicy.as-needed;

                    CodegenPage {
                        width: max(parent.visible-width, 840px);
                        height: max(parent.visible-height, 620px);
                        codegen_language <=> root.codegen_language;
                        codegen_output <=> root.codegen_output;
                        codegen_metadata: root.codegen_metadata;
                        codegen_path <=> root.codegen_path;
                        busy: root.busy;
                        generate_code => {
                            root.generate_code();
                        }
                        copy_codegen => {
                            root.copy_codegen();
                        }
                        save_codegen(path) => {
                            root.save_codegen(path);
                        }
                    }
                }

                ScrollView {
                    visible: root.active_page_index == 5;
                    width: parent.width;
                    height: parent.height;
                    viewport-width: max(self.visible-width, 1040px);
                    viewport-height: max(self.visible-height, 620px);
                    vertical-scrollbar-policy: ScrollBarPolicy.as-needed;
                    horizontal-scrollbar-policy: ScrollBarPolicy.as-needed;

                    AnalyticsPage {
                        width: max(parent.visible-width, 1040px);
                        height: max(parent.visible-height, 620px);
                        route_count: root.total_route_count;
                        history_count: root.history_rows.length;
                        mock_logs: root.mock_logs;
                        response_status: root.response_status;
                        response_time: root.response_time;
                        response_size: root.response_size;
                    }
                }

                ScrollView {
                    visible: root.active_page_index == 6;
                    width: parent.width;
                    height: parent.height;
                    viewport-width: max(self.visible-width, 1040px);
                    viewport-height: max(self.visible-height, 620px);
                    vertical-scrollbar-policy: ScrollBarPolicy.as-needed;
                    horizontal-scrollbar-policy: ScrollBarPolicy.as-needed;

                    DocumentationPage {
                        width: max(parent.visible-width, 1040px);
                        height: max(parent.visible-height, 620px);
                        routes: root.routes;
                        selected_route <=> root.selected_route;
                        method: root.method;
                        url <=> root.url;
                        auth_mode: root.auth_mode;
                        busy: root.busy;
                        select_route(index) => {
                            root.select_route(index);
                        }
                        send_request => {
                            root.send_request();
                        }
                    }
                }

                ScrollView {
                    visible: root.active_page_index == 7;
                    width: parent.width;
                    height: parent.height;
                    viewport-width: max(self.visible-width, 1040px);
                    viewport-height: max(self.visible-height, 620px);
                    vertical-scrollbar-policy: ScrollBarPolicy.as-needed;
                    horizontal-scrollbar-policy: ScrollBarPolicy.as-needed;

                    ApiKeysPage {
                        width: max(parent.visible-width, 1040px);
                        height: max(parent.visible-height, 620px);
                        auth_mode: root.auth_mode;
                        auth_config: root.auth_config;
                        auth_basic_username: root.auth_basic_username;
                        auth_key_rows: root.auth_key_rows;
                        url: root.url;
                    }
                }

                ScrollView {
                    visible: root.active_page_index == 8;
                    width: parent.width;
                    height: parent.height;
                    viewport-width: max(self.visible-width, 1040px);
                    viewport-height: max(self.visible-height, 620px);
                    vertical-scrollbar-policy: ScrollBarPolicy.as-needed;
                    horizontal-scrollbar-policy: ScrollBarPolicy.as-needed;

                    TeamPage {
                        width: max(parent.visible-width, 1040px);
                        height: max(parent.visible-height, 620px);
                        spec_label: root.spec_label;
                        spec_loaded: root.spec_loaded;
                        collection_name: root.collection_name;
                        route_count: root.total_route_count;
                    }
                }

                ScrollView {
                    visible: root.active_page_index == 9;
                    width: parent.width;
                    height: parent.height;
                    viewport-width: max(self.visible-width, 1040px);
                    viewport-height: max(self.visible-height, 620px);
                    vertical-scrollbar-policy: ScrollBarPolicy.as-needed;
                    horizontal-scrollbar-policy: ScrollBarPolicy.as-needed;

                    SettingsPage {
                        width: max(parent.visible-width, 1040px);
                        height: max(parent.visible-height, 620px);
                        spec_label: root.spec_label;
                        spec_loaded: root.spec_loaded;
                        file_path: root.file_path;
                        collection_name: root.collection_name;
                        collection_path: root.collection_path;
                        route_count: root.total_route_count;
                        history_count: root.history_rows.length;
                    }
                }
            }

            BottomNavigation {
                x: 0px;
                y: parent.height - 56px;
                width: parent.width;
                visible: root.compact_mode;
                active_page_index <=> root.active_page_index;
                navigate_page(page_index) => {
                    root.navigate_page(page_index);
                }
            }
        }

    }
}
