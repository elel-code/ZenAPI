        text: "Lead Architect";
        width: parent.width - 52px;
        height: 24px;
        color: Theme.primary;
        font-size: 14px;
        font-weight: 800;
        overflow: elide;
        vertical-alignment: center;
    }

    UiText {
        x: 52px;
        y: 29px;
        text: "Dev-Ops Team";
        width: parent.width - 52px;
        height: 22px;
        color: Theme.on_surface_variant;
        font-size: 14px;
        overflow: elide;
        vertical-alignment: center;
    }
}

component SidebarFolderRow inherits Rectangle {
    in property <string> label;
    in property <bool> selected: false;
    callback picked();

    height: 36px;
    horizontal-stretch: 1;
    border-radius: 8px;
    background: root.selected ? #00a572 : touch.has-hover ? Theme.surface_variant : transparent;

    touch := TouchArea {
        mouse-cursor: pointer;
        clicked => {
            root.picked();
        }
    }

    Rectangle {
        x: 10px;
        y: 12px;
        width: 15px;
        height: 11px;
        border-radius: 2px;
        border-width: 1px;
        border-color: root.selected ? #00311f : Theme.on_surface_variant;
        background: transparent;
    }

    Rectangle {
        x: 10px;
        y: 9px;
        width: 8px;
        height: 4px;
        border-radius: 1px;
        background: root.selected ? #00311f : Theme.on_surface_variant;
    }

    UiText {
        x: 34px;
        text: root.label;
        width: parent.width - 44px;
        height: parent.height;
        color: root.selected ? #00311f : Theme.on_surface;
        font-size: 14px;
        font-weight: root.selected ? 800 : 500;
        overflow: elide;
        vertical-alignment: center;
    }
}

component SidebarRequestLink inherits Rectangle {
    in property <string> method;
    in property <string> label;
    in property <bool> selected: false;
    callback picked();

    height: 30px;
    horizontal-stretch: 1;
    border-radius: 6px;
    border-width: root.selected ? 1px : 0px;
    border-color: Theme.outline_variant;
    background: root.selected ? Theme.surface_variant : touch.has-hover ? Theme.surface_container_high : transparent;

    touch := TouchArea {
        mouse-cursor: pointer;
        clicked => {
            root.picked();
        }
    }

    UiText {
        x: 10px;
        text: root.method;
        width: 34px;
        height: parent.height;
        font-family: "JetBrains Mono";
        font-size: 10px;
        font-weight: 800;
        color: root.method == "GET" ? Theme.secondary : root.method == "POST" ? #00a572 : root.method == "PUT" ? Theme.tertiary : root.method == "DELETE" ? Theme.error : Theme.primary;
        overflow: elide;
        vertical-alignment: center;
    }

    UiText {
        x: 48px;
        text: root.label;
        width: parent.width - 58px;
        height: parent.height;
        color: Theme.on_surface;
        font-size: 13px;
        font-weight: root.selected ? 700 : 500;
        overflow: elide;
        vertical-alignment: center;
    }
}

component SidebarHistoryLink inherits Rectangle {
    in property <string> method;
    in property <string> label;
    callback picked();

    height: 26px;
    horizontal-stretch: 1;
    border-radius: 6px;
    background: touch.has-hover ? Theme.surface_container_high : transparent;

    touch := TouchArea {
        mouse-cursor: pointer;
        clicked => {
            root.picked();
        }
    }

    UiText {
        x: 0px;
        text: root.method;
        width: 32px;
        height: parent.height;
        font-family: "JetBrains Mono";
        font-size: 10px;
        color: root.method == "DELETE" ? Theme.error : root.method == "POST" ? #00a572 : Theme.secondary;
        overflow: elide;
        vertical-alignment: center;
    }

    UiText {
        x: 38px;
        text: root.label;
        width: parent.width - 38px;
        height: parent.height;
        color: Theme.on_surface_variant;
        font-size: 12px;
        overflow: elide;
        vertical-alignment: center;
    }
}

component Sidebar inherits Rectangle {
    in-out property <[RouteRow]> routes;
    in-out property <[CollectionRow]> collection_rows;
    in-out property <[HistoryRow]> history_rows;
    in-out property <[MockLogRow]> mock_logs;
    in-out property <int> selected_route;
    in-out property <string> route_filter;
    in-out property <string> history_filter;
    in-out property <string> mock_log_filter;
    in-out property <string> mock_log_path;
    in-out property <string> collection_path;
    in-out property <int> selected_collection_request;
    in-out property <string> collection_request_name;
    in-out property <string> collection_name;
    in-out property <string> collection_status;
    in property <int> total_route_count;
    in property <bool> busy;
    callback select_route(int);
    callback select_collection_request(int);
    callback rename_collection_request(int, string);
    callback duplicate_collection_request(int);
    callback delete_collection_request(int);
    callback import_collection(string);
    callback save_current_request();
    callback save_collection(string);
    callback export_postman_collection(string);
    callback select_history(int);
    callback filter_history(string);
    callback delete_history(int);
    callback clear_history();
    callback filter_mock_logs(string);
    callback save_mock_logs(string);
    callback clear_mock_logs();
    callback filter_routes(string);

    width: 240px;
    vertical-stretch: 1;
    background: Theme.surface_container_low;

    VerticalLayout {
        padding: 16px;
        spacing: 14px;

        SidebarProfile {}

        Rectangle {
            horizontal-stretch: 1;
            vertical-stretch: 1;
            background: transparent;

            VerticalLayout {
                padding: 0px;
                spacing: 8px;

                HorizontalLayout {
                    height: 24px;
                    spacing: 8px;
                    alignment: center;

                    UiText {
                        text: "COLLECTIONS";
                        horizontal-stretch: 1;
                        height: parent.height;
                        color: Theme.on_surface_variant;
                        font-size: 12px;
                        font-weight: 800;
                        vertical-alignment: center;
                        overflow: elide;
                    }

                    ActionButton {
                        text: "+";
                        button_width: 30px;
                        enabled: !root.busy;
                        clicked => {
                            root.save_current_request();
                        }
                    }
                }

                SidebarFolderRow {
                    label: "Auth";
                    selected: false;
                }

                SidebarFolderRow {
                    label: root.collection_name == "" ? "Users" : root.collection_name;
                    selected: true;
                }

                Rectangle {
                    height: root.collection_rows.length == 0 && root.routes.length == 0 ? 34px : 170px;
                    horizontal-stretch: 1;
                    background: transparent;

                    Rectangle {
                        x: 19px;
                        width: 1px;
                        height: parent.height;
                        background: Theme.outline_variant;
                    }

                    if root.collection_rows.length == 0 && root.routes.length == 0: UiText {
                        x: 32px;
                        text: root.total_route_count == 0 ? "No requests" : "No matching routes";
                        width: parent.width - 32px;
                        height: 30px;
                        color: Theme.outline;
                        font-size: 12px;
                        vertical-alignment: center;
                        overflow: elide;
                    }

                    if root.collection_rows.length != 0: ListView {
                        x: 32px;
                        width: parent.width - 32px;
                        height: parent.height;
                        vertical-scrollbar-policy: ScrollBarPolicy.as-needed;
                        horizontal-scrollbar-policy: ScrollBarPolicy.as-needed;

                        for entry in root.collection_rows: SidebarRequestLink {
                            method: entry.method;
                            label: entry.name;
                            selected: root.selected_collection_request == entry.id;
                            picked => {
                                root.selected_collection_request = entry.id;
                                root.select_collection_request(entry.id);
                            }
                        }
                    }

                    if root.collection_rows.length == 0 && root.routes.length != 0: ListView {
                        x: 32px;
                        width: parent.width - 32px;
                        height: parent.height;
                        vertical-scrollbar-policy: ScrollBarPolicy.as-needed;
                        horizontal-scrollbar-policy: ScrollBarPolicy.as-needed;

                        for route[i] in root.routes: SidebarRequestLink {
                            method: route.method;
                            label: route.summary == "" ? route.path : route.summary;
                            selected: root.selected_route == i;
                            picked => {
                                root.selected_route = i;
                                root.select_route(i);
                            }
                        }
                    }
                }

                SidebarFolderRow {
                    label: "Billing";
                    selected: false;
                }
            }
        }

        Rectangle {
            height: 112px;
            horizontal-stretch: 1;
            background: transparent;

            VerticalLayout {
                padding: 0px;
                spacing: 8px;

                HorizontalLayout {
                    height: 24px;
                    spacing: 8px;
                    alignment: center;

                    UiText {
                        text: "HISTORY";
                        horizontal-stretch: 1;
                        height: parent.height;
                        color: Theme.on_surface_variant;
                        font-size: 12px;
                        font-weight: 800;
                        vertical-alignment: center;
                        overflow: elide;
                    }

                    ActionButton {
                        text: "...";
                        button_width: 34px;
                        enabled: !root.busy && root.history_rows.length > 0;
                        clicked => {
                            root.clear_history();
                        }
                    }
                }

                if root.history_rows.length == 0: UiText {
                    text: "No requests yet";
                    height: 26px;
                    horizontal-stretch: 1;
                    color: Theme.outline;
                    font-size: 12px;
                    vertical-alignment: center;
                    overflow: elide;
                }

                if root.history_rows.length != 0: ListView {
                    horizontal-stretch: 1;
                    vertical-stretch: 1;
                    vertical-scrollbar-policy: ScrollBarPolicy.as-needed;
                    horizontal-scrollbar-policy: ScrollBarPolicy.as-needed;

                    for entry in root.history_rows: SidebarHistoryLink {
                        method: entry.method;
                        label: entry.url;
                        picked => {
                            root.select_history(entry.id);
                        }
                    }
                }
            }
        }
    }
}

component TopBar inherits Rectangle {
    in-out property <string> file_path;
    in property <bool> busy;
    callback import_openapi(string);

    height: 64px;
    horizontal-stretch: 1;
    background: Theme.surface_dim;

    HorizontalLayout {
        padding-left: 20px;
        padding-right: 20px;
        spacing: 16px;
        alignment: center;

        Rectangle {
            width: 36px;
            height: 36px;
            border-radius: 8px;
            background: menu_touch.has-hover ? Theme.surface_container_high : transparent;

            menu_touch := TouchArea {
                enabled: !root.busy;
                mouse-cursor: root.busy ? default : pointer;
                clicked => {
                    import_popup.show();
                }
            }

            Rectangle {
                x: 7px;
                y: 11px;
                width: 22px;
                height: 2px;
                background: Theme.primary;
            }

            Rectangle {
                x: 7px;
                y: 17px;
                width: 22px;
                height: 2px;
                background: Theme.primary;
            }

            Rectangle {
                x: 7px;
                y: 23px;
                width: 22px;
                height: 2px;
                background: Theme.primary;
            }
        }

        UiText {
            text: "API Architect";
            width: 220px;
            height: root.height;
            font-size: 24px;
            font-weight: 800;
            color: Theme.primary;
            vertical-alignment: center;
            overflow: elide;
        }

        Rectangle {
            horizontal-stretch: 1;
        }

        Rectangle {
            width: 36px;
            height: 36px;
            border-radius: 8px;
            background: search_touch.has-hover ? Theme.surface_container_high : transparent;

            search_touch := TouchArea {
                mouse-cursor: pointer;
            }

            Rectangle {
                x: 9px;
                y: 8px;
                width: 14px;
                height: 14px;
                border-radius: 7px;
                border-width: 2px;
                border-color: Theme.primary;
                background: transparent;
            }

            Rectangle {
                x: 22px;
                y: 22px;
                width: 8px;
                height: 2px;
                background: Theme.primary;
            }
        }
    }

    Rectangle {
        y: parent.height - 1px;
        width: parent.width;
        height: 1px;
        background: Theme.outline_variant;
    }

    import_popup := PopupWindow {
        x: 20px;
        y: root.height + 6px;
        width: root.width - 40px;
        height: 58px;
        close-policy: close-on-click-outside;

        Rectangle {
            width: parent.width;
            height: parent.height;
            background: Theme.surface_container;
            border-radius: 8px;
            border-width: 1px;
            border-color: Theme.outline_variant;

            HorizontalLayout {
                padding: 10px;
                spacing: 10px;
                alignment: center;

                TextField {
                    text <=> root.file_path;
                    placeholder: "Local JSON or YAML file path";
                    mono: true;
                    enabled: !root.busy;
                    horizontal-stretch: 1;
                    accepted => {
                        if !root.busy {
                            import_popup.close();
                            root.import_openapi(root.file_path);
                        }
                    }
                }

                ActionButton {
                    text: "Import";
                    primary: true;
                    enabled: !root.busy;
                    button_width: 82px;
                    clicked => {
                        if !root.busy {
                            import_popup.close();
                            root.import_openapi(root.file_path);
                        }
                    }
                }
            }
        }
    }
}

component AppNavItem inherits Rectangle {
    in property <string> page;
    in property <string> label;
    in property <string> glyph;
    in property <bool> selected;
    callback picked(string);

    height: 36px;
    horizontal-stretch: 1;
    border-radius: 8px;
    background: root.selected ? Theme.primary_container : touch.has-hover ? Theme.surface_variant : transparent;

    touch := TouchArea {
        mouse-cursor: pointer;
        clicked => {
            root.picked(root.page);
        }
    }

    UiText {
        x: 12px;
        text: root.glyph;
        width: 22px;
        height: parent.height;
        color: root.selected ? Theme.on_primary_container : Theme.on_surface_variant;
        font-size: 16px;
        font-weight: 800;
        horizontal-alignment: center;
        vertical-alignment: center;
        overflow: elide;
    }

    UiText {
        x: 46px;
        text: root.label;
        width: parent.width - 58px;
        height: parent.height;
        color: root.selected ? Theme.on_primary_container : Theme.on_surface_variant;
        font-size: 13px;
        font-weight: root.selected ? 800 : 600;
        vertical-alignment: center;
        overflow: elide;
    }
}

component AppNavigation inherits Rectangle {
    in-out property <string> active_page;

    width: 240px;
    vertical-stretch: 1;
    background: Theme.surface_container_low;

    nav_scroll := ScrollView {
        width: parent.width;
        height: parent.height;
        viewport-width: self.visible-width;
        viewport-height: max(self.visible-height, 650px);
        vertical-scrollbar-policy: ScrollBarPolicy.as-needed;
        horizontal-scrollbar-policy: ScrollBarPolicy.as-needed;

        Rectangle {
            width: nav_scroll.visible-width;
            height: max(nav_scroll.visible-height, 650px);
            background: transparent;

            VerticalLayout {
                padding: 16px;
                spacing: 12px;

                SidebarProfile {}

                Rectangle {
                    height: 1px;
                    horizontal-stretch: 1;
                    background: Theme.outline_variant;
                }

                for item in [
                    { page: "dashboard", label: "Dashboard", glyph: "D" },
                    { page: "requests", label: "Requests", glyph: "R" },
                    { page: "mocks", label: "Mocks", glyph: "M" },
                    { page: "runner", label: "Test Runner", glyph: "T" },
                    { page: "environments", label: "Environments", glyph: "E" },
                    { page: "analytics", label: "Traffic Analytics", glyph: "A" },
                ]: AppNavItem {
                    page: item.page;
                    label: item.label;
                    glyph: item.glyph;
                    selected: root.active_page == item.page;
                    picked(page) => {
                        root.active_page = page;
                    }
                }

                Rectangle {
                    height: 1px;
                    horizontal-stretch: 1;
                    background: Theme.outline_variant;
                }

                for item in [
                    { page: "docs", label: "API Docs", glyph: "D" },
                    { page: "keys", label: "API Keys", glyph: "K" },
                    { page: "team", label: "Team Members", glyph: "T" },
                    { page: "settings", label: "Project Settings", glyph: "S" },
                    { page: "codegen", label: "Codegen", glyph: "C" },
                ]: AppNavItem {
                    page: item.page;
                    label: item.label;
                    glyph: item.glyph;
                    selected: root.active_page == item.page;
                    picked(page) => {
                        root.active_page = page;
                    }
                }

                Rectangle {
                    vertical-stretch: 1;
                }

                UiText {
                    text: "v2.4.0";
                    height: 20px;
                    horizontal-stretch: 1;
                    color: Theme.outline;
                    font-family: "JetBrains Mono";
                    font-size: 12px;
                    vertical-alignment: center;
                    overflow: elide;
                }
            }
        }
    }
}

