import { ListView, ScrollView } from "std-widgets.slint";
import { Theme } from "theme.slint";

export struct RouteRow {
    method: string,
    path: string,
    summary: string,
}

component UiText inherits Text {
    font-family: "Inter";
    font-size: 13px;
    font-weight: 500;
    color: Theme.on_surface;
    letter-spacing: 0px;
}

global MethodStyle {
    public pure function text_color(method: string) -> color {
        return method == "GET" ? #60a5fa : method == "POST" ? #4ade80 : method == "PUT" ? #facc15 : method == "PATCH" ? #facc15 : method == "DELETE" ? #f87171 : Theme.outline;
    }

    public pure function background(method: string) -> color {
        return method == "GET" ? #1d3d66 : method == "POST" ? #17452c : method == "PUT" ? #4a3b12 : method == "PATCH" ? #4a3b12 : method == "DELETE" ? #4f1d22 : #242430;
    }

    public pure function border(method: string) -> color {
        return method == "GET" ? #3b82f6 : method == "POST" ? #22c55e : method == "PUT" ? #eab308 : method == "PATCH" ? #eab308 : method == "DELETE" ? #ef4444 : Theme.outline_variant;
    }
}

global ToneStyle {
    public pure function color(tone: string) -> color {
        return tone == "error" ? Theme.error : tone == "busy" ? Theme.tertiary : tone == "success" ? Theme.secondary : Theme.on_surface_variant;
    }
}

global ButtonStyle {
    public pure function border_color(enabled: bool, primary: bool, warning: bool) -> color {
        return !enabled ? Theme.outline_variant : warning ? Theme.tertiary : primary ? Theme.primary_container : Theme.outline_variant;
    }

    public pure function background_color(enabled: bool, primary: bool, warning: bool, pressed: bool, hovered: bool) -> color {
        return !enabled ? Theme.surface_container_low : warning ? (pressed ? #9b520f : hovered ? #c96b18 : #7a430d) : primary ? (pressed ? #3d3fba : hovered ? #5557df : Theme.inverse_primary) : (pressed ? Theme.surface_container_highest : hovered ? Theme.surface_container_high : Theme.surface_container);
    }

    public pure function text_color(enabled: bool, primary: bool, warning: bool) -> color {
        return !enabled ? Theme.outline : primary ? Theme.on_surface : warning ? Theme.on_surface : Theme.on_surface;
    }
}

component MethodChip inherits Rectangle {
    in property <string> method;

    width: 62px;
    height: 22px;
    border-radius: 4px;
    border-width: 1px;
    border-color: MethodStyle.border(root.method);
    background: MethodStyle.background(root.method);

    UiText {
        text: root.method;
        width: parent.width;
        height: parent.height;
        font-family: "JetBrains Mono";
        font-size: 12px;
        font-weight: 800;
        color: MethodStyle.text_color(root.method);
        horizontal-alignment: center;
        vertical-alignment: center;
        overflow: elide;
    }
}

component StatusDot inherits Rectangle {
    in property <string> tone: "inactive";

    width: 8px;
    height: 8px;
    border-radius: 4px;
    background: root.tone == "active" ? Theme.secondary : root.tone == "error" ? Theme.error : Theme.outline_variant;
}

component SectionTitle inherits Rectangle {
    in property <string> text;
    in property <string> meta: "";

    height: 24px;
    horizontal-stretch: 1;

    UiText {
        x: 0px;
        text: root.text;
        width: parent.width - 80px;
        height: parent.height;
        font-size: 12px;
        font-weight: 800;
        color: Theme.on_surface;
        overflow: elide;
        vertical-alignment: center;
    }

    UiText {
        x: parent.width - 76px;
        text: root.meta;
        width: 76px;
        height: parent.height;
        font-size: 12px;
        color: Theme.outline;
        overflow: elide;
        horizontal-alignment: right;
        vertical-alignment: center;
    }
}

component ActionButton inherits Rectangle {
    in property <string> text;
    in property <bool> enabled: true;
    in property <bool> primary: false;
    in property <bool> warning: false;
    in property <length> button_width: 96px;
    callback clicked();

    width: root.button_width;
    height: 34px;
    border-radius: 8px;
    border-width: 1px;
    border-color: ButtonStyle.border_color(root.enabled, root.primary, root.warning);
    background: ButtonStyle.background_color(root.enabled, root.primary, root.warning, touch.pressed, touch.has-hover);
    opacity: root.enabled ? 1 : 0.62;

    touch := TouchArea {
        enabled: root.enabled;
        mouse-cursor: root.enabled ? pointer : default;
        clicked => {
            root.clicked();
        }
    }

    UiText {
        text: root.text;
        width: parent.width;
        height: parent.height;
        color: ButtonStyle.text_color(root.enabled, root.primary, root.warning);
        font-size: 13px;
        font-weight: 700;
        horizontal-alignment: center;
        vertical-alignment: center;
        overflow: elide;
    }
}

component TextField inherits Rectangle {
    in-out property <string> text;
    in property <string> placeholder;
    in property <bool> mono: false;
    in property <bool> enabled: true;
    in property <bool> embedded: false;
    out property <bool> focused: input.has-focus;
    callback edited();
    callback accepted();

    height: 36px;
    horizontal-stretch: 1;
    border-radius: root.embedded ? 0px : 8px;
    border-width: root.embedded ? 0px : 1px;
    border-color: root.enabled && input.has-focus ? Theme.primary : Theme.outline_variant;
    background: root.embedded ? transparent : (root.enabled ? Theme.surface_container_lowest : Theme.surface_container_low);
    opacity: root.enabled ? 1 : 0.7;

    Text {
        x: 12px;
        text: root.text == "" ? root.placeholder : "";
        width: parent.width - 24px;
        height: parent.height;
        color: Theme.outline;
        font-family: root.mono ? "JetBrains Mono" : "Inter";
        font-size: 13px;
        font-weight: 400;
        letter-spacing: 0px;
        vertical-alignment: center;
        overflow: elide;
    }

    input := TextInput {
        x: 12px;
        text <=> root.text;
        width: parent.width - 24px;
        height: parent.height;
        enabled: root.enabled;
        single-line: true;
        font-family: root.mono ? "JetBrains Mono" : "Inter";
        font-size: 13px;
        font-weight: 400;
        letter-spacing: 0px;
        color: Theme.on_surface;
        selection-background-color: Theme.primary_container;
        selection-foreground-color: Theme.on_surface;
        text-cursor-width: root.enabled ? 2px : 0px;
        vertical-alignment: center;
        edited => {
            root.edited();
        }
        accepted => {
            if root.enabled {
                root.accepted();
            }
        }
    }
}

component MethodOption inherits Rectangle {
    in property <string> value;
    in property <bool> selected;
    callback picked(string);

    height: 32px;
    horizontal-stretch: 1;
    border-radius: 6px;
    background: root.selected ? Theme.surface_variant : option_touch.has-hover ? Theme.surface_container_high : Theme.surface_container;

    option_touch := TouchArea {
        mouse-cursor: pointer;
        clicked => {
            root.picked(root.value);
        }
    }

    MethodChip {
        x: 8px;
        y: 5px;
        method: root.value;
    }
}

component BodyModeButton inherits Rectangle {
    in property <string> mode;
    in property <string> label;
    in property <bool> selected;
    in property <bool> enabled: true;
    in property <length> button_width: 76px;
    callback picked(string);

    width: root.button_width;
    height: 26px;
    border-radius: 6px;
    border-width: 1px;
    border-color: root.selected ? Theme.primary : Theme.outline_variant;
    background: !root.enabled ? Theme.surface_container_low : root.selected ? Theme.surface_variant : touch.has-hover ? Theme.surface_container_high : Theme.surface_container_low;
    opacity: root.enabled ? 1 : 0.65;

    touch := TouchArea {
        enabled: root.enabled;
        mouse-cursor: root.enabled ? pointer : default;
        clicked => {
            root.picked(root.mode);
        }
    }

    UiText {
        text: root.label;
        width: parent.width;
        height: parent.height;
        color: root.selected ? Theme.primary : Theme.on_surface_variant;
        font-size: 12px;
        font-weight: root.selected ? 800 : 600;
        horizontal-alignment: center;
        vertical-alignment: center;
        overflow: elide;
    }
}

component MethodSelector inherits Rectangle {
    in-out property <string> method;
    in property <bool> enabled: true;

    width: 100px;
    height: 38px;
    background: root.enabled && touch.has-hover ? Theme.surface_container_high : Theme.surface_container_lowest;

    touch := TouchArea {
        enabled: root.enabled;
        mouse-cursor: root.enabled ? pointer : default;
        clicked => {
            method_popup.show();
        }
    }

    MethodChip {
        x: 12px;
        y: 8px;
        method: root.method;
    }

    UiText {
        x: parent.width - 26px;
        text: "v";
        width: 14px;
        height: parent.height;
        color: Theme.outline;
        horizontal-alignment: center;
        vertical-alignment: center;
    }

    Rectangle {
        x: parent.width - 1px;
        width: 1px;
        height: parent.height;
        background: Theme.outline_variant;
    }

    method_popup := PopupWindow {
        x: 0px;
        y: root.height + 6px;
        width: root.width;
        height: 236px;
        close-policy: close-on-click-outside;

        Rectangle {
            width: parent.width;
            height: parent.height;
            background: Theme.surface_container;
            border-radius: 8px;
            border-width: 1px;
            border-color: Theme.outline_variant;
            clip: true;

            VerticalLayout {
                padding: 6px;
                spacing: 2px;

                for name in ["GET", "POST", "PUT", "PATCH", "DELETE", "HEAD", "OPTIONS"]: MethodOption {
                    value: name;
                    selected: root.method == name;
                    picked(value) => {
                        root.method = value;
                        method_popup.close();
                    }
                }
            }
        }
    }
}

component CodePane inherits Rectangle {
    in-out property <string> text;
    in property <bool> read_only;

    horizontal-stretch: 1;
    vertical-stretch: 1;
    border-radius: 8px;
    border-width: 1px;
    border-color: Theme.outline_variant;
    background: Theme.surface_container_lowest;

    ScrollView {
        x: 1px;
        y: 1px;
        width: parent.width - 2px;
        height: parent.height - 2px;
        viewport-width: max(self.visible-width, code_input.preferred-width + 28px);
        viewport-height: max(self.visible-height, code_input.preferred-height + 24px);
        vertical-scrollbar-policy: ScrollBarPolicy.always-off;
        horizontal-scrollbar-policy: ScrollBarPolicy.always-off;

        code_input := TextInput {
            x: 14px;
            y: 12px;
            width: max(parent.visible-width - 28px, self.preferred-width);
            height: max(parent.visible-height - 24px, self.preferred-height);
            text <=> root.text;
            read-only: root.read_only;
            single-line: false;
            wrap: word-wrap;
            font-family: "JetBrains Mono";
            font-size: 13px;
            font-weight: 400;
            letter-spacing: 0px;
            color: Theme.on_surface;
            selection-background-color: Theme.primary_container;
            selection-foreground-color: Theme.on_surface;
            text-cursor-width: root.read_only ? 0px : 2px;
        }
    }
}

component LabeledEditor inherits Rectangle {
    in-out property <string> text;
    in property <string> label;
    in property <bool> read_only: false;

    horizontal-stretch: 1;
    vertical-stretch: 1;
    background: transparent;

    VerticalLayout {
        padding: 0px;
        spacing: 6px;

        UiText {
            text: root.label;
            height: 20px;
            horizontal-stretch: 1;
            color: Theme.on_surface_variant;
            font-size: 12px;
            font-weight: 800;
            vertical-alignment: center;
            overflow: elide;
        }

        CodePane {
            text <=> root.text;
            read_only: root.read_only;
        }
    }
}

component TabHeader inherits Rectangle {
    in property <string> label;
    in property <string> status: "";
    in property <string> tone: "neutral";

    height: 36px;
    horizontal-stretch: 1;
    background: Theme.surface_container_low;

    Rectangle {
        y: parent.height - 1px;
        width: parent.width;
        height: 1px;
        background: Theme.outline_variant;
    }

    UiText {
        x: 14px;
        text: root.label;
        width: 220px;
        height: parent.height;
        color: Theme.primary;
        font-size: 13px;
        font-weight: 700;
        vertical-alignment: center;
        overflow: elide;
    }

    Rectangle {
        x: 14px;
        y: parent.height - 2px;
        width: 72px;
        height: 2px;
        background: Theme.primary;
    }

    if root.status != "": UiText {
        x: parent.width - 328px;
        text: root.status;
        width: 312px;
        height: parent.height;
        font-family: "JetBrains Mono";
        font-size: 12px;
        font-weight: 600;
        color: ToneStyle.color(root.tone);
        horizontal-alignment: right;
        vertical-alignment: center;
        overflow: elide;
    }
}

component RouteListItem inherits Rectangle {
    in property <string> method;
    in property <string> path;
    in property <string> summary;
    in property <bool> selected;
    callback picked();

    height: 44px;
    horizontal-stretch: 1;
    border-radius: 6px;
    background: root.selected ? Theme.surface_variant : touch.has-hover ? Theme.surface_container_high : Theme.surface_container_low;

    touch := TouchArea {
        mouse-cursor: pointer;
        clicked => {
            root.picked();
        }
    }

    Rectangle {
        x: 0px;
        y: 5px;
        width: 2px;
        height: 34px;
        background: Theme.primary;
        visible: root.selected;
    }

    MethodChip {
        x: 10px;
        y: 11px;
        method: root.method;
    }

    UiText {
        x: 82px;
        y: 5px;
        text: root.path;
        width: parent.width - 92px;
        height: 19px;
        font-family: "JetBrains Mono";
        font-size: 12px;
        font-weight: 700;
        color: Theme.on_surface;
        overflow: elide;
        vertical-alignment: center;
    }

    UiText {
        x: 82px;
        y: 24px;
        text: root.summary;
        width: parent.width - 92px;
        height: 15px;
        font-size: 11px;
        color: Theme.on_surface_variant;
        visible: root.summary != "";
        overflow: elide;
        vertical-alignment: center;
    }
}

component Sidebar inherits Rectangle {
    in-out property <[RouteRow]> routes;
    in-out property <int> selected_route;
    in-out property <string> route_filter;
    in property <int> total_route_count;
    callback select_route(int);
    callback filter_routes(string);

    width: 240px;
    vertical-stretch: 1;
    background: Theme.surface_container_low;

    VerticalLayout {
        padding: 12px;
        spacing: 8px;

        SectionTitle {
            text: "ENDPOINTS";
            meta: root.total_route_count == 0 ? "" : root.routes.length + "/" + root.total_route_count;
        }

        TextField {
            text <=> root.route_filter;
            placeholder: "Filter routes";
            height: root.total_route_count > 0 ? 32px : 0px;
            visible: root.total_route_count > 0;
            edited => {
                root.filter_routes(root.route_filter);
            }
        }

        if root.routes.length == 0: Rectangle {
            height: 40px;
            horizontal-stretch: 1;
            background: Theme.surface_container;
            border-radius: 6px;

            UiText {
                text: root.total_route_count == 0 ? "No endpoints imported" : "No matching routes";
                width: parent.width;
                height: parent.height;
                color: Theme.outline;
                font-size: 12px;
                horizontal-alignment: center;
                vertical-alignment: center;
                overflow: elide;
            }
        }

        ListView {
            horizontal-stretch: 1;
            vertical-stretch: 1;
            vertical-scrollbar-policy: ScrollBarPolicy.always-off;
            horizontal-scrollbar-policy: ScrollBarPolicy.always-off;

            for route[i] in root.routes: RouteListItem {
                method: route.method;
                path: route.path;
                summary: route.summary;
                selected: root.selected_route == i;
                picked => {
                    root.selected_route = i;
                    root.select_route(i);
                }
            }
        }
    }
}

component TopBar inherits Rectangle {
    in-out property <string> file_path;
    in property <string> spec_label;
    in property <bool> spec_loaded;
    in property <bool> server_running;
    in property <string> server_status;
    in property <int> route_count;
    in property <bool> busy;
    callback import_openapi(string);
    callback toggle_server();

    height: 48px;
    horizontal-stretch: 1;
    background: Theme.surface_dim;

    HorizontalLayout {
        padding-left: 16px;
        padding-right: 12px;
        spacing: 12px;
        alignment: center;

        UiText {
            text: "ZenAPI";
            width: 92px;
            height: root.height;
            font-size: 18px;
            font-weight: 800;
            color: Theme.primary;
            vertical-alignment: center;
            overflow: elide;
        }

        Rectangle {
            horizontal-stretch: 1;
            height: 32px;
            background: Theme.surface_container_low;
            border-radius: 8px;
            border-width: 1px;
            border-color: Theme.outline_variant;

            TouchArea {
                enabled: !root.busy;
                mouse-cursor: root.busy ? default : pointer;
                clicked => {
                    import_popup.show();
                }
            }

            UiText {
                x: 12px;
                text: root.spec_loaded ? root.spec_label : "Import OpenAPI or Swagger file";
                width: parent.width - 24px;
                height: parent.height;
                color: root.spec_loaded ? Theme.on_surface : Theme.outline;
                font-family: root.spec_loaded ? "JetBrains Mono" : "Inter";
                font-size: 13px;
                vertical-alignment: center;
                horizontal-alignment: center;
                overflow: elide;
            }
        }

        Rectangle {
            width: 184px;
            height: 34px;

            HorizontalLayout {
                spacing: 8px;
                alignment: center;

                StatusDot {
                    tone: root.server_running ? "active" : "inactive";
                }

                UiText {
                    text: root.server_running ? root.server_status : "Mock stopped";
                    width: 92px;
                    height: parent.height;
                    font-family: "JetBrains Mono";
                    font-size: 12px;
                    color: root.server_running ? Theme.secondary : Theme.outline;
                    overflow: elide;
                    vertical-alignment: center;
                }

                ActionButton {
                    text: root.server_running ? "Stop" : "Mock";
                    button_width: 64px;
                    warning: root.server_running;
                    enabled: !root.busy && (root.server_running || root.route_count > 0);
                    clicked => {
                        root.toggle_server();
                    }
                }
            }
        }
    }

    Rectangle {
        y: parent.height - 1px;
        width: parent.width;
        height: 1px;
        background: Theme.outline_variant;
    }

    import_popup := PopupWindow {
        x: 128px;
        y: root.height + 6px;
        width: root.width - 360px;
        height: 58px;
        close-policy: close-on-click-outside;

        Rectangle {
            width: parent.width;
            height: parent.height;
            background: Theme.surface_container;
            border-radius: 8px;
            border-width: 1px;
            border-color: Theme.outline_variant;

            HorizontalLayout {
                padding: 10px;
                spacing: 10px;
                alignment: center;

                TextField {
                    text <=> root.file_path;
                    placeholder: "Local JSON or YAML file path";
                    mono: true;
                    enabled: !root.busy;
                    horizontal-stretch: 1;
                    accepted => {
                        if !root.busy {
                            import_popup.close();
                            root.import_openapi(root.file_path);
                        }
                    }
                }

                ActionButton {
                    text: "Import";
                    primary: true;
                    enabled: !root.busy;
                    button_width: 82px;
                    clicked => {
                        if !root.busy {
                            import_popup.close();
                            root.import_openapi(root.file_path);
                        }
                    }
                }
            }
        }
    }
}

component AddressBar inherits Rectangle {
    in-out property <string> method;
    in-out property <string> url;
    in property <bool> busy;
    callback send_request();

    height: 54px;
    horizontal-stretch: 1;
    background: Theme.surface;

    Rectangle {
        x: 14px;
        y: 8px;
        width: root.width - 28px;
        height: 38px;
        background: Theme.surface_container_lowest;
        border-radius: 8px;
        border-width: 1px;
        border-color: !root.busy && url_field.focused ? Theme.primary : Theme.outline_variant;
        clip: true;

        HorizontalLayout {
            spacing: 0px;
            alignment: center;

            MethodSelector {
                method <=> root.method;
                enabled: !root.busy;
            }

            url_field := TextField {
                text <=> root.url;
                placeholder: "Enter request URL";
                embedded: true;
                mono: true;
                enabled: !root.busy;
                height: 38px;
                horizontal-stretch: 1;
                accepted => {
                    if !root.busy {
                        root.send_request();
                    }
                }
            }

            Rectangle {
                width: 1px;
                height: parent.height;
                background: Theme.outline_variant;
            }

            ActionButton {
                text: "Send";
                enabled: !root.busy;
                primary: true;
                button_width: 86px;
                clicked => {
                    root.send_request();
                }
            }
        }
    }

    Rectangle {
        y: parent.height - 1px;
        width: parent.width;
        height: 1px;
        background: Theme.outline_variant;
    }
}

component RequestPanel inherits Rectangle {
    in-out property <string> global_variables;
    in-out property <string> environment_name;
    in-out property <string> environment_variables;
    in-out property <string> query_params;
    in-out property <string> request_headers;
    in-out property <string> auth_mode;
    in-out property <string> auth_config;
    in-out property <string> body_mode;
    in-out property <string> request_body;

    horizontal-stretch: 1;
    vertical-stretch: 1;
    background: Theme.surface;

    VerticalLayout {
        padding: 0px;
        spacing: 0px;

        TabHeader {
            label: "Request";
        }

        Rectangle {
            height: 112px;
            background: Theme.surface;

            HorizontalLayout {
                padding: 10px;
                spacing: 10px;

                Rectangle {
                    width: 128px;
                    vertical-stretch: 1;

                    VerticalLayout {
                        padding: 0px;
                        spacing: 6px;

                        UiText {
                            text: "Env";
                            height: 20px;
                            color: Theme.on_surface_variant;
                            font-size: 12px;
                            font-weight: 800;
                            vertical-alignment: center;
                            overflow: elide;
                        }

                        TextField {
                            text <=> root.environment_name;
                            placeholder: "dev";
                            mono: true;
                            height: 34px;
                        }
                    }
                }

                LabeledEditor {
                    label: "Globals";
                    text <=> root.global_variables;
                }

                LabeledEditor {
                    label: "Env Vars";
                    text <=> root.environment_variables;
                }
            }
        }

        Rectangle {
            height: 1px;
            background: Theme.outline_variant;
        }

        Rectangle {
            height: 134px;
            background: Theme.surface;

            HorizontalLayout {
                padding: 10px;
                spacing: 10px;

                LabeledEditor {
                    label: "Params";
                    text <=> root.query_params;
                }

                LabeledEditor {
                    label: "Headers";
                    text <=> root.request_headers;
                }

                LabeledEditor {
                    label: "Auth / " + root.auth_mode;
                    text <=> root.auth_config;
                    read_only: root.auth_mode == "none";
                }
            }
        }

        Rectangle {
            height: 1px;
            background: Theme.outline_variant;
        }

        Rectangle {
            height: 34px;
            background: Theme.surface_container_lowest;

            HorizontalLayout {
                padding-left: 10px;
                padding-right: 10px;
                spacing: 8px;
                alignment: center;

                for item in [
                    { mode: "none", label: "no auth" },
                    { mode: "bearer", label: "bearer" },
                    { mode: "basic", label: "basic" },
                    { mode: "jwt", label: "jwt" },
                    { mode: "api-header", label: "api-h" },
                    { mode: "api-query", label: "api-q" },
                ]: BodyModeButton {
                    mode: item.mode;
                    label: item.label;
                    selected: root.auth_mode == item.mode;
                    picked(mode) => {
                        root.auth_mode = mode;
                    }
                }
            }
        }

        Rectangle {
            height: 1px;
            background: Theme.outline_variant;
        }

        Rectangle {
            height: 34px;
            background: Theme.surface_container_lowest;

            HorizontalLayout {
                padding-left: 10px;
                padding-right: 10px;
                spacing: 8px;
                alignment: center;

                for item in [
                    { mode: "none", label: "none" },
                    { mode: "raw", label: "raw" },
                    { mode: "form", label: "form" },
                    { mode: "urlenc", label: "urlenc" },
                    { mode: "graphql", label: "graphql" },
                    { mode: "binary", label: "binary" },
                ]: BodyModeButton {
                    mode: item.mode;
                    label: item.label;
                    selected: root.body_mode == item.mode;
                    picked(mode) => {
                        root.body_mode = mode;
                    }
                }
            }
        }

        Rectangle {
            vertical-stretch: 1;
            background: Theme.surface;

            VerticalLayout {
                padding: 10px;

                LabeledEditor {
                    label: "Body / " + root.body_mode;
                    text <=> root.request_body;
                    read_only: root.body_mode == "none";
                }
            }
        }
    }
}

component ResponsePanel inherits Rectangle {
    in-out property <string> response_body;
    in-out property <string> response_headers;
    in-out property <string> codegen_language;
    in-out property <string> codegen_output;
    in property <string> response_status;
    in property <string> response_meta;
    in property <string> response_tone;
    in property <bool> busy;
    callback generate_code();

    width: 420px;
    vertical-stretch: 1;
    background: Theme.surface;

    VerticalLayout {
        padding: 0px;
        spacing: 0px;

        TabHeader {
            label: "Response";
            status: root.response_status + (root.response_meta == "" ? "" : " / " + root.response_meta);
            tone: root.response_tone;
        }

        Rectangle {
            height: 34px;
            background: Theme.surface_container_lowest;

            UiText {
                x: 14px;
                text: "Body  Headers  Cookies";
                width: parent.width - 28px;
                height: parent.height;
                font-size: 12px;
                color: Theme.outline;
                vertical-alignment: center;
                overflow: elide;
            }
        }

        Rectangle {
            vertical-stretch: 1;
            background: Theme.surface;

            VerticalLayout {
                padding: 10px;
                spacing: 10px;

                LabeledEditor {
                    label: "Body";
                    text <=> root.response_body;
                    read_only: true;
                }

                Rectangle {
                    height: 126px;
                    horizontal-stretch: 1;

                    LabeledEditor {
                        label: "Headers";
                        text <=> root.response_headers;
                        read_only: true;
                    }
                }

                Rectangle {
                    height: 182px;
                    horizontal-stretch: 1;
                    background: transparent;

                    VerticalLayout {
                        padding: 0px;
                        spacing: 8px;

                        HorizontalLayout {
                            height: 28px;
                            spacing: 8px;
                            alignment: center;

                            for item in [
                                { mode: "curl", label: "curl" },
                                { mode: "python", label: "py" },
                                { mode: "js", label: "js" },
                                { mode: "rust", label: "rust" },
                                { mode: "go", label: "go" },
                            ]: BodyModeButton {
                                mode: item.mode;
                                label: item.label;
                                button_width: 54px;
                                selected: root.codegen_language == item.mode;
                                enabled: !root.busy;
                                picked(mode) => {
                                    root.codegen_language = mode;
                                }
                            }

                            ActionButton {
                                text: "Generate";
                                button_width: 86px;
                                primary: true;
                                enabled: !root.busy;
                                clicked => {
                                    root.generate_code();
                                }
                            }
                        }

                        LabeledEditor {
                            label: "Code / " + root.codegen_language;
                            text <=> root.codegen_output;
                            read_only: true;
                        }
                    }
                }
            }
        }
    }
}

component StatusBar inherits Rectangle {
    in property <bool> server_running;
    in property <string> server_status;
    in property <int> route_count;
    in property <bool> busy;
    in property <string> activity;

    height: 28px;
    horizontal-stretch: 1;
    background: Theme.surface_container;

    Rectangle {
        width: parent.width;
        height: 1px;
        background: Theme.outline_variant;
    }

    HorizontalLayout {
        padding-left: 14px;
        padding-right: 14px;
        spacing: 18px;
        alignment: center;

        UiText {
            text: root.server_running ? "Mock " + root.server_status : "Mock stopped";
            width: 220px;
            height: parent.height;
            font-family: "JetBrains Mono";
            font-size: 12px;
            color: root.server_running ? Theme.secondary : Theme.outline;
            vertical-alignment: center;
            overflow: elide;
        }

        UiText {
            text: root.route_count + " routes";
            width: 90px;
            height: parent.height;
            font-family: "JetBrains Mono";
            font-size: 12px;
            color: Theme.on_surface_variant;
            vertical-alignment: center;
            overflow: elide;
        }

        UiText {
            text: root.busy ? "Busy" : "";
            width: 52px;
            height: parent.height;
            color: Theme.tertiary;
            font-size: 12px;
            vertical-alignment: center;
            overflow: elide;
        }

        UiText {
            text: root.activity;
            horizontal-stretch: 1;
            height: parent.height;
            color: Theme.on_surface_variant;
            font-size: 12px;
            horizontal-alignment: right;
            vertical-alignment: center;
            overflow: elide;
        }
    }
}

export component AppWindow inherits Window {
    title: "ZenAPI";
    preferred-width: 1280px;
    preferred-height: 800px;
    min-width: 980px;
    min-height: 640px;
    default-font-family: "Inter";
    default-font-size: 13px;
    default-font-weight: 500;

    in-out property <[RouteRow]> routes;
    in-out property <int> selected_route: -1;
    in-out property <string> file_path;
    in-out property <string> spec_label: "";
    in-out property <bool> spec_loaded: false;
    in-out property <string> method: "GET";
    in-out property <string> url;
    in-out property <string> global_variables: "baseUrl=https://api.example.com";
    in-out property <string> environment_name: "dev";
    in-out property <string> environment_variables: "baseUrl=http://127.0.0.1:8080";
    in-out property <string> query_params;
    in-out property <string> request_headers: "Accept: application/json";
    in-out property <string> auth_mode: "none";
    in-out property <string> auth_config;
    in-out property <string> body_mode: "none";
    in-out property <string> request_body;
    in-out property <string> response_status: "Idle";
    in-out property <string> response_meta: "";
    in-out property <string> response_tone: "neutral";
    in-out property <string> response_body: "Import an OpenAPI or Swagger document to begin.";
    in-out property <string> response_headers: "";
    in-out property <string> codegen_language: "curl";
    in-out property <string> codegen_output: "";
    in-out property <string> route_filter;
    in-out property <int> total_route_count: 0;
    in-out property <string> server_status: "Stopped";
    in-out property <bool> server_running: false;
    in-out property <bool> busy: false;
    in-out property <string> activity: "";

    callback import_openapi(string);
    callback filter_routes(string);
    callback select_route(int);
    callback send_request();
    callback toggle_server();
    callback generate_code();

    background: Theme.background;

    VerticalLayout {
        padding: 0px;
        spacing: 0px;

        TopBar {
            file_path <=> root.file_path;
            spec_label: root.spec_label;
            spec_loaded: root.spec_loaded;
            server_running: root.server_running;
            server_status: root.server_status;
            route_count: root.total_route_count;
            busy: root.busy;
            import_openapi(path) => {
                root.import_openapi(path);
            }
            toggle_server => {
                root.toggle_server();
            }
        }

        HorizontalLayout {
            spacing: 0px;
            vertical-stretch: 1;

            Sidebar {
                routes <=> root.routes;
                selected_route <=> root.selected_route;
                route_filter <=> root.route_filter;
                total_route_count: root.total_route_count;
                filter_routes(query) => {
                    root.filter_routes(query);
                }
                select_route(index) => {
                    root.select_route(index);
                }
            }

            Rectangle {
                width: 1px;
                background: Theme.outline_variant;
            }

            Rectangle {
                horizontal-stretch: 1;
                vertical-stretch: 1;
                background: Theme.surface;

                VerticalLayout {
                    padding: 0px;
                    spacing: 0px;

                    AddressBar {
                        method <=> root.method;
                        url <=> root.url;
                        busy: root.busy;
                        send_request => {
                            root.send_request();
                        }
                    }

                    HorizontalLayout {
                        padding: 0px;
                        spacing: 0px;
                        vertical-stretch: 1;

                        RequestPanel {
                            global_variables <=> root.global_variables;
                            environment_name <=> root.environment_name;
                            environment_variables <=> root.environment_variables;
                            query_params <=> root.query_params;
                            request_headers <=> root.request_headers;
                            auth_mode <=> root.auth_mode;
                            auth_config <=> root.auth_config;
                            body_mode <=> root.body_mode;
                            request_body <=> root.request_body;
                        }

                        Rectangle {
                            width: 1px;
                            background: Theme.outline_variant;
                        }

                        ResponsePanel {
                            response_body <=> root.response_body;
                            response_headers <=> root.response_headers;
                            codegen_language <=> root.codegen_language;
                            codegen_output <=> root.codegen_output;
                            response_status: root.response_status;
                            response_meta: root.response_meta;
                            response_tone: root.response_tone;
                            busy: root.busy;
                            generate_code => {
                                root.generate_code();
                            }
                        }
                    }
                }
            }
        }

        StatusBar {
            server_running: root.server_running;
            server_status: root.server_status;
            route_count: root.total_route_count;
            busy: root.busy;
            activity: root.activity;
        }
    }
}
