import { ListView, ScrollView } from "std-widgets.slint";
import { Theme } from "theme.slint";
import { ActionButton, BodyModeButton, CodePane, LabeledEditor, MethodChip, MethodSelector, StatusDot, TextField, UiText } from "widgets.slint";

export struct RouteRow {
    method: string,
    path: string,
    summary: string,
}

export struct HistoryRow {
    id: int,
    method: string,
    url: string,
    status: string,
}

export struct CollectionRow {
    id: int,
    method: string,
    name: string,
    url: string,
}

export struct RunnerRow {
    method: string,
    name: string,
    status: string,
    detail: string,
    tone: string,
}

export struct MockLogRow {
    method: string,
    path: string,
    status: string,
}

export struct VariableTableRow {
    row_id: int,
    scope: string,
    name: string,
    initial_value: string,
    current_value: string,
}

export struct KeyValueTableRow {
    row_id: int,
    key: string,
    value: string,
}

component KeyValueEditorPanel inherits Rectangle {
    in-out property <string> text;
    in property <string> title;
    in property <string> key_header: "Key";
    in property <string> value_header: "Value";
    in property <string> helper: "";
    in property <bool> read_only: false;

    horizontal-stretch: 1;
    vertical-stretch: 1;
    background: transparent;

    VerticalLayout {
        padding: 0px;
        spacing: 6px;

        if root.title != "": UiText {
            text: root.title;
            height: 20px;
            horizontal-stretch: 1;
            color: Theme.on_surface_variant;
            font-size: 12px;
            font-weight: 800;
            vertical-alignment: center;
            overflow: elide;
        }

        Rectangle {
            height: 30px;
            horizontal-stretch: 1;
            border-radius: 6px;
            border-width: 1px;
            border-color: Theme.outline_variant;
            background: Theme.surface_container;

            UiText {
                x: 12px;
                text: root.key_header;
                width: 128px;
                height: parent.height;
                color: Theme.on_surface_variant;
                font-size: 12px;
                font-weight: 800;
                vertical-alignment: center;
                overflow: elide;
            }

            Rectangle {
                x: 148px;
                y: 6px;
                width: 1px;
                height: parent.height - 12px;
                background: Theme.outline_variant;
            }

            UiText {
                x: 160px;
                text: root.value_header;
                width: parent.width - 172px;
                height: parent.height;
                color: Theme.on_surface_variant;
                font-size: 12px;
                font-weight: 800;
                vertical-alignment: center;
                overflow: elide;
            }
        }

        CodePane {
            text <=> root.text;
            read_only: root.read_only;
        }

        if root.helper != "": UiText {
            text: root.helper;
            height: 18px;
            horizontal-stretch: 1;
            color: Theme.outline;
            font-size: 12px;
            vertical-alignment: center;
            overflow: elide;
        }
    }
}

component KeyValueTableLine inherits Rectangle {
    in property <int> row_id;
    in-out property <string> key;
    in-out property <string> value;
    in property <bool> enabled: true;
    callback edited(int, string, string);
    callback delete_requested(int);

    height: 44px;
    horizontal-stretch: 1;
    border-radius: 6px;
    border-width: 1px;
    border-color: Theme.outline_variant;
    background: row_touch.has-hover ? Theme.surface_container_high : Theme.surface_container_low;

    row_touch := TouchArea {}

    TextField {
        x: 10px;
        y: 5px;
        width: 154px;
        height: 34px;
        text <=> root.key;
        placeholder: "key";
        mono: true;
        enabled: root.enabled;
        edited => {
            root.edited(root.row_id, root.key, root.value);
        }
    }

    TextField {
        x: 176px;
        y: 5px;
        width: parent.width - 240px;
        height: 34px;
        text <=> root.value;
        placeholder: "value";
        mono: true;
        enabled: root.enabled;
        edited => {
            root.edited(root.row_id, root.key, root.value);
        }
    }

    ActionButton {
        x: parent.width - 54px;
        y: 5px;
        text: "Del";
        button_width: 44px;
        warning: true;
        enabled: root.enabled;
        clicked => {
            root.delete_requested(root.row_id);
        }
    }
}

component KeyValueTablePanel inherits Rectangle {
    in-out property <[KeyValueTableRow]> rows;
    in property <string> title;
    in property <string> key_header: "Key";
    in property <string> value_header: "Value";
    in property <string> helper: "";
    in property <bool> busy: false;
    callback add_row();
    callback update_row(int, string, string);
    callback delete_row(int);

    horizontal-stretch: 1;
    vertical-stretch: 1;
    background: transparent;

    VerticalLayout {
        padding: 0px;
        spacing: 8px;

        HorizontalLayout {
            height: 28px;
            spacing: 8px;
            alignment: center;

            UiText {
                text: root.title;
                horizontal-stretch: 1;
                height: parent.height;
                color: Theme.on_surface_variant;
                font-size: 12px;
                font-weight: 800;
                vertical-alignment: center;
                overflow: elide;
            }

            ActionButton {
                text: "+";
                button_width: 34px;
                enabled: !root.busy;
                clicked => {
                    root.add_row();
                }
            }
        }

        Rectangle {
            height: 30px;
            horizontal-stretch: 1;
            border-radius: 6px;
            border-width: 1px;
            border-color: Theme.outline_variant;
            background: Theme.surface_container;

            UiText {
                x: 14px;
                text: root.key_header;
                width: 150px;
                height: parent.height;
                color: Theme.on_surface_variant;
                font-size: 12px;
                font-weight: 800;
                vertical-alignment: center;
                overflow: elide;
            }

            Rectangle {
                x: 172px;
                y: 6px;
                width: 1px;
                height: parent.height - 12px;
                background: Theme.outline_variant;
            }

            UiText {
                x: 184px;
                text: root.value_header;
                width: parent.width - 244px;
                height: parent.height;
                color: Theme.on_surface_variant;
                font-size: 12px;
                font-weight: 800;
                vertical-alignment: center;
                overflow: elide;
            }
        }

        Rectangle {
            horizontal-stretch: 1;
            vertical-stretch: 1;
            background: transparent;

            if root.rows.length == 0: UiText {
                text: "No rows";
                width: parent.width;
                height: 32px;
                color: Theme.outline;
                font-size: 12px;
                vertical-alignment: center;
                overflow: elide;
            }

            if root.rows.length != 0: ListView {
                width: parent.width;
                height: parent.height;
                vertical-scrollbar-policy: ScrollBarPolicy.as-needed;
                horizontal-scrollbar-policy: ScrollBarPolicy.as-needed;

                for row in root.rows: KeyValueTableLine {
                    row_id: row.row_id;
                    key: row.key;
                    value: row.value;
                    enabled: !root.busy;
                    edited(row_id, key, value) => {
                        root.update_row(row_id, key, value);
                    }
                    delete_requested(row_id) => {
                        root.delete_row(row_id);
                    }
                }
            }
        }

        if root.helper != "": UiText {
            text: root.helper;
            height: 18px;
            horizontal-stretch: 1;
            color: Theme.outline;
            font-size: 12px;
            vertical-alignment: center;
            overflow: elide;
        }
    }
}

