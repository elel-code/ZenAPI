import { ListView, ScrollView } from "std-widgets.slint";
import "fonts/Inter-VariableFont.ttf";
import "fonts/NotoSansMono-Regular.ttf";

export struct RouteRow {
    method: string,
    path: string,
    summary: string,
}

component UiText inherits Text {
    font-family: "Inter";
    font-size: 13px;
    font-weight: 500;
    color: #111827;
    letter-spacing: 0px;
}

global MethodStyle {
    public pure function text-color(method: string) -> color {
        return method == "GET" ? #059669 : method == "POST" ? #d97706 : method == "PUT" ? #2563eb : method == "PATCH" ? #7c3aed : method == "DELETE" ? #dc2626 : #6b7280;
    }

    public pure function background-color(method: string) -> color {
        return method == "GET" ? #ecfdf5 : method == "POST" ? #fffbeb : method == "PUT" ? #eff6ff : method == "PATCH" ? #f5f3ff : method == "DELETE" ? #fef2f2 : #f3f4f6;
    }
}

global ToneStyle {
    public pure function color(tone: string) -> color {
        return tone == "error" ? #dc2626 : tone == "busy" ? #d97706 : tone == "success" ? #059669 : #6b7280;
    }
}

global ButtonStyle {
    public pure function border-color(enabled: bool, primary: bool, warning: bool) -> color {
        return !enabled ? #d1d5db : warning ? #b45309 : primary ? #1d4ed8 : #d1d5db;
    }

    public pure function background-color(enabled: bool, primary: bool, warning: bool, pressed: bool, hovered: bool) -> color {
        return !enabled ? #f3f4f6 : warning ? (pressed ? #92400e : hovered ? #d97706 : #b45309) : primary ? (pressed ? #1d4ed8 : hovered ? #3b82f6 : #2563eb) : (pressed ? #e5e7eb : hovered ? #f3f4f6 : #ffffff);
    }

    public pure function text-color(enabled: bool, primary: bool, warning: bool) -> color {
        return !enabled ? #9ca3af : primary || warning ? #ffffff : #374151;
    }
}

component PaneHeader inherits Rectangle {
    in property <string> text;

    height: 36px;
    horizontal-stretch: 1;
    background: #ffffff;

    HorizontalLayout {
        padding-left: 14px;
        padding-right: 14px;
        alignment: center;

        UiText {
            text: root.text;
            height: root.height;
            color: #111827;
            font-weight: 700;
            font-size: 13px;
            vertical-alignment: center;
        }
    }
}

component PopupSurface inherits Rectangle {
    background: #ffffff;
    border-radius: 6px;
    border-width: 1px;
    border-color: #d1d5db;
    clip: true;
    drop-shadow-color: #0000001a;
    drop-shadow-blur: 6px;
    drop-shadow-offset-y: 2px;
}

component ActionButton inherits Rectangle {
    in property <string> text;
    in property <bool> enabled: true;
    in property <bool> primary: false;
    in property <bool> warning: false;
    in property <bool> embedded: false;
    callback clicked();

    height: 34px;
    width: 104px;
    border-top-left-radius: root.embedded ? 0px : 6px;
    border-bottom-left-radius: root.embedded ? 0px : 6px;
    border-top-right-radius: root.embedded ? 5px : 6px;
    border-bottom-right-radius: root.embedded ? 5px : 6px;
    border-width: root.embedded ? 0px : 1px;
    border-color: ButtonStyle.border-color(root.enabled, root.primary, root.warning);
    background: ButtonStyle.background-color(root.enabled, root.primary, root.warning, touch.pressed, touch.has-hover);
    opacity: root.enabled ? 1 : 0.65;

    touch := TouchArea {
        width: parent.width;
        height: parent.height;
        enabled: root.enabled;
        mouse-cursor: root.enabled ? pointer : default;
        clicked => {
            root.clicked();
        }
    }

    UiText {
        text: root.text;
        width: parent.width;
        height: parent.height;
        color: ButtonStyle.text-color(root.enabled, root.primary, root.warning);
        font-size: 13px;
        font-weight: 700;
        horizontal-alignment: center;
        vertical-alignment: center;
        overflow: elide;
    }
}

component ButtonSlot inherits Rectangle {
    in property <string> text;
    in property <bool> enabled: true;
    in property <bool> primary: false;
    in property <bool> warning: false;
    in property <bool> embedded: false;
    in property <length> button-width: 104px;
    in property <length> button-height: 34px;
    in property <length> slot-height: 40px;
    callback clicked();

    width: root.button-width;
    height: root.slot-height;
    vertical-stretch: 0;

    ActionButton {
        y: (root.slot-height - root.button-height) / 2;
        text: root.text;
        enabled: root.enabled;
        primary: root.primary;
        warning: root.warning;
        embedded: root.embedded;
        width: root.button-width;
        height: root.button-height;
        clicked => {
            root.clicked();
        }
    }
}

component TextFieldShell inherits Rectangle {
    in-out property <string> text;
    in property <string> placeholder;
    in property <bool> show-label: false;
    in property <string> label: "";
    in property <bool> embedded: false;
    in property <bool> mono: false;
    in property <bool> enabled: true;
    out property <bool> focused: text-input.has-focus;
    callback edited();
    callback accepted();

    height: 36px;
    horizontal-stretch: 1;
    vertical-stretch: 0;
    border-radius: root.embedded ? 0px : 6px;
    border-width: root.embedded ? 0px : 1px;
    border-color: root.enabled && text-input.has-focus ? #2563eb : root.enabled ? #d1d5db : #e5e7eb;
    background: root.embedded ? transparent : root.enabled ? #ffffff : #f9fafb;
    opacity: root.enabled ? 1 : 0.72;

    HorizontalLayout {
        padding-left: 12px;
        padding-right: 12px;
        spacing: 10px;
        alignment: center;

        if root.show-label: UiText {
            text: root.label;
            width: 30px;
            height: root.height;
            font-size: 11px;
            font-weight: 800;
            color: #6b7280;
            horizontal-alignment: center;
            vertical-alignment: center;
        }

        Rectangle {
            horizontal-stretch: 1;
            height: parent.height;
            background: transparent;

            Text {
                text: root.text == "" ? root.placeholder : "";
                width: parent.width;
                height: parent.height;
                color: #9ca3af;
                font-family: root.mono ? "Noto Sans Mono" : "Inter";
                font-size: 13px;
                font-weight: root.mono ? 400 : 500;
                letter-spacing: 0px;
                horizontal-alignment: left;
                vertical-alignment: center;
                overflow: elide;
            }

            text-input := TextInput {
                text <=> root.text;
                width: parent.width;
                height: parent.height;
                enabled: root.enabled;
                single-line: true;
                font-family: root.mono ? "Noto Sans Mono" : "Inter";
                font-size: 13px;
                font-weight: root.mono ? 400 : 500;
                letter-spacing: 0px;
                color: #111827;
                selection-background-color: #2563eb;
                selection-foreground-color: #ffffff;
                text-cursor-width: 2px;
                vertical-alignment: center;
                edited => {
                    root.edited();
                }
                accepted => {
                    if root.enabled {
                        root.accepted();
                    }
                }
            }
        }
    }
}

component MethodOption inherits Rectangle {
    in property <string> value;
    in property <bool> selected;
    callback picked(string);

    height: 32px;
    horizontal-stretch: 1;
    border-radius: 4px;
    background: root.selected ? #eef2ff : option-touch.has-hover ? #f3f4f6 : #ffffff;

    option-touch := TouchArea {
        mouse-cursor: pointer;
        clicked => {
            root.picked(root.value);
        }
    }

    UiText {
        x: 10px;
        y: 0px;
        text: root.value;
        width: root.width - 20px;
        height: root.height;
        font-size: 12px;
        font-weight: 800;
        color: MethodStyle.text-color(root.value);
        overflow: elide;
        vertical-alignment: center;
    }
}

component ChevronDown inherits Path {
    width: 10px;
    height: 6px;
    viewbox-width: 10;
    viewbox-height: 6;
    fill: transparent;
    stroke: #6b7280;
    stroke-width: 1.5px;

    MoveTo {
        x: 1;
        y: 1;
    }

    LineTo {
        x: 5;
        y: 5;
    }

    LineTo {
        x: 9;
        y: 1;
    }
}

component MethodSelector inherits Rectangle {
    in-out property <string> method;
    in property <bool> embedded: false;
    in property <bool> enabled: true;

    width: 108px;
    height: 36px;
    vertical-stretch: 0;
    border-radius: root.embedded ? 0px : 6px;
    border-width: root.embedded ? 0px : 1px;
    border-color: #d1d5db;
    background: !root.enabled ? (root.embedded ? transparent : #f9fafb) : root.embedded ? (picker-touch.pressed ? #f3f4f6 : picker-touch.has-hover ? #f9fafb : transparent) : (picker-touch.pressed ? #f3f4f6 : picker-touch.has-hover ? #f9fafb : #ffffff);
    opacity: root.enabled ? 1 : 0.72;

    picker-touch := TouchArea {
        enabled: root.enabled;
        mouse-cursor: root.enabled ? pointer : default;
        clicked => {
            if root.enabled {
                method-popup.show();
            }
        }
    }

    UiText {
        x: 12px;
        y: 0px;
        text: root.method;
        width: 68px;
        height: root.height;
        font-size: 12px;
        font-weight: 800;
        color: MethodStyle.text-color(root.method);
        overflow: elide;
        horizontal-alignment: center;
        vertical-alignment: center;
    }

    ChevronDown {
        x: root.width - 22px;
        y: (root.height - 6px) / 2;
        width: 10px;
        height: 6px;
    }

    Rectangle {
        x: root.width - 1px;
        width: 1px;
        height: root.height;
        background: #e5e7eb;
        visible: root.embedded;
    }

    method-popup := PopupWindow {
        x: 0px;
        y: root.height + 6px;
        width: root.width;
        height: 250px;
        close-policy: close-on-click-outside;

        PopupSurface {
            width: method-popup.width;
            height: method-popup.height;

            ScrollView {
                x: 6px;
                y: 6px;
                width: parent.width - 12px;
                height: parent.height - 12px;
                vertical-scrollbar-policy: ScrollBarPolicy.always-off;
                horizontal-scrollbar-policy: ScrollBarPolicy.always-off;

                VerticalLayout {
                    spacing: 2px;

                    MethodOption {
                        value: "GET";
                        selected: root.method == "GET";
                        picked(value) => {
                            root.method = value;
                            method-popup.close();
                        }
                    }

                    MethodOption {
                        value: "POST";
                        selected: root.method == "POST";
                        picked(value) => {
                            root.method = value;
                            method-popup.close();
                        }
                    }

                    MethodOption {
                        value: "PUT";
                        selected: root.method == "PUT";
                        picked(value) => {
                            root.method = value;
                            method-popup.close();
                        }
                    }

                    MethodOption {
                        value: "PATCH";
                        selected: root.method == "PATCH";
                        picked(value) => {
                            root.method = value;
                            method-popup.close();
                        }
                    }

                    MethodOption {
                        value: "DELETE";
                        selected: root.method == "DELETE";
                        picked(value) => {
                            root.method = value;
                            method-popup.close();
                        }
                    }

                    MethodOption {
                        value: "HEAD";
                        selected: root.method == "HEAD";
                        picked(value) => {
                            root.method = value;
                            method-popup.close();
                        }
                    }

                    MethodOption {
                        value: "OPTIONS";
                        selected: root.method == "OPTIONS";
                        picked(value) => {
                            root.method = value;
                            method-popup.close();
                        }
                    }
                }
            }
        }
    }
}

component CodePane inherits Rectangle {
    in-out property <string> text;
    in property <bool> read-only;

    horizontal-stretch: 1;
    vertical-stretch: 1;
    background: #ffffff;
    border-color: !root.read-only && code-input.has-focus ? #2563eb : #e5e7eb;
    border-width: 1px;
    border-radius: 4px;

    VerticalLayout {
        padding: 0px;

        ScrollView {
            viewport-width: max(self.visible-width, code-input.preferred-width + 28px);
            viewport-height: max(self.visible-height, code-input.preferred-height + 24px);
            vertical-scrollbar-policy: ScrollBarPolicy.always-off;
            horizontal-scrollbar-policy: ScrollBarPolicy.always-off;

            code-input := TextInput {
                x: 14px;
                y: 12px;
                width: max(parent.visible-width - 28px, self.preferred-width);
                height: max(parent.visible-height - 24px, self.preferred-height);
                text <=> root.text;
                read-only: root.read-only;
                single-line: false;
                wrap: word-wrap;
                font-family: "Noto Sans Mono";
                font-size: 13px;
                font-weight: 400;
                letter-spacing: 0px;
                color: #111827;
                selection-background-color: #2563eb;
                selection-foreground-color: #ffffff;
                text-cursor-width: root.read-only ? 0px : 2px;
            }
        }
    }
}

component SpecStatusSlot inherits Rectangle {
    in property <string> text;
    in property <bool> loaded;
    in property <length> slot-height: 48px;

    width: 360px;
    height: root.slot-height;
    vertical-stretch: 0;
    background: transparent;

    Rectangle {
        y: (root.slot-height - 34px) / 2;
        width: parent.width;
        height: 34px;
        vertical-stretch: 0;
        border-radius: 6px;
        border-width: 1px;
        border-color: #d1d5db;
        background: #f3f4f6;

        UiText {
            x: 12px;
            y: 0px;
            text: root.text;
            width: parent.width - 24px;
            height: parent.height;
            color: root.loaded ? #374151 : #6b7280;
            font-family: root.loaded ? "Noto Sans Mono" : "Inter";
            font-size: 13px;
            font-italic: !root.loaded;
            overflow: elide;
            vertical-alignment: center;
        }
    }
}

component MockControlSlot inherits Rectangle {
    in property <bool> server-running;
    in property <string> server-status;
    in property <int> route-count;
    in property <bool> busy;
    in property <length> slot-height: 48px;
    callback toggled();

    width: 230px;
    height: root.slot-height;
    vertical-stretch: 0;
    background: transparent;

    UiText {
        x: 0px;
        y: (root.slot-height - 34px) / 2;
        text: root.server-running ? root.server-status : "";
        width: 112px;
        height: 34px;
        color: #6b7280;
        font-family: "Noto Sans Mono";
        font-size: 12px;
        overflow: elide;
        horizontal-alignment: right;
        vertical-alignment: center;
    }

    ButtonSlot {
        x: 120px;
        y: 0px;
        text: root.server-running ? "Stop Mock" : "Start Mock";
        enabled: !root.busy && (root.server-running || root.route-count > 0);
        warning: root.server-running;
        button-width: 110px;
        button-height: 34px;
        slot-height: root.slot-height;
        clicked => {
            root.toggled();
        }
    }
}

component TopBar inherits Rectangle {
    in-out property <string> file-path;
    in property <string> spec-label;
    in property <bool> spec-loaded;
    in property <bool> server-running;
    in property <string> server-status;
    in property <int> route-count;
    in property <bool> busy;
    callback import-openapi(string);
    callback toggle-server();

    height: 48px;
    horizontal-stretch: 1;
    background: #f9fafb;

    HorizontalLayout {
        padding-left: 0px;
        padding-right: 14px;
        spacing: 0px;
        alignment: center;

        Rectangle {
            width: 260px;
            height: root.height;
            vertical-stretch: 0;
            background: #f9fafb;

            UiText {
                x: 16px;
                y: 0px;
                text: "ZenAPI";
                width: parent.width - 30px;
                height: parent.height;
                font-size: 16px;
                font-weight: 800;
                color: #111827;
                overflow: elide;
                vertical-alignment: center;
            }
        }

        HorizontalLayout {
            padding-left: 15px;
            padding-right: 14px;
            spacing: 8px;
            alignment: center;
            horizontal-stretch: 1;

            SpecStatusSlot {
                text: root.spec-loaded ? root.spec-label : "No specification loaded";
                loaded: root.spec-loaded;
                slot-height: root.height;
            }

            ButtonSlot {
                text: "Import";
                enabled: !root.busy;
                button-width: 78px;
                button-height: 34px;
                slot-height: root.height;
                clicked => {
                    import-popup.show();
                }
            }

            Rectangle {
                horizontal-stretch: 1;
            }
        }

        MockControlSlot {
            server-running: root.server-running;
            server-status: root.server-status;
            route-count: root.route-count;
            busy: root.busy;
            slot-height: root.height;
            toggled => {
                root.toggle-server();
            }
        }
    }

    import-popup := PopupWindow {
        x: 275px;
        y: root.height + 4px;
        width: 520px;
        height: 92px;
        close-policy: close-on-click-outside;

        PopupSurface {
            width: import-popup.width;
            height: import-popup.height;

            VerticalLayout {
                padding: 10px;
                spacing: 8px;

                UiText {
                    text: "OpenAPI specification";
                    height: 18px;
                    font-size: 12px;
                    font-weight: 700;
                    color: #6b7280;
                    vertical-alignment: center;
                }

                HorizontalLayout {
                    spacing: 8px;
                    alignment: center;

                    TextFieldShell {
                        text <=> root.file-path;
                        placeholder: "Local JSON or YAML file path";
                        show-label: true;
                        label: "PATH";
                        mono: true;
                        enabled: !root.busy;
                        height: 34px;
                        horizontal-stretch: 1;
                        accepted => {
                            if !root.busy {
                                import-popup.close();
                                root.import-openapi(root.file-path);
                            }
                        }
                    }

                    ActionButton {
                        text: "Import";
                        enabled: !root.busy;
                        primary: true;
                        width: 78px;
                        height: 34px;
                        clicked => {
                            if !root.busy {
                                import-popup.close();
                                root.import-openapi(root.file-path);
                            }
                        }
                    }
                }
            }
        }
    }
}

component Sidebar inherits Rectangle {
    in-out property <[RouteRow]> routes;
    in-out property <int> selected-route;
    in-out property <string> route-filter;
    in property <int> total-route-count;
    callback select-route(int);
    callback filter-routes(string);

    width: 260px;
    vertical-stretch: 1;
    background: #f9fafb;

    VerticalLayout {
        padding: 12px;
        spacing: 8px;

        HorizontalLayout {
            spacing: 8px;

            UiText {
                text: "Endpoints";
                font-size: 13px;
                font-weight: 700;
                color: #111827;
                height: 22px;
                vertical-alignment: center;
            }

            Rectangle {
                horizontal-stretch: 1;
            }

            UiText {
                text: root.total-route-count == 0 ? "" : root.routes.length + "/" + root.total-route-count;
                font-size: 12px;
                color: #6b7280;
                height: 22px;
                vertical-alignment: center;
            }
        }

        TextFieldShell {
            text <=> root.route-filter;
            placeholder: "Filter method, path, or summary";
            show-label: true;
            label: "FIND";
            height: root.total-route-count > 0 ? 32px : 0px;
            visible: root.total-route-count > 0;
            edited => {
                root.filter-routes(root.route-filter);
            }
        }

        Rectangle {
            height: root.routes.length == 0 ? 38px : 0px;
            background: #f9fafb;
            border-radius: 0px;
            border-width: 0px;

            VerticalLayout {
                padding: 0px;
                spacing: 0px;
                alignment: center;

                UiText {
                    text: root.routes.length == 0 ? (root.total-route-count == 0 ? "No endpoints" : "No matches") : "";
                    height: 20px;
                    font-size: 13px;
                    font-weight: 500;
                    color: #6b7280;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
            }
        }

        ListView {
            horizontal-stretch: 1;
            vertical-stretch: 1;
            vertical-scrollbar-policy: ScrollBarPolicy.always-off;
            horizontal-scrollbar-policy: ScrollBarPolicy.always-off;

            for route[i] in root.routes: Rectangle {
                height: 38px;
                border-radius: 4px;
                background: root.selected-route == i ? #eef2ff : (route-touch.has-hover ? #f3f4f6 : #f9fafb);

                route-touch := TouchArea {
                    mouse-cursor: pointer;
                    clicked => {
                        root.selected-route = i;
                        root.select-route(i);
                    }
                }

                HorizontalLayout {
                    padding-left: 6px;
                    padding-right: 8px;
                    spacing: 8px;
                    alignment: center;

                    Rectangle {
                        width: 60px;
                        height: 22px;
                        border-radius: 4px;
                        background: MethodStyle.background-color(route.method);

                        UiText {
                            text: route.method;
                            width: parent.width;
                            height: parent.height;
                            font-size: 11px;
                            font-weight: 800;
                            color: MethodStyle.text-color(route.method);
                            overflow: elide;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }

                    Rectangle {
                        horizontal-stretch: 1;
                        height: 32px;
                        background: transparent;

                        VerticalLayout {
                            spacing: 0px;
                            alignment: center;

                            UiText {
                                text: route.path;
                                height: 18px;
                                font-family: "Noto Sans Mono";
                                font-size: 12px;
                                font-weight: 700;
                                color: root.selected-route == i ? #111827 : #374151;
                                overflow: elide;
                                vertical-alignment: center;
                            }

                            UiText {
                                text: route.summary;
                                height: route.summary == "" ? 0px : 14px;
                                font-size: 10px;
                                font-weight: 500;
                                color: #6b7280;
                                visible: route.summary != "";
                                overflow: elide;
                                vertical-alignment: center;
                            }
                        }
                    }
                }
            }
        }
    }
}

component RequestBar inherits Rectangle {
    in-out property <string> method;
    in-out property <string> url;
    in property <bool> busy;
    callback send-request();

    height: 52px;
    horizontal-stretch: 1;
    background: #ffffff;
    border-width: 0px;
    border-radius: 0px;

    Rectangle {
        x: 14px;
        y: (root.height - 36px) / 2;
        width: root.width - 28px;
        height: 36px;
        background: root.busy ? #f9fafb : #ffffff;
        border-radius: 6px;
        border-width: 1px;
        border-color: !root.busy && url-field.focused ? #2563eb : root.busy ? #e5e7eb : #d1d5db;
        clip: true;

        HorizontalLayout {
            spacing: 0px;
            alignment: center;

            MethodSelector {
                method <=> root.method;
                embedded: true;
                enabled: !root.busy;
            }

            url-field := TextFieldShell {
                text <=> root.url;
                placeholder: "Enter request URL";
                show-label: true;
                label: "URL";
                embedded: true;
                mono: true;
                enabled: !root.busy;
                height: 36px;
                horizontal-stretch: 1;
                accepted => {
                    if !root.busy {
                        root.send-request();
                    }
                }
            }

            ButtonSlot {
                text: "Send";
                enabled: !root.busy;
                primary: true;
                embedded: true;
                button-width: 90px;
                button-height: 34px;
                slot-height: 36px;
                clicked => {
                    root.send-request();
                }
            }
        }
    }
}

component RequestPanel inherits Rectangle {
    in-out property <string> request-body;

    horizontal-stretch: 1;
    vertical-stretch: 1;
    background: #ffffff;
    border-width: 0px;
    border-radius: 0px;

    VerticalLayout {
        padding: 0px;
        spacing: 0px;

        PaneHeader {
            text: "Body";
        }

        Rectangle {
            height: 1px;
            background: #e5e7eb;
        }

        Rectangle {
            vertical-stretch: 1;
            background: #ffffff;

            VerticalLayout {
                padding: 8px;

                CodePane {
                    text <=> root.request-body;
                    read-only: false;
                }
            }
        }
    }
}

component ResponsePanel inherits Rectangle {
    in-out property <string> response-body;
    in property <string> response-status;
    in property <string> response-meta;
    in property <string> response-tone;

    horizontal-stretch: 1;
    vertical-stretch: 1;
    background: #ffffff;
    border-width: 0px;
    border-radius: 0px;

    VerticalLayout {
        padding: 0px;
        spacing: 0px;

        Rectangle {
            height: 52px;
            background: #ffffff;

            HorizontalLayout {
                padding-left: 14px;
                padding-right: 14px;
                spacing: 8px;
                alignment: center;

                Rectangle {
                    horizontal-stretch: 1;
                }

                UiText {
                    text: root.response-status + (root.response-meta == "" ? "" : " - " + root.response-meta);
                    width: 260px;
                    height: 30px;
                    font-size: 12px;
                    font-weight: 600;
                    color: ToneStyle.color(root.response-tone);
                    overflow: elide;
                    horizontal-alignment: right;
                    vertical-alignment: center;
                }
            }
        }

        PaneHeader {
            text: "Response";
        }

        Rectangle {
            height: 1px;
            background: #e5e7eb;
        }

        Rectangle {
            vertical-stretch: 1;
            background: #ffffff;

            VerticalLayout {
                padding: 8px;

                CodePane {
                    text <=> root.response-body;
                    read-only: true;
                }
            }
        }
    }
}

export component AppWindow inherits Window {
    title: "ZenAPI";
    preferred-width: 1280px;
    preferred-height: 800px;
    min-width: 980px;
    min-height: 640px;
    default-font-family: "Inter";
    default-font-size: 13px;
    default-font-weight: 500;

    in-out property <[RouteRow]> routes;
    in-out property <int> selected-route: -1;
    in-out property <string> file-path;
    in-out property <string> spec-label: "";
    in-out property <bool> spec-loaded: false;
    in-out property <string> method: "GET";
    in-out property <string> url;
    in-out property <string> request-body;
    in-out property <string> response-status: "Idle";
    in-out property <string> response-meta: "";
    in-out property <string> response-tone: "neutral";
    in-out property <string> response-body: "";
    in-out property <string> route-filter;
    in-out property <int> total-route-count: 0;
    in-out property <string> server-status: "Idle";
    in-out property <bool> server-running: false;
    in-out property <bool> busy: false;

    callback import-openapi(string);
    callback filter-routes(string);
    callback select-route(int);
    callback send-request();
    callback toggle-server();

    background: #ffffff;

    VerticalLayout {
        padding: 0px;
        spacing: 0px;

        TopBar {
            file-path <=> root.file-path;
            spec-label: root.spec-label;
            spec-loaded: root.spec-loaded;
            server-running: root.server-running;
            server-status: root.server-status;
            route-count: root.total-route-count;
            busy: root.busy;
            import-openapi(path) => {
                root.import-openapi(path);
            }
            toggle-server => {
                root.toggle-server();
            }
        }

        Rectangle {
            height: 1px;
            background: #e5e7eb;
        }

        HorizontalLayout {
            spacing: 0px;
            vertical-stretch: 1;

            Sidebar {
                routes <=> root.routes;
                selected-route <=> root.selected-route;
                route-filter <=> root.route-filter;
                total-route-count: root.total-route-count;
                filter-routes(query) => {
                    root.filter-routes(query);
                }
                select-route(index) => {
                    root.select-route(index);
                }
            }

            Rectangle {
                width: 1px;
                background: #e5e7eb;
            }

            Rectangle {
                horizontal-stretch: 1;
                vertical-stretch: 1;
                background: #ffffff;

                HorizontalLayout {
                    padding: 0px;
                    spacing: 0px;

                    Rectangle {
                        horizontal-stretch: 1;
                        vertical-stretch: 1;
                        background: #ffffff;

                        VerticalLayout {
                            padding: 0px;
                            spacing: 0px;

                            RequestBar {
                                method <=> root.method;
                                url <=> root.url;
                                busy: root.busy;
                                send-request => {
                                    root.send-request();
                                }
                            }

                            RequestPanel {
                                request-body <=> root.request-body;
                            }
                        }
                    }

                    Rectangle {
                        width: 1px;
                        background: #e5e7eb;
                    }

                    ResponsePanel {
                        response-body <=> root.response-body;
                        response-status: root.response-status;
                        response-meta: root.response-meta;
                        response-tone: root.response-tone;
                    }
                }
            }
        }
    }
}
