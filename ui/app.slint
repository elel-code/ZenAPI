component DocumentationPage inherits Rectangle {
    in property <[RouteRow]> routes;
    in-out property <int> selected_route;
    in property <string> method;
    in-out property <string> url;
    in property <bool> busy;
    callback select_route(int);
    callback send_request();

    horizontal-stretch: 1;
    vertical-stretch: 1;
    background: Theme.background;

    HorizontalLayout {
        spacing: 0px;

        Rectangle {
            width: 280px;
            vertical-stretch: 1;
            background: Theme.surface_container_low;

            VerticalLayout {
                padding: 16px;
                spacing: 12px;

                TextField {
                    text: "";
                    placeholder: "Search docs...";
                    mono: false;
                }

                UiText {
                    text: "GETTING STARTED";
                    height: 20px;
                    horizontal-stretch: 1;
                    color: Theme.on_surface_variant;
                    font-size: 12px;
                    font-weight: 800;
                    vertical-alignment: center;
                    overflow: elide;
                }

                DocNavLine { label: "Introduction"; method: ""; selected: false; }
                DocNavLine { label: "Authentication"; method: ""; selected: false; }
                DocNavLine { label: "Errors"; method: ""; selected: false; }

                UiText {
                    text: "ENDPOINTS";
                    height: 20px;
                    horizontal-stretch: 1;
                    color: Theme.on_surface_variant;
                    font-size: 12px;
                    font-weight: 800;
                    vertical-alignment: center;
                    overflow: elide;
                }

                if root.routes.length == 0: DocNavLine {
                    label: "Retrieve a User";
                    method: "GET";
                    selected: true;
                }

                if root.routes.length != 0: ListView {
                    horizontal-stretch: 1;
                    vertical-stretch: 1;
                    vertical-scrollbar-policy: ScrollBarPolicy.as-needed;
                    horizontal-scrollbar-policy: ScrollBarPolicy.as-needed;

                    for route[i] in root.routes: DocNavLine {
                        label: route.summary == "" ? route.path : route.summary;
                        method: route.method;
                        selected: root.selected_route == i;
                        picked => {
                            root.selected_route = i;
                            root.select_route(i);
                        }
                    }
                }
            }
        }

        Rectangle {
            width: 1px;
            background: Theme.outline_variant;
        }

        Rectangle {
            horizontal-stretch: 1;
            vertical-stretch: 1;
            background: Theme.surface;

            VerticalLayout {
                padding: 28px;
                spacing: 18px;

                PageTitle {
                    title: root.method + " Endpoint";
                    subtitle: "Detailed endpoint reference, parameters, and response shape.";
                }

                DataPanel {
                    title: "Endpoint";
                    body: root.method + " " + (root.url == "" ? "https://api.example.com/v1/users/{user_id}" : root.url);
                }

                HorizontalLayout {
                    height: 164px;
                    spacing: 16px;

                    DataPanel {
                        title: "Path Parameters";
                        body: "user_id    string    REQUIRED\nUnique identifier generated when the user is created.";
                    }

                    DataPanel {
                        title: "Query Parameters";
                        body: "expand     array     OPTIONAL\nSupported values: organization, billing_details.";
                    }
                }

                DataPanel {
                    title: "Returns";
                    body: "id        string\nobject    user\nemail     string\nmetadata  object";
                }
            }
        }

        Rectangle {
            width: 400px;
            vertical-stretch: 1;
            background: Theme.surface_container_lowest;

            VerticalLayout {
                padding: 16px;
                spacing: 12px;

                HorizontalLayout {
                    height: 30px;
                    spacing: 8px;

                    BodyModeButton { mode: "curl"; label: "cURL"; selected: true; }
                    BodyModeButton { mode: "python"; label: "Python"; selected: false; button_width: 84px; }
                    BodyModeButton { mode: "node"; label: "Node.js"; selected: false; button_width: 84px; }
                }

                CodePane {
                    height: 144px;
                    text: "curl \"" + (root.url == "" ? "https://api.example.com/v1/users/usr_12345" : root.url) + "\" \\\n  -H \"Authorization: Bearer sk_test_...\"";
                    read_only: true;
                }

                DataPanel {
                    title: "Response";
                    body: "{\n  \"id\": \"usr_12345\",\n  \"object\": \"user\",\n  \"email\": \"developer@example.com\"\n}";
                }

                UiText {
                    text: "TRY IT OUT";
                    height: 20px;
                    horizontal-stretch: 1;
                    color: Theme.on_surface_variant;
                    font-size: 12px;
                    font-weight: 800;
                    vertical-alignment: center;
                    overflow: elide;
                }

                TextField {
                    text: "";
                    placeholder: "Bearer token";
                    mono: true;
                    enabled: !root.busy;
                }

                TextField {
                    text <=> root.url;
                    placeholder: "Request URL";
                    mono: true;
                    enabled: !root.busy;
                }

                ActionButton {
                    text: "Execute Request";
                    primary: true;
                    button_width: 368px;
                    enabled: !root.busy;
                    clicked => {
                        root.send_request();
                    }
                }
            }
        }
    }
}

