                    font-size: 12px;
                    wrap: word-wrap;
                    vertical-alignment: top;
                }

                Rectangle {
                    height: 32px;
                    horizontal-stretch: 1;
                    border-radius: 4px;
                    border-width: 1px;
                    border-color: Theme.outline_variant;
                    background: Theme.surface_dim;

                    UiText {
                        x: 8px;
                        text: "DB_URL={{DB_HOST}}:{{DB_PORT}}";
                        width: parent.width - 16px;
                        height: parent.height;
                        color: Theme.tertiary;
                        font-family: "JetBrains Mono";
                        font-size: 11px;
                        vertical-alignment: center;
                        overflow: elide;
                    }
                }
            }
        }
    }
}

component EnvironmentPage inherits Rectangle {
    in-out property <[EnvironmentRow]> environment_rows;
    in-out property <[VariableTableRow]> variable_rows;
    in-out property <string> global_variables;
    in-out property <string> environment_name;
    in-out property <string> environment_draft_name;
    in-out property <string> environment_variables;
    in-out property <string> variables_json_preview;
    in property <bool> busy;
    callback select_environment(string);
    callback environment_name_changed(string);
    callback add_environment(string);
    callback rename_environment(string, string);
    callback move_environment(string, int);
    callback delete_environment(string);
    callback update_variable_row(int, string, string, string);
    callback add_variable(string);
    callback delete_variable_row(int, string);

    horizontal-stretch: 1;
    vertical-stretch: 1;
    background: Theme.background;

    HorizontalLayout {
        spacing: 0px;

        Rectangle {
            width: 256px;
            vertical-stretch: 1;
            background: Theme.surface_container;

            VerticalLayout {
                padding: 0px;
                spacing: 0px;

                Rectangle {
                    height: 68px;
                    horizontal-stretch: 1;
                    background: Theme.surface_container;

                    UiText {
                        x: 16px;
                        text: "Environments";
                        width: parent.width - 32px;
                        height: parent.height;
                        color: Theme.on_surface;
                        font-size: 20px;
                        font-weight: 800;
                        vertical-alignment: center;
                        overflow: elide;
                    }
                }

                Rectangle {
                    height: 1px;
                    horizontal-stretch: 1;
                    background: Theme.outline_variant;
                }

                Rectangle {
                    horizontal-stretch: 1;
                    vertical-stretch: 1;
                    background: transparent;

                    VerticalLayout {
                        padding: 10px;
                        spacing: 6px;

                        if root.environment_rows.length == 0: UiText {
                            text: "No environments";
                            height: 28px;
                            horizontal-stretch: 1;
                            color: Theme.outline;
                            font-size: 12px;
                            vertical-alignment: center;
                            overflow: elide;
                        }

                        if root.environment_rows.length != 0: ListView {
                            horizontal-stretch: 1;
                            vertical-stretch: 1;
                            vertical-scrollbar-policy: ScrollBarPolicy.as-needed;
                            horizontal-scrollbar-policy: ScrollBarPolicy.as-needed;

                            for item[i] in root.environment_rows: HorizontalLayout {
                                height: 52px;
                                horizontal-stretch: 1;
                                spacing: 4px;
                                alignment: center;

                                EnvironmentNavRow {
                                    mode: item.name;
                                    label: item.label;
                                    detail: item.detail;
                                    tone: item.tone;
                                    selected: root.environment_name == item.name;
                                    picked(mode) => {
                                        root.select_environment(mode);
                                    }
                                }

                                ActionButton {
                                    text: "^";
                                    button_width: 30px;
                                    enabled: !root.busy && i > 0;
                                    clicked => {
                                        root.move_environment(item.name, -1);
                                    }
                                }

                                ActionButton {
                                    text: "v";
                                    button_width: 30px;
                                    enabled: !root.busy && i < root.environment_rows.length - 1;
                                    clicked => {
                                        root.move_environment(item.name, 1);
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }

        Rectangle {
            width: 1px;
            vertical-stretch: 1;
            background: Theme.outline_variant;
        }

        EnvironmentVariableTable {
            variable_rows <=> root.variable_rows;
            environment_name <=> root.environment_name;
            environment_draft_name <=> root.environment_draft_name;
            busy: root.busy;
            environment_name_changed(name) => {
                root.environment_name_changed(name);
            }
            add_environment(name) => {
                root.add_environment(name);
            }
            rename_environment(old_name, new_name) => {
                root.rename_environment(old_name, new_name);
            }
            delete_environment(name) => {
                root.delete_environment(name);
            }
            update_variable_row(row_id, scope, name, value) => {
                root.update_variable_row(row_id, scope, name, value);
            }
            add_variable(scope) => {
                root.add_variable(scope);
            }
            delete_variable_row(row_id, scope) => {
                root.delete_variable_row(row_id, scope);
            }
        }

        Rectangle {
            width: 1px;
            vertical-stretch: 1;
            background: Theme.outline_variant;
        }

        VariableDetailsPanel {
            preview: root.variables_json_preview;
        }
    }
}

