component AuthEditorPanel inherits Rectangle {
    in-out property <string> auth_mode;
    in-out property <string> auth_config;
    in property <bool> busy;

    horizontal-stretch: 1;
    vertical-stretch: 1;
    background: transparent;

    VerticalLayout {
        padding: 0px;
        spacing: 12px;

        HorizontalLayout {
            height: 30px;
            spacing: 8px;
            alignment: center;

            for item in [
                { mode: "none", label: "none", width: 64px },
                { mode: "bearer", label: "bearer", width: 78px },
                { mode: "basic", label: "basic", width: 72px },
                { mode: "jwt", label: "jwt", width: 58px },
                { mode: "api-header", label: "api hdr", width: 88px },
                { mode: "api-query", label: "api query", width: 96px },
            ]: BodyModeButton {
                mode: item.mode;
                label: item.label;
                button_width: item.width;
                selected: root.auth_mode == item.mode;
                enabled: !root.busy;
                picked(mode) => {
                    root.auth_mode = mode;
                }
            }

            Rectangle {
                horizontal-stretch: 1;
            }
        }

        if root.auth_mode == "none": DataPanel {
            title: "No Authentication";
            body: "Requests are sent without generated Authorization headers or API key query parameters.";
        }

        if root.auth_mode == "bearer": Rectangle {
            height: 92px;
            horizontal-stretch: 1;
            background: transparent;

            VerticalLayout {
                padding: 0px;
                spacing: 8px;

                UiText {
                    text: "Bearer Token";
                    height: 20px;
                    horizontal-stretch: 1;
                    color: Theme.on_surface_variant;
                    font-size: 12px;
                    font-weight: 800;
                    vertical-alignment: center;
                    overflow: elide;
                }

                TextField {
                    text <=> root.auth_config;
                    placeholder: "token or {{token}}";
                    mono: true;
                    enabled: !root.busy;
                }

                UiText {
                    text: "Sends Authorization: Bearer <token>.";
                    height: 18px;
                    horizontal-stretch: 1;
                    color: Theme.outline;
                    font-size: 12px;
                    vertical-alignment: center;
                    overflow: elide;
                }
            }
        }

        if root.auth_mode == "jwt": Rectangle {
            height: 92px;
            horizontal-stretch: 1;
            background: transparent;

            VerticalLayout {
                padding: 0px;
                spacing: 8px;

                UiText {
                    text: "JWT";
                    height: 20px;
                    horizontal-stretch: 1;
                    color: Theme.on_surface_variant;
                    font-size: 12px;
                    font-weight: 800;
                    vertical-alignment: center;
                    overflow: elide;
                }

                TextField {
                    text <=> root.auth_config;
                    placeholder: "eyJhbGciOi...";
                    mono: true;
                    enabled: !root.busy;
                }

                UiText {
                    text: "JWT is sent as Authorization: Bearer <token>.";
                    height: 18px;
                    horizontal-stretch: 1;
                    color: Theme.outline;
                    font-size: 12px;
                    vertical-alignment: center;
                    overflow: elide;
                }
            }
        }

        if root.auth_mode == "basic": Rectangle {
            height: 92px;
            horizontal-stretch: 1;
            background: transparent;

            VerticalLayout {
                padding: 0px;
                spacing: 8px;

                UiText {
                    text: "Basic Credentials";
                    height: 20px;
                    horizontal-stretch: 1;
                    color: Theme.on_surface_variant;
                    font-size: 12px;
                    font-weight: 800;
                    vertical-alignment: center;
                    overflow: elide;
                }

                TextField {
                    text <=> root.auth_config;
                    placeholder: "username:password";
                    mono: true;
                    enabled: !root.busy;
                }

                UiText {
                    text: "The value is base64 encoded before sending.";
                    height: 18px;
                    horizontal-stretch: 1;
                    color: Theme.outline;
                    font-size: 12px;
                    vertical-alignment: center;
                    overflow: elide;
                }
            }
        }

        if root.auth_mode == "api-header": KeyValueEditorPanel {
            text <=> root.auth_config;
            title: "API Key Header";
            key_header: "Header";
            value_header: "Value";
            helper: "One API key header per line, for example x-api-key={{apiKey}}.";
        }

        if root.auth_mode == "api-query": KeyValueEditorPanel {
            text <=> root.auth_config;
            title: "API Key Query";
            key_header: "Param";
            value_header: "Value";
            helper: "One API key query parameter per line, for example api_key={{apiKey}}.";
        }

    }
}

component RealtimeEditorPanel inherits Rectangle {
    in-out property <string> realtime_mode;
    in-out property <string> realtime_message;
    in-out property <string> sse_max_events;
    in-out property <string> sse_last_event_id;
    in-out property <bool> sse_streaming;
    in-out property <string> grpc_endpoint;
    in-out property <string> grpc_method;
    in-out property <string> grpc_metadata;
    in-out property <string> grpc_message;
    in property <bool> busy;
    callback open_websocket();
    callback run_websocket();
    callback close_websocket();
    callback run_sse();
    callback open_sse_stream();
    callback close_sse_stream();
    callback build_grpc_draft();

    horizontal-stretch: 1;
    vertical-stretch: 1;
    background: transparent;

    VerticalLayout {
        padding: 0px;
        spacing: 12px;

        HorizontalLayout {
            height: 30px;
            spacing: 8px;
            alignment: center;

            for item in [
                { mode: "ws", label: "WebSocket", width: 104px },
                { mode: "sse", label: "SSE", width: 68px },
                { mode: "grpc", label: "gRPC", width: 72px },
            ]: BodyModeButton {
                mode: item.mode;
                label: item.label;
                button_width: item.width;
                selected: root.realtime_mode == item.mode;
                enabled: !root.busy;
                picked(mode) => {
                    root.realtime_mode = mode;
                }
            }

            Rectangle {
                horizontal-stretch: 1;
            }
        }

        if root.realtime_mode == "ws": HorizontalLayout {
            spacing: 12px;
            vertical-stretch: 1;

            LabeledEditor {
                label: "WebSocket Message";
                text <=> root.realtime_message;
            }

            Rectangle {
                width: 190px;
                vertical-stretch: 1;
                background: Theme.surface_container;
                border-radius: 8px;
                border-width: 1px;
                border-color: Theme.outline_variant;

                VerticalLayout {
                    padding: 14px;
                    spacing: 10px;

                    UiText {
                        text: "SESSION";
                        height: 20px;
                        horizontal-stretch: 1;
                        color: Theme.on_surface_variant;
                        font-size: 12px;
                        font-weight: 800;
                        vertical-alignment: center;
                        overflow: elide;
                    }

                    ActionButton {
                        text: "Open";
                        button_width: 162px;
                        enabled: !root.busy;
                        clicked => {
                            root.open_websocket();
                        }
                    }

                    ActionButton {
                        text: "Send";
                        button_width: 162px;
                        primary: true;
                        enabled: !root.busy;
                        clicked => {
                            root.run_websocket();
                        }
                    }

                    ActionButton {
                        text: "End";
                        button_width: 162px;
                        warning: true;
                        enabled: !root.busy;
                        clicked => {
                            root.close_websocket();
                        }
                    }

                    UiText {
                        text: "Uses the request URL and request headers.";
                        horizontal-stretch: 1;
                        vertical-stretch: 1;
                        color: Theme.outline;
                        font-size: 12px;
                        vertical-alignment: top;
                        overflow: elide;
                    }
                }
            }
        }

        if root.realtime_mode == "sse": HorizontalLayout {
            spacing: 12px;
            vertical-stretch: 1;

            Rectangle {
                horizontal-stretch: 1;
                vertical-stretch: 1;
                background: transparent;

                VerticalLayout {
                    padding: 0px;
                    spacing: 10px;

                    TextField {
                        text <=> root.sse_max_events;
                        placeholder: "Preview event count";
                        mono: true;
                        enabled: !root.busy && !root.sse_streaming;
                    }

                    TextField {
                        text <=> root.sse_last_event_id;
                        placeholder: "Last-Event-ID";
                        mono: true;
                        enabled: !root.busy;
                    }

                    DataPanel {
                        title: root.sse_streaming ? "SSE Streaming" : "SSE Preview";
                        body: "Uses the request URL and request headers.\nLast-Event-ID is updated from incoming events when available.";
                    }
                }
            }

            Rectangle {
                width: 190px;
                vertical-stretch: 1;
                background: Theme.surface_container;
                border-radius: 8px;
                border-width: 1px;
                border-color: Theme.outline_variant;

                VerticalLayout {
                    padding: 14px;
                    spacing: 10px;

                    UiText {
                        text: "EVENT STREAM";
                        height: 20px;
                        horizontal-stretch: 1;
                        color: Theme.on_surface_variant;
                        font-size: 12px;
                        font-weight: 800;
                        vertical-alignment: center;
                        overflow: elide;
                    }

                    ActionButton {
                        text: "Once";
                        button_width: 162px;
                        enabled: !root.busy && !root.sse_streaming;
                        clicked => {
                            root.run_sse();
                        }
                    }

                    ActionButton {
                        text: "Stream";
                        button_width: 162px;
                        primary: true;
                        enabled: !root.busy && !root.sse_streaming;
                        clicked => {
                            root.open_sse_stream();
                        }
                    }

                    ActionButton {
                        text: "Stop";
                        button_width: 162px;
                        warning: true;
                        enabled: root.sse_streaming;
                        clicked => {
                            root.close_sse_stream();
                        }
                    }
                }
            }
        }

        if root.realtime_mode == "grpc": HorizontalLayout {
            spacing: 12px;
            vertical-stretch: 1;

            Rectangle {
                horizontal-stretch: 1;
                vertical-stretch: 1;
                background: transparent;

                VerticalLayout {
                    padding: 0px;
                    spacing: 10px;

                    HorizontalLayout {
                        height: 36px;
                        spacing: 10px;

                        TextField {
                            text <=> root.grpc_endpoint;
                            placeholder: "http://localhost:50051";
                            mono: true;
                            enabled: !root.busy;
                        }

                        TextField {
                            text <=> root.grpc_method;
                            placeholder: "package.Service/Method";
                            mono: true;
                            enabled: !root.busy;
                        }
                    }

                    HorizontalLayout {
                        spacing: 12px;
                        vertical-stretch: 1;

                        LabeledEditor {
                            label: "Metadata";
                            text <=> root.grpc_metadata;
                        }

                        LabeledEditor {
                            label: "Message";
                            text <=> root.grpc_message;
                        }
                    }
                }
            }

            Rectangle {
                width: 190px;
                vertical-stretch: 1;
                background: Theme.surface_container;
                border-radius: 8px;
                border-width: 1px;
                border-color: Theme.outline_variant;

                VerticalLayout {
                    padding: 14px;
                    spacing: 10px;

                    UiText {
                        text: "DRAFT";
                        height: 20px;
                        horizontal-stretch: 1;
                        color: Theme.on_surface_variant;
                        font-size: 12px;
                        font-weight: 800;
                        vertical-alignment: center;
                        overflow: elide;
                    }

                    ActionButton {
                        text: "Build Draft";
                        button_width: 162px;
                        primary: true;
                        enabled: !root.busy;
                        clicked => {
                            root.build_grpc_draft();
                        }
                    }

                    UiText {
                        text: "Validates endpoint, method, metadata, and JSON message. Unary transport is still future work.";
                        horizontal-stretch: 1;
                        vertical-stretch: 1;
                        color: Theme.outline;
                        font-size: 12px;
                        vertical-alignment: top;
                        overflow: elide;
                    }
                }
            }
        }
    }
}

component SendRequestButton inherits Rectangle {
    in property <bool> enabled: true;
    callback clicked();

    width: 112px;
    height: 40px;
    border-radius: 6px;
    border-width: 1px;
    border-color: root.enabled ? Theme.primary_container : Theme.outline_variant;
    background: !root.enabled ? Theme.surface_container_low : send_touch.pressed ? #3d3fba : send_touch.has-hover ? #5557df : Theme.inverse_primary;
    opacity: root.enabled ? 1 : 0.62;

    send_touch := TouchArea {
        enabled: root.enabled;
        mouse-cursor: root.enabled ? pointer : default;
        clicked => {
            root.clicked();
        }
    }

    UiText {
        x: 22px;
        text: "Send";
        width: 50px;
        height: parent.height;
        color: Theme.on_surface;
        font-size: 13px;
        font-weight: 800;
        horizontal-alignment: center;
        vertical-alignment: center;
        overflow: elide;
    }

    UiText {
        x: parent.width - 34px;
        text: ">";
        width: 16px;
        height: parent.height;
        color: Theme.on_surface;
        font-size: 16px;
        font-weight: 800;
        horizontal-alignment: center;
        vertical-alignment: center;
        overflow: elide;
    }
}

component AddressBar inherits Rectangle {
    in-out property <string> method;
    in-out property <string> url;
    in property <string> request_name;
    in property <bool> busy;
    callback send_request();

    property <string> request_label: root.request_name != "" ? root.request_name : root.url == "" ? "New Request" : root.method + " Request";

    height: 104px;
    horizontal-stretch: 1;
    background: Theme.surface_container_low;

    Rectangle {
        y: parent.height - 1px;
        width: parent.width;
        height: 1px;
        background: Theme.outline_variant;
    }

    VerticalLayout {
        padding: 16px;
        spacing: 8px;

        HorizontalLayout {
            height: 22px;
            spacing: 8px;
            alignment: center;

            UiText {
                text: "Users";
                width: 48px;
                height: parent.height;
                color: Theme.on_surface_variant;
                font-size: 14px;
                vertical-alignment: center;
                overflow: elide;
            }

            UiText {
                text: ">";
                width: 10px;
                height: parent.height;
                color: Theme.on_surface_variant;
                font-size: 14px;
                horizontal-alignment: center;
                vertical-alignment: center;
            }

            UiText {
                text: root.request_label;
                horizontal-stretch: 1;
                height: parent.height;
                color: Theme.on_surface;
                font-size: 14px;
                vertical-alignment: center;
                overflow: elide;
            }
        }

        HorizontalLayout {
            height: 40px;
            spacing: 8px;
            alignment: center;

            Rectangle {
                height: 40px;
                horizontal-stretch: 1;
                background: Theme.surface_container;
                border-radius: 6px;
                border-width: 1px;
                border-color: !root.busy && url_field.focused ? Theme.primary : Theme.outline_variant;
                clip: true;

                HorizontalLayout {
                    spacing: 0px;
                    alignment: center;

                    MethodSelector {
                        method <=> root.method;
                        enabled: !root.busy;
                    }

                    Rectangle {
                        width: 1px;
                        height: parent.height - 10px;
                        background: Theme.outline_variant;
                    }

                    url_field := TextField {
                        text <=> root.url;
                        placeholder: "Enter request URL";
                        embedded: true;
                        mono: true;
                        enabled: !root.busy;
                        height: 40px;
                        horizontal-stretch: 1;
                        accepted => {
                            if !root.busy {
                                root.send_request();
                            }
                        }
                    }
                }
            }

            SendRequestButton {
                enabled: !root.busy;
                clicked => {
                    root.send_request();
                }
            }
        }
    }
}

component WorkspaceTab inherits Rectangle {
    in property <string> mode;
    in property <string> label;
