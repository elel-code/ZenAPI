import { ListView, ScrollView } from "std-widgets.slint";
import "fonts/Inter-VariableFont.ttf";
import "fonts/NotoSansMono-Regular.ttf";

export struct RouteRow {
    method: string,
    path: string,
    summary: string,
}

component Tab inherits Rectangle {
    in property <string> text;
    in property <bool> selected;
    callback clicked();

    width: 86px;
    height: 36px;
    background: #ffffff;

    TouchArea {
        mouse-cursor: pointer;
        clicked => {
            root.clicked();
        }
    }

    Text {
        text: root.text;
        width: parent.width;
        height: parent.height;
        color: root.selected ? #111827 : #6b7280;
        font-weight: root.selected ? 700 : 500;
        font-size: 13px;
        horizontal-alignment: center;
        vertical-alignment: center;
    }

    VerticalLayout {
        alignment: end;

        Rectangle {
            height: 2px;
            background: root.selected ? #2563eb : transparent;
        }
    }
}

component ActionButton inherits Rectangle {
    in property <string> text;
    in property <bool> enabled: true;
    in property <bool> primary: false;
    in property <bool> warning: false;
    in property <bool> embedded: false;
    callback clicked();

    height: 34px;
    width: 104px;
    border-radius: root.embedded ? 4px : 6px;
    border-width: root.embedded ? 0px : 1px;
    border-color: !root.enabled ? #d1d5db : root.warning ? #b45309 : root.primary ? #1d4ed8 : #d1d5db;
    background: !root.enabled ? #f3f4f6 : root.warning ? (touch.pressed ? #92400e : touch.has-hover ? #d97706 : #b45309) : root.primary ? (touch.pressed ? #1d4ed8 : touch.has-hover ? #3b82f6 : #2563eb) : (touch.pressed ? #e5e7eb : touch.has-hover ? #f3f4f6 : #ffffff);
    opacity: root.enabled ? 1 : 0.65;

    touch := TouchArea {
        width: parent.width;
        height: parent.height;
        enabled: root.enabled;
        mouse-cursor: root.enabled ? pointer : default;
        clicked => {
            root.clicked();
        }
    }

    Text {
        text: root.text;
        width: parent.width;
        height: parent.height;
        color: !root.enabled ? #9ca3af : root.primary || root.warning ? #ffffff : #374151;
        font-size: 13px;
        font-weight: 700;
        horizontal-alignment: center;
        vertical-alignment: center;
        overflow: elide;
    }
}

component ButtonSlot inherits Rectangle {
    in property <string> text;
    in property <bool> enabled: true;
    in property <bool> primary: false;
    in property <bool> warning: false;
    in property <bool> embedded: false;
    in property <length> button-width: 104px;
    in property <length> button-height: 34px;
    in property <length> slot-height: 40px;
    callback clicked();

    width: root.button-width;
    height: root.slot-height;
    vertical-stretch: 0;

    ActionButton {
        y: (root.slot-height - root.button-height) / 2;
        text: root.text;
        enabled: root.enabled;
        primary: root.primary;
        warning: root.warning;
        embedded: root.embedded;
        width: root.button-width;
        height: root.button-height;
        clicked => {
            root.clicked();
        }
    }
}

component TextFieldShell inherits Rectangle {
    in-out property <string> text;
    in property <string> placeholder;
    in property <bool> show-label: false;
    in property <string> label: "";
    in property <bool> embedded: false;
    in property <bool> mono: false;
    out property <bool> focused: text-input.has-focus;
    callback edited();
    callback accepted();

    height: 36px;
    horizontal-stretch: 1;
    vertical-stretch: 0;
    border-radius: root.embedded ? 0px : 6px;
    border-width: root.embedded ? 0px : 1px;
    border-color: text-input.has-focus ? #2563eb : #d1d5db;
    background: root.embedded ? transparent : #ffffff;

    HorizontalLayout {
        padding-left: 12px;
        padding-right: 12px;
        spacing: 10px;
        alignment: center;

        if root.show-label: Text {
            text: root.label;
            width: 30px;
            height: root.height;
            font-size: 11px;
            font-weight: 800;
            color: #6b7280;
            horizontal-alignment: center;
            vertical-alignment: center;
        }

        Rectangle {
            horizontal-stretch: 1;
            height: parent.height;
            background: transparent;

            Text {
                text: root.text == "" ? root.placeholder : "";
                width: parent.width;
                height: parent.height;
                color: #9ca3af;
                font-family: root.mono ? "Noto Sans Mono" : "Inter";
                font-size: 13px;
                horizontal-alignment: left;
                vertical-alignment: center;
                overflow: elide;
            }

            text-input := TextInput {
                text <=> root.text;
                width: parent.width;
                height: parent.height;
                single-line: true;
                font-family: root.mono ? "Noto Sans Mono" : "Inter";
                font-size: 13px;
                color: #111827;
                selection-background-color: #2563eb;
                selection-foreground-color: #ffffff;
                text-cursor-width: 2px;
                vertical-alignment: center;
                edited => {
                    root.edited();
                }
                accepted => {
                    root.accepted();
                }
            }
        }
    }
}

component MethodOption inherits Rectangle {
    in property <string> value;
    in property <bool> selected;
    callback picked(string);

    height: 32px;
    horizontal-stretch: 1;
    border-radius: 4px;
    background: root.selected ? #eef2ff : option-touch.has-hover ? #f3f4f6 : #ffffff;

    option-touch := TouchArea {
        mouse-cursor: pointer;
        clicked => {
            root.picked(root.value);
        }
    }

    HorizontalLayout {
        padding-left: 10px;
        padding-right: 10px;
        spacing: 8px;
        alignment: center;

        Text {
            text: root.value;
            width: 62px;
            height: root.height;
            font-size: 12px;
            font-weight: 800;
            color: root.value == "GET" ? #059669 : root.value == "POST" ? #d97706 : root.value == "PUT" ? #2563eb : root.value == "PATCH" ? #7c3aed : root.value == "DELETE" ? #dc2626 : #6b7280;
            vertical-alignment: center;
        }

        Rectangle {
            horizontal-stretch: 1;
        }
    }
}

component ChevronDown inherits Path {
    width: 10px;
    height: 6px;
    viewbox-width: 10;
    viewbox-height: 6;
    fill: transparent;
    stroke: #6b7280;
    stroke-width: 1.5px;

    MoveTo {
        x: 1;
        y: 1;
    }

    LineTo {
        x: 5;
        y: 5;
    }

    LineTo {
        x: 9;
        y: 1;
    }
}

component MethodSelector inherits Rectangle {
    in-out property <string> method;
    in property <bool> embedded: false;

    width: 98px;
    height: 36px;
    border-radius: root.embedded ? 0px : 6px;
    border-width: root.embedded ? 0px : 1px;
    border-color: #d1d5db;
    background: root.embedded ? (picker-touch.pressed ? #f3f4f6 : picker-touch.has-hover ? #f9fafb : transparent) : (picker-touch.pressed ? #f3f4f6 : picker-touch.has-hover ? #f9fafb : #ffffff);

    picker-touch := TouchArea {
        mouse-cursor: pointer;
        clicked => {
            method-popup.show();
        }
    }

    HorizontalLayout {
        padding-left: 12px;
        padding-right: 11px;
        spacing: 8px;
        alignment: center;

        Text {
            text: root.method;
            width: 58px;
            height: root.height;
            font-size: 12px;
            font-weight: 800;
            color: root.method == "GET" ? #059669 : root.method == "POST" ? #d97706 : root.method == "PUT" ? #2563eb : root.method == "PATCH" ? #7c3aed : root.method == "DELETE" ? #dc2626 : #6b7280;
            vertical-alignment: center;
        }

        ChevronDown {
            width: 10px;
            height: 6px;
        }
    }

    method-popup := PopupWindow {
        x: 0px;
        y: root.height + 6px;
        width: root.width;
        height: 250px;
        close-policy: close-on-click-outside;

        Rectangle {
            width: method-popup.width;
            height: method-popup.height;
            background: #ffffff;
            border-radius: 6px;
            border-width: 1px;
            border-color: #d1d5db;
            drop-shadow-color: #00000030;
            drop-shadow-blur: 10px;
            drop-shadow-offset-y: 3px;

            ScrollView {
                x: 6px;
                y: 6px;
                width: parent.width - 12px;
                height: parent.height - 12px;
                vertical-scrollbar-policy: ScrollBarPolicy.always-off;
                horizontal-scrollbar-policy: ScrollBarPolicy.always-off;

                VerticalLayout {
                    spacing: 2px;

                    MethodOption {
                        value: "GET";
                        selected: root.method == "GET";
                        picked(value) => {
                            root.method = value;
                            method-popup.close();
                        }
                    }

                    MethodOption {
                        value: "POST";
                        selected: root.method == "POST";
                        picked(value) => {
                            root.method = value;
                            method-popup.close();
                        }
                    }

                    MethodOption {
                        value: "PUT";
                        selected: root.method == "PUT";
                        picked(value) => {
                            root.method = value;
                            method-popup.close();
                        }
                    }

                    MethodOption {
                        value: "PATCH";
                        selected: root.method == "PATCH";
                        picked(value) => {
                            root.method = value;
                            method-popup.close();
                        }
                    }

                    MethodOption {
                        value: "DELETE";
                        selected: root.method == "DELETE";
                        picked(value) => {
                            root.method = value;
                            method-popup.close();
                        }
                    }

                    MethodOption {
                        value: "HEAD";
                        selected: root.method == "HEAD";
                        picked(value) => {
                            root.method = value;
                            method-popup.close();
                        }
                    }

                    MethodOption {
                        value: "OPTIONS";
                        selected: root.method == "OPTIONS";
                        picked(value) => {
                            root.method = value;
                            method-popup.close();
                        }
                    }
                }
            }
        }
    }
}

component CodePane inherits Rectangle {
    in-out property <string> text;
    in property <bool> read-only;

    horizontal-stretch: 1;
    vertical-stretch: 1;
    background: #ffffff;
    border-color: code-input.has-focus ? #2563eb : #e5e7eb;
    border-width: 1px;
    border-radius: 4px;

    VerticalLayout {
        padding: 0px;

        ScrollView {
            viewport-width: max(self.visible-width, code-input.preferred-width + 28px);
            viewport-height: max(self.visible-height, code-input.preferred-height + 24px);
            vertical-scrollbar-policy: ScrollBarPolicy.always-off;
            horizontal-scrollbar-policy: ScrollBarPolicy.always-off;

            code-input := TextInput {
                x: 14px;
                y: 12px;
                width: max(parent.visible-width - 28px, self.preferred-width);
                height: max(parent.visible-height - 24px, self.preferred-height);
                text <=> root.text;
                read-only: root.read-only;
                single-line: false;
                wrap: word-wrap;
                font-family: "Noto Sans Mono";
                font-size: 13px;
                font-weight: 400;
                color: #111827;
                selection-background-color: #2563eb;
                selection-foreground-color: #ffffff;
                text-cursor-width: 2px;
            }
        }
    }
}

component TopBar inherits Rectangle {
    in-out property <string> file-path;
    in property <string> spec-label;
    in property <bool> spec-loaded;
    in property <bool> server-running;
    in property <string> server-status;
    in property <int> route-count;
    in property <bool> busy;
    callback import-openapi(string);
    callback toggle-server();

    height: 48px;
    horizontal-stretch: 1;
    background: #f9fafb;

    HorizontalLayout {
        padding-left: 0px;
        padding-right: 14px;
        spacing: 0px;
        alignment: center;

        Rectangle {
            width: 260px;
            background: #f9fafb;

            HorizontalLayout {
                padding-left: 16px;
                padding-right: 14px;
                alignment: center;

                Text {
                    text: "ZenAPI";
                    font-size: 16px;
                    font-weight: 800;
                    color: #111827;
                    vertical-alignment: center;
                }

                Rectangle {
                    horizontal-stretch: 1;
                }
            }
        }

        Rectangle {
            width: 1px;
            background: #e5e7eb;
        }

        HorizontalLayout {
            padding-left: 14px;
            padding-right: 14px;
            spacing: 8px;
            alignment: center;
            horizontal-stretch: 1;

            Rectangle {
                width: 360px;
                height: 34px;
                border-radius: 6px;
                border-width: 1px;
                border-color: #d1d5db;
                background: #f3f4f6;

                HorizontalLayout {
                    padding-left: 12px;
                    padding-right: 12px;
                    spacing: 0px;
                    alignment: center;

                    Text {
                        text: root.spec-loaded ? root.spec-label : "No specification loaded";
                        color: root.spec-loaded ? #374151 : #6b7280;
                        font-size: 13px;
                        font-italic: !root.spec-loaded;
                        horizontal-stretch: 1;
                        overflow: elide;
                        vertical-alignment: center;
                    }
                }
            }

            ButtonSlot {
                text: "Import";
                enabled: !root.busy;
                button-width: 78px;
                button-height: 34px;
                slot-height: root.height;
                clicked => {
                    import-popup.show();
                }
            }

            Rectangle {
                horizontal-stretch: 1;
            }
        }

        HorizontalLayout {
            width: 232px;
            spacing: 8px;
            alignment: center;

            Text {
                text: root.server-running ? root.server-status : "";
                width: 112px;
                height: 34px;
                color: #6b7280;
                font-family: "Noto Sans Mono";
                font-size: 12px;
                overflow: elide;
                horizontal-alignment: right;
                vertical-alignment: center;
            }

            ButtonSlot {
                text: root.server-running ? "Stop Mock" : "Start Mock";
                enabled: !root.busy && (root.server-running || root.route-count > 0);
                warning: root.server-running;
                button-width: 110px;
                button-height: 34px;
                slot-height: root.height;
                clicked => {
                    root.toggle-server();
                }
            }
        }
    }

    import-popup := PopupWindow {
        x: 274px;
        y: root.height + 4px;
        width: 520px;
        height: 92px;
        close-policy: close-on-click-outside;

        Rectangle {
            width: import-popup.width;
            height: import-popup.height;
            background: #ffffff;
            border-radius: 6px;
            border-width: 1px;
            border-color: #d1d5db;
            drop-shadow-color: #00000030;
            drop-shadow-blur: 10px;
            drop-shadow-offset-y: 3px;

            VerticalLayout {
                padding: 10px;
                spacing: 8px;

                Text {
                    text: "OpenAPI specification";
                    height: 18px;
                    font-size: 12px;
                    font-weight: 700;
                    color: #6b7280;
                    vertical-alignment: center;
                }

                HorizontalLayout {
                    spacing: 8px;
                    alignment: center;

                    TextFieldShell {
                        text <=> root.file-path;
                        placeholder: "Local JSON or YAML file path";
                        show-label: true;
                        label: "PATH";
                        mono: true;
                        height: 34px;
                        horizontal-stretch: 1;
                        accepted => {
                            import-popup.close();
                            root.import-openapi(root.file-path);
                        }
                    }

                    ActionButton {
                        text: "Import";
                        enabled: !root.busy;
                        primary: true;
                        width: 78px;
                        height: 34px;
                        clicked => {
                            import-popup.close();
                            root.import-openapi(root.file-path);
                        }
                    }
                }
            }
        }
    }
}

component Sidebar inherits Rectangle {
    in-out property <[RouteRow]> routes;
    in-out property <int> selected-route;
    in-out property <string> route-filter;
    in property <int> total-route-count;
    callback select-route(int);
    callback filter-routes(string);

    width: 260px;
    vertical-stretch: 1;
    background: #f9fafb;

    VerticalLayout {
        padding: 12px;
        spacing: 8px;

        HorizontalLayout {
            spacing: 8px;

            Text {
                text: "Endpoints";
                font-size: 13px;
                font-weight: 700;
                color: #111827;
                height: 22px;
                vertical-alignment: center;
            }

            Rectangle {
                horizontal-stretch: 1;
            }

            Text {
                text: root.total-route-count == 0 ? "" : root.routes.length + "/" + root.total-route-count;
                font-size: 12px;
                color: #6b7280;
                height: 22px;
                vertical-alignment: center;
            }
        }

        TextFieldShell {
            text <=> root.route-filter;
            placeholder: "Filter method, path, or summary";
            show-label: true;
            label: "FIND";
            height: root.total-route-count > 0 ? 32px : 0px;
            visible: root.total-route-count > 0;
            edited => {
                root.filter-routes(root.route-filter);
            }
        }

        Rectangle {
            height: root.routes.length == 0 ? 44px : 0px;
            background: #f9fafb;
            border-radius: 4px;
            border-width: 0px;

            VerticalLayout {
                padding: 8px;
                spacing: 0px;
                alignment: center;

                Text {
                    text: root.routes.length == 0 ? (root.total-route-count == 0 ? "No endpoints" : "No matches") : "";
                    height: 20px;
                    font-size: 13px;
                    font-weight: 700;
                    color: #111827;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
            }
        }

        ListView {
            horizontal-stretch: 1;
            vertical-stretch: 1;
            vertical-scrollbar-policy: ScrollBarPolicy.always-off;
            horizontal-scrollbar-policy: ScrollBarPolicy.always-off;

            for route[i] in root.routes: Rectangle {
                height: 38px;
                border-radius: 4px;
                background: root.selected-route == i ? #eef2ff : (route-touch.has-hover ? #f3f4f6 : #f9fafb);

                route-touch := TouchArea {
                    mouse-cursor: pointer;
                    clicked => {
                        root.selected-route = i;
                        root.select-route(i);
                    }
                }

                HorizontalLayout {
                    padding-left: 6px;
                    padding-right: 8px;
                    spacing: 8px;
                    alignment: center;

                    Rectangle {
                        width: 45px;
                        height: 22px;
                        border-radius: 4px;
                        background: route.method == "GET" ? #ecfdf5 : route.method == "POST" ? #fffbeb : route.method == "PUT" ? #eff6ff : route.method == "PATCH" ? #f5f3ff : route.method == "DELETE" ? #fef2f2 : #f3f4f6;

                        Text {
                            text: route.method;
                            width: parent.width;
                            height: parent.height;
                            font-size: 11px;
                            font-weight: 800;
                            color: route.method == "GET" ? #059669 : route.method == "POST" ? #d97706 : route.method == "PUT" ? #2563eb : route.method == "PATCH" ? #7c3aed : route.method == "DELETE" ? #dc2626 : #6b7280;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }

                    Rectangle {
                        horizontal-stretch: 1;
                        height: 32px;
                        background: transparent;

                        VerticalLayout {
                            spacing: 0px;
                            alignment: center;

                            Text {
                                text: route.path;
                                height: 18px;
                                font-family: "Noto Sans Mono";
                                font-size: 12px;
                                font-weight: 700;
                                color: root.selected-route == i ? #111827 : #374151;
                                overflow: elide;
                                vertical-alignment: center;
                            }

                            Text {
                                text: route.summary;
                                height: route.summary == "" ? 0px : 14px;
                                font-size: 10px;
                                font-weight: 500;
                                color: #6b7280;
                                visible: route.summary != "";
                                overflow: elide;
                                vertical-alignment: center;
                            }
                        }
                    }
                }
            }
        }
    }
}

component RequestBar inherits Rectangle {
    in-out property <string> method;
    in-out property <string> url;
    in property <bool> busy;
    callback send-request();

    height: 52px;
    horizontal-stretch: 1;
    background: #ffffff;
    border-width: 0px;
    border-radius: 0px;

    VerticalLayout {
        padding-left: 14px;
        padding-right: 14px;
        alignment: center;

        Rectangle {
            height: 36px;
            horizontal-stretch: 1;
            background: #ffffff;
            border-radius: 6px;
            border-width: 1px;
            border-color: url-field.focused ? #2563eb : #d1d5db;

            HorizontalLayout {
                spacing: 0px;
                alignment: center;

                MethodSelector {
                    method <=> root.method;
                    embedded: true;
                }

                url-field := TextFieldShell {
                    text <=> root.url;
                    placeholder: "Enter request URL";
                    show-label: true;
                    label: "URL";
                    embedded: true;
                    mono: true;
                    height: 36px;
                    horizontal-stretch: 1;
                    accepted => {
                        if !root.busy {
                            root.send-request();
                        }
                    }
                }

                ButtonSlot {
                    text: "Send";
                    enabled: !root.busy;
                    primary: true;
                    embedded: true;
                    button-width: 90px;
                    button-height: 34px;
                    slot-height: 36px;
                    clicked => {
                        root.send-request();
                    }
                }
            }
        }
    }
}

component RequestPanel inherits Rectangle {
    in-out property <string> request-body;
    in-out property <int> active-req-tab;

    horizontal-stretch: 1;
    vertical-stretch: 1;
    background: #ffffff;
    border-width: 0px;
    border-radius: 0px;

    VerticalLayout {
        padding: 0px;
        spacing: 0px;

        Rectangle {
            height: 36px;
            background: #ffffff;
            border-radius: 0px;

            HorizontalLayout {
                padding-left: 12px;
                spacing: 0px;
                alignment: center;

                Tab {
                    text: "Body";
                    selected: true;
                    clicked => {
                        root.active-req-tab = 0;
                    }
                }
            }
        }

        Rectangle {
            height: 1px;
            background: #e5e7eb;
        }

        Rectangle {
            vertical-stretch: 1;
            background: #ffffff;

            VerticalLayout {
                padding: 8px;

                CodePane {
                    text <=> root.request-body;
                    read-only: false;
                }
            }
        }
    }
}

component ResponsePanel inherits Rectangle {
    in-out property <string> response-body;
    in-out property <int> active-res-tab;
    in property <string> response-status;
    in property <string> response-meta;
    in property <string> response-tone;

    horizontal-stretch: 1;
    vertical-stretch: 1;
    background: #ffffff;
    border-width: 0px;
    border-radius: 0px;

    VerticalLayout {
        padding: 0px;
        spacing: 0px;

        Rectangle {
            height: 52px;
            background: #ffffff;

            HorizontalLayout {
                padding-left: 14px;
                padding-right: 14px;
                spacing: 8px;
                alignment: center;

                Rectangle {
                    horizontal-stretch: 1;
                }

                Text {
                    text: root.response-status + (root.response-meta == "" ? "" : " - " + root.response-meta);
                    width: 260px;
                    height: 30px;
                    font-size: 12px;
                    font-weight: 600;
                    color: root.response-tone == "error" ? #dc2626 : root.response-tone == "busy" ? #d97706 : root.response-tone == "success" ? #059669 : #6b7280;
                    overflow: elide;
                    horizontal-alignment: right;
                    vertical-alignment: center;
                }
            }
        }

        Rectangle {
            height: 36px;
            background: #ffffff;
            border-radius: 0px;

            HorizontalLayout {
                padding-left: 12px;
                padding-right: 12px;
                spacing: 0px;
                alignment: center;

                Tab {
                    text: "Response";
                    selected: true;
                    clicked => {
                        root.active-res-tab = 0;
                    }
                }
            }
        }

        Rectangle {
            height: 1px;
            background: #e5e7eb;
        }

        Rectangle {
            vertical-stretch: 1;
            background: #ffffff;

            VerticalLayout {
                padding: 8px;

                CodePane {
                    text <=> root.response-body;
                    read-only: true;
                }
            }
        }
    }
}

export component AppWindow inherits Window {
    title: "ZenAPI";
    preferred-width: 1280px;
    preferred-height: 800px;
    min-width: 980px;
    min-height: 640px;
    default-font-family: "Inter";
    default-font-size: 13px;
    default-font-weight: 500;

    in-out property <[RouteRow]> routes;
    in-out property <int> selected-route: -1;
    in-out property <string> file-path;
    in-out property <string> spec-label: "";
    in-out property <bool> spec-loaded: false;
    in-out property <string> method: "GET";
    in-out property <string> url;
    in-out property <string> request-body;
    in-out property <string> response-status: "Idle";
    in-out property <string> response-meta: "";
    in-out property <string> response-tone: "neutral";
    in-out property <string> response-body: "";
    in-out property <string> route-filter;
    in-out property <int> total-route-count: 0;
    in-out property <string> server-status: "Idle";
    in-out property <bool> server-running: false;
    in-out property <bool> busy: false;

    in-out property <int> active-req-tab: 0;
    in-out property <int> active-res-tab: 0;

    callback import-openapi(string);
    callback filter-routes(string);
    callback select-route(int);
    callback send-request();
    callback toggle-server();

    background: #ffffff;

    VerticalLayout {
        padding: 0px;
        spacing: 0px;

        TopBar {
            file-path <=> root.file-path;
            spec-label: root.spec-label;
            spec-loaded: root.spec-loaded;
            server-running: root.server-running;
            server-status: root.server-status;
            route-count: root.total-route-count;
            busy: root.busy;
            import-openapi(path) => {
                root.import-openapi(path);
            }
            toggle-server => {
                root.toggle-server();
            }
        }

        Rectangle {
            height: 1px;
            background: #e5e7eb;
        }

        HorizontalLayout {
            spacing: 0px;
            vertical-stretch: 1;

            Sidebar {
                routes <=> root.routes;
                selected-route <=> root.selected-route;
                route-filter <=> root.route-filter;
                total-route-count: root.total-route-count;
                filter-routes(query) => {
                    root.filter-routes(query);
                }
                select-route(index) => {
                    root.select-route(index);
                }
            }

            Rectangle {
                width: 1px;
                background: #e5e7eb;
            }

            Rectangle {
                horizontal-stretch: 1;
                vertical-stretch: 1;
                background: #ffffff;

                HorizontalLayout {
                    padding: 0px;
                    spacing: 0px;

                    Rectangle {
                        horizontal-stretch: 1;
                        vertical-stretch: 1;
                        background: #ffffff;

                        VerticalLayout {
                            padding: 0px;
                            spacing: 0px;

                            RequestBar {
                                method <=> root.method;
                                url <=> root.url;
                                busy: root.busy;
                                send-request => {
                                    root.send-request();
                                }
                            }

                            RequestPanel {
                                request-body <=> root.request-body;
                                active-req-tab <=> root.active-req-tab;
                            }
                        }
                    }

                    Rectangle {
                        width: 1px;
                        background: #e5e7eb;
                    }

                    ResponsePanel {
                        response-body <=> root.response-body;
                        active-res-tab <=> root.active-res-tab;
                        response-status: root.response-status;
                        response-meta: root.response-meta;
                        response-tone: root.response-tone;
                    }
                }
            }
        }
    }
}
