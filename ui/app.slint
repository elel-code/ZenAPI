import { ListView, ScrollView } from "std-widgets.slint";

export struct RouteRow {
    method: string,
    path: string,
    summary: string,
}

component Tab inherits Rectangle {
    in property <string> text;
    in property <bool> selected;
    callback clicked();

    width: 86px;
    height: 36px;
    background: #151720;

    TouchArea {
        clicked => {
            root.clicked();
        }
    }

    Text {
        text: root.text;
        width: parent.width;
        height: parent.height;
        color: root.selected ? #e2e8f0 : #64748b;
        font-weight: root.selected ? 700 : 500;
        font-size: 13px;
        horizontal-alignment: center;
        vertical-alignment: center;
    }

    VerticalLayout {
        alignment: end;

        Rectangle {
            height: 2px;
            background: root.selected ? #10b981 : transparent;
        }
    }
}

component ActionButton inherits Rectangle {
    in property <string> text;
    in property <bool> enabled: true;
    in property <bool> primary: false;
    in property <bool> warning: false;
    in property <bool> dark: false;
    in property <bool> embedded: false;
    callback clicked();

    height: 34px;
    width: 104px;
    border-radius: root.embedded ? 4px : 6px;
    border-width: root.embedded ? 0px : 1px;
    border-color: !root.enabled ? #252936 : root.warning ? #92400e : root.primary ? #1d4ed8 : #343946;
    background: !root.enabled ? #20242b : root.warning ? (touch.pressed ? #92400e : touch.has-hover ? #d97706 : #b45309) : root.primary ? (touch.pressed ? #1d4ed8 : touch.has-hover ? #3b82f6 : #2563eb) : (touch.pressed ? #151720 : touch.has-hover ? #252936 : #1a1d26);
    opacity: root.enabled ? 1 : 0.65;

    touch := TouchArea {
        width: parent.width;
        height: parent.height;
        enabled: root.enabled;
        mouse-cursor: pointer;
        clicked => {
            root.clicked();
        }
    }

    Text {
        text: root.text;
        width: parent.width;
        height: parent.height;
        color: !root.enabled ? #64748b : root.primary || root.warning ? #ffffff : #e2e8f0;
        font-size: 13px;
        font-weight: 700;
        horizontal-alignment: center;
        vertical-alignment: center;
        overflow: elide;
    }
}

component ButtonSlot inherits Rectangle {
    in property <string> text;
    in property <bool> enabled: true;
    in property <bool> primary: false;
    in property <bool> warning: false;
    in property <bool> dark: false;
    in property <length> button-width: 104px;
    in property <length> button-height: 34px;
    in property <length> slot-height: 40px;
    callback clicked();

    width: root.button-width;
    height: root.slot-height;
    vertical-stretch: 0;

    ActionButton {
        y: (root.slot-height - root.button-height) / 2;
        text: root.text;
        enabled: root.enabled;
        primary: root.primary;
        warning: root.warning;
        dark: root.dark;
        width: root.button-width;
        height: root.button-height;
        clicked => {
            root.clicked();
        }
    }
}

component TextFieldShell inherits Rectangle {
    in-out property <string> text;
    in property <string> placeholder;
    in property <bool> dark: false;
    in property <bool> show-label: false;
    in property <string> label: "";
    in property <bool> embedded: false;
    callback edited();

    height: 36px;
    horizontal-stretch: 1;
    vertical-stretch: 0;
    border-radius: root.embedded ? 0px : 6px;
    border-width: root.embedded ? 0px : 1px;
    border-color: text-input.has-focus ? #3b82f6 : #252936;
    background: root.embedded ? transparent : (text-input.has-focus ? #1f2430 : #1a1d26);

    HorizontalLayout {
        padding-left: 12px;
        padding-right: 12px;
        spacing: 10px;
        alignment: center;

        if root.show-label: Text {
            text: root.label;
            width: 30px;
            height: root.height;
            font-size: 11px;
            font-weight: 800;
            color: root.dark ? #94a3b8 : #64748b;
            horizontal-alignment: center;
            vertical-alignment: center;
        }

        Rectangle {
            horizontal-stretch: 1;
            height: parent.height;
            background: transparent;

            Text {
                text: root.text == "" ? root.placeholder : "";
                width: parent.width;
                height: parent.height;
                color: #64748b;
                font-size: 13px;
                horizontal-alignment: left;
                vertical-alignment: center;
                overflow: elide;
            }

            text-input := TextInput {
                text <=> root.text;
                width: parent.width;
                height: parent.height;
                single-line: true;
                font-family: "Zen Sans";
                font-size: 13px;
                color: #e2e8f0;
                selection-background-color: #2563eb;
                selection-foreground-color: #ffffff;
                vertical-alignment: center;
                edited => {
                    root.edited();
                }
            }
        }
    }
}

component MethodOption inherits Rectangle {
    in property <string> value;
    in property <bool> selected;
    callback picked(string);

    height: 32px;
    horizontal-stretch: 1;
    border-radius: 4px;
    background: root.selected ? #1f2937 : option-touch.has-hover ? #20242b : #151720;

    option-touch := TouchArea {
        mouse-cursor: pointer;
        clicked => {
            root.picked(root.value);
        }
    }

    HorizontalLayout {
        padding-left: 10px;
        padding-right: 10px;
        spacing: 8px;
        alignment: center;

        Text {
            text: root.value;
            width: 62px;
            height: root.height;
            font-size: 12px;
            font-weight: 800;
            color: root.value == "GET" ? #10b981 : root.value == "POST" ? #f59e0b : root.value == "PUT" ? #3b82f6 : root.value == "PATCH" ? #a78bfa : root.value == "DELETE" ? #ef4444 : #94a3b8;
            vertical-alignment: center;
        }

        Rectangle {
            horizontal-stretch: 1;
        }

        Rectangle {
            width: root.selected ? 7px : 0px;
            height: 7px;
            border-radius: 4px;
            background: root.selected ? #10b981 : transparent;
        }
    }
}

component MethodSelector inherits Rectangle {
    in-out property <string> method;
    in property <bool> embedded: false;

    width: 98px;
    height: 36px;
    border-radius: root.embedded ? 0px : 6px;
    border-width: root.embedded ? 0px : 1px;
    border-color: #252936;
    background: root.embedded ? (picker-touch.pressed ? #0e1015 : picker-touch.has-hover ? #20242b : transparent) : (picker-touch.pressed ? #0e1015 : picker-touch.has-hover ? #20242b : #1a1d26);

    picker-touch := TouchArea {
        mouse-cursor: pointer;
        clicked => {
            method-popup.show();
        }
    }

    HorizontalLayout {
        padding-left: 12px;
        padding-right: 11px;
        spacing: 8px;
        alignment: center;

        Text {
            text: root.method;
            width: 58px;
            height: root.height;
            font-size: 12px;
            font-weight: 800;
            color: root.method == "GET" ? #10b981 : root.method == "POST" ? #f59e0b : root.method == "PUT" ? #3b82f6 : root.method == "PATCH" ? #a78bfa : root.method == "DELETE" ? #ef4444 : #94a3b8;
            vertical-alignment: center;
        }

        Text {
            text: "v";
            width: 12px;
            height: root.height;
            font-size: 10px;
            font-weight: 700;
            color: #94a3b8;
            horizontal-alignment: right;
            vertical-alignment: center;
        }
    }

    method-popup := PopupWindow {
        x: 0px;
        y: root.height + 6px;
        width: root.width;
        height: 250px;
        close-policy: close-on-click-outside;

        Rectangle {
            width: method-popup.width;
            height: method-popup.height;
            background: #151720;
            border-radius: 6px;
            border-width: 1px;
            border-color: #252936;
            drop-shadow-color: #00000080;
            drop-shadow-blur: 14px;
            drop-shadow-offset-y: 4px;

            ScrollView {
                x: 6px;
                y: 6px;
                width: parent.width - 12px;
                height: parent.height - 12px;

                VerticalLayout {
                    spacing: 2px;

                    MethodOption {
                        value: "GET";
                        selected: root.method == "GET";
                        picked(value) => {
                            root.method = value;
                            method-popup.close();
                        }
                    }

                    MethodOption {
                        value: "POST";
                        selected: root.method == "POST";
                        picked(value) => {
                            root.method = value;
                            method-popup.close();
                        }
                    }

                    MethodOption {
                        value: "PUT";
                        selected: root.method == "PUT";
                        picked(value) => {
                            root.method = value;
                            method-popup.close();
                        }
                    }

                    MethodOption {
                        value: "PATCH";
                        selected: root.method == "PATCH";
                        picked(value) => {
                            root.method = value;
                            method-popup.close();
                        }
                    }

                    MethodOption {
                        value: "DELETE";
                        selected: root.method == "DELETE";
                        picked(value) => {
                            root.method = value;
                            method-popup.close();
                        }
                    }

                    MethodOption {
                        value: "HEAD";
                        selected: root.method == "HEAD";
                        picked(value) => {
                            root.method = value;
                            method-popup.close();
                        }
                    }

                    MethodOption {
                        value: "OPTIONS";
                        selected: root.method == "OPTIONS";
                        picked(value) => {
                            root.method = value;
                            method-popup.close();
                        }
                    }
                }
            }
        }
    }
}

component CodePane inherits Rectangle {
    in-out property <string> text;
    in property <bool> read-only;

    background: #1a1d26;
    border-color: #252936;
    border-width: 1px;
    border-radius: 4px;

    VerticalLayout {
        padding: 0px;

        ScrollView {
            viewport-width: max(self.visible-width, code-input.preferred-width + 28px);
            viewport-height: max(self.visible-height, code-input.preferred-height + 24px);

            code-input := TextInput {
                x: 14px;
                y: 12px;
                width: max(parent.visible-width - 28px, self.preferred-width);
                height: max(parent.visible-height - 24px, self.preferred-height);
                text <=> root.text;
                read-only: root.read-only;
                single-line: false;
                wrap: word-wrap;
                font-family: "Zen Mono";
                font-size: 13px;
                font-weight: 400;
                color: #d1d5db;
                selection-background-color: #2563eb;
                selection-foreground-color: #ffffff;
            }
        }
    }
}

component TopBar inherits Rectangle {
    in-out property <string> file-path;
    in property <string> spec-label;
    in property <bool> spec-loaded;
    in property <bool> server-running;
    in property <int> route-count;
    in property <bool> busy;
    callback import-openapi(string);
    callback toggle-server();

    height: 48px;
    background: #151720;

    HorizontalLayout {
        padding-left: 0px;
        padding-right: 14px;
        spacing: 0px;
        alignment: center;

        Rectangle {
            width: 260px;
            background: #151720;

            HorizontalLayout {
                padding-left: 16px;
                padding-right: 14px;
                alignment: center;

                Text {
                    text: "ZenAPI";
                    font-size: 16px;
                    font-weight: 800;
                    color: #e2e8f0;
                    vertical-alignment: center;
                }

                Rectangle {
                    horizontal-stretch: 1;
                }
            }
        }

        Rectangle {
            width: 1px;
            background: #252936;
        }

        HorizontalLayout {
            padding-left: 14px;
            padding-right: 14px;
            spacing: 8px;
            alignment: center;
            horizontal-stretch: 1;

            Rectangle {
                width: 360px;
                height: 34px;
                border-radius: 6px;
                border-width: 1px;
                border-color: #252936;
                background: #1a1d26;

                HorizontalLayout {
                    padding-left: 12px;
                    padding-right: 12px;
                    spacing: 8px;
                    alignment: center;

                    Rectangle {
                        width: 7px;
                        height: 7px;
                        border-radius: 4px;
                        background: root.spec-loaded ? #10b981 : #64748b;
                    }

                    Text {
                        text: root.spec-loaded ? root.spec-label : "No specification loaded";
                        color: root.spec-loaded ? #cbd5e1 : #64748b;
                        font-size: 13px;
                        font-italic: !root.spec-loaded;
                        horizontal-stretch: 1;
                        overflow: elide;
                        vertical-alignment: center;
                    }
                }
            }

            ActionButton {
                text: "Import";
                enabled: !root.busy;
                width: 78px;
                height: 34px;
                dark: true;
                clicked => {
                    import-popup.show();
                }
            }

            Rectangle {
                horizontal-stretch: 1;
            }
        }

        HorizontalLayout {
            width: 174px;
            spacing: 8px;
            alignment: center;

            Text {
                text: root.server-running ? "Port 8080" : "";
                width: 56px;
                height: 34px;
                color: #94a3b8;
                font-size: 12px;
                horizontal-alignment: right;
                vertical-alignment: center;
            }

            ButtonSlot {
                text: root.server-running ? "Stop Mock" : "Start Mock";
                enabled: !root.busy && (root.server-running || root.route-count > 0);
                warning: root.server-running;
                dark: true;
                button-width: 110px;
                button-height: 34px;
                slot-height: root.height;
                clicked => {
                    root.toggle-server();
                }
            }
        }
    }

    import-popup := PopupWindow {
        x: 274px;
        y: root.height + 4px;
        width: 520px;
        height: 92px;
        close-policy: close-on-click-outside;

        Rectangle {
            width: import-popup.width;
            height: import-popup.height;
            background: #151720;
            border-radius: 6px;
            border-width: 1px;
            border-color: #252936;
            drop-shadow-color: #00000080;
            drop-shadow-blur: 14px;
            drop-shadow-offset-y: 4px;

            VerticalLayout {
                padding: 10px;
                spacing: 8px;

                Text {
                    text: "OpenAPI specification";
                    height: 18px;
                    font-size: 12px;
                    font-weight: 700;
                    color: #94a3b8;
                    vertical-alignment: center;
                }

                HorizontalLayout {
                    spacing: 8px;
                    alignment: center;

                    TextFieldShell {
                        text <=> root.file-path;
                        placeholder: "Local JSON or YAML file path";
                        dark: true;
                        show-label: true;
                        label: "PATH";
                        height: 34px;
                        horizontal-stretch: 1;
                    }

                    ActionButton {
                        text: "Import";
                        enabled: !root.busy;
                        primary: true;
                        width: 78px;
                        height: 34px;
                        clicked => {
                            import-popup.close();
                            root.import-openapi(root.file-path);
                        }
                    }
                }
            }
        }
    }
}

component Sidebar inherits Rectangle {
    in-out property <[RouteRow]> routes;
    in-out property <int> selected-route;
    in-out property <string> route-filter;
    in property <int> total-route-count;
    callback select-route(int);
    callback filter-routes(string);

    width: 260px;
    background: #151720;

    VerticalLayout {
        padding: 12px;
        spacing: 8px;

        HorizontalLayout {
            spacing: 8px;

            Text {
                text: "Endpoints";
                font-size: 13px;
                font-weight: 700;
                color: #e2e8f0;
                height: 22px;
                vertical-alignment: center;
            }

            Rectangle {
                horizontal-stretch: 1;
            }

            Text {
                text: root.total-route-count == 0 ? "" : root.routes.length + "/" + root.total-route-count;
                font-size: 12px;
                color: #64748b;
                height: 22px;
                vertical-alignment: center;
            }
        }

        Rectangle {
            height: 1px;
            background: #252936;
        }

        TextFieldShell {
            text <=> root.route-filter;
            placeholder: "Filter method, path, or summary";
            show-label: true;
            label: "FIND";
            height: 32px;
            visible: root.total-route-count > 0;
            edited => {
                root.filter-routes(root.route-filter);
            }
        }

        Rectangle {
            height: root.routes.length == 0 ? 96px : 0px;
            background: #151720;
            border-radius: 4px;
            border-width: root.routes.length == 0 ? 1px : 0px;
            border-color: #252936;

            VerticalLayout {
                padding: 12px;
                spacing: 4px;
                alignment: center;

                Rectangle {
                    width: 42px;
                    height: 1px;
                    background: #343946;
                }

                Text {
                    text: root.routes.length == 0 ? (root.total-route-count == 0 ? "No endpoints" : "No matches") : "";
                    height: 20px;
                    font-size: 13px;
                    font-weight: 700;
                    color: #e2e8f0;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }

                Text {
                    text: root.routes.length == 0 ? (root.total-route-count == 0 ? "Spec not loaded" : "Filter returned none") : "";
                    height: 18px;
                    font-size: 12px;
                    color: #64748b;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
            }
        }

        ListView {
            for route[i] in root.routes: Rectangle {
                height: 38px;
                border-radius: 4px;
                background: root.selected-route == i ? #1f2937 : (route-touch.has-hover ? #20242b : #151720);

                route-touch := TouchArea {
                    clicked => {
                        root.selected-route = i;
                        root.select-route(i);
                    }
                }

                HorizontalLayout {
                    padding-left: 6px;
                    padding-right: 8px;
                    spacing: 8px;
                    alignment: center;

                    Rectangle {
                        width: 45px;
                        height: 22px;
                        border-radius: 4px;
                        background: route.method == "GET" ? #0b2f26 : route.method == "POST" ? #33240b : route.method == "PUT" ? #102445 : route.method == "PATCH" ? #281945 : route.method == "DELETE" ? #3a1117 : #20242b;

                        Text {
                            text: route.method;
                            width: parent.width;
                            height: parent.height;
                            font-size: 11px;
                            font-weight: 800;
                            color: route.method == "GET" ? #10b981 : route.method == "POST" ? #f59e0b : route.method == "PUT" ? #3b82f6 : route.method == "PATCH" ? #a78bfa : route.method == "DELETE" ? #ef4444 : #94a3b8;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }

                    Rectangle {
                        horizontal-stretch: 1;
                        height: 32px;
                        background: transparent;

                        VerticalLayout {
                            spacing: 0px;
                            alignment: center;

                            Text {
                                text: route.path;
                                height: 18px;
                                font-size: 12px;
                                font-weight: 700;
                                color: root.selected-route == i ? #e2e8f0 : #cbd5e1;
                                overflow: elide;
                                vertical-alignment: center;
                            }

                            Text {
                                text: route.summary == "" ? "No summary" : route.summary;
                                height: 14px;
                                font-size: 10px;
                                font-weight: 500;
                                color: #64748b;
                                overflow: elide;
                                vertical-alignment: center;
                            }
                        }
                    }
                }
            }
        }
    }
}

component RequestBar inherits Rectangle {
    in-out property <string> method;
    in-out property <string> url;
    in property <bool> busy;
    callback send-request();

    height: 52px;
    background: #11131a;
    border-color: #252936;
    border-width: 1px;
    border-radius: 0px;

    VerticalLayout {
        padding-left: 14px;
        padding-right: 14px;
        alignment: center;

        Rectangle {
            height: 36px;
            horizontal-stretch: 1;
            background: #1a1d26;
            border-radius: 6px;
            border-width: 1px;
            border-color: #252936;

            HorizontalLayout {
                spacing: 0px;
                alignment: center;

                MethodSelector {
                    method <=> root.method;
                    embedded: true;
                }

                Rectangle {
                    width: 1px;
                    height: 24px;
                    background: #252936;
                }

                TextFieldShell {
                    text <=> root.url;
                    placeholder: "Enter request URL";
                    show-label: true;
                    label: "URL";
                    embedded: true;
                    height: 36px;
                    horizontal-stretch: 1;
                }

                Rectangle {
                    width: 1px;
                    height: 24px;
                    background: #252936;
                }

                ActionButton {
                    text: root.busy ? "Sending..." : "Send";
                    enabled: !root.busy;
                    primary: true;
                    embedded: true;
                    width: 90px;
                    height: 34px;
                    clicked => {
                        root.send-request();
                    }
                }
            }
        }
    }
}

component RequestPanel inherits Rectangle {
    in-out property <string> request-body;
    in-out property <int> active-req-tab;

    vertical-stretch: 1;
    background: #11131a;
    border-color: #252936;
    border-width: 1px;
    border-radius: 0px;

    VerticalLayout {
        padding: 0px;
        spacing: 0px;

        Rectangle {
            height: 36px;
            background: #151720;
            border-radius: 0px;

            HorizontalLayout {
                padding-left: 12px;
                spacing: 0px;
                alignment: center;

                Tab {
                    text: "Body";
                    selected: true;
                    clicked => {
                        root.active-req-tab = 0;
                    }
                }
            }
        }

        Rectangle {
            height: 1px;
            background: #252936;
        }

        Rectangle {
            background: #11131a;

            VerticalLayout {
                padding: 8px;

                CodePane {
                    text <=> root.request-body;
                    read-only: false;
                }
            }
        }
    }
}

component ResponsePanel inherits Rectangle {
    in-out property <string> response-body;
    in-out property <int> active-res-tab;
    in property <string> response-status;
    in property <string> response-meta;
    in property <string> response-tone;

    vertical-stretch: 1;
    background: #11131a;
    border-color: #252936;
    border-width: 1px;
    border-radius: 0px;

    VerticalLayout {
        padding: 0px;
        spacing: 0px;

        Rectangle {
            height: 36px;
            background: #151720;
            border-radius: 0px;

            HorizontalLayout {
                padding-left: 12px;
                padding-right: 12px;
                spacing: 0px;
                alignment: center;

                Tab {
                    text: "Response";
                    selected: true;
                    clicked => {
                        root.active-res-tab = 0;
                    }
                }

                Text {
                    text: root.response-status + (root.response-meta == "" ? "" : " - " + root.response-meta);
                    font-size: 12px;
                    font-weight: 600;
                    color: root.response-tone == "error" ? #ef4444 : root.response-tone == "busy" ? #f59e0b : root.response-tone == "success" ? #10b981 : #64748b;
                    horizontal-stretch: 1;
                    overflow: elide;
                    horizontal-alignment: right;
                    vertical-alignment: center;
                }
            }
        }

        Rectangle {
            height: 1px;
            background: #252936;
        }

        Rectangle {
            background: #11131a;

            VerticalLayout {
                padding: 8px;

                CodePane {
                    text <=> root.response-body;
                    read-only: true;
                }
            }
        }
    }
}

export component AppWindow inherits Window {
    title: "ZenAPI";
    preferred-width: 1280px;
    preferred-height: 800px;
    min-width: 980px;
    min-height: 640px;
    default-font-family: "Zen Sans";
    default-font-size: 13px;
    default-font-weight: 500;

    in-out property <[RouteRow]> routes;
    in-out property <int> selected-route: -1;
    in-out property <string> file-path;
    in-out property <string> spec-label: "";
    in-out property <bool> spec-loaded: false;
    in-out property <string> method: "GET";
    in-out property <string> url;
    in-out property <string> request-body;
    in-out property <string> response-status: "Idle";
    in-out property <string> response-meta: "";
    in-out property <string> response-tone: "neutral";
    in-out property <string> response-body: "";
    in-out property <string> route-filter;
    in-out property <int> total-route-count: 0;
    in-out property <string> server-status: "Idle";
    in-out property <bool> server-running: false;
    in-out property <bool> busy: false;

    in-out property <int> active-req-tab: 0;
    in-out property <int> active-res-tab: 0;

    callback import-openapi(string);
    callback filter-routes(string);
    callback select-route(int);
    callback send-request();
    callback toggle-server();

    background: #0e1015;

    VerticalLayout {
        padding: 0px;
        spacing: 0px;

        TopBar {
            file-path <=> root.file-path;
            spec-label: root.spec-label;
            spec-loaded: root.spec-loaded;
            server-running: root.server-running;
            route-count: root.total-route-count;
            busy: root.busy;
            import-openapi(path) => {
                root.import-openapi(path);
            }
            toggle-server => {
                root.toggle-server();
            }
        }

        Rectangle {
            height: 1px;
            background: #252936;
        }

        HorizontalLayout {
            spacing: 0px;

            Sidebar {
                routes <=> root.routes;
                selected-route <=> root.selected-route;
                route-filter <=> root.route-filter;
                total-route-count: root.total-route-count;
                filter-routes(query) => {
                    root.filter-routes(query);
                }
                select-route(index) => {
                    root.select-route(index);
                }
            }

            Rectangle {
                width: 1px;
                background: #252936;
            }

            Rectangle {
                background: #0e1015;

                VerticalLayout {
                    padding: 0px;
                    spacing: 0px;

                    RequestBar {
                        method <=> root.method;
                        url <=> root.url;
                        busy: root.busy;
                        send-request => {
                            root.send-request();
                        }
                    }

                    RequestPanel {
                        request-body <=> root.request-body;
                        active-req-tab <=> root.active-req-tab;
                    }

                    ResponsePanel {
                        response-body <=> root.response-body;
                        active-res-tab <=> root.active-res-tab;
                        response-status: root.response-status;
                        response-meta: root.response-meta;
                        response-tone: root.response-tone;
                    }
                }
            }
        }
    }
}
