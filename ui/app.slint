import { ListView } from "std-widgets.slint";
import { Theme } from "theme.slint";
import { ActionButton, BodyModeButton, LabeledEditor, MethodChip, MethodSelector, SectionTitle, StatusDot, TabHeader, TextField, ToneStyle, UiText } from "widgets.slint";

export struct RouteRow {
    method: string,
    path: string,
    summary: string,
}

export struct HistoryRow {
    id: int,
    method: string,
    url: string,
    status: string,
}

export struct CollectionRow {
    id: int,
    method: string,
    name: string,
    url: string,
}

export struct RunnerRow {
    method: string,
    name: string,
    status: string,
    detail: string,
    tone: string,
}

export struct MockLogRow {
    method: string,
    path: string,
    status: string,
}

component RouteListItem inherits Rectangle {
    in property <string> method;
    in property <string> path;
    in property <string> summary;
    in property <bool> selected;
    callback picked();

    height: 44px;
    horizontal-stretch: 1;
    border-radius: 6px;
    background: root.selected ? Theme.surface_variant : touch.has-hover ? Theme.surface_container_high : Theme.surface_container_low;

    touch := TouchArea {
        mouse-cursor: pointer;
        clicked => {
            root.picked();
        }
    }

    Rectangle {
        x: 0px;
        y: 5px;
        width: 2px;
        height: 34px;
        background: Theme.primary;
        visible: root.selected;
    }

    MethodChip {
        x: 10px;
        y: 11px;
        method: root.method;
    }

    UiText {
        x: 82px;
        y: 5px;
        text: root.path;
        width: parent.width - 92px;
        height: 19px;
        font-family: "JetBrains Mono";
        font-size: 12px;
        font-weight: 700;
        color: Theme.on_surface;
        overflow: elide;
        vertical-alignment: center;
    }

    UiText {
        x: 82px;
        y: 24px;
        text: root.summary;
        width: parent.width - 92px;
        height: 15px;
        font-size: 11px;
        color: Theme.on_surface_variant;
        visible: root.summary != "";
        overflow: elide;
        vertical-alignment: center;
    }
}

component HistoryListItem inherits Rectangle {
    in property <int> entry_id;
    in property <string> method;
    in property <string> url;
    in property <string> status;
    in property <bool> enabled: true;
    callback picked(int);
    callback delete_requested(int);

    height: 52px;
    horizontal-stretch: 1;
    border-radius: 6px;
    background: touch.has-hover ? Theme.surface_container_high : Theme.surface_container_low;

    touch := TouchArea {
        mouse-cursor: pointer;
        clicked => {
            root.picked(root.entry_id);
        }
    }

    MethodChip {
        x: 10px;
        y: 8px;
        method: root.method;
    }

    UiText {
        x: 82px;
        y: 6px;
        text: root.url;
        width: parent.width - 142px;
        height: 20px;
        font-family: "JetBrains Mono";
        font-size: 12px;
        font-weight: 700;
        color: Theme.on_surface;
        overflow: elide;
        vertical-alignment: center;
    }

    UiText {
        x: 82px;
        y: 28px;
        text: root.status;
        width: parent.width - 142px;
        height: 16px;
        font-family: "JetBrains Mono";
        font-size: 11px;
        color: Theme.on_surface_variant;
        overflow: elide;
        vertical-alignment: center;
    }

    ActionButton {
        x: parent.width - 52px;
        y: 9px;
        text: "Del";
        button_width: 42px;
        warning: true;
        enabled: root.enabled;
        clicked => {
            root.delete_requested(root.entry_id);
        }
    }
}

component CollectionListItem inherits Rectangle {
    in property <int> entry_id;
    in property <string> method;
    in property <string> name;
    in property <string> url;
    callback picked(int);

    height: 54px;
    horizontal-stretch: 1;
    border-radius: 6px;
    background: touch.has-hover ? Theme.surface_container_high : Theme.surface_container_low;

    touch := TouchArea {
        mouse-cursor: pointer;
        clicked => {
            root.picked(root.entry_id);
        }
    }

    MethodChip {
        x: 10px;
        y: 9px;
        method: root.method;
    }

    UiText {
        x: 82px;
        y: 6px;
        text: root.name;
        width: parent.width - 92px;
        height: 20px;
        font-size: 12px;
        font-weight: 700;
        color: Theme.on_surface;
        overflow: elide;
        vertical-alignment: center;
    }

    UiText {
        x: 82px;
        y: 29px;
        text: root.url;
        width: parent.width - 92px;
        height: 16px;
        font-family: "JetBrains Mono";
        font-size: 11px;
        color: Theme.on_surface_variant;
        overflow: elide;
        vertical-alignment: center;
    }
}

component MockLogItem inherits Rectangle {
    in property <string> method;
    in property <string> path;
    in property <string> status;

    height: 34px;
    horizontal-stretch: 1;
    border-radius: 6px;
    background: Theme.surface_container_low;

    MethodChip {
        x: 8px;
        y: 6px;
        method: root.method;
    }

    UiText {
        x: 78px;
        y: 4px;
        text: root.path;
        width: parent.width - 126px;
        height: 26px;
        font-family: "JetBrains Mono";
        font-size: 11px;
        font-weight: 700;
        color: Theme.on_surface;
        overflow: elide;
        vertical-alignment: center;
    }

    UiText {
        x: parent.width - 40px;
        y: 4px;
        text: root.status;
        width: 32px;
        height: 26px;
        font-family: "JetBrains Mono";
        font-size: 11px;
        font-weight: 800;
        color: root.status == "200" || root.status == "204" ? Theme.secondary : Theme.error;
        horizontal-alignment: right;
        overflow: elide;
        vertical-alignment: center;
    }
}

component Sidebar inherits Rectangle {
    in-out property <[RouteRow]> routes;
    in-out property <[CollectionRow]> collection_rows;
    in-out property <[HistoryRow]> history_rows;
    in-out property <[MockLogRow]> mock_logs;
    in-out property <int> selected_route;
    in-out property <string> route_filter;
    in-out property <string> history_filter;
    in-out property <string> collection_path;
    in-out property <string> collection_name;
    in-out property <string> collection_status;
    in property <int> total_route_count;
    in property <bool> busy;
    callback select_route(int);
    callback select_collection_request(int);
    callback import_collection(string);
    callback save_current_request();
    callback save_collection(string);
    callback export_postman_collection(string);
    callback select_history(int);
    callback filter_history(string);
    callback delete_history(int);
    callback clear_history();
    callback filter_routes(string);

    width: 240px;
    vertical-stretch: 1;
    background: Theme.surface_container_low;

    VerticalLayout {
        padding: 12px;
        spacing: 8px;

        SectionTitle {
            text: "ENDPOINTS";
            meta: root.total_route_count == 0 ? "" : root.routes.length + "/" + root.total_route_count;
        }

        TextField {
            text <=> root.route_filter;
            placeholder: "Filter routes";
            height: root.total_route_count > 0 ? 32px : 0px;
            visible: root.total_route_count > 0;
            edited => {
                root.filter_routes(root.route_filter);
            }
        }

        if root.routes.length == 0: Rectangle {
            height: 40px;
            horizontal-stretch: 1;
            background: Theme.surface_container;
            border-radius: 6px;

            UiText {
                text: root.total_route_count == 0 ? "No endpoints imported" : "No matching routes";
                width: parent.width;
                height: parent.height;
                color: Theme.outline;
                font-size: 12px;
                horizontal-alignment: center;
                vertical-alignment: center;
                overflow: elide;
            }
        }

        ListView {
            horizontal-stretch: 1;
            vertical-stretch: 1;
            vertical-scrollbar-policy: ScrollBarPolicy.always-off;
            horizontal-scrollbar-policy: ScrollBarPolicy.always-off;

            for route[i] in root.routes: RouteListItem {
                method: route.method;
                path: route.path;
                summary: route.summary;
                selected: root.selected_route == i;
                picked => {
                    root.selected_route = i;
                    root.select_route(i);
                }
            }
        }

        Rectangle {
            height: 1px;
            horizontal-stretch: 1;
            background: Theme.outline_variant;
        }

        SectionTitle {
            text: "COLLECTION";
            meta: root.collection_rows.length == 0 ? "" : root.collection_rows.length + "";
        }

        TextField {
            text <=> root.collection_path;
            placeholder: "Collection JSON path";
            mono: true;
            enabled: !root.busy;
            height: 32px;
            accepted => {
                root.import_collection(root.collection_path);
            }
        }

        Rectangle {
            height: 34px;
            horizontal-stretch: 1;

            HorizontalLayout {
                padding: 0px;
                spacing: 6px;
                alignment: center;

                ActionButton {
                    text: "Load";
                    button_width: 46px;
                    enabled: !root.busy;
                    clicked => {
                        root.import_collection(root.collection_path);
                    }
                }

                ActionButton {
                    text: "Add";
                    button_width: 46px;
                    enabled: !root.busy;
                    clicked => {
                        root.save_current_request();
                    }
                }

                ActionButton {
                    text: "Save";
                    button_width: 46px;
                    enabled: !root.busy;
                    clicked => {
                        root.save_collection(root.collection_path);
                    }
                }

                ActionButton {
                    text: "PM";
                    button_width: 46px;
                    enabled: !root.busy;
                    clicked => {
                        root.export_postman_collection(root.collection_path);
                    }
                }
            }
        }

        UiText {
            text: root.collection_status != "" ? root.collection_status : root.collection_name;
            height: 18px;
            horizontal-stretch: 1;
            color: Theme.outline;
            font-size: 11px;
            overflow: elide;
            vertical-alignment: center;
        }

        if root.collection_rows.length == 0: Rectangle {
            height: 34px;
            horizontal-stretch: 1;
            background: Theme.surface_container;
            border-radius: 6px;

            UiText {
                text: "No saved requests";
                width: parent.width;
                height: parent.height;
                color: Theme.outline;
                font-size: 12px;
                horizontal-alignment: center;
                vertical-alignment: center;
                overflow: elide;
            }
        }

        if root.collection_rows.length != 0: ListView {
            height: 84px;
            horizontal-stretch: 1;
            vertical-scrollbar-policy: ScrollBarPolicy.always-off;
            horizontal-scrollbar-policy: ScrollBarPolicy.always-off;

            for entry in root.collection_rows: CollectionListItem {
                entry_id: entry.id;
                method: entry.method;
                name: entry.name;
                url: entry.url;
                picked(id) => {
                    root.select_collection_request(id);
                }
            }
        }

        Rectangle {
            height: 1px;
            horizontal-stretch: 1;
            background: Theme.outline_variant;
        }

        SectionTitle {
            text: "HISTORY";
            meta: root.history_rows.length == 0 ? "" : root.history_rows.length + "";
        }

        HorizontalLayout {
            height: 32px;
            spacing: 6px;

            TextField {
                text <=> root.history_filter;
                placeholder: "Filter history";
                mono: true;
                enabled: !root.busy;
                height: 32px;
                edited => {
                    root.filter_history(root.history_filter);
                }
            }

            ActionButton {
                text: "Clear";
                button_width: 54px;
                warning: true;
                enabled: !root.busy && root.history_rows.length > 0;
                clicked => {
                    root.clear_history();
                }
            }
        }

        if root.history_rows.length == 0: Rectangle {
            height: 34px;
            horizontal-stretch: 1;
            background: Theme.surface_container;
            border-radius: 6px;

            UiText {
                text: "No requests yet";
                width: parent.width;
                height: parent.height;
                color: Theme.outline;
                font-size: 12px;
                horizontal-alignment: center;
                vertical-alignment: center;
                overflow: elide;
            }
        }

        if root.history_rows.length != 0: ListView {
            height: 72px;
            horizontal-stretch: 1;
            vertical-scrollbar-policy: ScrollBarPolicy.always-off;
            horizontal-scrollbar-policy: ScrollBarPolicy.always-off;

            for entry in root.history_rows: HistoryListItem {
                entry_id: entry.id;
                method: entry.method;
                url: entry.url;
                status: entry.status;
                enabled: !root.busy;
                picked(id) => {
                    root.select_history(id);
                }
                delete_requested(id) => {
                    root.delete_history(id);
                }
            }
        }

        Rectangle {
            height: 1px;
            horizontal-stretch: 1;
            background: Theme.outline_variant;
        }

        SectionTitle {
            text: "MOCK LOGS";
            meta: root.mock_logs.length == 0 ? "" : root.mock_logs.length + "";
        }

        if root.mock_logs.length == 0: Rectangle {
            height: 34px;
            horizontal-stretch: 1;
            background: Theme.surface_container;
            border-radius: 6px;

            UiText {
                text: "No mock requests";
                width: parent.width;
                height: parent.height;
                color: Theme.outline;
                font-size: 12px;
                horizontal-alignment: center;
                vertical-alignment: center;
                overflow: elide;
            }
        }

        if root.mock_logs.length != 0: ListView {
            height: 92px;
            horizontal-stretch: 1;
            vertical-scrollbar-policy: ScrollBarPolicy.always-off;
            horizontal-scrollbar-policy: ScrollBarPolicy.always-off;

            for log in root.mock_logs: MockLogItem {
                method: log.method;
                path: log.path;
                status: log.status;
            }
        }
    }
}

component TopBar inherits Rectangle {
    in-out property <string> file_path;
    in property <string> spec_label;
    in property <bool> spec_loaded;
    in property <bool> server_running;
    in property <string> server_status;
    in property <int> route_count;
    in property <bool> busy;
    callback import_openapi(string);
    callback toggle_server();

    height: 48px;
    horizontal-stretch: 1;
    background: Theme.surface_dim;

    HorizontalLayout {
        padding-left: 16px;
        padding-right: 12px;
        spacing: 12px;
        alignment: center;

        UiText {
            text: "ZenAPI";
            width: 92px;
            height: root.height;
            font-size: 18px;
            font-weight: 800;
            color: Theme.primary;
            vertical-alignment: center;
            overflow: elide;
        }

        Rectangle {
            horizontal-stretch: 1;
            height: 32px;
            background: Theme.surface_container_low;
            border-radius: 8px;
            border-width: 1px;
            border-color: Theme.outline_variant;

            TouchArea {
                enabled: !root.busy;
                mouse-cursor: root.busy ? default : pointer;
                clicked => {
                    import_popup.show();
                }
            }

            UiText {
                x: 12px;
                text: root.spec_loaded ? root.spec_label : "Import OpenAPI or Swagger file";
                width: parent.width - 24px;
                height: parent.height;
                color: root.spec_loaded ? Theme.on_surface : Theme.outline;
                font-family: root.spec_loaded ? "JetBrains Mono" : "Inter";
                font-size: 13px;
                vertical-alignment: center;
                horizontal-alignment: center;
                overflow: elide;
            }
        }

        Rectangle {
            width: 184px;
            height: 34px;

            HorizontalLayout {
                spacing: 8px;
                alignment: center;

                StatusDot {
                    tone: root.server_running ? "active" : "inactive";
                }

                UiText {
                    text: root.server_running ? root.server_status : "Mock stopped";
                    width: 92px;
                    height: parent.height;
                    font-family: "JetBrains Mono";
                    font-size: 12px;
                    color: root.server_running ? Theme.secondary : Theme.outline;
                    overflow: elide;
                    vertical-alignment: center;
                }

                ActionButton {
                    text: root.server_running ? "Stop" : "Mock";
                    button_width: 64px;
                    warning: root.server_running;
                    enabled: !root.busy && (root.server_running || root.route_count > 0);
                    clicked => {
                        root.toggle_server();
                    }
                }
            }
        }
    }

    Rectangle {
        y: parent.height - 1px;
        width: parent.width;
        height: 1px;
        background: Theme.outline_variant;
    }

    import_popup := PopupWindow {
        x: 128px;
        y: root.height + 6px;
        width: root.width - 360px;
        height: 58px;
        close-policy: close-on-click-outside;

        Rectangle {
            width: parent.width;
            height: parent.height;
            background: Theme.surface_container;
            border-radius: 8px;
            border-width: 1px;
            border-color: Theme.outline_variant;

            HorizontalLayout {
                padding: 10px;
                spacing: 10px;
                alignment: center;

                TextField {
                    text <=> root.file_path;
                    placeholder: "Local JSON or YAML file path";
                    mono: true;
                    enabled: !root.busy;
                    horizontal-stretch: 1;
                    accepted => {
                        if !root.busy {
                            import_popup.close();
                            root.import_openapi(root.file_path);
                        }
                    }
                }

                ActionButton {
                    text: "Import";
                    primary: true;
                    enabled: !root.busy;
                    button_width: 82px;
                    clicked => {
                        if !root.busy {
                            import_popup.close();
                            root.import_openapi(root.file_path);
                        }
                    }
                }
            }
        }
    }
}

component AddressBar inherits Rectangle {
    in-out property <string> method;
    in-out property <string> url;
    in property <bool> busy;
    callback send_request();

    height: 54px;
    horizontal-stretch: 1;
    background: Theme.surface;

    Rectangle {
        x: 14px;
        y: 8px;
        width: root.width - 28px;
        height: 38px;
        background: Theme.surface_container_lowest;
        border-radius: 8px;
        border-width: 1px;
        border-color: !root.busy && url_field.focused ? Theme.primary : Theme.outline_variant;
        clip: true;

        HorizontalLayout {
            spacing: 0px;
            alignment: center;

            MethodSelector {
                method <=> root.method;
                enabled: !root.busy;
            }

            url_field := TextField {
                text <=> root.url;
                placeholder: "Enter request URL";
                embedded: true;
                mono: true;
                enabled: !root.busy;
                height: 38px;
                horizontal-stretch: 1;
                accepted => {
                    if !root.busy {
                        root.send_request();
                    }
                }
            }

            Rectangle {
                width: 1px;
                height: parent.height;
                background: Theme.outline_variant;
            }

            ActionButton {
                text: "Send";
                enabled: !root.busy;
                primary: true;
                button_width: 86px;
                clicked => {
                    root.send_request();
                }
            }
        }
    }

    Rectangle {
        y: parent.height - 1px;
        width: parent.width;
        height: 1px;
        background: Theme.outline_variant;
    }
}

component RequestPanel inherits Rectangle {
    in-out property <string> global_variables;
    in-out property <string> environment_name;
    in-out property <string> environment_variables;
    in-out property <string> query_params;
    in-out property <string> request_headers;
    in-out property <string> auth_mode;
    in-out property <string> auth_config;
    in-out property <string> body_mode;
    in-out property <string> request_body;
    in-out property <string> graphql_variables;
    in-out property <string> pre_request_script;
    in-out property <string> request_tests;
    in-out property <string> realtime_mode;
    in-out property <string> realtime_message;
    in-out property <string> sse_max_events;
    in-out property <string> grpc_endpoint;
    in-out property <string> grpc_method;
    in-out property <string> grpc_metadata;
    in-out property <string> grpc_message;
    in property <bool> busy;
    callback run_websocket();
    callback run_sse();
    callback build_grpc_draft();

    horizontal-stretch: 1;
    vertical-stretch: 1;
    background: Theme.surface;

    VerticalLayout {
        padding: 0px;
        spacing: 0px;

        TabHeader {
            label: "Request";
        }

        Rectangle {
            height: 112px;
            background: Theme.surface;

            HorizontalLayout {
                padding: 10px;
                spacing: 10px;

                Rectangle {
                    width: 128px;
                    vertical-stretch: 1;

                    VerticalLayout {
                        padding: 0px;
                        spacing: 6px;

                        UiText {
                            text: "Env";
                            height: 20px;
                            color: Theme.on_surface_variant;
                            font-size: 12px;
                            font-weight: 800;
                            vertical-alignment: center;
                            overflow: elide;
                        }

                        TextField {
                            text <=> root.environment_name;
                            placeholder: "dev";
                            mono: true;
                            height: 34px;
                        }
                    }
                }

                LabeledEditor {
                    label: "Globals";
                    text <=> root.global_variables;
                }

                LabeledEditor {
                    label: "Env Vars";
                    text <=> root.environment_variables;
                }
            }
        }

        Rectangle {
            height: 1px;
            background: Theme.outline_variant;
        }

        Rectangle {
            height: 134px;
            background: Theme.surface;

            HorizontalLayout {
                padding: 10px;
                spacing: 10px;

                LabeledEditor {
                    label: "Params";
                    text <=> root.query_params;
                }

                LabeledEditor {
                    label: "Headers";
                    text <=> root.request_headers;
                }

                LabeledEditor {
                    label: "Auth / " + root.auth_mode;
                    text <=> root.auth_config;
                    read_only: root.auth_mode == "none";
                }
            }
        }

        Rectangle {
            height: 1px;
            background: Theme.outline_variant;
        }

        Rectangle {
            height: 34px;
            background: Theme.surface_container_lowest;

            HorizontalLayout {
                padding-left: 10px;
                padding-right: 10px;
                spacing: 8px;
                alignment: center;

                for item in [
                    { mode: "none", label: "no auth" },
                    { mode: "bearer", label: "bearer" },
                    { mode: "basic", label: "basic" },
                    { mode: "jwt", label: "jwt" },
                    { mode: "api-header", label: "api-h" },
                    { mode: "api-query", label: "api-q" },
                ]: BodyModeButton {
                    mode: item.mode;
                    label: item.label;
                    selected: root.auth_mode == item.mode;
                    picked(mode) => {
                        root.auth_mode = mode;
                    }
                }
            }
        }

        Rectangle {
            height: 1px;
            background: Theme.outline_variant;
        }

        Rectangle {
            height: 34px;
            background: Theme.surface_container_lowest;

            HorizontalLayout {
                padding-left: 10px;
                padding-right: 10px;
                spacing: 8px;
                alignment: center;

                for item in [
                    { mode: "none", label: "none" },
                    { mode: "raw", label: "raw" },
                    { mode: "form", label: "form" },
                    { mode: "urlenc", label: "urlenc" },
                    { mode: "graphql", label: "graphql" },
                    { mode: "binary", label: "binary" },
                ]: BodyModeButton {
                    mode: item.mode;
                    label: item.label;
                    selected: root.body_mode == item.mode;
                    picked(mode) => {
                        root.body_mode = mode;
                    }
                }
            }
        }

        Rectangle {
            vertical-stretch: 1;
            background: Theme.surface;

            VerticalLayout {
                padding: 10px;
                spacing: 10px;

                if root.body_mode == "graphql": HorizontalLayout {
                    spacing: 10px;

                    LabeledEditor {
                        label: "GraphQL Query";
                        text <=> root.request_body;
                    }

                    LabeledEditor {
                        label: "GraphQL Variables";
                        text <=> root.graphql_variables;
                    }
                }

                if root.body_mode != "graphql": LabeledEditor {
                    label: "Body / " + root.body_mode;
                    text <=> root.request_body;
                    read_only: root.body_mode == "none";
                }

                Rectangle {
                    height: 126px;
                    horizontal-stretch: 1;

                    HorizontalLayout {
                        padding: 0px;
                        spacing: 10px;

                        LabeledEditor {
                            label: "Pre-request";
                            text <=> root.pre_request_script;
                        }

                        LabeledEditor {
                            label: "Tests";
                            text <=> root.request_tests;
                        }

                        Rectangle {
                            horizontal-stretch: 1;
                            vertical-stretch: 1;

                            VerticalLayout {
                                padding: 0px;
                                spacing: 6px;

                                UiText {
                                    text: "Realtime / " + root.realtime_mode;
                                    height: 20px;
                                    horizontal-stretch: 1;
                                    color: Theme.on_surface_variant;
                                    font-size: 12px;
                                    font-weight: 800;
                                    vertical-alignment: center;
                                    overflow: elide;
                                }

                                HorizontalLayout {
                                    height: 26px;
                                    spacing: 8px;

                                    BodyModeButton {
                                        mode: "ws";
                                        label: "ws";
                                        button_width: 48px;
                                        selected: root.realtime_mode == "ws";
                                        enabled: !root.busy;
                                        picked(mode) => {
                                            root.realtime_mode = mode;
                                        }
                                    }

                                    BodyModeButton {
                                        mode: "sse";
                                        label: "sse";
                                        button_width: 48px;
                                        selected: root.realtime_mode == "sse";
                                        enabled: !root.busy;
                                        picked(mode) => {
                                            root.realtime_mode = mode;
                                        }
                                    }

                                    TextField {
                                        text <=> root.sse_max_events;
                                        placeholder: "events";
                                        mono: true;
                                        enabled: !root.busy;
                                        height: 26px;
                                    }
                                }

                                TextField {
                                    text <=> root.realtime_message;
                                    placeholder: "WebSocket message";
                                    mono: true;
                                    enabled: !root.busy;
                                    height: 28px;
                                }

                                HorizontalLayout {
                                    height: 30px;
                                    spacing: 8px;

                                    ActionButton {
                                        text: "WS Send";
                                        button_width: 82px;
                                        enabled: !root.busy;
                                        primary: root.realtime_mode == "ws";
                                        clicked => {
                                            root.run_websocket();
                                        }
                                    }

                                    ActionButton {
                                        text: "SSE Once";
                                        button_width: 82px;
                                        enabled: !root.busy;
                                        primary: root.realtime_mode == "sse";
                                        clicked => {
                                            root.run_sse();
                                        }
                                    }
                                }
                            }
                        }

                        Rectangle {
                            horizontal-stretch: 1;
                            vertical-stretch: 1;

                            VerticalLayout {
                                padding: 0px;
                                spacing: 6px;

                                UiText {
                                    text: "gRPC Draft";
                                    height: 20px;
                                    horizontal-stretch: 1;
                                    color: Theme.on_surface_variant;
                                    font-size: 12px;
                                    font-weight: 800;
                                    vertical-alignment: center;
                                    overflow: elide;
                                }

                                TextField {
                                    text <=> root.grpc_endpoint;
                                    placeholder: "http://localhost:50051";
                                    mono: true;
                                    enabled: !root.busy;
                                    height: 28px;
                                }

                                TextField {
                                    text <=> root.grpc_method;
                                    placeholder: "package.Service/Method";
                                    mono: true;
                                    enabled: !root.busy;
                                    height: 28px;
                                }

                                TextField {
                                    text <=> root.grpc_metadata;
                                    placeholder: "metadata name=value";
                                    mono: true;
                                    enabled: !root.busy;
                                    height: 28px;
                                }

                                HorizontalLayout {
                                    height: 30px;
                                    spacing: 8px;

                                    TextField {
                                        text <=> root.grpc_message;
                                        placeholder: "{}";
                                        mono: true;
                                        enabled: !root.busy;
                                        height: 30px;
                                    }

                                    ActionButton {
                                        text: "Build";
                                        button_width: 64px;
                                        enabled: !root.busy;
                                        clicked => {
                                            root.build_grpc_draft();
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}

component RunnerResultItem inherits Rectangle {
    in property <string> method;
    in property <string> name;
    in property <string> status;
    in property <string> detail;
    in property <string> tone;

    height: 50px;
    horizontal-stretch: 1;
    border-radius: 6px;
    background: Theme.surface_container_low;

    MethodChip {
        x: 10px;
        y: 8px;
        method: root.method;
    }

    UiText {
        x: 82px;
        y: 5px;
        text: root.name;
        width: parent.width - 150px;
        height: 19px;
        font-size: 12px;
        font-weight: 700;
        color: Theme.on_surface;
        overflow: elide;
        vertical-alignment: center;
    }

    UiText {
        x: parent.width - 58px;
        y: 5px;
        text: root.status;
        width: 48px;
        height: 19px;
        font-family: "JetBrains Mono";
        font-size: 11px;
        font-weight: 800;
        color: ToneStyle.color(root.tone);
        horizontal-alignment: right;
        overflow: elide;
        vertical-alignment: center;
    }

    UiText {
        x: 82px;
        y: 27px;
        text: root.detail;
        width: parent.width - 92px;
        height: 16px;
        font-family: "JetBrains Mono";
        font-size: 11px;
        color: Theme.on_surface_variant;
        overflow: elide;
        vertical-alignment: center;
    }
}

component ResponsePanel inherits Rectangle {
    in-out property <string> response_body;
    in-out property <string> response_headers;
    in-out property <string> codegen_language;
    in-out property <string> codegen_output;
    in-out property <[RunnerRow]> runner_rows;
    in-out property <string> runner_summary;
    in-out property <string> runner_delay_ms;
    in-out property <bool> runner_stop_on_failure;
    in property <string> response_status;
    in property <string> response_meta;
    in property <string> response_tone;
    in property <bool> busy;
    callback generate_code();
    callback run_collection();

    width: 420px;
    vertical-stretch: 1;
    background: Theme.surface;

    VerticalLayout {
        padding: 0px;
        spacing: 0px;

        TabHeader {
            label: "Response";
            status: root.response_status + (root.response_meta == "" ? "" : " / " + root.response_meta);
            tone: root.response_tone;
        }

        Rectangle {
            height: 34px;
            background: Theme.surface_container_lowest;

            UiText {
                x: 14px;
                text: "Body  Headers  Cookies";
                width: parent.width - 28px;
                height: parent.height;
                font-size: 12px;
                color: Theme.outline;
                vertical-alignment: center;
                overflow: elide;
            }
        }

        Rectangle {
            vertical-stretch: 1;
            background: Theme.surface;

            VerticalLayout {
                padding: 10px;
                spacing: 10px;

                LabeledEditor {
                    label: "Body";
                    text <=> root.response_body;
                    read_only: true;
                }

                Rectangle {
                    height: 96px;
                    horizontal-stretch: 1;

                    LabeledEditor {
                        label: "Headers";
                        text <=> root.response_headers;
                        read_only: true;
                    }
                }

                Rectangle {
                    height: 166px;
                    horizontal-stretch: 1;
                    background: transparent;

                    VerticalLayout {
                        padding: 0px;
                        spacing: 8px;

                        HorizontalLayout {
                            height: 34px;
                            spacing: 8px;
                            alignment: center;

                            BodyModeButton {
                                mode: "continue";
                                label: "continue";
                                button_width: 76px;
                                selected: !root.runner_stop_on_failure;
                                enabled: !root.busy;
                                picked(mode) => {
                                    root.runner_stop_on_failure = false;
                                }
                            }

                            BodyModeButton {
                                mode: "stop";
                                label: "stop fail";
                                button_width: 76px;
                                selected: root.runner_stop_on_failure;
                                enabled: !root.busy;
                                picked(mode) => {
                                    root.runner_stop_on_failure = true;
                                }
                            }

                            Rectangle {
                                width: 78px;
                                height: 30px;

                                TextField {
                                    text <=> root.runner_delay_ms;
                                    placeholder: "Delay ms";
                                    mono: true;
                                    enabled: !root.busy;
                                    width: parent.width;
                                    height: parent.height;
                                }
                            }

                            ActionButton {
                                text: "Run";
                                button_width: 64px;
                                primary: true;
                                enabled: !root.busy;
                                clicked => {
                                    root.run_collection();
                                }
                            }
                        }

                        UiText {
                            text: root.runner_summary == "" ? "No runner results" : root.runner_summary;
                            height: 18px;
                            horizontal-stretch: 1;
                            color: Theme.on_surface_variant;
                            font-size: 11px;
                            overflow: elide;
                            vertical-alignment: center;
                        }

                        if root.runner_rows.length == 0: Rectangle {
                            vertical-stretch: 1;
                            horizontal-stretch: 1;
                            background: Theme.surface_container;
                            border-radius: 6px;

                            UiText {
                                text: "No results";
                                width: parent.width;
                                height: parent.height;
                                color: Theme.outline;
                                font-size: 12px;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                                overflow: elide;
                            }
                        }

                        if root.runner_rows.length != 0: ListView {
                            vertical-stretch: 1;
                            horizontal-stretch: 1;
                            vertical-scrollbar-policy: ScrollBarPolicy.always-off;
                            horizontal-scrollbar-policy: ScrollBarPolicy.always-off;

                            for result in root.runner_rows: RunnerResultItem {
                                method: result.method;
                                name: result.name;
                                status: result.status;
                                detail: result.detail;
                                tone: result.tone;
                            }
                        }
                    }
                }

                Rectangle {
                    height: 150px;
                    horizontal-stretch: 1;
                    background: transparent;

                    VerticalLayout {
                        padding: 0px;
                        spacing: 8px;

                        HorizontalLayout {
                            height: 28px;
                            spacing: 8px;
                            alignment: center;

                            for item in [
                                { mode: "curl", label: "curl" },
                                { mode: "python", label: "py" },
                                { mode: "js", label: "js" },
                                { mode: "rust", label: "rust" },
                                { mode: "go", label: "go" },
                            ]: BodyModeButton {
                                mode: item.mode;
                                label: item.label;
                                button_width: 54px;
                                selected: root.codegen_language == item.mode;
                                enabled: !root.busy;
                                picked(mode) => {
                                    root.codegen_language = mode;
                                }
                            }

                            ActionButton {
                                text: "Generate";
                                button_width: 86px;
                                primary: true;
                                enabled: !root.busy;
                                clicked => {
                                    root.generate_code();
                                }
                            }
                        }

                        LabeledEditor {
                            label: "Code / " + root.codegen_language;
                            text <=> root.codegen_output;
                            read_only: true;
                        }
                    }
                }
            }
        }
    }
}

component StatusBar inherits Rectangle {
    in property <bool> server_running;
    in property <string> server_status;
    in property <int> route_count;
    in property <bool> busy;
    in property <string> activity;

    height: 28px;
    horizontal-stretch: 1;
    background: Theme.surface_container;

    Rectangle {
        width: parent.width;
        height: 1px;
        background: Theme.outline_variant;
    }

    HorizontalLayout {
        padding-left: 14px;
        padding-right: 14px;
        spacing: 18px;
        alignment: center;

        UiText {
            text: root.server_running ? "Mock " + root.server_status : "Mock stopped";
            width: 220px;
            height: parent.height;
            font-family: "JetBrains Mono";
            font-size: 12px;
            color: root.server_running ? Theme.secondary : Theme.outline;
            vertical-alignment: center;
            overflow: elide;
        }

        UiText {
            text: root.route_count + " routes";
            width: 90px;
            height: parent.height;
            font-family: "JetBrains Mono";
            font-size: 12px;
            color: Theme.on_surface_variant;
            vertical-alignment: center;
            overflow: elide;
        }

        UiText {
            text: root.busy ? "Busy" : "";
            width: 52px;
            height: parent.height;
            color: Theme.tertiary;
            font-size: 12px;
            vertical-alignment: center;
            overflow: elide;
        }

        UiText {
            text: root.activity;
            horizontal-stretch: 1;
            height: parent.height;
            color: Theme.on_surface_variant;
            font-size: 12px;
            horizontal-alignment: right;
            vertical-alignment: center;
            overflow: elide;
        }
    }
}

export component AppWindow inherits Window {
    title: "ZenAPI";
    preferred-width: 1280px;
    preferred-height: 800px;
    min-width: 980px;
    min-height: 640px;
    default-font-family: "Inter";
    default-font-size: 13px;
    default-font-weight: 500;

    in-out property <[RouteRow]> routes;
    in-out property <[CollectionRow]> collection_rows;
    in-out property <[HistoryRow]> history_rows;
    in-out property <[RunnerRow]> runner_rows;
    in-out property <[MockLogRow]> mock_logs;
    in-out property <int> selected_route: -1;
    in-out property <string> file_path;
    in-out property <string> spec_label: "";
    in-out property <bool> spec_loaded: false;
    in-out property <string> collection_path;
    in-out property <string> collection_name: "ZenAPI Collection";
    in-out property <string> collection_status: "";
    in-out property <string> method: "GET";
    in-out property <string> url;
    in-out property <string> global_variables: "baseUrl=https://api.example.com";
    in-out property <string> environment_name: "dev";
    in-out property <string> environment_variables: "baseUrl=http://127.0.0.1:8080";
    in-out property <string> query_params;
    in-out property <string> request_headers: "Accept: application/json";
    in-out property <string> auth_mode: "none";
    in-out property <string> auth_config;
    in-out property <string> body_mode: "none";
    in-out property <string> request_body;
    in-out property <string> graphql_variables: "{}";
    in-out property <string> pre_request_script;
    in-out property <string> request_tests;
    in-out property <string> realtime_mode: "ws";
    in-out property <string> realtime_message: "hello";
    in-out property <string> sse_max_events: "3";
    in-out property <string> grpc_endpoint: "http://localhost:50051";
    in-out property <string> grpc_method: "package.Service/Method";
    in-out property <string> grpc_metadata: "";
    in-out property <string> grpc_message: "{}";
    in-out property <string> response_status: "Idle";
    in-out property <string> response_meta: "";
    in-out property <string> response_tone: "neutral";
    in-out property <string> response_body: "Import an OpenAPI or Swagger document to begin.";
    in-out property <string> response_headers: "";
    in-out property <string> codegen_language: "curl";
    in-out property <string> codegen_output: "";
    in-out property <string> runner_summary: "";
    in-out property <string> runner_delay_ms: "0";
    in-out property <bool> runner_stop_on_failure: false;
    in-out property <string> route_filter;
    in-out property <string> history_filter;
    in-out property <int> total_route_count: 0;
    in-out property <string> server_status: "Stopped";
    in-out property <bool> server_running: false;
    in-out property <bool> busy: false;
    in-out property <string> activity: "";

    callback import_openapi(string);
    callback filter_routes(string);
    callback select_route(int);
    callback select_collection_request(int);
    callback import_collection(string);
    callback save_current_request();
    callback save_collection(string);
    callback export_postman_collection(string);
    callback select_history(int);
    callback filter_history(string);
    callback delete_history(int);
    callback clear_history();
    callback send_request();
    callback toggle_server();
    callback generate_code();
    callback run_collection();
    callback run_websocket();
    callback run_sse();
    callback build_grpc_draft();

    background: Theme.background;

    VerticalLayout {
        padding: 0px;
        spacing: 0px;

        TopBar {
            file_path <=> root.file_path;
            spec_label: root.spec_label;
            spec_loaded: root.spec_loaded;
            server_running: root.server_running;
            server_status: root.server_status;
            route_count: root.total_route_count;
            busy: root.busy;
            import_openapi(path) => {
                root.import_openapi(path);
            }
            toggle_server => {
                root.toggle_server();
            }
        }

        HorizontalLayout {
            spacing: 0px;
            vertical-stretch: 1;

            Sidebar {
                routes <=> root.routes;
                collection_rows <=> root.collection_rows;
                history_rows <=> root.history_rows;
                mock_logs <=> root.mock_logs;
                selected_route <=> root.selected_route;
                route_filter <=> root.route_filter;
                history_filter <=> root.history_filter;
                collection_path <=> root.collection_path;
                collection_name <=> root.collection_name;
                collection_status <=> root.collection_status;
                total_route_count: root.total_route_count;
                busy: root.busy;
                filter_routes(query) => {
                    root.filter_routes(query);
                }
                select_route(index) => {
                    root.select_route(index);
                }
                select_collection_request(id) => {
                    root.select_collection_request(id);
                }
                import_collection(path) => {
                    root.import_collection(path);
                }
                save_current_request => {
                    root.save_current_request();
                }
                save_collection(path) => {
                    root.save_collection(path);
                }
                export_postman_collection(path) => {
                    root.export_postman_collection(path);
                }
                select_history(id) => {
                    root.select_history(id);
                }
                filter_history(query) => {
                    root.filter_history(query);
                }
                delete_history(id) => {
                    root.delete_history(id);
                }
                clear_history => {
                    root.clear_history();
                }
            }

            Rectangle {
                width: 1px;
                background: Theme.outline_variant;
            }

            Rectangle {
                horizontal-stretch: 1;
                vertical-stretch: 1;
                background: Theme.surface;

                VerticalLayout {
                    padding: 0px;
                    spacing: 0px;

                    AddressBar {
                        method <=> root.method;
                        url <=> root.url;
                        busy: root.busy;
                        send_request => {
                            root.send_request();
                        }
                    }

                    HorizontalLayout {
                        padding: 0px;
                        spacing: 0px;
                        vertical-stretch: 1;

                        RequestPanel {
                            global_variables <=> root.global_variables;
                            environment_name <=> root.environment_name;
                            environment_variables <=> root.environment_variables;
                            query_params <=> root.query_params;
                            request_headers <=> root.request_headers;
                            auth_mode <=> root.auth_mode;
                            auth_config <=> root.auth_config;
                            body_mode <=> root.body_mode;
                            request_body <=> root.request_body;
                            graphql_variables <=> root.graphql_variables;
                            pre_request_script <=> root.pre_request_script;
                            request_tests <=> root.request_tests;
                            realtime_mode <=> root.realtime_mode;
                            realtime_message <=> root.realtime_message;
                            sse_max_events <=> root.sse_max_events;
                            grpc_endpoint <=> root.grpc_endpoint;
                            grpc_method <=> root.grpc_method;
                            grpc_metadata <=> root.grpc_metadata;
                            grpc_message <=> root.grpc_message;
                            busy: root.busy;
                            run_websocket => {
                                root.run_websocket();
                            }
                            run_sse => {
                                root.run_sse();
                            }
                            build_grpc_draft => {
                                root.build_grpc_draft();
                            }
                        }

                        Rectangle {
                            width: 1px;
                            background: Theme.outline_variant;
                        }

                        ResponsePanel {
                            response_body <=> root.response_body;
                            response_headers <=> root.response_headers;
                            codegen_language <=> root.codegen_language;
                            codegen_output <=> root.codegen_output;
                            runner_rows <=> root.runner_rows;
                            runner_summary <=> root.runner_summary;
                            runner_delay_ms <=> root.runner_delay_ms;
                            runner_stop_on_failure <=> root.runner_stop_on_failure;
                            response_status: root.response_status;
                            response_meta: root.response_meta;
                            response_tone: root.response_tone;
                            busy: root.busy;
                            generate_code => {
                                root.generate_code();
                            }
                            run_collection => {
                                root.run_collection();
                            }
                        }
                    }
                }
            }
        }

        StatusBar {
            server_running: root.server_running;
            server_status: root.server_status;
            route_count: root.total_route_count;
            busy: root.busy;
            activity: root.activity;
        }
    }
}
