import { ListView, ScrollView } from "std-widgets.slint";
import { Theme } from "theme.slint";
import { MockLogRow, RouteRow } from "types.slint";
import { ActionButton, BodyModeButton, CodePane, DataPanel, LabeledEditor, MethodChip, MethodSelector, MetricCard, MockLogLine, ReadOnlyCodeBlock, ResponseTab, StatusDot, TextField, UiText, WorkspaceTab } from "widgets.slint";
import { RealtimeEditorPanel } from "realtime_editor_panel.slint";
import { CodegenPage } from "codegen_page.slint";
import { SettingsPage } from "settings_page.slint";
import { TeamPage } from "team_page.slint";
import { ApiKeysPage } from "api_keys_page.slint";
import { AnalyticsPage } from "analytics_page.slint";
import { DocumentationPage } from "documentation_page.slint";

export struct HistoryRow {
    id: int,
    method: string,
    url: string,
    status: string,
}

export struct CollectionRow {
    id: int,
    method: string,
    name: string,
    url: string,
    is_folder: bool,
    folder_path: string,
}

export struct RunnerRow {
    method: string,
    name: string,
    status: string,
    detail: string,
    tone: string,
}

export struct MockRuleRow {
    row_id: int,
    source: string,
    name: string,
    value: string,
    body_preview: string,
}

export struct VariableTableRow {
    row_id: int,
    scope: string,
    name: string,
    initial_value: string,
    current_value: string,
}

export struct EnvironmentRow {
    name: string,
    label: string,
    detail: string,
    tone: string,
}

export struct KeyValueTableRow {
    row_id: int,
    key: string,
    value: string,
}

export struct TestAssertionRow {
    row_id: int,
    kind: string,
    target: string,
    expected: string,
}

component KeyValueTableLine inherits Rectangle {
    in property <int> row_id;
    in-out property <string> key;
    in-out property <string> value;
    in property <bool> enabled: true;
    callback edited(int, string, string);
    callback delete_requested(int);

    height: 44px;
    horizontal-stretch: 1;
    border-radius: 6px;
    border-width: 1px;
    border-color: Theme.outline_variant;
    background: row_touch.has-hover ? Theme.surface_container_high : Theme.surface_container_low;

    row_touch := TouchArea {}

    TextField {
        x: 10px;
        y: 5px;
        width: 154px;
        height: 34px;
        text <=> root.key;
        placeholder: "key";
        mono: true;
        enabled: root.enabled;
        edited => {
            root.edited(root.row_id, root.key, root.value);
        }
    }

    TextField {
        x: 176px;
        y: 5px;
        width: parent.width - 240px;
        height: 34px;
        text <=> root.value;
        placeholder: "value";
        mono: true;
        enabled: root.enabled;
        edited => {
            root.edited(root.row_id, root.key, root.value);
        }
    }

    ActionButton {
        x: parent.width - 54px;
        y: 5px;
        text: "Del";
        button_width: 44px;
        warning: true;
        enabled: root.enabled;
        clicked => {
            root.delete_requested(root.row_id);
        }
    }
}

component KeyValueTablePanel inherits Rectangle {
    in-out property <[KeyValueTableRow]> rows;
    in property <string> title;
    in property <string> key_header: "Key";
    in property <string> value_header: "Value";
    in property <string> helper: "";
    in property <bool> busy: false;
    in property <bool> show_paste: false;
    in property <bool> show_import: false;
    in-out property <string> import_path;
    in property <bool> show_file_attach: false;
    in-out property <string> file_field;
    in-out property <string> file_path;
    callback add_row();
    callback paste_rows();
    callback import_rows(string);
    callback add_file_row(string, string);
    callback update_row(int, string, string);
    callback delete_row(int);

    horizontal-stretch: 1;
    vertical-stretch: 1;
    background: transparent;

    VerticalLayout {
        padding: 0px;
        spacing: 8px;

        HorizontalLayout {
            height: 28px;
            spacing: 8px;
            alignment: center;

            UiText {
                text: root.title;
                horizontal-stretch: 1;
                height: parent.height;
                color: Theme.on_surface_variant;
                font-size: 12px;
                font-weight: 800;
                vertical-alignment: center;
                overflow: elide;
            }

            ActionButton {
                text: "+";
                button_width: 34px;
                enabled: !root.busy;
                clicked => {
                    root.add_row();
                }
            }

            if root.show_paste: ActionButton {
                text: "Paste";
                button_width: 58px;
                enabled: !root.busy;
                clicked => {
                    root.paste_rows();
                }
            }
        }

        if root.show_import: HorizontalLayout {
            height: 34px;
            spacing: 8px;

            TextField {
                text <=> root.import_path;
                placeholder: "key-value file path";
                mono: true;
                enabled: !root.busy;
            }

            ActionButton {
                text: "Import";
                button_width: 68px;
                enabled: !root.busy && root.import_path != "";
                clicked => {
                    root.import_rows(root.import_path);
                }
            }
        }

        if root.show_file_attach: HorizontalLayout {
            height: 34px;
            spacing: 8px;

            TextField {
                text <=> root.file_field;
                placeholder: "file field";
                mono: true;
                enabled: !root.busy;
            }

            TextField {
                text <=> root.file_path;
                placeholder: "/absolute/path/to/file";
                mono: true;
                enabled: !root.busy;
            }

            ActionButton {
                text: "Add File";
                button_width: 76px;
                enabled: !root.busy && root.file_field != "" && root.file_path != "";
                clicked => {
                    root.add_file_row(root.file_field, root.file_path);
                }
            }
        }

        Rectangle {
            height: 30px;
            horizontal-stretch: 1;
            border-radius: 6px;
            border-width: 1px;
            border-color: Theme.outline_variant;
            background: Theme.surface_container;

            UiText {
                x: 14px;
                text: root.key_header;
                width: 150px;
                height: parent.height;
                color: Theme.on_surface_variant;
                font-size: 12px;
                font-weight: 800;
                vertical-alignment: center;
                overflow: elide;
            }

            Rectangle {
                x: 172px;
                y: 6px;
                width: 1px;
                height: parent.height - 12px;
                background: Theme.outline_variant;
            }

            UiText {
                x: 184px;
                text: root.value_header;
                width: parent.width - 244px;
                height: parent.height;
                color: Theme.on_surface_variant;
                font-size: 12px;
                font-weight: 800;
                vertical-alignment: center;
                overflow: elide;
            }
        }

        Rectangle {
            horizontal-stretch: 1;
            vertical-stretch: 1;
            background: transparent;

            if root.rows.length == 0: UiText {
                text: "No rows";
                width: parent.width;
                height: 32px;
                color: Theme.outline;
                font-size: 12px;
                vertical-alignment: center;
                overflow: elide;
            }

            if root.rows.length != 0: ListView {
                width: parent.width;
                height: parent.height;
                vertical-scrollbar-policy: ScrollBarPolicy.as-needed;
                horizontal-scrollbar-policy: ScrollBarPolicy.as-needed;

                for row in root.rows: KeyValueTableLine {
                    row_id: row.row_id;
                    key: row.key;
                    value: row.value;
                    enabled: !root.busy;
                    edited(row_id, key, value) => {
                        root.update_row(row_id, key, value);
                    }
                    delete_requested(row_id) => {
                        root.delete_row(row_id);
                    }
                }
            }
        }

        if root.helper != "": UiText {
            text: root.helper;
            height: 18px;
            horizontal-stretch: 1;
            color: Theme.outline;
            font-size: 12px;
            vertical-alignment: center;
            overflow: elide;
        }
    }
}

component TestAssertionLine inherits Rectangle {
    in property <int> row_id;
    in-out property <string> kind;
    in-out property <string> target;
    in-out property <string> expected;
    in property <bool> enabled: true;
    callback edited(int, string, string, string);
    callback cycle_kind_requested(int, string);
    callback delete_requested(int);

    height: 44px;
    horizontal-stretch: 1;
    border-radius: 6px;
    border-width: 1px;
    border-color: Theme.outline_variant;
    background: row_touch.has-hover ? Theme.surface_container_high : Theme.surface_container_low;

    row_touch := TouchArea {}

    ActionButton {
        x: 10px;
        y: 5px;
        text: "Kind";
        button_width: 52px;
        enabled: root.enabled;
        clicked => {
            root.cycle_kind_requested(root.row_id, root.kind);
        }
    }

    TextField {
        x: 70px;
        y: 5px;
        width: 116px;
        height: 34px;
        text <=> root.kind;
        placeholder: "status_equals";
        mono: true;
        enabled: root.enabled;
        edited => {
            root.edited(root.row_id, root.kind, root.target, root.expected);
        }
    }

    TextField {
        x: 198px;
        y: 5px;
        width: 118px;
        height: 34px;
        text <=> root.target;
        placeholder: "target";
        mono: true;
        enabled: root.enabled;
        edited => {
            root.edited(root.row_id, root.kind, root.target, root.expected);
        }
    }

    TextField {
        x: 328px;
        y: 5px;
        width: parent.width - 392px;
        height: 34px;
        text <=> root.expected;
        placeholder: "expected";
        mono: true;
        enabled: root.enabled;
        edited => {
            root.edited(root.row_id, root.kind, root.target, root.expected);
        }
    }

    ActionButton {
        x: parent.width - 54px;
        y: 5px;
        text: "Del";
        button_width: 44px;
        warning: true;
        enabled: root.enabled;
        clicked => {
            root.delete_requested(root.row_id);
        }
    }
}

component TestAssertionEditorPanel inherits Rectangle {
    in-out property <[TestAssertionRow]> rows;
    in property <bool> busy: false;
    property <string> custom_kind: "status_equals";
    property <string> custom_target: "200";
    property <string> custom_expected: "";
    callback add_row();
    callback add_template_row(string);
    callback add_custom_row(string, string, string);
    callback update_row(int, string, string, string);
    callback cycle_kind_row(int, string);
    callback delete_row(int);

    horizontal-stretch: 1;
    vertical-stretch: 1;
    background: transparent;

    VerticalLayout {
        padding: 0px;
        spacing: 6px;

        HorizontalLayout {
            height: 34px;
            spacing: 8px;
            alignment: center;

            UiText {
                text: "Tests";
                horizontal-stretch: 1;
                height: parent.height;
                color: Theme.on_surface_variant;
                font-size: 12px;
                font-weight: 800;
                vertical-alignment: center;
                overflow: elide;
            }

            ActionButton {
                text: "Add";
                button_width: 58px;
                enabled: !root.busy;
                clicked => {
                    root.add_row();
                }
            }

            for template in [
                { name: "status", label: "Status", width: 62px },
                { name: "header", label: "Header", width: 62px },
                { name: "body", label: "Body", width: 54px },
                { name: "json", label: "JSON", width: 52px },
            ]: ActionButton {
                text: template.label;
                button_width: template.width;
                enabled: !root.busy;
                clicked => {
                    root.add_template_row(template.name);
                }
            }
        }

        HorizontalLayout {
            height: 34px;
            spacing: 8px;
            alignment: center;

            TextField {
                text <=> root.custom_kind;
                placeholder: "kind";
                mono: true;
                enabled: !root.busy;
                horizontal-stretch: 1;
            }

            TextField {
                text <=> root.custom_target;
                placeholder: "target";
                mono: true;
                enabled: !root.busy;
                horizontal-stretch: 1;
            }

            TextField {
                text <=> root.custom_expected;
                placeholder: "expected";
                mono: true;
                enabled: !root.busy;
                horizontal-stretch: 1;
                accepted => {
                    if !root.busy && root.custom_kind != "" && root.custom_target != "" {
                        root.add_custom_row(root.custom_kind, root.custom_target, root.custom_expected);
                    }
                }
            }

            ActionButton {
                text: "Build";
                button_width: 58px;
                enabled: !root.busy && root.custom_kind != "" && root.custom_target != "";
                clicked => {
                    root.add_custom_row(root.custom_kind, root.custom_target, root.custom_expected);
                }
            }
        }

        Rectangle {
            height: 30px;
            horizontal-stretch: 1;
            border-radius: 6px;
            border-width: 1px;
            border-color: Theme.outline_variant;
            background: Theme.surface_container;

            UiText {
                x: 12px;
                text: "Kind";
                width: 180px;
                height: parent.height;
                color: Theme.on_surface_variant;
                font-size: 12px;
                font-weight: 800;
                vertical-alignment: center;
                overflow: elide;
            }

            Rectangle {
                x: 204px;
                y: 6px;
                width: 1px;
                height: parent.height - 12px;
                background: Theme.outline_variant;
            }

            UiText {
                x: 216px;
                text: "Target";
                width: 126px;
                height: parent.height;
                color: Theme.on_surface_variant;
                font-size: 12px;
                font-weight: 800;
                vertical-alignment: center;
                overflow: elide;
            }

            Rectangle {
                x: 346px;
                y: 6px;
                width: 1px;
                height: parent.height - 12px;
                background: Theme.outline_variant;
            }

            UiText {
                x: 358px;
                text: "Expect";
                width: parent.width - 370px;
                height: parent.height;
                color: Theme.on_surface_variant;
                font-size: 12px;
                font-weight: 800;
                vertical-alignment: center;
                overflow: elide;
            }
        }

        Rectangle {
            horizontal-stretch: 1;
            vertical-stretch: 1;
            background: transparent;

            if root.rows.length == 0: UiText {
                text: "No tests";
                width: parent.width;
                height: 32px;
                color: Theme.outline;
                font-size: 12px;
                vertical-alignment: center;
                overflow: elide;
            }

            if root.rows.length != 0: ListView {
                width: parent.width;
                height: parent.height;
                vertical-scrollbar-policy: ScrollBarPolicy.as-needed;
                horizontal-scrollbar-policy: ScrollBarPolicy.as-needed;

                for row in root.rows: TestAssertionLine {
                    row_id: row.row_id;
                    kind: row.kind;
                    target: row.target;
                    expected: row.expected;
                    enabled: !root.busy;
                    edited(row_id, kind, target, expected) => {
                        root.update_row(row_id, kind, target, expected);
                    }
                    cycle_kind_requested(row_id, kind) => {
                        root.cycle_kind_row(row_id, kind);
                    }
                    delete_requested(row_id) => {
                        root.delete_row(row_id);
                    }
                }
            }
        }

        UiText {
            text: "Line format: status_equals 200, header_equals content-type application/json, json_path_equals data.id 1.";
            height: 18px;
            horizontal-stretch: 1;
            color: Theme.outline;
            font-size: 12px;
            vertical-alignment: center;
            overflow: elide;
        }
    }
}

component HeaderEditorPanel inherits Rectangle {
    in-out property <string> request_headers;
    in-out property <[KeyValueTableRow]> header_rows;
    in-out property <string> header_import_path;
    in property <bool> busy;
    callback apply_header_preset(string);
    callback add_header();
    callback paste_headers();
    callback import_headers(string);
    callback update_header_row(int, string, string);
    callback delete_header_row(int);
    callback copy_headers();

    horizontal-stretch: 1;
    vertical-stretch: 1;
    background: transparent;

    VerticalLayout {
        padding: 0px;
        spacing: 6px;

        HorizontalLayout {
            height: 22px;
            spacing: 6px;
            alignment: center;

            UiText {
                text: "Headers";
                horizontal-stretch: 1;
                height: parent.height;
                color: Theme.on_surface_variant;
                font-size: 12px;
                font-weight: 800;
                vertical-alignment: center;
                overflow: elide;
            }

            ActionButton {
                text: "Accept";
                button_width: 58px;
                enabled: !root.busy;
                clicked => {
                    root.apply_header_preset("accept-json");
                }
            }

            ActionButton {
                text: "Content";
                button_width: 64px;
                enabled: !root.busy;
                clicked => {
                    root.apply_header_preset("content-json");
                }
            }

            ActionButton {
                text: "Bearer";
                button_width: 60px;
                enabled: !root.busy;
                clicked => {
                    root.apply_header_preset("bearer-token");
                }
            }

            ActionButton {
                text: "Copy";
                button_width: 54px;
                enabled: root.request_headers != "";
                clicked => {
                    root.copy_headers();
                }
            }

            ActionButton {
                text: "Paste";
                button_width: 58px;
                enabled: !root.busy;
                clicked => {
                    root.paste_headers();
                }
            }
        }

        HorizontalLayout {
            height: 34px;
            spacing: 8px;

            TextField {
                text <=> root.header_import_path;
                placeholder: "header file path";
                mono: true;
                enabled: !root.busy;
            }

            ActionButton {
                text: "Import";
                button_width: 68px;
                enabled: !root.busy && root.header_import_path != "";
                clicked => {
                    root.import_headers(root.header_import_path);
                }
            }
        }

        KeyValueTablePanel {
            rows <=> root.header_rows;
            title: "";
            key_header: "Header";
            value_header: "Value";
            helper: "Stored as Header=value lines; presets update common headers.";
            busy: root.busy;
            add_row => {
                root.add_header();
            }
            update_row(row_id, key, value) => {
                root.update_header_row(row_id, key, value);
            }
            delete_row(row_id) => {
                root.delete_header_row(row_id);
            }
        }
    }
}

component SidebarProfile inherits Rectangle {
    in property <string> title;
    in property <string> subtitle;

    height: 46px;
    horizontal-stretch: 1;
    background: transparent;

    UiText {
        x: 0px;
        y: 0px;
        text: root.title;
        width: parent.width;
        height: 24px;
        color: Theme.primary;
        font-size: 14px;
        font-weight: 800;
        overflow: elide;
        vertical-alignment: center;
    }

    UiText {
        x: 0px;
        y: 24px;
        text: root.subtitle;
        width: parent.width;
        height: 22px;
        color: Theme.on_surface_variant;
        font-size: 12px;
        overflow: elide;
        vertical-alignment: center;
    }
}

component SidebarFolderRow inherits Rectangle {
    in property <string> label;
    in property <bool> selected: false;
    in property <bool> interactive: false;
    callback picked();

    height: 36px;
    horizontal-stretch: 1;
    border-radius: 8px;
    background: root.selected ? #00a572 : touch.has-hover && root.interactive ? Theme.surface_container_high : transparent;

    touch := TouchArea {
        enabled: root.interactive;
        mouse-cursor: pointer;
        clicked => {
            root.picked();
        }
    }

    Rectangle {
        x: 10px;
        y: 12px;
        width: 15px;
        height: 11px;
        border-radius: 2px;
        border-width: 1px;
        border-color: root.selected ? #00311f : Theme.on_surface_variant;
        background: transparent;
    }

    Rectangle {
        x: 10px;
        y: 9px;
        width: 8px;
        height: 4px;
        border-radius: 1px;
        background: root.selected ? #00311f : Theme.on_surface_variant;
    }

    UiText {
        x: 34px;
        text: root.label;
        width: parent.width - 44px;
        height: parent.height;
        color: root.selected ? #00311f : Theme.on_surface;
        font-size: 14px;
        font-weight: root.selected ? 800 : 500;
        overflow: elide;
        vertical-alignment: center;
    }
}

component SidebarRequestLink inherits Rectangle {
    in property <string> method;
    in property <string> label;
    in property <bool> selected: false;
    callback picked();

    height: 30px;
    horizontal-stretch: 1;
    border-radius: 6px;
    border-width: root.selected ? 1px : 0px;
    border-color: Theme.outline_variant;
    background: root.selected ? Theme.surface_variant : touch.has-hover ? Theme.surface_container_high : transparent;

    touch := TouchArea {
        mouse-cursor: pointer;
        clicked => {
            root.picked();
        }
    }

    UiText {
        x: 10px;
        text: root.method;
        width: 34px;
        height: parent.height;
        font-family: "JetBrains Mono";
        font-size: 10px;
        font-weight: 800;
        color: root.method == "GET" ? Theme.secondary : root.method == "POST" ? #00a572 : root.method == "PUT" ? Theme.tertiary : root.method == "DELETE" ? Theme.error : Theme.primary;
        overflow: elide;
        vertical-alignment: center;
    }

    UiText {
        x: 48px;
        text: root.label;
        width: parent.width - 58px;
        height: parent.height;
        color: Theme.on_surface;
        font-size: 13px;
        font-weight: root.selected ? 700 : 500;
        overflow: elide;
        vertical-alignment: center;
    }
}

component SidebarHistoryLink inherits Rectangle {
    in property <string> method;
    in property <string> label;
    callback picked();

    height: 26px;
    horizontal-stretch: 1;
    border-radius: 6px;
    background: touch.has-hover ? Theme.surface_container_high : transparent;

    touch := TouchArea {
        mouse-cursor: pointer;
        clicked => {
            root.picked();
