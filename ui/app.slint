import { ListView } from "std-widgets.slint";
import { Theme } from "theme.slint";
import { ActionButton, BodyModeButton, CodePane, LabeledEditor, MethodSelector, RunnerResultItem, TabHeader, TextField, UiText } from "widgets.slint";

export struct RouteRow {
    method: string,
    path: string,
    summary: string,
}

export struct HistoryRow {
    id: int,
    method: string,
    url: string,
    status: string,
}

export struct CollectionRow {
    id: int,
    method: string,
    name: string,
    url: string,
}

export struct RunnerRow {
    method: string,
    name: string,
    status: string,
    detail: string,
    tone: string,
}

export struct MockLogRow {
    method: string,
    path: string,
    status: string,
}

global AuthText {
    public pure function title(mode: string) -> string {
        return mode == "none" ? "Auth disabled" : mode == "basic" ? "Basic credentials" : mode == "api-header" ? "API key header" : mode == "api-query" ? "API key query" : mode == "jwt" ? "JWT token" : "Bearer token";
    }

    public pure function hint(mode: string) -> string {
        return mode == "none" ? "disabled" : mode == "basic" ? "username:password" : mode == "api-header" ? "Header-Name=secret" : mode == "api-query" ? "query_key=secret" : "token";
    }

    public pure function detail(mode: string) -> string {
        return mode == "none" ? "No auth entries will be sent." : mode == "basic" ? "Sent as Authorization: Basic ..." : mode == "api-header" ? "Adds one request header." : mode == "api-query" ? "Adds one query parameter." : "Sent as Authorization: Bearer ...";
    }
}

component AuthConfigPanel inherits Rectangle {
    in-out property <string> auth_mode;
    in-out property <string> auth_config;
    in property <bool> busy;

    horizontal-stretch: 1;
    vertical-stretch: 1;
    background: transparent;

    VerticalLayout {
        padding: 0px;
        spacing: 6px;

        UiText {
            text: "Auth / " + AuthText.title(root.auth_mode);
            height: 20px;
            horizontal-stretch: 1;
            color: Theme.on_surface_variant;
            font-size: 12px;
            font-weight: 800;
            vertical-alignment: center;
            overflow: elide;
        }

        TextField {
            text <=> root.auth_config;
            placeholder: AuthText.hint(root.auth_mode);
            mono: true;
            enabled: !root.busy && root.auth_mode != "none";
            height: 34px;
        }

        UiText {
            text: AuthText.detail(root.auth_mode);
            height: 18px;
            horizontal-stretch: 1;
            color: Theme.outline;
            font-size: 11px;
            overflow: elide;
            vertical-alignment: center;
        }
    }
}

component HeaderEditorPanel inherits Rectangle {
    in-out property <string> request_headers;
    in property <bool> busy;
    callback apply_header_preset(string);

    horizontal-stretch: 1;
    vertical-stretch: 1;
    background: transparent;

    VerticalLayout {
        padding: 0px;
        spacing: 6px;

        HorizontalLayout {
            height: 22px;
            spacing: 6px;
            alignment: center;

            UiText {
                text: "Headers";
                horizontal-stretch: 1;
                height: parent.height;
                color: Theme.on_surface_variant;
                font-size: 12px;
                font-weight: 800;
                vertical-alignment: center;
                overflow: elide;
            }

            ActionButton {
                text: "Accept";
                button_width: 58px;
                enabled: !root.busy;
                clicked => {
                    root.apply_header_preset("accept-json");
                }
            }

            ActionButton {
                text: "Content";
                button_width: 64px;
                enabled: !root.busy;
                clicked => {
                    root.apply_header_preset("content-json");
                }
            }

            ActionButton {
                text: "Bearer";
                button_width: 60px;
                enabled: !root.busy;
                clicked => {
                    root.apply_header_preset("bearer-token");
                }
            }
        }

        CodePane {
            text <=> root.request_headers;
            read_only: false;
        }
    }
}

component SidebarProfile inherits Rectangle {
    height: 58px;
    horizontal-stretch: 1;
    background: transparent;

    Rectangle {
        x: 0px;
        y: 6px;
        width: 40px;
        height: 40px;
        border-radius: 20px;
        background: Theme.surface_container_highest;
    }

    UiText {
        x: 52px;
        y: 5px;
        text: "Lead Architect";
        width: parent.width - 52px;
        height: 24px;
        color: Theme.primary;
        font-size: 14px;
        font-weight: 800;
        overflow: elide;
        vertical-alignment: center;
    }

    UiText {
        x: 52px;
        y: 29px;
        text: "Dev-Ops Team";
        width: parent.width - 52px;
        height: 22px;
        color: Theme.on_surface_variant;
        font-size: 14px;
        overflow: elide;
        vertical-alignment: center;
    }
}

component SidebarFolderRow inherits Rectangle {
    in property <string> label;
    in property <bool> selected: false;
    callback picked();

    height: 36px;
    horizontal-stretch: 1;
    border-radius: 8px;
    background: root.selected ? #00a572 : touch.has-hover ? Theme.surface_variant : transparent;

    touch := TouchArea {
        mouse-cursor: pointer;
        clicked => {
            root.picked();
        }
    }

    Rectangle {
        x: 10px;
        y: 12px;
        width: 15px;
        height: 11px;
        border-radius: 2px;
        border-width: 1px;
        border-color: root.selected ? #00311f : Theme.on_surface_variant;
        background: transparent;
    }

    Rectangle {
        x: 10px;
        y: 9px;
        width: 8px;
        height: 4px;
        border-radius: 1px;
        background: root.selected ? #00311f : Theme.on_surface_variant;
    }

    UiText {
        x: 34px;
        text: root.label;
        width: parent.width - 44px;
        height: parent.height;
        color: root.selected ? #00311f : Theme.on_surface;
        font-size: 14px;
        font-weight: root.selected ? 800 : 500;
        overflow: elide;
        vertical-alignment: center;
    }
}

component SidebarRequestLink inherits Rectangle {
    in property <string> method;
    in property <string> label;
    in property <bool> selected: false;
    callback picked();

    height: 30px;
    horizontal-stretch: 1;
    border-radius: 6px;
    border-width: root.selected ? 1px : 0px;
    border-color: Theme.outline_variant;
    background: root.selected ? Theme.surface_variant : touch.has-hover ? Theme.surface_container_high : transparent;

    touch := TouchArea {
        mouse-cursor: pointer;
        clicked => {
            root.picked();
        }
    }

    UiText {
        x: 10px;
        text: root.method;
        width: 34px;
        height: parent.height;
        font-family: "JetBrains Mono";
        font-size: 10px;
        font-weight: 800;
        color: root.method == "GET" ? Theme.secondary : root.method == "POST" ? #00a572 : root.method == "PUT" ? Theme.tertiary : root.method == "DELETE" ? Theme.error : Theme.primary;
        overflow: elide;
        vertical-alignment: center;
    }

    UiText {
        x: 48px;
        text: root.label;
        width: parent.width - 58px;
        height: parent.height;
        color: Theme.on_surface;
        font-size: 13px;
        font-weight: root.selected ? 700 : 500;
        overflow: elide;
        vertical-alignment: center;
    }
}

component SidebarHistoryLink inherits Rectangle {
    in property <string> method;
    in property <string> label;
    callback picked();

    height: 26px;
    horizontal-stretch: 1;
    border-radius: 6px;
    background: touch.has-hover ? Theme.surface_container_high : transparent;

    touch := TouchArea {
        mouse-cursor: pointer;
        clicked => {
            root.picked();
        }
    }

    UiText {
        x: 0px;
        text: root.method;
        width: 32px;
        height: parent.height;
        font-family: "JetBrains Mono";
        font-size: 10px;
        color: root.method == "DELETE" ? Theme.error : root.method == "POST" ? #00a572 : Theme.secondary;
        overflow: elide;
        vertical-alignment: center;
    }

    UiText {
        x: 38px;
        text: root.label;
        width: parent.width - 38px;
        height: parent.height;
        color: Theme.on_surface_variant;
        font-size: 12px;
        overflow: elide;
        vertical-alignment: center;
    }
}

component Sidebar inherits Rectangle {
    in-out property <[RouteRow]> routes;
    in-out property <[CollectionRow]> collection_rows;
    in-out property <[HistoryRow]> history_rows;
    in-out property <[MockLogRow]> mock_logs;
    in-out property <int> selected_route;
    in-out property <string> route_filter;
    in-out property <string> history_filter;
    in-out property <string> mock_log_filter;
    in-out property <string> mock_log_path;
    in-out property <string> collection_path;
    in-out property <int> selected_collection_request;
    in-out property <string> collection_request_name;
    in-out property <string> collection_name;
    in-out property <string> collection_status;
    in property <int> total_route_count;
    in property <bool> busy;
    callback select_route(int);
    callback select_collection_request(int);
    callback rename_collection_request(int, string);
    callback duplicate_collection_request(int);
    callback delete_collection_request(int);
    callback import_collection(string);
    callback save_current_request();
    callback save_collection(string);
    callback export_postman_collection(string);
    callback select_history(int);
    callback filter_history(string);
    callback delete_history(int);
    callback clear_history();
    callback filter_mock_logs(string);
    callback save_mock_logs(string);
    callback clear_mock_logs();
    callback filter_routes(string);

    width: 240px;
    vertical-stretch: 1;
    background: Theme.surface_container_low;

    VerticalLayout {
        padding: 16px;
        spacing: 14px;

        SidebarProfile {}

        Rectangle {
            horizontal-stretch: 1;
            vertical-stretch: 1;
            background: transparent;

            VerticalLayout {
                padding: 0px;
                spacing: 8px;

                HorizontalLayout {
                    height: 24px;
                    spacing: 8px;
                    alignment: center;

                    UiText {
                        text: "COLLECTIONS";
                        horizontal-stretch: 1;
                        height: parent.height;
                        color: Theme.on_surface_variant;
                        font-size: 12px;
                        font-weight: 800;
                        vertical-alignment: center;
                        overflow: elide;
                    }

                    ActionButton {
                        text: "+";
                        button_width: 30px;
                        enabled: !root.busy;
                        clicked => {
                            root.save_current_request();
                        }
                    }
                }

                SidebarFolderRow {
                    label: "Auth";
                    selected: false;
                }

                SidebarFolderRow {
                    label: root.collection_name == "" ? "Users" : root.collection_name;
                    selected: true;
                }

                Rectangle {
                    height: root.collection_rows.length == 0 && root.routes.length == 0 ? 34px : 170px;
                    horizontal-stretch: 1;
                    background: transparent;

                    Rectangle {
                        x: 19px;
                        width: 1px;
                        height: parent.height;
                        background: Theme.outline_variant;
                    }

                    if root.collection_rows.length == 0 && root.routes.length == 0: UiText {
                        x: 32px;
                        text: root.total_route_count == 0 ? "No requests" : "No matching routes";
                        width: parent.width - 32px;
                        height: 30px;
                        color: Theme.outline;
                        font-size: 12px;
                        vertical-alignment: center;
                        overflow: elide;
                    }

                    if root.collection_rows.length != 0: ListView {
                        x: 32px;
                        width: parent.width - 32px;
                        height: parent.height;
                        vertical-scrollbar-policy: ScrollBarPolicy.always-off;
                        horizontal-scrollbar-policy: ScrollBarPolicy.always-off;

                        for entry in root.collection_rows: SidebarRequestLink {
                            method: entry.method;
                            label: entry.name;
                            selected: root.selected_collection_request == entry.id;
                            picked => {
                                root.selected_collection_request = entry.id;
                                root.select_collection_request(entry.id);
                            }
                        }
                    }

                    if root.collection_rows.length == 0 && root.routes.length != 0: ListView {
                        x: 32px;
                        width: parent.width - 32px;
                        height: parent.height;
                        vertical-scrollbar-policy: ScrollBarPolicy.always-off;
                        horizontal-scrollbar-policy: ScrollBarPolicy.always-off;

                        for route[i] in root.routes: SidebarRequestLink {
                            method: route.method;
                            label: route.summary == "" ? route.path : route.summary;
                            selected: root.selected_route == i;
                            picked => {
                                root.selected_route = i;
                                root.select_route(i);
                            }
                        }
                    }
                }

                SidebarFolderRow {
                    label: "Billing";
                    selected: false;
                }
            }
        }

        Rectangle {
            height: 112px;
            horizontal-stretch: 1;
            background: transparent;

            VerticalLayout {
                padding: 0px;
                spacing: 8px;

                HorizontalLayout {
                    height: 24px;
                    spacing: 8px;
                    alignment: center;

                    UiText {
                        text: "HISTORY";
                        horizontal-stretch: 1;
                        height: parent.height;
                        color: Theme.on_surface_variant;
                        font-size: 12px;
                        font-weight: 800;
                        vertical-alignment: center;
                        overflow: elide;
                    }

                    ActionButton {
                        text: "...";
                        button_width: 34px;
                        enabled: !root.busy && root.history_rows.length > 0;
                        clicked => {
                            root.clear_history();
                        }
                    }
                }

                if root.history_rows.length == 0: UiText {
                    text: "No requests yet";
                    height: 26px;
                    horizontal-stretch: 1;
                    color: Theme.outline;
                    font-size: 12px;
                    vertical-alignment: center;
                    overflow: elide;
                }

                if root.history_rows.length != 0: ListView {
                    horizontal-stretch: 1;
                    vertical-stretch: 1;
                    vertical-scrollbar-policy: ScrollBarPolicy.always-off;
                    horizontal-scrollbar-policy: ScrollBarPolicy.always-off;

                    for entry in root.history_rows: SidebarHistoryLink {
                        method: entry.method;
                        label: entry.url;
                        picked => {
                            root.select_history(entry.id);
                        }
                    }
                }
            }
        }
    }
}

component TopBar inherits Rectangle {
    in-out property <string> file_path;
    in property <bool> busy;
    callback import_openapi(string);

    height: 64px;
    horizontal-stretch: 1;
    background: Theme.surface_dim;

    HorizontalLayout {
        padding-left: 20px;
        padding-right: 20px;
        spacing: 16px;
        alignment: center;

        Rectangle {
            width: 36px;
            height: 36px;
            border-radius: 8px;
            background: menu_touch.has-hover ? Theme.surface_container_high : transparent;

            menu_touch := TouchArea {
                enabled: !root.busy;
                mouse-cursor: root.busy ? default : pointer;
                clicked => {
                    import_popup.show();
                }
            }

            Rectangle {
                x: 7px;
                y: 11px;
                width: 22px;
                height: 2px;
                background: Theme.primary;
            }

            Rectangle {
                x: 7px;
                y: 17px;
                width: 22px;
                height: 2px;
                background: Theme.primary;
            }

            Rectangle {
                x: 7px;
                y: 23px;
                width: 22px;
                height: 2px;
                background: Theme.primary;
            }
        }

        UiText {
            text: "API Architect";
            width: 220px;
            height: root.height;
            font-size: 24px;
            font-weight: 800;
            color: Theme.primary;
            vertical-alignment: center;
            overflow: elide;
        }

        Rectangle {
            horizontal-stretch: 1;
        }

        Rectangle {
            width: 36px;
            height: 36px;
            border-radius: 8px;
            background: search_touch.has-hover ? Theme.surface_container_high : transparent;

            search_touch := TouchArea {
                mouse-cursor: pointer;
            }

            Rectangle {
                x: 9px;
                y: 8px;
                width: 14px;
                height: 14px;
                border-radius: 7px;
                border-width: 2px;
                border-color: Theme.primary;
                background: transparent;
            }

            Rectangle {
                x: 22px;
                y: 22px;
                width: 8px;
                height: 2px;
                background: Theme.primary;
            }
        }
    }

    Rectangle {
        y: parent.height - 1px;
        width: parent.width;
        height: 1px;
        background: Theme.outline_variant;
    }

    import_popup := PopupWindow {
        x: 20px;
        y: root.height + 6px;
        width: root.width - 40px;
        height: 58px;
        close-policy: close-on-click-outside;

        Rectangle {
            width: parent.width;
            height: parent.height;
            background: Theme.surface_container;
            border-radius: 8px;
            border-width: 1px;
            border-color: Theme.outline_variant;

            HorizontalLayout {
                padding: 10px;
                spacing: 10px;
                alignment: center;

                TextField {
                    text <=> root.file_path;
                    placeholder: "Local JSON or YAML file path";
                    mono: true;
                    enabled: !root.busy;
                    horizontal-stretch: 1;
                    accepted => {
                        if !root.busy {
                            import_popup.close();
                            root.import_openapi(root.file_path);
                        }
                    }
                }

                ActionButton {
                    text: "Import";
                    primary: true;
                    enabled: !root.busy;
                    button_width: 82px;
                    clicked => {
                        if !root.busy {
                            import_popup.close();
                            root.import_openapi(root.file_path);
                        }
                    }
                }
            }
        }
    }
}

component AddressBar inherits Rectangle {
    in-out property <string> method;
    in-out property <string> url;
    in property <bool> busy;
    callback send_request();

    height: 136px;
    horizontal-stretch: 1;
    background: Theme.surface_container_low;

    Rectangle {
        y: parent.height - 1px;
        width: parent.width;
        height: 1px;
        background: Theme.outline_variant;
    }

    VerticalLayout {
        padding: 16px;
        spacing: 12px;

        HorizontalLayout {
            height: 22px;
            spacing: 8px;
            alignment: center;

            UiText {
                text: "Users";
                width: 46px;
                height: parent.height;
                color: Theme.on_surface_variant;
                font-size: 14px;
                vertical-alignment: center;
                overflow: elide;
            }

            UiText {
                text: ">";
                width: 10px;
                height: parent.height;
                color: Theme.on_surface_variant;
                font-size: 14px;
                horizontal-alignment: center;
                vertical-alignment: center;
            }

            UiText {
                text: root.url == "" ? "New Request" : "Request";
                horizontal-stretch: 1;
                height: parent.height;
                color: Theme.on_surface;
                font-size: 14px;
                vertical-alignment: center;
                overflow: elide;
            }
        }

        HorizontalLayout {
            height: 42px;
            spacing: 8px;
            alignment: center;

            Rectangle {
                height: 42px;
                horizontal-stretch: 1;
                background: Theme.surface_container;
                border-radius: 8px;
                border-width: 1px;
                border-color: !root.busy && url_field.focused ? Theme.primary : Theme.outline_variant;
                clip: true;

                HorizontalLayout {
                    spacing: 0px;
                    alignment: center;

                    MethodSelector {
                        method <=> root.method;
                        enabled: !root.busy;
                    }

                    Rectangle {
                        width: 1px;
                        height: parent.height - 10px;
                        background: Theme.outline_variant;
                    }

                    url_field := TextField {
                        text <=> root.url;
                        placeholder: "Enter request URL";
                        embedded: true;
                        mono: true;
                        enabled: !root.busy;
                        height: 42px;
                        horizontal-stretch: 1;
                        accepted => {
                            if !root.busy {
                                root.send_request();
                            }
                        }
                    }
                }
            }

            ActionButton {
                text: "Send";
                enabled: !root.busy;
                primary: true;
                button_width: 124px;
                clicked => {
                    root.send_request();
                }
            }
        }
    }
}

component RequestPanel inherits Rectangle {
    in-out property <string> global_variables;
    in-out property <string> environment_name;
    in-out property <string> environment_variables;
    in-out property <string> query_params;
    in-out property <string> request_headers;
    in-out property <string> auth_mode;
    in-out property <string> auth_config;
    in-out property <string> body_mode;
    in-out property <string> request_body;
    in-out property <string> graphql_variables;
    in-out property <string> pre_request_script;
    in-out property <string> request_tests;
    in-out property <string> realtime_mode;
    in-out property <string> realtime_message;
    in-out property <string> sse_max_events;
    in-out property <string> sse_last_event_id;
    in-out property <bool> sse_streaming;
    in-out property <string> grpc_endpoint;
    in-out property <string> grpc_method;
    in-out property <string> grpc_metadata;
    in-out property <string> grpc_message;
    in property <bool> busy;
    callback open_websocket();
    callback run_websocket();
    callback close_websocket();
    callback run_sse();
    callback open_sse_stream();
    callback close_sse_stream();
    callback apply_graphql_template(string);
    callback apply_header_preset(string);
    callback build_grpc_draft();

    horizontal-stretch: 1;
    vertical-stretch: 1;
    background: Theme.surface;

    VerticalLayout {
        padding: 0px;
        spacing: 0px;

        TabHeader {
            label: "Request";
        }

        Rectangle {
            height: 112px;
            background: Theme.surface;

            HorizontalLayout {
                padding: 10px;
                spacing: 10px;

                Rectangle {
                    width: 128px;
                    vertical-stretch: 1;

                    VerticalLayout {
                        padding: 0px;
                        spacing: 6px;

                        UiText {
                            text: "Env";
                            height: 20px;
                            color: Theme.on_surface_variant;
                            font-size: 12px;
                            font-weight: 800;
                            vertical-alignment: center;
                            overflow: elide;
                        }

                        TextField {
                            text <=> root.environment_name;
                            placeholder: "dev";
                            mono: true;
                            enabled: !root.busy;
                            height: 34px;
                        }

                        HorizontalLayout {
                            height: 28px;
                            spacing: 4px;

                            for item in [
                                { mode: "dev", label: "dev" },
                                { mode: "test", label: "test" },
                                { mode: "prod", label: "prod" },
                            ]: BodyModeButton {
                                mode: item.mode;
                                label: item.label;
                                button_width: 38px;
                                selected: root.environment_name == item.mode;
                                enabled: !root.busy;
                                picked(mode) => {
                                    root.environment_name = mode;
                                }
                            }
                        }
                    }
                }

                LabeledEditor {
                    label: "Globals";
                    text <=> root.global_variables;
                }

                LabeledEditor {
                    label: "Env Vars";
                    text <=> root.environment_variables;
                }
            }
        }

        Rectangle {
            height: 1px;
            background: Theme.outline_variant;
        }

        Rectangle {
            height: 134px;
            background: Theme.surface;

            HorizontalLayout {
                padding: 10px;
                spacing: 10px;

                LabeledEditor {
                    label: "Params";
                    text <=> root.query_params;
                }

                HeaderEditorPanel {
                    request_headers <=> root.request_headers;
                    busy: root.busy;
                    apply_header_preset(preset) => {
                        root.apply_header_preset(preset);
                    }
                }

                AuthConfigPanel {
                    auth_mode <=> root.auth_mode;
                    auth_config <=> root.auth_config;
                    busy: root.busy;
                }
            }
        }

        Rectangle {
            height: 1px;
            background: Theme.outline_variant;
        }

        Rectangle {
            height: 34px;
            background: Theme.surface_container_lowest;

            HorizontalLayout {
                padding-left: 10px;
                padding-right: 10px;
                spacing: 8px;
                alignment: center;

                for item in [
                    { mode: "none", label: "no auth" },
                    { mode: "bearer", label: "bearer" },
                    { mode: "basic", label: "basic" },
                    { mode: "jwt", label: "jwt" },
                    { mode: "api-header", label: "api-h" },
                    { mode: "api-query", label: "api-q" },
                ]: BodyModeButton {
                    mode: item.mode;
                    label: item.label;
                    selected: root.auth_mode == item.mode;
                    picked(mode) => {
                        root.auth_mode = mode;
                    }
                }
            }
        }

        Rectangle {
            height: 1px;
            background: Theme.outline_variant;
        }

        Rectangle {
            height: 34px;
            background: Theme.surface_container_lowest;

            HorizontalLayout {
                padding-left: 10px;
                padding-right: 10px;
                spacing: 8px;
                alignment: center;

                for item in [
                    { mode: "none", label: "none" },
                    { mode: "raw", label: "raw" },
                    { mode: "form", label: "form" },
                    { mode: "urlenc", label: "urlenc" },
                    { mode: "graphql", label: "graphql" },
                    { mode: "binary", label: "binary" },
                ]: BodyModeButton {
                    mode: item.mode;
                    label: item.label;
                    selected: root.body_mode == item.mode;
                    picked(mode) => {
                        root.body_mode = mode;
                    }
                }
            }
        }

        Rectangle {
            vertical-stretch: 1;
            background: Theme.surface;

            VerticalLayout {
                padding: 10px;
                spacing: 10px;

                if root.body_mode == "graphql": HorizontalLayout {
                    height: 30px;
                    spacing: 8px;
                    alignment: start;

                    ActionButton {
                        text: "Intro";
                        button_width: 58px;
                        enabled: !root.busy;
                        clicked => {
                            root.apply_graphql_template("introspection");
                        }
                    }

                    ActionButton {
                        text: "Query";
                        button_width: 58px;
                        enabled: !root.busy;
                        clicked => {
                            root.apply_graphql_template("query");
                        }
                    }

                    ActionButton {
                        text: "Mutation";
                        button_width: 78px;
                        enabled: !root.busy;
                        clicked => {
                            root.apply_graphql_template("mutation");
                        }
                    }
                }

                if root.body_mode == "graphql": HorizontalLayout {
                    spacing: 10px;

                    LabeledEditor {
                        label: "GraphQL Query";
                        text <=> root.request_body;
                    }

                    LabeledEditor {
                        label: "GraphQL Variables";
                        text <=> root.graphql_variables;
                    }
                }

                if root.body_mode != "graphql": LabeledEditor {
                    label: "Body / " + root.body_mode;
                    text <=> root.request_body;
                    read_only: root.body_mode == "none";
                }

                Rectangle {
                    height: 126px;
                    horizontal-stretch: 1;

                    HorizontalLayout {
                        padding: 0px;
                        spacing: 10px;

                        LabeledEditor {
                            label: "Pre-request";
                            text <=> root.pre_request_script;
                        }

                        LabeledEditor {
                            label: "Tests";
                            text <=> root.request_tests;
                        }

                        Rectangle {
                            horizontal-stretch: 1;
                            vertical-stretch: 1;

                            VerticalLayout {
                                padding: 0px;
                                spacing: 6px;

                                UiText {
                                    text: "Realtime / " + root.realtime_mode;
                                    height: 20px;
                                    horizontal-stretch: 1;
                                    color: Theme.on_surface_variant;
                                    font-size: 12px;
                                    font-weight: 800;
                                    vertical-alignment: center;
                                    overflow: elide;
                                }

                                HorizontalLayout {
                                    height: 26px;
                                    spacing: 8px;

                                    BodyModeButton {
                                        mode: "ws";
                                        label: "ws";
                                        button_width: 48px;
                                        selected: root.realtime_mode == "ws";
                                        enabled: !root.busy;
                                        picked(mode) => {
                                            root.realtime_mode = mode;
                                        }
                                    }

                                    BodyModeButton {
                                        mode: "sse";
                                        label: "sse";
                                        button_width: 48px;
                                        selected: root.realtime_mode == "sse";
                                        enabled: !root.busy;
                                        picked(mode) => {
                                            root.realtime_mode = mode;
                                        }
                                    }

                                    TextField {
                                        text <=> root.sse_max_events;
                                        placeholder: "events";
                                        mono: true;
                                        enabled: !root.busy && root.realtime_mode == "sse" && !root.sse_streaming;
                                        height: 26px;
                                    }

                                    TextField {
                                        text <=> root.sse_last_event_id;
                                        placeholder: "Last-Event-ID";
                                        mono: true;
                                        enabled: !root.busy && root.realtime_mode == "sse" && !root.sse_streaming;
                                        height: 26px;
                                    }
                                }

                                TextField {
                                    text <=> root.realtime_message;
                                    placeholder: "WebSocket message";
                                    mono: true;
                                    enabled: !root.busy && root.realtime_mode == "ws";
                                    height: 28px;
                                }

                                HorizontalLayout {
                                    height: 30px;
                                    spacing: 8px;

                                    ActionButton {
                                        text: "Open";
                                        button_width: 54px;
                                        visible: root.realtime_mode == "ws";
                                        enabled: !root.busy && root.realtime_mode == "ws";
                                        primary: root.realtime_mode == "ws";
                                        clicked => {
                                            root.open_websocket();
                                        }
                                    }

                                    ActionButton {
                                        text: "Send";
                                        button_width: 54px;
                                        visible: root.realtime_mode == "ws";
                                        enabled: !root.busy && root.realtime_mode == "ws";
                                        primary: root.realtime_mode == "ws";
                                        clicked => {
                                            root.run_websocket();
                                        }
                                    }

                                    ActionButton {
                                        text: "End";
                                        button_width: 46px;
                                        warning: true;
                                        visible: root.realtime_mode == "ws";
                                        enabled: !root.busy && root.realtime_mode == "ws";
                                        clicked => {
                                            root.close_websocket();
                                        }
                                    }

                                    ActionButton {
                                        text: "Once";
                                        button_width: 56px;
                                        visible: root.realtime_mode == "sse";
                                        enabled: !root.busy && root.realtime_mode == "sse" && !root.sse_streaming;
                                        primary: root.realtime_mode == "sse";
                                        clicked => {
                                            root.run_sse();
                                        }
                                    }

                                    ActionButton {
                                        text: "Stream";
                                        button_width: 68px;
                                        visible: root.realtime_mode == "sse";
                                        enabled: !root.busy && root.realtime_mode == "sse" && !root.sse_streaming;
                                        primary: root.realtime_mode == "sse";
                                        clicked => {
                                            root.open_sse_stream();
                                        }
                                    }

                                    ActionButton {
                                        text: "Stop";
                                        button_width: 54px;
                                        warning: true;
                                        visible: root.realtime_mode == "sse";
                                        enabled: root.realtime_mode == "sse" && root.sse_streaming;
                                        clicked => {
                                            root.close_sse_stream();
                                        }
                                    }
                                }
                            }
                        }

                        Rectangle {
                            horizontal-stretch: 1;
                            vertical-stretch: 1;

                            VerticalLayout {
                                padding: 0px;
                                spacing: 6px;

                                UiText {
                                    text: "gRPC Draft";
                                    height: 20px;
                                    horizontal-stretch: 1;
                                    color: Theme.on_surface_variant;
                                    font-size: 12px;
                                    font-weight: 800;
                                    vertical-alignment: center;
                                    overflow: elide;
                                }

                                TextField {
                                    text <=> root.grpc_endpoint;
                                    placeholder: "http://localhost:50051";
                                    mono: true;
                                    enabled: !root.busy;
                                    height: 28px;
                                }

                                TextField {
                                    text <=> root.grpc_method;
                                    placeholder: "package.Service/Method";
                                    mono: true;
                                    enabled: !root.busy;
                                    height: 28px;
                                }

                                TextField {
                                    text <=> root.grpc_metadata;
                                    placeholder: "metadata name=value";
                                    mono: true;
                                    enabled: !root.busy;
                                    height: 28px;
                                }

                                HorizontalLayout {
                                    height: 30px;
                                    spacing: 8px;

                                    TextField {
                                        text <=> root.grpc_message;
                                        placeholder: "{}";
                                        mono: true;
                                        enabled: !root.busy;
                                        height: 30px;
                                    }

                                    ActionButton {
                                        text: "Build";
                                        button_width: 64px;
                                        enabled: !root.busy;
                                        clicked => {
                                            root.build_grpc_draft();
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}

component ResponsePanel inherits Rectangle {
    in-out property <string> response_body;
    in-out property <string> response_headers;
    in-out property <string> codegen_language;
    in-out property <string> codegen_output;
    in-out property <string> codegen_path;
    in-out property <[RunnerRow]> runner_rows;
    in-out property <string> runner_summary;
    in-out property <string> runner_delay_ms;
    in-out property <string> runner_report_path;
    in-out property <bool> runner_stop_on_failure;
    in-out property <bool> runner_active;
    in property <string> response_status;
    in property <string> response_meta;
    in property <string> response_tone;
    in property <bool> busy;
    callback generate_code();
    callback save_codegen(string);
    callback run_collection();
    callback cancel_collection_run();
    callback save_runner_report(string);

    width: 420px;
    vertical-stretch: 1;
    background: Theme.surface;

    VerticalLayout {
        padding: 0px;
        spacing: 0px;

        TabHeader {
            label: "Response";
            status: root.response_status + (root.response_meta == "" ? "" : " / " + root.response_meta);
            tone: root.response_tone;
        }

        Rectangle {
            height: 34px;
            background: Theme.surface_container_lowest;

            UiText {
                x: 14px;
                text: "Body  Headers  Cookies";
                width: parent.width - 28px;
                height: parent.height;
                font-size: 12px;
                color: Theme.outline;
                vertical-alignment: center;
                overflow: elide;
            }
        }

        Rectangle {
            vertical-stretch: 1;
            background: Theme.surface;

            VerticalLayout {
                padding: 10px;
                spacing: 10px;

                LabeledEditor {
                    label: "Body";
                    text <=> root.response_body;
                    read_only: true;
                }

                Rectangle {
                    height: 96px;
                    horizontal-stretch: 1;

                    LabeledEditor {
                        label: "Headers";
                        text <=> root.response_headers;
                        read_only: true;
                    }
                }

                Rectangle {
                    height: 190px;
                    horizontal-stretch: 1;
                    background: transparent;

                    VerticalLayout {
                        padding: 0px;
                        spacing: 8px;

                        HorizontalLayout {
                            height: 34px;
                            spacing: 8px;
                            alignment: center;

                            BodyModeButton {
                                mode: "continue";
                                label: "continue";
                                button_width: 76px;
                                selected: !root.runner_stop_on_failure;
                                enabled: !root.busy && !root.runner_active;
                                picked(mode) => {
                                    root.runner_stop_on_failure = false;
                                }
                            }

                            BodyModeButton {
                                mode: "stop";
                                label: "stop fail";
                                button_width: 76px;
                                selected: root.runner_stop_on_failure;
                                enabled: !root.busy && !root.runner_active;
                                picked(mode) => {
                                    root.runner_stop_on_failure = true;
                                }
                            }

                            Rectangle {
                                width: 78px;
                                height: 30px;

                                TextField {
                                    text <=> root.runner_delay_ms;
                                    placeholder: "Delay ms";
                                    mono: true;
                                    enabled: !root.busy && !root.runner_active;
                                    width: parent.width;
                                    height: parent.height;
                                }
                            }

                            ActionButton {
                                text: "Run";
                                button_width: 64px;
                                primary: true;
                                enabled: !root.busy && !root.runner_active;
                                clicked => {
                                    root.run_collection();
                                }
                            }

                            ActionButton {
                                text: "Cancel";
                                button_width: 68px;
                                warning: true;
                                enabled: root.runner_active;
                                clicked => {
                                    root.cancel_collection_run();
                                }
                            }
                        }

                        UiText {
                            text: root.runner_summary == "" ? "No runner results" : root.runner_summary;
                            height: 18px;
                            horizontal-stretch: 1;
                            color: Theme.on_surface_variant;
                            font-size: 11px;
                            overflow: elide;
                            vertical-alignment: center;
                        }

                        HorizontalLayout {
                            height: 32px;
                            spacing: 8px;
                            alignment: center;

                            TextField {
                                text <=> root.runner_report_path;
                                placeholder: "Runner report path";
                                mono: true;
                                enabled: !root.busy && !root.runner_active;
                                height: 32px;
                            }

                            ActionButton {
                                text: "Save";
                                button_width: 64px;
                                enabled: !root.busy && !root.runner_active && root.runner_report_path != "" && root.runner_summary != "";
                                clicked => {
                                    root.save_runner_report(root.runner_report_path);
                                }
                            }
                        }

                        if root.runner_rows.length == 0: Rectangle {
                            vertical-stretch: 1;
                            horizontal-stretch: 1;
                            background: Theme.surface_container;
                            border-radius: 6px;

                            UiText {
                                text: "No results";
                                width: parent.width;
                                height: parent.height;
                                color: Theme.outline;
                                font-size: 12px;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                                overflow: elide;
                            }
                        }

                        if root.runner_rows.length != 0: ListView {
                            vertical-stretch: 1;
                            horizontal-stretch: 1;
                            vertical-scrollbar-policy: ScrollBarPolicy.always-off;
                            horizontal-scrollbar-policy: ScrollBarPolicy.always-off;

                            for result in root.runner_rows: RunnerResultItem {
                                method: result.method;
                                name: result.name;
                                status: result.status;
                                detail: result.detail;
                                tone: result.tone;
                            }
                        }
                    }
                }

                Rectangle {
                    height: 190px;
                    horizontal-stretch: 1;
                    background: transparent;

                    VerticalLayout {
                        padding: 0px;
                        spacing: 8px;

                        HorizontalLayout {
                            height: 28px;
                            spacing: 8px;
                            alignment: center;

                            for item in [
                                { mode: "curl", label: "curl" },
                                { mode: "python", label: "py" },
                                { mode: "js", label: "js" },
                                { mode: "rust", label: "rust" },
                                { mode: "go", label: "go" },
                            ]: BodyModeButton {
                                mode: item.mode;
                                label: item.label;
                                button_width: 54px;
                                selected: root.codegen_language == item.mode;
                                enabled: !root.busy;
                                picked(mode) => {
                                    root.codegen_language = mode;
                                }
                            }

                            ActionButton {
                                text: "Generate";
                                button_width: 86px;
                                primary: true;
                                enabled: !root.busy;
                                clicked => {
                                    root.generate_code();
                                }
                            }
                        }

                        HorizontalLayout {
                            height: 32px;
                            spacing: 8px;
                            alignment: center;

                            TextField {
                                text <=> root.codegen_path;
                                placeholder: "Snippet path";
                                mono: true;
                                enabled: !root.busy;
                                height: 32px;
                            }

                            ActionButton {
                                text: "Save";
                                button_width: 64px;
                                enabled: !root.busy && root.codegen_path != "";
                                clicked => {
                                    root.save_codegen(root.codegen_path);
                                }
                            }
                        }

                        LabeledEditor {
                            label: "Code / " + root.codegen_language;
                            text <=> root.codegen_output;
                            read_only: true;
                        }
                    }
                }
            }
        }
    }
}

component StatusBar inherits Rectangle {
    in property <bool> server_running;
    in property <string> server_status;
    in property <int> route_count;
    in property <bool> busy;
    in property <string> activity;

    height: 28px;
    horizontal-stretch: 1;
    background: Theme.surface_container;

    Rectangle {
        width: parent.width;
        height: 1px;
        background: Theme.outline_variant;
    }

    HorizontalLayout {
        padding-left: 14px;
        padding-right: 14px;
        spacing: 18px;
        alignment: center;

        UiText {
            text: root.server_running ? "Mock " + root.server_status : "Mock stopped";
            width: 220px;
            height: parent.height;
            font-family: "JetBrains Mono";
            font-size: 12px;
            color: root.server_running ? Theme.secondary : Theme.outline;
            vertical-alignment: center;
            overflow: elide;
        }

        UiText {
            text: root.route_count + " routes";
            width: 90px;
            height: parent.height;
            font-family: "JetBrains Mono";
            font-size: 12px;
            color: Theme.on_surface_variant;
            vertical-alignment: center;
            overflow: elide;
        }

        UiText {
            text: root.busy ? "Busy" : "";
            width: 52px;
            height: parent.height;
            color: Theme.tertiary;
            font-size: 12px;
            vertical-alignment: center;
            overflow: elide;
        }

        UiText {
            text: root.activity;
            horizontal-stretch: 1;
            height: parent.height;
            color: Theme.on_surface_variant;
            font-size: 12px;
            horizontal-alignment: right;
            vertical-alignment: center;
            overflow: elide;
        }
    }
}

export component AppWindow inherits Window {
    title: "ZenAPI";
    preferred-width: 1280px;
    preferred-height: 800px;
    min-width: 980px;
    min-height: 640px;
    default-font-family: "Inter";
    default-font-size: 13px;
    default-font-weight: 500;

    in-out property <[RouteRow]> routes;
    in-out property <[CollectionRow]> collection_rows;
    in-out property <[HistoryRow]> history_rows;
    in-out property <[RunnerRow]> runner_rows;
    in-out property <[MockLogRow]> mock_logs;
    in-out property <int> selected_route: -1;
    in-out property <string> file_path;
    in-out property <string> spec_label: "";
    in-out property <bool> spec_loaded: false;
    in-out property <string> collection_path;
    in-out property <string> collection_name: "ZenAPI Collection";
    in-out property <string> collection_status: "";
    in-out property <string> method: "GET";
    in-out property <string> url;
    in-out property <string> global_variables: "baseUrl=https://api.example.com";
    in-out property <string> environment_name: "dev";
    in-out property <string> environment_variables: "baseUrl=http://127.0.0.1:8080";
    in-out property <string> query_params;
    in-out property <string> request_headers: "Accept: application/json";
    in-out property <string> auth_mode: "none";
    in-out property <string> auth_config;
    in-out property <string> body_mode: "none";
    in-out property <string> request_body;
    in-out property <string> graphql_variables: "{}";
    in-out property <string> pre_request_script;
    in-out property <string> request_tests;
    in-out property <string> realtime_mode: "ws";
    in-out property <string> realtime_message: "hello";
    in-out property <string> sse_max_events: "3";
    in-out property <string> sse_last_event_id: "";
    in-out property <bool> sse_streaming: false;
    in-out property <string> grpc_endpoint: "http://localhost:50051";
    in-out property <string> grpc_method: "package.Service/Method";
    in-out property <string> grpc_metadata: "";
    in-out property <string> grpc_message: "{}";
    in-out property <string> response_status: "Idle";
    in-out property <string> response_meta: "";
    in-out property <string> response_tone: "neutral";
    in-out property <string> response_body: "Import an OpenAPI or Swagger document to begin.";
    in-out property <string> response_headers: "";
    in-out property <string> codegen_language: "curl";
    in-out property <string> codegen_output: "";
    in-out property <string> codegen_path: "zenapi-snippet.txt";
    in-out property <string> runner_summary: "";
    in-out property <string> runner_delay_ms: "0";
    in-out property <string> runner_report_path: "zenapi-runner-report.txt";
    in-out property <bool> runner_stop_on_failure: false;
    in-out property <bool> runner_active: false;
    in-out property <string> route_filter;
    in-out property <string> history_filter;
    in-out property <string> mock_log_filter;
    in-out property <string> mock_log_path: "mock-logs.json";
    in-out property <int> total_route_count: 0;
    in-out property <int> selected_collection_request: -1;
    in-out property <string> collection_request_name: "";
    in-out property <string> server_status: "Stopped";
    in-out property <bool> server_running: false;
    in-out property <bool> busy: false;
    in-out property <string> activity: "";

    callback import_openapi(string);
    callback filter_routes(string);
    callback select_route(int);
    callback select_collection_request(int);
    callback rename_collection_request(int, string);
    callback duplicate_collection_request(int);
    callback delete_collection_request(int);
    callback import_collection(string);
    callback save_current_request();
    callback save_collection(string);
    callback export_postman_collection(string);
    callback select_history(int);
    callback filter_history(string);
    callback delete_history(int);
    callback clear_history();
    callback filter_mock_logs(string);
    callback save_mock_logs(string);
    callback clear_mock_logs();
    callback send_request();
    callback toggle_server();
    callback generate_code();
    callback save_codegen(string);
    callback run_collection();
    callback cancel_collection_run();
    callback save_runner_report(string);
    callback open_websocket();
    callback run_websocket();
    callback close_websocket();
    callback run_sse();
    callback open_sse_stream();
    callback close_sse_stream();
    callback apply_graphql_template(string);
    callback apply_header_preset(string);
    callback build_grpc_draft();

    background: Theme.background;

    VerticalLayout {
        padding: 0px;
        spacing: 0px;

        TopBar {
            file_path <=> root.file_path;
            busy: root.busy;
            import_openapi(path) => {
                root.import_openapi(path);
            }
        }

        HorizontalLayout {
            spacing: 0px;
            vertical-stretch: 1;

            Sidebar {
                routes <=> root.routes;
                collection_rows <=> root.collection_rows;
                history_rows <=> root.history_rows;
                mock_logs <=> root.mock_logs;
                selected_route <=> root.selected_route;
                route_filter <=> root.route_filter;
                history_filter <=> root.history_filter;
                mock_log_filter <=> root.mock_log_filter;
                mock_log_path <=> root.mock_log_path;
                collection_path <=> root.collection_path;
                selected_collection_request <=> root.selected_collection_request;
                collection_request_name <=> root.collection_request_name;
                collection_name <=> root.collection_name;
                collection_status <=> root.collection_status;
                total_route_count: root.total_route_count;
                busy: root.busy;
                filter_routes(query) => {
                    root.filter_routes(query);
                }
                select_route(index) => {
                    root.select_route(index);
                }
                select_collection_request(id) => {
                    root.select_collection_request(id);
                }
                rename_collection_request(id, name) => {
                    root.rename_collection_request(id, name);
                }
                duplicate_collection_request(id) => {
                    root.duplicate_collection_request(id);
                }
                delete_collection_request(id) => {
                    root.delete_collection_request(id);
                }
                import_collection(path) => {
                    root.import_collection(path);
                }
                save_current_request => {
                    root.save_current_request();
                }
                save_collection(path) => {
                    root.save_collection(path);
                }
                export_postman_collection(path) => {
                    root.export_postman_collection(path);
                }
                select_history(id) => {
                    root.select_history(id);
                }
                filter_history(query) => {
                    root.filter_history(query);
                }
                delete_history(id) => {
                    root.delete_history(id);
                }
                clear_history => {
                    root.clear_history();
                }
                filter_mock_logs(query) => {
                    root.filter_mock_logs(query);
                }
                save_mock_logs(path) => {
                    root.save_mock_logs(path);
                }
                clear_mock_logs => {
                    root.clear_mock_logs();
                }
            }

            Rectangle {
                width: 1px;
                background: Theme.outline_variant;
            }

            Rectangle {
                horizontal-stretch: 1;
                vertical-stretch: 1;
                background: Theme.surface;

                VerticalLayout {
                    padding: 0px;
                    spacing: 0px;

                    AddressBar {
                        method <=> root.method;
                        url <=> root.url;
                        busy: root.busy;
                        send_request => {
                            root.send_request();
                        }
                    }

                    HorizontalLayout {
                        padding: 0px;
                        spacing: 0px;
                        vertical-stretch: 1;

                        RequestPanel {
                            global_variables <=> root.global_variables;
                            environment_name <=> root.environment_name;
                            environment_variables <=> root.environment_variables;
                            query_params <=> root.query_params;
                            request_headers <=> root.request_headers;
                            auth_mode <=> root.auth_mode;
                            auth_config <=> root.auth_config;
                            body_mode <=> root.body_mode;
                            request_body <=> root.request_body;
                            graphql_variables <=> root.graphql_variables;
                            pre_request_script <=> root.pre_request_script;
                            request_tests <=> root.request_tests;
                            realtime_mode <=> root.realtime_mode;
                            realtime_message <=> root.realtime_message;
                            sse_max_events <=> root.sse_max_events;
                            sse_last_event_id <=> root.sse_last_event_id;
                            sse_streaming <=> root.sse_streaming;
                            grpc_endpoint <=> root.grpc_endpoint;
                            grpc_method <=> root.grpc_method;
                            grpc_metadata <=> root.grpc_metadata;
                            grpc_message <=> root.grpc_message;
                            busy: root.busy;
                            open_websocket => {
                                root.open_websocket();
                            }
                            run_websocket => {
                                root.run_websocket();
                            }
                            close_websocket => {
                                root.close_websocket();
                            }
                            run_sse => {
                                root.run_sse();
                            }
                            open_sse_stream => {
                                root.open_sse_stream();
                            }
                            close_sse_stream => {
                                root.close_sse_stream();
                            }
                            apply_graphql_template(template) => {
                                root.apply_graphql_template(template);
                            }
                            apply_header_preset(preset) => {
                                root.apply_header_preset(preset);
                            }
                            build_grpc_draft => {
                                root.build_grpc_draft();
                            }
                        }

                        Rectangle {
                            width: 1px;
                            background: Theme.outline_variant;
                        }

                        ResponsePanel {
                            response_body <=> root.response_body;
                            response_headers <=> root.response_headers;
                            codegen_language <=> root.codegen_language;
                            codegen_output <=> root.codegen_output;
                            codegen_path <=> root.codegen_path;
                            runner_rows <=> root.runner_rows;
                            runner_summary <=> root.runner_summary;
                            runner_delay_ms <=> root.runner_delay_ms;
                            runner_report_path <=> root.runner_report_path;
                            runner_stop_on_failure <=> root.runner_stop_on_failure;
                            runner_active <=> root.runner_active;
                            response_status: root.response_status;
                            response_meta: root.response_meta;
                            response_tone: root.response_tone;
                            busy: root.busy;
                            generate_code => {
                                root.generate_code();
                            }
                            save_codegen(path) => {
                                root.save_codegen(path);
                            }
                            run_collection => {
                                root.run_collection();
                            }
                            cancel_collection_run => {
                                root.cancel_collection_run();
                            }
                            save_runner_report(path) => {
                                root.save_runner_report(path);
                            }
                        }
                    }
                }
            }
        }

        StatusBar {
            server_running: root.server_running;
            server_status: root.server_status;
            route_count: root.total_route_count;
            busy: root.busy;
            activity: root.activity;
        }
    }
}
