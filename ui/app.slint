            text: "JSON Preview";
            height: 20px;
            horizontal-stretch: 1;
            color: Theme.on_surface_variant;
            font-size: 12px;
            font-weight: 800;
            vertical-alignment: center;
            overflow: elide;
        }

        ReadOnlyCodeBlock {
            height: 230px;
            text: root.preview;
        }

        Rectangle {
            height: 112px;
            horizontal-stretch: 1;
            border-radius: 8px;
            border-width: 1px;
            border-color: Theme.outline_variant;
            background: Theme.surface_container;

            VerticalLayout {
                padding: 12px;
                spacing: 8px;

                UiText {
                    text: "Secret Masking";
                    height: 18px;
                    horizontal-stretch: 1;
                    color: Theme.on_surface;
                    font-size: 13px;
                    font-weight: 800;
                    vertical-alignment: center;
                    overflow: elide;
                }

                UiText {
                    text: "Preview masks names containing key, token, or secret as ********.";
                    horizontal-stretch: 1;
                    vertical-stretch: 1;
                    color: Theme.on_surface_variant;
                    font-size: 12px;
                    wrap: word-wrap;
                    vertical-alignment: top;
                }
            }
        }

        Rectangle {
            height: 126px;
            horizontal-stretch: 1;
            border-radius: 8px;
            background: Theme.surface_variant;

            VerticalLayout {
                padding: 12px;
                spacing: 8px;

                UiText {
                    text: "Pro Tip";
                    height: 18px;
                    horizontal-stretch: 1;
                    color: Theme.on_surface;
                    font-size: 13px;
                    font-weight: 800;
                    vertical-alignment: center;
                    overflow: elide;
                }

                UiText {
                    text: "Reference variables from requests with double braces.";
                    height: 34px;
                    horizontal-stretch: 1;
                    color: Theme.on_surface_variant;
                    font-size: 12px;
                    wrap: word-wrap;
                    vertical-alignment: top;
                }

                Rectangle {
                    height: 32px;
                    horizontal-stretch: 1;
                    border-radius: 4px;
                    border-width: 1px;
                    border-color: Theme.outline_variant;
                    background: Theme.surface_dim;

                    UiText {
                        x: 8px;
                        text: "DB_URL={{DB_HOST}}:{{DB_PORT}}";
                        width: parent.width - 16px;
                        height: parent.height;
                        color: Theme.tertiary;
                        font-family: "JetBrains Mono";
                        font-size: 11px;
                        vertical-alignment: center;
                        overflow: elide;
                    }
                }
            }
        }
    }
}

component EnvironmentPage inherits Rectangle {
    in-out property <[VariableTableRow]> variable_rows;
    in-out property <string> global_variables;
    in-out property <string> environment_name;
    in-out property <string> environment_variables;
    in-out property <string> variables_json_preview;
    in property <bool> busy;
    callback select_environment(string);
    callback environment_name_changed(string);
    callback update_variable_row(int, string, string, string);
    callback add_variable(string);
    callback delete_variable_row(int, string);

    horizontal-stretch: 1;
    vertical-stretch: 1;
    background: Theme.background;

    HorizontalLayout {
        spacing: 0px;

        Rectangle {
            width: 256px;
            vertical-stretch: 1;
            background: Theme.surface_container;

            VerticalLayout {
                padding: 0px;
                spacing: 0px;

                Rectangle {
                    height: 68px;
                    horizontal-stretch: 1;
                    background: Theme.surface_container;

                    UiText {
                        x: 16px;
                        text: "Environments";
                        width: parent.width - 32px;
                        height: parent.height;
                        color: Theme.on_surface;
                        font-size: 20px;
                        font-weight: 800;
                        vertical-alignment: center;
                        overflow: elide;
                    }
                }

                Rectangle {
                    height: 1px;
                    horizontal-stretch: 1;
                    background: Theme.outline_variant;
                }

                Rectangle {
                    horizontal-stretch: 1;
                    vertical-stretch: 1;
                    background: transparent;

                    VerticalLayout {
                        padding: 10px;
                        spacing: 6px;

                        for item in [
                            { mode: "dev", label: "Development", detail: "Local development", tone: "inactive" },
                            { mode: "test", label: "Staging", detail: "Shared staging scope", tone: "inactive" },
                            { mode: "prod", label: "Production", detail: "Production values", tone: "error" },
                            { mode: "local", label: "Local", detail: "Machine overrides", tone: "inactive" },
                        ]: EnvironmentNavRow {
                            mode: item.mode;
                            label: item.label;
                            detail: item.detail;
                            tone: item.tone;
                            selected: root.environment_name == item.mode;
                            picked(mode) => {
                                root.select_environment(mode);
                            }
                        }
                    }
                }
            }
        }

        Rectangle {
            width: 1px;
            vertical-stretch: 1;
            background: Theme.outline_variant;
        }

        EnvironmentVariableTable {
            variable_rows <=> root.variable_rows;
            environment_name <=> root.environment_name;
            busy: root.busy;
            environment_name_changed(name) => {
                root.environment_name_changed(name);
            }
            update_variable_row(row_id, scope, name, value) => {
                root.update_variable_row(row_id, scope, name, value);
            }
            add_variable(scope) => {
                root.add_variable(scope);
            }
            delete_variable_row(row_id, scope) => {
                root.delete_variable_row(row_id, scope);
            }
        }

        Rectangle {
            width: 1px;
            vertical-stretch: 1;
            background: Theme.outline_variant;
        }

        VariableDetailsPanel {
            preview: root.variables_json_preview;
        }
    }
}

component RunnerResultLine inherits Rectangle {
    in property <string> method;
    in property <string> name;
    in property <string> status;
    in property <string> detail;
    in property <string> tone;

    height: 48px;
    horizontal-stretch: 1;
    border-radius: 6px;
    background: touch.has-hover ? Theme.surface_container_high : Theme.surface_container;

    touch := TouchArea {}

    UiText {
        x: 10px;
        text: root.method;
        width: 48px;
        height: parent.height;
        font-family: "JetBrains Mono";
        font-size: 11px;
        color: Theme.secondary;
        vertical-alignment: center;
        overflow: elide;
    }

    UiText {
        x: 66px;
        y: 6px;
        text: root.name;
        width: parent.width - 150px;
        height: 20px;
        color: Theme.on_surface;
        font-size: 12px;
        font-weight: 800;
        vertical-alignment: center;
        overflow: elide;
    }

    UiText {
        x: 66px;
        y: 26px;
        text: root.detail;
        width: parent.width - 150px;
        height: 16px;
        color: Theme.on_surface_variant;
        font-size: 11px;
        vertical-alignment: center;
        overflow: elide;
    }

    UiText {
        x: parent.width - 74px;
        text: root.status;
        width: 64px;
        height: parent.height;
        color: root.tone == "error" ? Theme.error : Theme.secondary;
        font-size: 12px;
        font-weight: 800;
        horizontal-alignment: right;
        vertical-alignment: center;
        overflow: elide;
    }
}

component RunnerPage inherits Rectangle {
    in-out property <[CollectionRow]> collection_rows;
    in-out property <[RunnerRow]> runner_rows;
    in-out property <string> runner_summary;
    in-out property <string> runner_delay_ms;
    in-out property <string> runner_report_path;
    in-out property <string> runner_report_format;
    in-out property <bool> runner_stop_on_failure;
    in-out property <bool> runner_active;
    in property <bool> busy;
    callback run_collection();
    callback cancel_collection_run();
    callback save_runner_report(string);

    horizontal-stretch: 1;
    vertical-stretch: 1;
    background: Theme.background;

    HorizontalLayout {
        spacing: 0px;

        Rectangle {
            width: 300px;
            vertical-stretch: 1;
            background: Theme.surface_container;

            VerticalLayout {
                padding: 16px;
                spacing: 10px;

                UiText {
                    text: "Test Collections";
                    height: 32px;
                    horizontal-stretch: 1;
                    color: Theme.on_surface;
                    font-size: 18px;
                    font-weight: 800;
                    vertical-alignment: center;
                    overflow: elide;
                }

                if root.collection_rows.length == 0: DataPanel {
                    title: "No collection";
                    body: "Save requests before running a suite.";
                }

                if root.collection_rows.length != 0: ListView {
                    horizontal-stretch: 1;
                    vertical-stretch: 1;
                    vertical-scrollbar-policy: ScrollBarPolicy.as-needed;
                    horizontal-scrollbar-policy: ScrollBarPolicy.as-needed;

                    for entry in root.collection_rows: SidebarRequestLink {
                        method: entry.method;
                        label: entry.name;
                    }
                }
            }
        }

        Rectangle {
            width: 1px;
            background: Theme.outline_variant;
        }

        Rectangle {
            horizontal-stretch: 1;
            vertical-stretch: 1;
            background: Theme.surface;

            VerticalLayout {
                padding: 20px;
                spacing: 16px;

                PageTitle {
                    title: "Automated Test Suite";
                    subtitle: root.runner_summary == "" ? "No runner results yet." : root.runner_summary;
                }

                HorizontalLayout {
                    height: 38px;
                    spacing: 10px;

                    BodyModeButton {
                        mode: "continue";
                        label: "continue";
                        button_width: 90px;
                        selected: !root.runner_stop_on_failure;
                        enabled: !root.busy && !root.runner_active;
                        picked(mode) => {
                            root.runner_stop_on_failure = false;
                        }
                    }

                    BodyModeButton {
                        mode: "stop";
                        label: "stop fail";
                        button_width: 90px;
                        selected: root.runner_stop_on_failure;
                        enabled: !root.busy && !root.runner_active;
                        picked(mode) => {
                            root.runner_stop_on_failure = true;
                        }
                    }

                    TextField {
                        text <=> root.runner_delay_ms;
                        placeholder: "Delay ms";
                        mono: true;
                        enabled: !root.busy && !root.runner_active;
                        width: 110px;
                        height: 38px;
                    }

                    ActionButton {
                        text: "Run Suite";
                        button_width: 104px;
                        primary: true;
                        enabled: !root.busy && !root.runner_active;
                        clicked => {
                            root.run_collection();
                        }
                    }

                    ActionButton {
                        text: "Cancel";
                        button_width: 82px;
                        warning: true;
                        enabled: root.runner_active;
                        clicked => {
                            root.cancel_collection_run();
                        }
                    }
                }

                if root.runner_rows.length == 0: DataPanel {
                    title: "Results";
                    body: "Run a collection to populate request results.";
                }

                if root.runner_rows.length != 0: ListView {
                    horizontal-stretch: 1;
                    vertical-stretch: 1;
                    vertical-scrollbar-policy: ScrollBarPolicy.as-needed;
                    horizontal-scrollbar-policy: ScrollBarPolicy.as-needed;

                    for result in root.runner_rows: RunnerResultLine {
                        method: result.method;
                        name: result.name;
                        status: result.status;
                        detail: result.detail;
                        tone: result.tone;
                    }
                }
            }
        }

        Rectangle {
            width: 320px;
            vertical-stretch: 1;
            background: Theme.surface_container_lowest;

            VerticalLayout {
                padding: 16px;
                spacing: 12px;

                UiText {
                    text: "REPORT";
                    height: 24px;
                    horizontal-stretch: 1;
                    color: Theme.on_surface;
                    font-size: 13px;
                    font-weight: 800;
                    vertical-alignment: center;
                    overflow: elide;
                }

                LabeledEditor {
                    label: "Summary";
                    text <=> root.runner_summary;
                    read_only: true;
                }

                HorizontalLayout {
                    height: 30px;
                    spacing: 8px;

                    BodyModeButton {
                        mode: "text";
                        label: "Text";
                        button_width: 68px;
                        selected: root.runner_report_format == "text";
                        enabled: !root.busy && !root.runner_active;
                        picked(mode) => {
                            root.runner_report_format = mode;
                        }
                    }

                    BodyModeButton {
                        mode: "json";
                        label: "JSON";
                        button_width: 68px;
                        selected: root.runner_report_format == "json";
                        enabled: !root.busy && !root.runner_active;
                        picked(mode) => {
                            root.runner_report_format = mode;
                        }
                    }
                }

                HorizontalLayout {
                    height: 34px;
                    spacing: 8px;

                    TextField {
                        text <=> root.runner_report_path;
                        placeholder: root.runner_report_format == "json" ? "runner-report.json" : "runner-report.txt";
                        mono: true;
                        enabled: !root.busy && !root.runner_active;
                    }

                    ActionButton {
                        text: "Save";
                        button_width: 64px;
                        enabled: !root.busy && !root.runner_active && root.runner_summary != "";
                        clicked => {
                            root.save_runner_report(root.runner_report_path);
                        }
                    }
                }
            }
        }
    }
}

component CodegenPage inherits Rectangle {
    in-out property <string> codegen_language;
    in-out property <string> codegen_output;
    in property <string> codegen_metadata;
    in-out property <string> codegen_path;
    in property <bool> busy;
    callback generate_code();
    callback copy_codegen();
    callback save_codegen(string);

    horizontal-stretch: 1;
    vertical-stretch: 1;
    background: Theme.background;

    VerticalLayout {
        padding: 20px;
        spacing: 16px;

        PageTitle {
            title: "Code Generation";
            subtitle: "Generate snippets from the current resolved request.";
        }

        HorizontalLayout {
            height: 38px;
            spacing: 10px;

            for item in [
                { mode: "curl", label: "curl" },
                { mode: "python", label: "python" },
                { mode: "js", label: "js" },
                { mode: "rust", label: "rust" },
                { mode: "go", label: "go" },
            ]: BodyModeButton {
                mode: item.mode;
                label: item.label;
                button_width: 76px;
                selected: root.codegen_language == item.mode;
                enabled: !root.busy;
                picked(mode) => {
                    root.codegen_language = mode;
                }
            }

            ActionButton {
                text: "Generate";
                button_width: 96px;
                primary: true;
                enabled: !root.busy;
                clicked => {
                    root.generate_code();
                }
            }
        }

        DataPanel {
            height: 92px;
            title: "Metadata";
            body: root.codegen_metadata;
        }

        if root.codegen_output == "": UiText {
            horizontal-stretch: 1;
            vertical-stretch: 1;
            text: "Generate a snippet from the current request.";
            color: Theme.outline;
            font-size: 12px;
            horizontal-alignment: center;
            vertical-alignment: center;
            overflow: elide;
        }

        if root.codegen_output != "": CodePane {
            text <=> root.codegen_output;
            read_only: true;
        }

        HorizontalLayout {
            height: 38px;
            spacing: 10px;

            TextField {
                text <=> root.codegen_path;
                placeholder: "zenapi-snippet.txt";
                mono: true;
                enabled: !root.busy;
            }

            ActionButton {
                text: "Save";
                button_width: 72px;
                enabled: !root.busy && root.codegen_path != "";
                clicked => {
                    root.save_codegen(root.codegen_path);
                }
            }

            ActionButton {
                text: "Copy";
                button_width: 72px;
                enabled: !root.busy && root.codegen_output != "";
                clicked => {
                    root.copy_codegen();
                }
            }
        }
    }
}

component Badge inherits Rectangle {
    in property <string> text;
    in property <string> tone: "neutral";
    in property <length> badge_width: 72px;

    width: root.badge_width;
    height: 22px;
    border-radius: 4px;
    border-width: 1px;
    border-color: root.tone == "success" ? Theme.secondary : root.tone == "error" ? Theme.error : root.tone == "warning" ? Theme.tertiary : Theme.outline_variant;
    background: root.tone == "success" ? #123627 : root.tone == "error" ? #3d1517 : root.tone == "warning" ? #3e2b13 : Theme.surface_container_high;

    UiText {
        text: root.text;
        width: parent.width;
        height: parent.height;
        color: root.tone == "success" ? Theme.secondary : root.tone == "error" ? Theme.error : root.tone == "warning" ? Theme.tertiary : Theme.on_surface_variant;
        font-family: "JetBrains Mono";
        font-size: 11px;
        font-weight: 800;
        horizontal-alignment: center;
        vertical-alignment: center;
        overflow: elide;
    }
}

component DocNavLine inherits Rectangle {
    in property <string> label;
    in property <string> method;
    in property <bool> selected;
    callback picked();

    height: 34px;
    horizontal-stretch: 1;
    border-radius: 6px;
    border-width: root.selected ? 1px : 0px;
    border-color: Theme.primary;
    background: root.selected ? Theme.surface_variant : touch.has-hover ? Theme.surface_container_high : transparent;

    touch := TouchArea {
        mouse-cursor: pointer;
        clicked => {
            root.picked();
        }
    }

    UiText {
        x: 10px;
        text: root.label;
        width: parent.width - 72px;
        height: parent.height;
        color: root.selected ? Theme.primary : Theme.on_surface_variant;
        font-size: 12px;
        font-weight: root.selected ? 800 : 600;
        vertical-alignment: center;
        overflow: elide;
    }

    UiText {
        x: parent.width - 54px;
        text: root.method;
        width: 44px;
        height: parent.height;
        color: root.method == "POST" ? Theme.secondary : root.method == "DELETE" ? Theme.error : root.method == "PUT" ? Theme.tertiary : Theme.primary;
        font-family: "JetBrains Mono";
        font-size: 10px;
        font-weight: 800;
        horizontal-alignment: right;
        vertical-alignment: center;
        overflow: elide;
    }
}

component KeyCard inherits Rectangle {
    in property <string> title;
    in property <string> token;
    in property <string> meta;
    in property <bool> selected;

    height: 92px;
    horizontal-stretch: 1;
    border-radius: 8px;
    border-width: 1px;
    border-color: root.selected ? Theme.primary_container : Theme.outline_variant;
    background: root.selected ? Theme.surface_container_high : Theme.surface_container;

    VerticalLayout {
        padding: 12px;
        spacing: 6px;

        UiText {
            text: root.title;
            height: 22px;
            horizontal-stretch: 1;
            color: Theme.on_surface;
            font-size: 15px;
            font-weight: 800;
            vertical-alignment: center;
            overflow: elide;
        }

        UiText {
            text: root.token;
            height: 18px;
            horizontal-stretch: 1;
            color: Theme.on_surface_variant;
            font-family: "JetBrains Mono";
            font-size: 12px;
            vertical-alignment: center;
            overflow: elide;
        }

        UiText {
            text: root.meta;
            height: 18px;
            horizontal-stretch: 1;
            color: Theme.outline;
            font-size: 11px;
            vertical-alignment: center;
            overflow: elide;
        }
    }
}

component DocumentationPage inherits Rectangle {
    in property <[RouteRow]> routes;
    in-out property <int> selected_route;
    in property <string> method;
    in-out property <string> url;
    in property <string> auth_mode;
    in property <bool> busy;
    callback select_route(int);
    callback send_request();
    property <string> sample_language: "curl";
    property <string> sample_url: root.url == "" ? "<request-url>" : root.url;
    property <string> auth_hint: root.auth_mode == "bearer" ? "Authorization: Bearer <configured-token>" : root.auth_mode == "jwt" ? "Authorization: Bearer <configured-jwt>" : root.auth_mode == "basic" ? "Authorization: Basic <base64-credentials>" : root.auth_mode == "api-header" ? "<configured-header>: <configured-value>" : "";
    property <string> auth_header_pair: root.auth_mode == "bearer" ? "\"Authorization\": \"Bearer <configured-token>\"" : root.auth_mode == "jwt" ? "\"Authorization\": \"Bearer <configured-jwt>\"" : root.auth_mode == "basic" ? "\"Authorization\": \"Basic <base64-credentials>\"" : root.auth_mode == "api-header" ? "\"<configured-header>\": \"<configured-value>\"" : "";
    property <bool> has_header_auth: root.auth_hint != "";
    property <string> sample_code: root.sample_language == "python"
        ? (root.auth_mode == "api-query"
                ? "import requests\n\nresponse = requests.request(\n    \"" + root.method + "\",\n    \"" + root.sample_url + "\",\n    params={\"<configured-key>\": \"<configured-value>\"},\n)\nprint(response.text)"
            : root.has_header_auth
                ? "import requests\n\nresponse = requests.request(\n    \"" + root.method + "\",\n    \"" + root.sample_url + "\",\n    headers={" + root.auth_header_pair + "},\n)\nprint(response.text)"
                : "import requests\n\nresponse = requests.request(\"" + root.method + "\", \"" + root.sample_url + "\")\nprint(response.text)")
        : root.sample_language == "node"
            ? (root.auth_mode == "api-query"
                ? "const response = await fetch(\"" + root.sample_url + "?<configured-key>=<configured-value>\", {\n  method: \"" + root.method + "\"\n});\n\nconsole.log(await response.text());"
                : root.has_header_auth
                    ? "const response = await fetch(\"" + root.sample_url + "\", {\n  method: \"" + root.method + "\",\n  headers: { " + root.auth_header_pair + " }\n});\n\nconsole.log(await response.text());"
                    : "const response = await fetch(\"" + root.sample_url + "\", {\n  method: \"" + root.method + "\"\n});\n\nconsole.log(await response.text());")
            : root.auth_mode == "api-query"
                ? "curl -X " + root.method + " \"" + root.sample_url + "?<configured-key>=<configured-value>\""
                : root.has_header_auth
                    ? "curl -X " + root.method + " \"" + root.sample_url + "\" \\\n  -H \"" + root.auth_hint + "\""
                    : "curl -X " + root.method + " \"" + root.sample_url + "\"";

    horizontal-stretch: 1;
    vertical-stretch: 1;
    background: Theme.background;

    HorizontalLayout {
        spacing: 0px;

        Rectangle {
            width: 280px;
            vertical-stretch: 1;
            background: Theme.surface_container_low;

            VerticalLayout {
                padding: 16px;
                spacing: 12px;

                UiText {
                    text: "ENDPOINTS";
                    height: 20px;
                    horizontal-stretch: 1;
                    color: Theme.on_surface_variant;
                    font-size: 12px;
                    font-weight: 800;
                    vertical-alignment: center;
                    overflow: elide;
                }

                if root.routes.length == 0: DataPanel {
                    title: "No Endpoints";
                    body: "Import an OpenAPI document to populate API Docs.";
                }

                if root.routes.length != 0: ListView {
                    horizontal-stretch: 1;
                    vertical-stretch: 1;
                    vertical-scrollbar-policy: ScrollBarPolicy.as-needed;
                    horizontal-scrollbar-policy: ScrollBarPolicy.as-needed;

                    for route[i] in root.routes: DocNavLine {
                        label: route.summary == "" ? route.path : route.summary;
                        method: route.method;
                        selected: root.selected_route == i;
                        picked => {
                            root.selected_route = i;
                            root.select_route(i);
                        }
                    }
                }
            }
        }

        Rectangle {
            width: 1px;
            background: Theme.outline_variant;
        }

        Rectangle {
            horizontal-stretch: 1;
            vertical-stretch: 1;
            background: Theme.surface;

            VerticalLayout {
                padding: 28px;
                spacing: 18px;

                PageTitle {
                    title: root.method + " Endpoint";
                    subtitle: "Detailed endpoint reference, parameters, and response shape.";
                }

                DataPanel {
                    title: "Endpoint";
                    body: root.url == "" ? "No request URL selected." : root.method + " " + root.url;
                }

                HorizontalLayout {
                    height: 164px;
                    spacing: 16px;

                    DataPanel {
                        title: "Path Parameters";
                        body: root.routes.length == 0 ? "Import an OpenAPI document to inspect endpoint parameters." : "Parameter details are derived from the imported spec when available.";
                    }

                    DataPanel {
                        title: "Query Parameters";
                        body: root.routes.length == 0 ? "No query parameters available." : "Use the Request Params tab to edit query values before executing.";
                    }
                }

                DataPanel {
                    title: "Returns";
                    body: root.routes.length == 0 ? "No response schema available." : "Response examples and schemas are available in imported route metadata when supported.";
                }
            }
        }

        Rectangle {
            width: 400px;
            vertical-stretch: 1;
            background: Theme.surface_container_lowest;

            VerticalLayout {
                padding: 16px;
                spacing: 12px;

                HorizontalLayout {
                    height: 30px;
                    spacing: 8px;

                    BodyModeButton {
                        mode: "curl";
                        label: "cURL";
                        selected: root.sample_language == "curl";
                        picked(mode) => {
                            root.sample_language = mode;
                        }
                    }

                    BodyModeButton {
                        mode: "python";
                        label: "Python";
                        selected: root.sample_language == "python";
                        button_width: 84px;
                        picked(mode) => {
                            root.sample_language = mode;
                        }
                    }

                    BodyModeButton {
                        mode: "node";
                        label: "Node.js";
                        selected: root.sample_language == "node";
                        button_width: 84px;
                        picked(mode) => {
                            root.sample_language = mode;
                        }
                    }
                }

                ReadOnlyCodeBlock {
                    height: 144px;
                    text: root.sample_code;
                }

                DataPanel {
                    title: "Response";
                    body: root.routes.length == 0 ? "Import an OpenAPI document, then execute a request to inspect responses." : "Execute the selected request to inspect the live response in the Response pane.";
                }

                UiText {
                    text: "TRY IT OUT";
                    height: 20px;
                    horizontal-stretch: 1;
                    color: Theme.on_surface_variant;
                    font-size: 12px;
                    font-weight: 800;
                    vertical-alignment: center;
                    overflow: elide;
                }

                TextField {
                    text <=> root.url;
                    placeholder: "Request URL";
                    mono: true;
                    enabled: !root.busy;
                }

                ActionButton {
                    text: "Execute Request";
                    primary: true;
                    button_width: 368px;
                    enabled: !root.busy;
                    clicked => {
                        root.send_request();
                    }
                }
            }
        }
    }
}

component ApiKeysPage inherits Rectangle {
    in property <string> auth_mode;
    in property <string> auth_config;
    in property <string> auth_basic_username;
    in property <[KeyValueTableRow]> auth_key_rows;
    in property <string> url;

    property <bool> has_auth: root.auth_mode != "none" && (root.auth_config != "" || root.auth_key_rows.length > 0 || root.auth_basic_username != "");
    property <string> mode_title: root.auth_mode == "bearer" ? "Bearer Token" : root.auth_mode == "jwt" ? "JWT Bearer" : root.auth_mode == "basic" ? "Basic Auth" : root.auth_mode == "api-header" ? "API Key Header" : root.auth_mode == "api-query" ? "API Key Query" : "No Auth";
    property <string> mode_summary: root.auth_mode == "api-header" ? root.auth_key_rows.length + " header row(s) configured" : root.auth_mode == "api-query" ? root.auth_key_rows.length + " query row(s) configured" : root.auth_mode == "basic" ? (root.auth_basic_username == "" ? "Username/password not configured" : "Username configured; password hidden") : root.has_auth ? "Credential value configured; secret hidden" : "No request auth configured";
    property <string> target_url: root.url == "" ? "<request-url>" : root.url;
    property <string> integration_hint: root.auth_mode == "bearer" ? "Authorization: Bearer <configured-token>" : root.auth_mode == "jwt" ? "Authorization: Bearer <configured-jwt>" : root.auth_mode == "basic" ? "Authorization: Basic <base64-credentials>" : root.auth_mode == "api-header" ? "Configured API key rows are merged into request headers." : root.auth_mode == "api-query" ? "Configured API key rows are merged into request query parameters." : "Requests are sent without generated authorization credentials.";
    property <string> curl_hint: root.auth_mode == "bearer" || root.auth_mode == "jwt" ? "curl \"" + root.target_url + "\" \\\n  -H \"" + root.integration_hint + "\"" : root.auth_mode == "basic" ? "curl \"" + root.target_url + "\" \\\n  -H \"Authorization: Basic <base64-credentials>\"" : root.auth_mode == "api-header" ? "curl \"" + root.target_url + "\" \\\n  -H \"<configured-header>: <configured-value>\"" : root.auth_mode == "api-query" ? "curl \"" + root.target_url + "?<configured-key>=<configured-value>\"" : "curl \"" + root.target_url + "\"";

    horizontal-stretch: 1;
    vertical-stretch: 1;
    background: Theme.background;

    HorizontalLayout {
        spacing: 0px;

        Rectangle {
            width: 280px;
            vertical-stretch: 1;
            background: Theme.surface_container_low;

            VerticalLayout {
                padding: 16px;
                spacing: 12px;

                PageTitle {
                    title: "Request Auth";
                    subtitle: "Current request credentials";
                }

                KeyCard {
                    title: root.mode_title;
                    token: root.has_auth ? root.mode_summary : "No credential material stored for this request.";
                    meta: "Source: Request / Auth tab";
                    selected: true;
                }

                if root.auth_mode == "api-header" || root.auth_mode == "api-query": DataPanel {
                    title: "Configured Rows";
                    body: root.auth_key_rows.length == 0 ? "No key rows configured." : root.auth_key_rows.length + " row(s) will be merged into the request.";
                }

                if root.auth_mode == "basic": DataPanel {
                    title: "Basic Username";
                    body: root.auth_basic_username == "" ? "No username configured." : root.auth_basic_username;
                }
            }
        }

        Rectangle { width: 1px; background: Theme.outline_variant; }

        Rectangle {
            horizontal-stretch: 1;
            vertical-stretch: 1;
            background: Theme.surface;

            VerticalLayout {
                padding: 28px;
                spacing: 18px;

                HorizontalLayout {
                    height: 58px;
                    spacing: 12px;

                    PageTitle {
                        title: root.mode_title;
                        subtitle: root.has_auth ? "Configured in the active request." : "No auth mode is active.";
                    }

                    Badge {
                        text: root.has_auth ? "ACTIVE" : "EMPTY";
                        tone: root.has_auth ? "success" : "neutral";
                        badge_width: 74px;
                    }
                }

                DataPanel {
                    title: "Credential Material";
                    body: root.has_auth ? root.mode_summary + "\nSecret values are hidden in this overview." : "Choose an auth mode in Request / Auth to populate this overview.";
                }

                HorizontalLayout {
                    height: 148px;
                    spacing: 16px;

                    DataPanel {
                        title: "Transport Mapping";
                        body: root.integration_hint;
                    }

                    DataPanel {
                        title: "Target Request";
                        body: root.target_url;
                    }
                }

                DataPanel {
                    title: "Settings";
                    body: "This page mirrors the active request auth configuration. Key rotation, scopes, and server-side key management are not implemented in the local Slint app.";
                }
            }
        }

        Rectangle {
            width: 320px;
            vertical-stretch: 1;
            background: Theme.surface_container_lowest;

            VerticalLayout {
                padding: 16px;
                spacing: 12px;

                UiText {
                    text: "INTEGRATION";
                    height: 22px;
                    horizontal-stretch: 1;
                    color: Theme.on_surface;
                    font-size: 13px;
                    font-weight: 800;
                    vertical-alignment: center;
                    overflow: elide;
                }

                UiText {
                    text: root.has_auth ? "Equivalent request auth mapping." : "No auth headers or query values will be generated.";
                    height: 36px;
                    horizontal-stretch: 1;
                    color: Theme.on_surface_variant;
                    font-size: 12px;
                    vertical-alignment: top;
                    overflow: elide;
                }

                ReadOnlyCodeBlock {
                    text: root.curl_hint;
                }

                ReadOnlyCodeBlock {
                    text: root.integration_hint;
                }
            }
        }
    }
}

component TeamPage inherits Rectangle {
