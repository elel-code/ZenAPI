component RunnerPage inherits Rectangle {
    in-out property <[CollectionRow]> collection_rows;
    in-out property <[RunnerRow]> runner_rows;
    in-out property <string> runner_summary;
    in-out property <string> runner_delay_ms;
    in-out property <string> runner_report_path;
    in-out property <string> runner_report_format;
    in-out property <bool> runner_stop_on_failure;
    in-out property <bool> runner_active;
    in property <bool> busy;
    callback run_collection();
    callback cancel_collection_run();
    callback save_runner_report(string);

    horizontal-stretch: 1;
    vertical-stretch: 1;
    background: Theme.background;

    HorizontalLayout {
        spacing: 0px;

        Rectangle {
            width: 300px;
            vertical-stretch: 1;
            background: Theme.surface_container;

            VerticalLayout {
                padding: 16px;
                spacing: 10px;

                UiText {
                    text: "Test Collections";
                    height: 32px;
                    horizontal-stretch: 1;
                    color: Theme.on_surface;
                    font-size: 18px;
                    font-weight: 800;
                    vertical-alignment: center;
                    overflow: elide;
                }

                if root.collection_rows.length == 0: DataPanel {
                    title: "No collection";
                    body: "Save requests before running a suite.";
                }

                if root.collection_rows.length != 0: ListView {
                    horizontal-stretch: 1;
                    vertical-stretch: 1;
                    vertical-scrollbar-policy: ScrollBarPolicy.as-needed;
                    horizontal-scrollbar-policy: ScrollBarPolicy.as-needed;

                    for entry in root.collection_rows: Rectangle {
                        height: entry.is_folder ? 36px : 30px;
                        horizontal-stretch: 1;
                        background: transparent;

                        if entry.is_folder: SidebarFolderRow {
                            label: entry.name;
                            selected: false;
                        }

                        if !entry.is_folder: SidebarRequestLink {
                            method: entry.method;
                            label: entry.name;
                        }
                    }
                }
            }
        }

        Rectangle {
            width: 1px;
            background: Theme.outline_variant;
        }

        Rectangle {
            horizontal-stretch: 1;
            vertical-stretch: 1;
            background: Theme.surface;

            VerticalLayout {
                padding: 20px;
                spacing: 16px;

                PageTitle {
                    title: "Automated Test Suite";
                    subtitle: root.runner_summary == "" ? "No runner results yet." : root.runner_summary;
                }

                HorizontalLayout {
                    height: 38px;
                    spacing: 10px;

                    BodyModeButton {
                        mode: "continue";
                        label: "continue";
                        button_width: 90px;
                        selected: !root.runner_stop_on_failure;
                        enabled: !root.busy && !root.runner_active;
                        picked(mode) => {
                            root.runner_stop_on_failure = false;
                        }
                    }

                    BodyModeButton {
                        mode: "stop";
                        label: "stop fail";
                        button_width: 90px;
                        selected: root.runner_stop_on_failure;
                        enabled: !root.busy && !root.runner_active;
                        picked(mode) => {
                            root.runner_stop_on_failure = true;
                        }
                    }

                    TextField {
                        text <=> root.runner_delay_ms;
                        placeholder: "Delay ms";
                        mono: true;
                        enabled: !root.busy && !root.runner_active;
                        width: 110px;
                        height: 38px;
                    }

                    ActionButton {
                        text: "Run Suite";
                        button_width: 104px;
                        primary: true;
                        enabled: !root.busy && !root.runner_active;
                        clicked => {
                            root.run_collection();
                        }
                    }

                    ActionButton {
                        text: "Cancel";
                        button_width: 82px;
                        warning: true;
                        enabled: root.runner_active;
                        clicked => {
                            root.cancel_collection_run();
                        }
                    }
                }

                if root.runner_rows.length == 0: DataPanel {
                    title: "Results";
                    body: "Run a collection to populate request results.";
                }

                if root.runner_rows.length != 0: ListView {
                    horizontal-stretch: 1;
                    vertical-stretch: 1;
                    vertical-scrollbar-policy: ScrollBarPolicy.as-needed;
                    horizontal-scrollbar-policy: ScrollBarPolicy.as-needed;

                    for result in root.runner_rows: RunnerResultLine {
                        method: result.method;
                        name: result.name;
                        status: result.status;
                        detail: result.detail;
                        tone: result.tone;
                    }
                }
            }
        }

        Rectangle {
            width: 320px;
            vertical-stretch: 1;
            background: Theme.surface_container_lowest;

            VerticalLayout {
                padding: 16px;
                spacing: 12px;

                UiText {
                    text: "REPORT";
                    height: 24px;
                    horizontal-stretch: 1;
                    color: Theme.on_surface;
                    font-size: 13px;
                    font-weight: 800;
                    vertical-alignment: center;
                    overflow: elide;
                }

                LabeledEditor {
                    label: "Summary";
                    text <=> root.runner_summary;
                    read_only: true;
                }

                HorizontalLayout {
                    height: 30px;
                    spacing: 8px;

                    BodyModeButton {
                        mode: "text";
                        label: "Text";
                        button_width: 68px;
                        selected: root.runner_report_format == "text";
                        enabled: !root.busy && !root.runner_active;
                        picked(mode) => {
                            root.runner_report_format = mode;
                        }
                    }

                    BodyModeButton {
                        mode: "json";
                        label: "JSON";
                        button_width: 68px;
                        selected: root.runner_report_format == "json";
                        enabled: !root.busy && !root.runner_active;
                        picked(mode) => {
                            root.runner_report_format = mode;
                        }
                    }
                }

                HorizontalLayout {
                    height: 34px;
                    spacing: 8px;

                    TextField {
                        text <=> root.runner_report_path;
                        placeholder: root.runner_report_format == "json" ? "runner-report.json" : "runner-report.txt";
                        mono: true;
                        enabled: !root.busy && !root.runner_active;
                    }

                    ActionButton {
                        text: "Save";
                        button_width: 64px;
                        enabled: !root.busy && !root.runner_active && root.runner_summary != "";
                        clicked => {
                            root.save_runner_report(root.runner_report_path);
                        }
                    }
                }
            }
        }
    }
}

component BottomNavItem inherits Rectangle {
    in property <int> page_index;
    in property <string> label;
    in property <string> glyph;
    in property <bool> selected;
    callback picked(int);

    horizontal-stretch: 1;
    height: 56px;
    background: touch.has-hover ? Theme.surface_container_high : transparent;

    touch := TouchArea {
        mouse-cursor: pointer;
        clicked => {
            root.picked(root.page_index);
        }
    }

    Rectangle {
        x: (parent.width - 44px) / 2;
        y: 6px;
        width: 44px;
        height: 22px;
        border-radius: 8px;
        background: root.selected ? Theme.primary_container : transparent;
    }

    UiText {
        x: 0px;
        y: 6px;
        text: root.glyph;
        width: parent.width;
        height: 22px;
        color: root.selected ? Theme.on_primary_container : Theme.on_surface_variant;
        font-size: 13px;
        font-weight: 800;
        horizontal-alignment: center;
        vertical-alignment: center;
        overflow: elide;
    }

    UiText {
        x: 0px;
        y: 31px;
        text: root.label;
        width: parent.width;
        height: 18px;
        color: root.selected ? Theme.primary : Theme.on_surface_variant;
        font-size: 11px;
        font-weight: root.selected ? 800 : 600;
        horizontal-alignment: center;
        vertical-alignment: center;
        overflow: elide;
    }
}

component BottomNavigation inherits Rectangle {
    in-out property <int> active_page_index;

    height: 56px;
    horizontal-stretch: 1;
    background: Theme.surface_container;

    Rectangle {
        width: parent.width;
        height: 1px;
        background: Theme.outline_variant;
    }

    HorizontalLayout {
        padding: 0px;
        spacing: 0px;

        for item in [
            { page_index: 0, label: "Dashboard", glyph: "D" },
            { page_index: 1, label: "Requests", glyph: "R" },
            { page_index: 2, label: "Mocks", glyph: "M" },
            { page_index: 6, label: "Docs", glyph: "A" },
        ]: BottomNavItem {
            page_index: item.page_index;
            label: item.label;
            glyph: item.glyph;
            selected: root.active_page_index == item.page_index;
            picked(page_index) => {
                if root.active_page_index != page_index {
                    root.active_page_index = page_index;
                }
            }
        }
    }
}

export component AppWindow inherits Window {
    title: "API Architect";
    preferred-width: 1280px;
    preferred-height: 800px;
    min-width: 720px;
    min-height: 560px;
    default-font-family: "Inter";
    default-font-size: 13px;
    default-font-weight: 500;

    in-out property <[RouteRow]> routes;
    in-out property <[CollectionRow]> collection_rows;
    in-out property <[HistoryRow]> history_rows;
    in-out property <[RunnerRow]> runner_rows;
    in-out property <[MockLogRow]> mock_logs;
    in-out property <[MockRuleRow]> mock_rule_rows;
    in-out property <int> selected_route: -1;
    in-out property <int> selected_mock_rule: -1;
    in-out property <string> file_path;
    in-out property <string> spec_label: "";
    in-out property <bool> spec_loaded: false;
    in-out property <string> collection_path;
    in-out property <string> collection_name: "Collection";
    in-out property <string> collection_status: "";
    in-out property <string> method: "GET";
    in-out property <string> url;
    in-out property <string> global_variables: "baseUrl=https://api.example.com";
    in-out property <string> environment_name: "dev";
    in-out property <string> environment_draft_name: "dev";
    in-out property <string> environment_variables: "baseUrl=http://127.0.0.1:8080";
    in-out property <[EnvironmentRow]> environment_rows;
    in-out property <[VariableTableRow]> variable_rows;
    in-out property <string> variables_json_preview: "{}";
    in-out property <string> query_params;
    in-out property <string> query_param_import_path: "";
    in-out property <string> request_headers: "Accept: application/json";
    in-out property <string> header_import_path: "";
    in-out property <string> auth_mode: "none";
    in-out property <string> auth_config;
    in-out property <string> auth_basic_username;
    in-out property <string> auth_basic_password;
    in-out property <[KeyValueTableRow]> auth_key_rows;
    in-out property <string> body_mode: "none";
    in-out property <string> raw_body_subtype: "json";
    in-out property <string> request_body;
    in-out property <[KeyValueTableRow]> body_field_rows;
    in-out property <string> form_file_field: "file";
    in-out property <string> form_file_path: "";
    in-out property <string> graphql_variables: "{}";
    in-out property <string> pre_request_script;
    in-out property <string> request_tests;
    in-out property <[TestAssertionRow]> test_assertion_rows;
    in-out property <string> realtime_mode: "ws";
    in-out property <string> realtime_message: "hello";
    in-out property <string> websocket_message_mode: "text";
    in-out property <string> websocket_protocols: "";
    in-out property <string> websocket_event_history: "";
    in-out property <string> sse_max_events: "3";
    in-out property <string> sse_last_event_id: "";
    in-out property <bool> sse_streaming: false;
    in-out property <string> sse_event_history: "";
    in-out property <string> grpc_endpoint: "http://localhost:50051";
    in-out property <string> grpc_method: "package.Service/Method";
    in-out property <string> grpc_metadata: "";
    in-out property <string> grpc_message: "{}";
    in-out property <string> grpc_method_catalog: "unary package.Service/Method package.Request package.Response";
    in-out property <string> response_status: "Idle";
    in-out property <string> response_meta: "";
    in-out property <string> response_time: "";
    in-out property <string> response_size: "";
    in-out property <string> response_tone: "neutral";
    in-out property <string> response_body: "Import an OpenAPI or Swagger document to begin.";
    in-out property <string> response_raw_body: "Import an OpenAPI or Swagger document to begin.";
    in-out property <string> response_headers: "";
    in-out property <string> response_cookies: "No cookies";
    in-out property <string> folded_response_body: "Import an OpenAPI or Swagger document to begin.";
    in-out property <string> folded_response_raw_body: "Import an OpenAPI or Swagger document to begin.";
    in-out property <string> folded_response_headers: "No headers";
    in-out property <string> folded_response_cookies: "No cookies";
    in-out property <string> codegen_language: "curl";
    in-out property <string> codegen_output: "";
    in-out property <string> codegen_metadata: "No snippet generated";
    in-out property <string> codegen_path: "zenapi-snippet.txt";
    in-out property <string> runner_summary: "";
    in-out property <string> runner_delay_ms: "0";
    in-out property <string> runner_report_path: "zenapi-runner-report.txt";
    in-out property <string> runner_report_format: "text";
    in-out property <bool> runner_stop_on_failure: false;
    in-out property <bool> runner_active: false;
    in-out property <string> route_filter;
    in-out property <string> history_filter;
    in-out property <string> mock_log_filter;
    in-out property <string> mock_log_path: "mock-logs.json";
    in-out property <string> selected_mock_method: "";
    in-out property <string> selected_mock_path: "";
    in-out property <string> selected_mock_summary: "";
    in-out property <string> selected_mock_body: "";
    in-out property <string> selected_mock_rule_source: "header";
    in-out property <string> selected_mock_rule_name: "";
    in-out property <string> selected_mock_rule_value: "";
    in-out property <string> selected_mock_rule_body: "{\n  \n}";
    in-out property <[KeyValueTableRow]> query_param_rows;
    in-out property <[KeyValueTableRow]> header_rows;
    in-out property <int> total_route_count: 0;
    in-out property <int> selected_collection_request: -1;
    in-out property <string> selected_collection_folder: "";
    in-out property <string> collection_move_target_label: "Collection";
    in-out property <string> collection_request_name: "";
    in-out property <string> collection_folder_name: "";
    in-out property <string> server_status: "Stopped";
    in-out property <bool> server_running: false;
    in-out property <bool> busy: false;
    in-out property <string> activity: "";
    in-out property <int> active_page_index: 1;
    property <bool> compact_mode: root.width < 900px;

    callback import_openapi(string);
    callback filter_routes(string);
    callback select_route(int);
    callback select_collection_request(int);
    callback rename_collection_request(int, string);
    callback duplicate_collection_request(int);
    callback delete_collection_request(int);
    callback move_collection_request(int, string);
    callback import_collection(string);
    callback add_collection_folder(string);
    callback save_current_request();
    callback save_collection(string);
    callback export_postman_collection(string);
    callback select_history(int);
    callback filter_history(string);
    callback delete_history(int);
    callback clear_history();
    callback filter_mock_logs(string);
    callback save_mock_logs(string);
    callback clear_mock_logs();
    callback save_mock_response(string);
    callback select_mock_rule(int);
    callback add_mock_rule(string);
    callback save_mock_rule(int, string, string, string, string);
    callback delete_mock_rule(int);
    callback add_query_param();
    callback paste_query_params();
    callback import_query_params(string);
    callback update_query_param_row(int, string, string);
    callback delete_query_param_row(int);
    callback add_header();
    callback paste_headers();
    callback import_headers(string);
    callback update_header_row(int, string, string);
    callback delete_header_row(int);
    callback copy_headers();
    callback auth_mode_changed(string);
    callback update_basic_auth(string, string);
    callback add_auth_key();
    callback update_auth_key_row(int, string, string);
    callback delete_auth_key_row(int);
    callback body_mode_changed(string);
    callback add_body_field();
    callback add_body_file_field(string, string);
    callback update_body_field_row(int, string, string);
    callback delete_body_field_row(int);
    callback add_test_assertion();
    callback add_test_assertion_template(string);
    callback add_custom_test_assertion(string, string, string);
    callback update_test_assertion_row(int, string, string, string);
    callback cycle_test_assertion_kind(int, string);
    callback delete_test_assertion_row(int);
    callback send_request();
    callback toggle_server();
    callback generate_code();
    callback copy_codegen();
    callback save_codegen(string);
    callback run_collection();
    callback cancel_collection_run();
    callback save_runner_report(string);
    callback copy_response(string, string, int, int);
    callback format_response(string);
    callback summarize_graphql_schema(string, string);
    callback open_websocket();
    callback run_websocket();
    callback close_websocket();
    callback copy_websocket_events();
    callback clear_websocket_events();
    callback run_sse();
    callback open_sse_stream();
    callback close_sse_stream();
    callback copy_sse_events();
    callback clear_sse_events();
    callback select_environment(string);
    callback environment_name_changed(string);
    callback add_environment(string);
    callback rename_environment(string, string);
    callback move_environment(string, int);
    callback delete_environment(string);
    callback update_variable_row(int, string, string, string);
    callback add_variable(string);
    callback delete_variable_row(int, string);
    callback apply_graphql_template(string);
    callback apply_header_preset(string);
    callback build_grpc_draft();

    background: Theme.background;

    VerticalLayout {
        padding: 0px;
        spacing: 0px;

        Rectangle {
            horizontal-stretch: 1;
            vertical-stretch: 1;
            background: Theme.background;
            clip: true;

            AppNavigation {
                x: 0px;
                y: 0px;
                height: parent.height;
                visible: !root.compact_mode;
                active_page_index <=> root.active_page_index;
                spec_label: root.spec_label;
                spec_loaded: root.spec_loaded;
            }

            Rectangle {
                x: 240px;
                y: 0px;
                width: 1px;
                height: parent.height;
                visible: !root.compact_mode;
                background: Theme.outline_variant;
            }

            Rectangle {
                x: root.compact_mode ? 0px : 241px;
                y: 0px;
                width: root.compact_mode ? parent.width : parent.width - 241px;
                height: root.compact_mode ? parent.height - 56px : parent.height;
                background: Theme.background;
                clip: true;

                ScrollView {
                    width: parent.width;
                    height: parent.height;
                    visible: root.active_page_index == 1;
                    viewport-width: max(self.visible-width, 1240px);
                    viewport-height: max(self.visible-height, 560px);
                    vertical-scrollbar-policy: ScrollBarPolicy.as-needed;
                    horizontal-scrollbar-policy: ScrollBarPolicy.as-needed;

                    HorizontalLayout {
                        width: max(parent.visible-width, 1240px);
                        height: max(parent.visible-height, 560px);
                        spacing: 0px;

                        Sidebar {
                            routes <=> root.routes;
                            collection_rows <=> root.collection_rows;
                            history_rows <=> root.history_rows;
                            mock_logs <=> root.mock_logs;
                            selected_route <=> root.selected_route;
                            route_filter <=> root.route_filter;
                            history_filter <=> root.history_filter;
                            mock_log_filter <=> root.mock_log_filter;
                            mock_log_path <=> root.mock_log_path;
                            collection_path <=> root.collection_path;
                            selected_collection_request <=> root.selected_collection_request;
                            selected_collection_folder <=> root.selected_collection_folder;
                            collection_move_target_label <=> root.collection_move_target_label;
                            collection_request_name <=> root.collection_request_name;
                            collection_folder_name <=> root.collection_folder_name;
                            collection_name <=> root.collection_name;
                            collection_status <=> root.collection_status;
                            file_path <=> root.file_path;
                            spec_label: root.spec_label;
                            spec_loaded: root.spec_loaded;
                            total_route_count: root.total_route_count;
                            busy: root.busy;
                            import_openapi(path) => {
                                root.import_openapi(path);
                            }
                            filter_routes(query) => {
                                root.filter_routes(query);
                            }
                            select_route(index) => {
                                root.select_route(index);
                            }
                            select_collection_request(id) => {
                                root.select_collection_request(id);
                            }
                            rename_collection_request(id, name) => {
                                root.rename_collection_request(id, name);
                            }
                            duplicate_collection_request(id) => {
                                root.duplicate_collection_request(id);
                            }
                            delete_collection_request(id) => {
                                root.delete_collection_request(id);
                            }
                            move_collection_request(id, folder_path) => {
                                root.move_collection_request(id, folder_path);
                            }
                            import_collection(path) => {
                                root.import_collection(path);
                            }
                            add_collection_folder(name) => {
                                root.add_collection_folder(name);
                            }
                            save_current_request => {
                                root.save_current_request();
                            }
                            save_collection(path) => {
                                root.save_collection(path);
                            }
                            export_postman_collection(path) => {
                                root.export_postman_collection(path);
                            }
                            select_history(id) => {
                                root.select_history(id);
                            }
                            filter_history(query) => {
                                root.filter_history(query);
                            }
                            delete_history(id) => {
                                root.delete_history(id);
                            }
                            clear_history => {
                                root.clear_history();
                            }
                            filter_mock_logs(query) => {
                                root.filter_mock_logs(query);
                            }
                            save_mock_logs(path) => {
                                root.save_mock_logs(path);
                            }
                            clear_mock_logs => {
                                root.clear_mock_logs();
                            }
                        }

                        Rectangle {
                            width: 1px;
                            background: Theme.outline_variant;
                        }

                        Rectangle {
                            width: max(560px, parent.width - 642px);
                            vertical-stretch: 1;
                            background: Theme.surface_container_lowest;
                            clip: true;

                            VerticalLayout {
                                padding: 0px;
                                spacing: 0px;

                                AddressBar {
                                    method <=> root.method;
                                    url <=> root.url;
                                    request_name: root.collection_request_name;
                                    collection_name: root.collection_name;
                                    busy: root.busy;
                                    send_request => {
                                        root.send_request();
                                    }
                                }

                                RequestPanel {
                                    global_variables <=> root.global_variables;
                                    environment_name <=> root.environment_name;
                                    environment_variables <=> root.environment_variables;
                                    query_params <=> root.query_params;
                                    query_param_rows <=> root.query_param_rows;
                                    query_param_import_path <=> root.query_param_import_path;
                                    request_headers <=> root.request_headers;
                                    header_rows <=> root.header_rows;
                                    header_import_path <=> root.header_import_path;
                                    auth_mode <=> root.auth_mode;
                                    auth_config <=> root.auth_config;
                                    auth_basic_username <=> root.auth_basic_username;
                                    auth_basic_password <=> root.auth_basic_password;
                                    auth_key_rows <=> root.auth_key_rows;
                                    body_mode <=> root.body_mode;
                                    raw_body_subtype <=> root.raw_body_subtype;
                                    request_body <=> root.request_body;
                                    body_field_rows <=> root.body_field_rows;
                                    form_file_field <=> root.form_file_field;
                                    form_file_path <=> root.form_file_path;
                                    graphql_variables <=> root.graphql_variables;
                                    pre_request_script <=> root.pre_request_script;
                                    request_tests <=> root.request_tests;
                                    test_assertion_rows <=> root.test_assertion_rows;
                                    realtime_mode <=> root.realtime_mode;
                                    realtime_message <=> root.realtime_message;
                                    websocket_message_mode <=> root.websocket_message_mode;
                                    websocket_protocols <=> root.websocket_protocols;
                                    websocket_event_history <=> root.websocket_event_history;
                                    sse_max_events <=> root.sse_max_events;
                                    sse_last_event_id <=> root.sse_last_event_id;
                                    sse_streaming <=> root.sse_streaming;
                                    sse_event_history <=> root.sse_event_history;
                                    grpc_endpoint <=> root.grpc_endpoint;
                                    grpc_method <=> root.grpc_method;
                                    grpc_metadata <=> root.grpc_metadata;
                                    grpc_message <=> root.grpc_message;
                                    grpc_method_catalog <=> root.grpc_method_catalog;
                                    busy: root.busy;
                                    add_query_param => {
                                        root.add_query_param();
                                    }
                                    paste_query_params => {
                                        root.paste_query_params();
                                    }
                                    import_query_params(path) => {
