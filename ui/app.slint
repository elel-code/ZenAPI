    UiText {
        x: 38px;
        text: root.label;
        width: parent.width - 38px;
        height: parent.height;
        color: Theme.on_surface_variant;
        font-size: 12px;
        overflow: elide;
        vertical-alignment: center;
    }
}

component Sidebar inherits Rectangle {
    in-out property <[RouteRow]> routes;
    in-out property <[CollectionRow]> collection_rows;
    in-out property <[HistoryRow]> history_rows;
    in-out property <[MockLogRow]> mock_logs;
    in-out property <int> selected_route;
    in-out property <string> route_filter;
    in-out property <string> history_filter;
    in-out property <string> mock_log_filter;
    in-out property <string> mock_log_path;
    in-out property <string> collection_path;
    in-out property <int> selected_collection_request;
    in-out property <string> selected_collection_folder;
    in-out property <string> collection_move_target_label;
    in-out property <string> collection_request_name;
    in-out property <string> collection_folder_name;
    in-out property <string> collection_name;
    in-out property <string> collection_status;
    in-out property <string> file_path;
    in property <string> spec_label;
    in property <bool> spec_loaded;
    in property <int> total_route_count;
    in property <bool> busy;
    callback import_openapi(string);
    callback select_route(int);
    callback select_collection_request(int);
    callback rename_collection_request(int, string);
    callback duplicate_collection_request(int);
    callback delete_collection_request(int);
    callback move_collection_request(int, string);
    callback import_collection(string);
    callback add_collection_folder(string);
    callback save_current_request();
    callback save_collection(string);
    callback export_postman_collection(string);
    callback select_history(int);
    callback filter_history(string);
    callback delete_history(int);
    callback clear_history();
    callback filter_mock_logs(string);
    callback save_mock_logs(string);
    callback clear_mock_logs();
    callback filter_routes(string);

    width: 240px;
    vertical-stretch: 1;
    background: Theme.surface_container_low;

    VerticalLayout {
        padding: 16px;
        spacing: 14px;

        SidebarProfile {
            title: root.spec_loaded ? root.spec_label : "Workspace";
            subtitle: root.spec_loaded ? "OpenAPI imported" : "No OpenAPI loaded";
        }

        Rectangle {
            height: 72px;
            horizontal-stretch: 1;
            background: transparent;

            VerticalLayout {
                padding: 0px;
                spacing: 8px;

                UiText {
                    text: "OPENAPI";
                    height: 18px;
                    horizontal-stretch: 1;
                    color: Theme.on_surface_variant;
                    font-size: 12px;
                    font-weight: 800;
                    vertical-alignment: center;
                    overflow: elide;
                }

                HorizontalLayout {
                    height: 36px;
                    spacing: 8px;
                    alignment: center;

                    TextField {
                        text <=> root.file_path;
                        placeholder: "spec path";
                        mono: true;
                        enabled: !root.busy;
                        horizontal-stretch: 1;
                        accepted => {
                            if !root.busy && root.file_path != "" {
                                root.import_openapi(root.file_path);
                            }
                        }
                    }

                    ActionButton {
                        text: "Import";
                        primary: true;
                        enabled: !root.busy && root.file_path != "";
                        button_width: 66px;
                        clicked => {
                            root.import_openapi(root.file_path);
                        }
                    }
                }
            }
        }

        Rectangle {
            horizontal-stretch: 1;
            vertical-stretch: 1;
            background: transparent;

            VerticalLayout {
                padding: 0px;
                spacing: 8px;

                HorizontalLayout {
                    height: 24px;
                    spacing: 8px;
                    alignment: center;

                    UiText {
                        text: "COLLECTIONS";
                        horizontal-stretch: 1;
                        height: parent.height;
                        color: Theme.on_surface_variant;
                        font-size: 12px;
                        font-weight: 800;
                        vertical-alignment: center;
                        overflow: elide;
                    }

                    ActionButton {
                        text: "+";
                        button_width: 30px;
                        enabled: !root.busy;
                        clicked => {
                            root.save_current_request();
                        }
                    }
                }

                SidebarFolderRow {
                    label: root.collection_name == "" ? "Collection" : root.collection_name;
                    selected: root.selected_collection_folder == "" && root.selected_collection_request < 0;
                    interactive: true;
                    picked => {
                        root.selected_collection_folder = "";
                        root.collection_move_target_label = root.collection_name == "" ? "Collection" : root.collection_name;
                        root.selected_collection_request = -1;
                        root.collection_request_name = "";
                    }
                }

                HorizontalLayout {
                    height: 34px;
                    spacing: 8px;
                    alignment: center;

                    TextField {
                        text <=> root.collection_folder_name;
                        placeholder: "folder name";
                        enabled: !root.busy;
                        horizontal-stretch: 1;
                        accepted => {
                            if !root.busy && root.collection_folder_name != "" {
                                root.add_collection_folder(root.collection_folder_name);
                            }
                        }
                    }

                    ActionButton {
                        text: "Folder";
                        button_width: 62px;
                        enabled: !root.busy && root.collection_folder_name != "";
                        clicked => {
                            root.add_collection_folder(root.collection_folder_name);
                        }
                    }
                }

                Rectangle {
                    height: root.collection_rows.length == 0 && root.routes.length == 0 ? 34px : 170px;
                    horizontal-stretch: 1;
                    background: transparent;

                    Rectangle {
                        x: 19px;
                        width: 1px;
                        height: parent.height;
                        background: Theme.outline_variant;
                    }

                    if root.collection_rows.length == 0 && root.routes.length == 0: UiText {
                        x: 32px;
                        text: root.total_route_count == 0 ? "No requests" : "No matching routes";
                        width: parent.width - 32px;
                        height: 30px;
                        color: Theme.outline;
                        font-size: 12px;
                        vertical-alignment: center;
                        overflow: elide;
                    }

                    if root.collection_rows.length != 0: ListView {
                        x: 32px;
                        width: parent.width - 32px;
                        height: parent.height;
                        vertical-scrollbar-policy: ScrollBarPolicy.as-needed;
                        horizontal-scrollbar-policy: ScrollBarPolicy.as-needed;

                        for entry in root.collection_rows: Rectangle {
                            height: entry.is_folder ? 36px : 30px;
                            horizontal-stretch: 1;
                            background: transparent;

                            if entry.is_folder: SidebarFolderRow {
                                label: entry.name;
                                selected: root.selected_collection_folder == entry.folder_path;
                                interactive: true;
                                picked => {
                                    root.selected_collection_folder = entry.folder_path;
                                    root.collection_move_target_label = entry.name;
                                    root.selected_collection_request = -1;
                                    root.collection_request_name = "";
                                }
                            }

                            if !entry.is_folder: SidebarRequestLink {
                                method: entry.method;
                                label: entry.name;
                                selected: root.selected_collection_request == entry.id;
                                picked => {
                                    root.selected_collection_request = entry.id;
                                    root.select_collection_request(entry.id);
                                }
                            }
                        }
                    }

                    if root.collection_rows.length == 0 && root.routes.length != 0: ListView {
                        x: 32px;
                        width: parent.width - 32px;
                        height: parent.height;
                        vertical-scrollbar-policy: ScrollBarPolicy.as-needed;
                        horizontal-scrollbar-policy: ScrollBarPolicy.as-needed;

                        for route[i] in root.routes: SidebarRequestLink {
                            method: route.method;
                            label: route.summary == "" ? route.path : route.summary;
                            selected: root.selected_route == i;
                            picked => {
                                root.selected_route = i;
                                root.select_route(i);
                            }
                        }
                    }
                }

                HorizontalLayout {
                    height: 34px;
                    spacing: 6px;
                    alignment: center;

                    TextField {
                        text <=> root.collection_request_name;
                        placeholder: "request name";
                        enabled: !root.busy && root.selected_collection_request >= 0;
                        horizontal-stretch: 1;
                        accepted => {
                            if !root.busy && root.selected_collection_request >= 0 && root.collection_request_name != "" {
                                root.rename_collection_request(root.selected_collection_request, root.collection_request_name);
                            }
                        }
                    }

                    ActionButton {
                        text: "Ren";
                        button_width: 40px;
                        enabled: !root.busy && root.selected_collection_request >= 0 && root.collection_request_name != "";
                        clicked => {
                            root.rename_collection_request(root.selected_collection_request, root.collection_request_name);
                        }
                    }
                }

                HorizontalLayout {
                    height: 30px;
                    spacing: 6px;
                    alignment: center;

                    UiText {
                        text: "Target: " + root.collection_move_target_label;
                        horizontal-stretch: 1;
                        height: parent.height;
                        color: Theme.outline;
                        font-size: 11px;
                        vertical-alignment: center;
                        overflow: elide;
                    }

                    ActionButton {
                        text: "Move";
                        button_width: 50px;
                        enabled: !root.busy && root.selected_collection_request >= 0;
                        clicked => {
                            root.move_collection_request(root.selected_collection_request, root.selected_collection_folder);
                        }
                    }

                    ActionButton {
                        text: "Dup";
                        button_width: 42px;
                        enabled: !root.busy && root.selected_collection_request >= 0;
                        clicked => {
                            root.duplicate_collection_request(root.selected_collection_request);
                        }
                    }

                    ActionButton {
                        text: "Del";
                        button_width: 40px;
                        warning: true;
                        enabled: !root.busy && root.selected_collection_request >= 0;
                        clicked => {
                            root.delete_collection_request(root.selected_collection_request);
                        }
                    }
                }

            }
        }

        Rectangle {
            height: 112px;
            horizontal-stretch: 1;
            background: transparent;

            VerticalLayout {
                padding: 0px;
                spacing: 8px;

                HorizontalLayout {
                    height: 24px;
                    spacing: 8px;
                    alignment: center;

                    UiText {
                        text: "HISTORY";
                        horizontal-stretch: 1;
                        height: parent.height;
                        color: Theme.on_surface_variant;
                        font-size: 12px;
                        font-weight: 800;
                        vertical-alignment: center;
                        overflow: elide;
                    }

                    ActionButton {
                        text: "...";
                        button_width: 34px;
                        enabled: !root.busy && root.history_rows.length > 0;
                        clicked => {
                            root.clear_history();
                        }
                    }
                }

                if root.history_rows.length == 0: UiText {
                    text: "No requests yet";
                    height: 26px;
                    horizontal-stretch: 1;
                    color: Theme.outline;
                    font-size: 12px;
                    vertical-alignment: center;
                    overflow: elide;
                }

                if root.history_rows.length != 0: ListView {
                    horizontal-stretch: 1;
                    vertical-stretch: 1;
                    vertical-scrollbar-policy: ScrollBarPolicy.as-needed;
                    horizontal-scrollbar-policy: ScrollBarPolicy.as-needed;

                    for entry in root.history_rows: SidebarHistoryLink {
                        method: entry.method;
                        label: entry.url;
                        picked => {
                            root.select_history(entry.id);
                        }
                    }
                }
            }
        }
    }
}

component AppNavItem inherits Rectangle {
    in property <int> page_index;
    in property <string> label;
    in property <string> glyph;
    in property <bool> selected;
    callback picked(int);

    height: 36px;
    horizontal-stretch: 1;
    border-radius: 8px;
    background: root.selected ? Theme.primary_container : touch.has-hover ? Theme.surface_variant : transparent;

    touch := TouchArea {
        mouse-cursor: pointer;
        clicked => {
            root.picked(root.page_index);
        }
    }

    UiText {
        x: 12px;
        text: root.glyph;
        width: 22px;
        height: parent.height;
        color: root.selected ? Theme.on_primary_container : Theme.on_surface_variant;
        font-size: 16px;
        font-weight: 800;
        horizontal-alignment: center;
        vertical-alignment: center;
        overflow: elide;
    }

    UiText {
        x: 46px;
        text: root.label;
        width: parent.width - 58px;
        height: parent.height;
        color: root.selected ? Theme.on_primary_container : Theme.on_surface_variant;
        font-size: 13px;
        font-weight: root.selected ? 800 : 600;
        vertical-alignment: center;
        overflow: elide;
    }
}

component AppNavigation inherits Rectangle {
    in-out property <int> active_page_index;
    in property <string> spec_label;
    in property <bool> spec_loaded;

    width: 240px;
    vertical-stretch: 1;
    background: Theme.surface_container_low;

    nav_scroll := ScrollView {
        width: parent.width;
        height: parent.height;
        viewport-width: self.visible-width;
        viewport-height: max(self.visible-height, 650px);
        vertical-scrollbar-policy: ScrollBarPolicy.as-needed;
        horizontal-scrollbar-policy: ScrollBarPolicy.as-needed;

        Rectangle {
            width: nav_scroll.visible-width;
            height: max(nav_scroll.visible-height, 650px);
            background: transparent;

            VerticalLayout {
                padding: 16px;
                spacing: 12px;

                SidebarProfile {
                    title: root.spec_loaded ? root.spec_label : "Workspace";
                    subtitle: root.spec_loaded ? "OpenAPI imported" : "No OpenAPI loaded";
                }

                Rectangle {
                    height: 1px;
                    horizontal-stretch: 1;
                    background: Theme.outline_variant;
                }

                for item in [
                    { page_index: 0, label: "Dashboard", glyph: "D" },
                    { page_index: 1, label: "Requests", glyph: "R" },
                    { page_index: 2, label: "Mocks", glyph: "M" },
                    { page_index: 3, label: "Test Runner", glyph: "T" },
                    { page_index: 4, label: "Environments", glyph: "E" },
                    { page_index: 5, label: "Traffic Analytics", glyph: "A" },
                ]: AppNavItem {
                    page_index: item.page_index;
                    label: item.label;
                    glyph: item.glyph;
                    selected: root.active_page_index == item.page_index;
                    picked(page_index) => {
                        if root.active_page_index != page_index {
                            root.active_page_index = page_index;
                        }
                    }
                }

                Rectangle {
                    height: 1px;
                    horizontal-stretch: 1;
                    background: Theme.outline_variant;
                }

                for item in [
                    { page_index: 6, label: "API Docs", glyph: "D" },
                    { page_index: 7, label: "API Keys", glyph: "K" },
                    { page_index: 8, label: "Team Members", glyph: "T" },
                    { page_index: 9, label: "Project Settings", glyph: "S" },
                    { page_index: 10, label: "Codegen", glyph: "C" },
                ]: AppNavItem {
                    page_index: item.page_index;
                    label: item.label;
                    glyph: item.glyph;
                    selected: root.active_page_index == item.page_index;
                    picked(page_index) => {
                        if root.active_page_index != page_index {
                            root.active_page_index = page_index;
                        }
                    }
                }

                Rectangle {
                    vertical-stretch: 1;
                }

                UiText {
                    text: "v2.4.0";
                    height: 20px;
                    horizontal-stretch: 1;
                    color: Theme.outline;
                    font-family: "JetBrains Mono";
                    font-size: 12px;
                    vertical-alignment: center;
                    overflow: elide;
                }
            }
        }
    }
}

component PageTitle inherits Rectangle {
    in property <string> title;
    in property <string> subtitle;

    height: 66px;
    horizontal-stretch: 1;
    background: transparent;

    VerticalLayout {
        padding: 0px;
        spacing: 4px;

        UiText {
            text: root.title;
            height: 38px;
            horizontal-stretch: 1;
            color: Theme.on_surface;
            font-size: 32px;
            font-weight: 800;
            vertical-alignment: center;
            overflow: elide;
        }

        UiText {
            text: root.subtitle;
            height: 20px;
            horizontal-stretch: 1;
            color: Theme.on_surface_variant;
            font-size: 14px;
            vertical-alignment: center;
            overflow: elide;
        }
    }
}

component AuthEditorPanel inherits Rectangle {
    in-out property <string> auth_mode;
    in-out property <string> auth_config;
    in-out property <string> auth_basic_username;
    in-out property <string> auth_basic_password;
    in-out property <[KeyValueTableRow]> auth_key_rows;
    in property <bool> busy;
    callback auth_mode_changed(string);
    callback update_basic_auth(string, string);
    callback add_auth_key();
    callback update_auth_key_row(int, string, string);
    callback delete_auth_key_row(int);

    horizontal-stretch: 1;
    vertical-stretch: 1;
    background: transparent;

    VerticalLayout {
        padding: 0px;
        spacing: 12px;

        HorizontalLayout {
            height: 30px;
            spacing: 8px;
            alignment: center;

            for item in [
                { mode: "none", label: "none", width: 64px },
                { mode: "bearer", label: "bearer", width: 78px },
                { mode: "basic", label: "basic", width: 72px },
                { mode: "jwt", label: "jwt", width: 58px },
                { mode: "api-header", label: "api hdr", width: 88px },
                { mode: "api-query", label: "api query", width: 96px },
            ]: BodyModeButton {
                mode: item.mode;
                label: item.label;
                button_width: item.width;
                selected: root.auth_mode == item.mode;
                enabled: !root.busy;
                picked(mode) => {
                    root.auth_mode = mode;
                    root.auth_mode_changed(mode);
                }
            }

            Rectangle {
                horizontal-stretch: 1;
            }
        }

        if root.auth_mode == "none": DataPanel {
            title: "No Authentication";
            body: "Requests are sent without generated Authorization headers or API key query parameters.";
        }

        if root.auth_mode == "bearer": Rectangle {
            height: 92px;
            horizontal-stretch: 1;
            background: transparent;

            VerticalLayout {
                padding: 0px;
                spacing: 8px;

                UiText {
                    text: "Bearer Token";
                    height: 20px;
                    horizontal-stretch: 1;
                    color: Theme.on_surface_variant;
                    font-size: 12px;
                    font-weight: 800;
                    vertical-alignment: center;
                    overflow: elide;
                }

                TextField {
                    text <=> root.auth_config;
                    placeholder: "token or {{token}}";
                    mono: true;
                    enabled: !root.busy;
                }

                UiText {
                    text: "Sends Authorization: Bearer <token>.";
                    height: 18px;
                    horizontal-stretch: 1;
                    color: Theme.outline;
                    font-size: 12px;
                    vertical-alignment: center;
                    overflow: elide;
                }
            }
        }

        if root.auth_mode == "jwt": Rectangle {
            height: 92px;
            horizontal-stretch: 1;
            background: transparent;

            VerticalLayout {
                padding: 0px;
                spacing: 8px;

                UiText {
                    text: "JWT";
                    height: 20px;
                    horizontal-stretch: 1;
                    color: Theme.on_surface_variant;
                    font-size: 12px;
                    font-weight: 800;
                    vertical-alignment: center;
                    overflow: elide;
                }

                TextField {
                    text <=> root.auth_config;
                    placeholder: "eyJhbGciOi...";
                    mono: true;
                    enabled: !root.busy;
                }

                UiText {
                    text: "JWT is sent as Authorization: Bearer <token>.";
                    height: 18px;
                    horizontal-stretch: 1;
                    color: Theme.outline;
                    font-size: 12px;
                    vertical-alignment: center;
                    overflow: elide;
                }
            }
        }

        if root.auth_mode == "basic": Rectangle {
            height: 98px;
            horizontal-stretch: 1;
            background: transparent;

            VerticalLayout {
                padding: 0px;
                spacing: 8px;

                UiText {
                    text: "Basic Credentials";
                    height: 20px;
                    horizontal-stretch: 1;
                    color: Theme.on_surface_variant;
                    font-size: 12px;
                    font-weight: 800;
                    vertical-alignment: center;
                    overflow: elide;
                }

                HorizontalLayout {
                    height: 36px;
                    spacing: 10px;

                    TextField {
                        text <=> root.auth_basic_username;
                        placeholder: "username";
                        mono: true;
                        enabled: !root.busy;
                        edited => {
                            root.update_basic_auth(root.auth_basic_username, root.auth_basic_password);
                        }
                        accepted => {
                            root.update_basic_auth(root.auth_basic_username, root.auth_basic_password);
                        }
                    }

                    TextField {
                        text <=> root.auth_basic_password;
                        placeholder: "password";
                        mono: true;
                        enabled: !root.busy;
                        edited => {
                            root.update_basic_auth(root.auth_basic_username, root.auth_basic_password);
                        }
                        accepted => {
                            root.update_basic_auth(root.auth_basic_username, root.auth_basic_password);
                        }
                    }
                }

                UiText {
                    text: "Saved as username:password and base64 encoded before sending.";
                    height: 18px;
                    horizontal-stretch: 1;
                    color: Theme.outline;
                    font-size: 12px;
                    vertical-alignment: center;
                    overflow: elide;
                }
            }
        }

        if root.auth_mode == "api-header": KeyValueTablePanel {
            rows <=> root.auth_key_rows;
            title: "API Key Header";
            key_header: "Header";
            value_header: "Value";
            helper: "Stored as key=value lines, for example x-api-key={{apiKey}}.";
            busy: root.busy;
            add_row => {
                root.add_auth_key();
            }
            update_row(row_id, key, value) => {
                root.update_auth_key_row(row_id, key, value);
            }
            delete_row(row_id) => {
                root.delete_auth_key_row(row_id);
            }
        }

        if root.auth_mode == "api-query": KeyValueTablePanel {
            rows <=> root.auth_key_rows;
            title: "API Key Query";
            key_header: "Param";
            value_header: "Value";
            helper: "Stored as key=value lines, for example api_key={{apiKey}}.";
            busy: root.busy;
            add_row => {
                root.add_auth_key();
            }
            update_row(row_id, key, value) => {
                root.update_auth_key_row(row_id, key, value);
            }
            delete_row(row_id) => {
                root.delete_auth_key_row(row_id);
            }
        }

    }
}

component SendRequestButton inherits Rectangle {
    in property <bool> enabled: true;
    callback clicked();

    width: 112px;
    height: 40px;
    border-radius: 6px;
    border-width: 1px;
    border-color: root.enabled ? Theme.primary_container : Theme.outline_variant;
    background: !root.enabled ? Theme.surface_container_low : send_touch.pressed ? #3d3fba : send_touch.has-hover ? #5557df : Theme.inverse_primary;
    opacity: root.enabled ? 1 : 0.62;

    send_touch := TouchArea {
        enabled: root.enabled;
        mouse-cursor: root.enabled ? pointer : default;
        clicked => {
            root.clicked();
        }
    }

    UiText {
        x: 22px;
        text: "Send";
        width: 50px;
        height: parent.height;
        color: Theme.on_surface;
        font-size: 13px;
        font-weight: 800;
        horizontal-alignment: center;
        vertical-alignment: center;
        overflow: elide;
    }

    UiText {
        x: parent.width - 34px;
        text: ">";
        width: 16px;
        height: parent.height;
        color: Theme.on_surface;
        font-size: 16px;
        font-weight: 800;
        horizontal-alignment: center;
        vertical-alignment: center;
        overflow: elide;
    }
}

component AddressBar inherits Rectangle {
    in-out property <string> method;
    in-out property <string> url;
    in property <string> request_name;
    in property <string> collection_name;
    in property <bool> busy;
    callback send_request();

    property <string> request_label: root.request_name != "" ? root.request_name : root.url == "" ? "New Request" : root.method + " Request";

    height: 104px;
    horizontal-stretch: 1;
    background: Theme.surface_container_low;

    Rectangle {
        y: parent.height - 1px;
        width: parent.width;
        height: 1px;
        background: Theme.outline_variant;
    }

    VerticalLayout {
        padding: 16px;
        spacing: 8px;

        HorizontalLayout {
            height: 22px;
            spacing: 8px;
            alignment: center;

            UiText {
                text: root.collection_name == "" ? "Collection" : root.collection_name;
                width: 108px;
                height: parent.height;
                color: Theme.on_surface_variant;
                font-size: 14px;
                vertical-alignment: center;
                overflow: elide;
            }

            UiText {
                text: ">";
                width: 10px;
                height: parent.height;
                color: Theme.on_surface_variant;
                font-size: 14px;
                horizontal-alignment: center;
                vertical-alignment: center;
            }

            UiText {
                text: root.request_label;
                horizontal-stretch: 1;
                height: parent.height;
                color: Theme.on_surface;
                font-size: 14px;
                vertical-alignment: center;
                overflow: elide;
            }
        }

        HorizontalLayout {
            height: 40px;
            spacing: 8px;
            alignment: center;

            Rectangle {
                height: 40px;
                horizontal-stretch: 1;
                background: Theme.surface_container;
                border-radius: 6px;
                border-width: 1px;
                border-color: !root.busy && url_field.focused ? Theme.primary : Theme.outline_variant;
                clip: true;

                HorizontalLayout {
                    spacing: 0px;
                    alignment: center;

                    MethodSelector {
                        method <=> root.method;
                        enabled: !root.busy;
                    }

                    Rectangle {
                        width: 1px;
                        height: parent.height - 10px;
                        background: Theme.outline_variant;
                    }

                    url_field := TextField {
                        text <=> root.url;
                        placeholder: "Enter request URL";
                        embedded: true;
                        mono: true;
                        enabled: !root.busy;
                        height: 40px;
                        horizontal-stretch: 1;
                        accepted => {
                            if !root.busy {
                                root.send_request();
                            }
                        }
                    }
                }
            }

            SendRequestButton {
                enabled: !root.busy;
                clicked => {
                    root.send_request();
                }
            }
        }
    }
}

component RequestPanel inherits Rectangle {
    in-out property <string> global_variables;
    in-out property <string> environment_name;
    in-out property <string> environment_variables;
    in-out property <string> query_params;
    in-out property <[KeyValueTableRow]> query_param_rows;
    in-out property <string> query_param_import_path;
    in-out property <string> request_headers;
    in-out property <[KeyValueTableRow]> header_rows;
    in-out property <string> header_import_path;
    in-out property <string> auth_mode;
    in-out property <string> auth_config;
    in-out property <string> auth_basic_username;
    in-out property <string> auth_basic_password;
    in-out property <[KeyValueTableRow]> auth_key_rows;
    in-out property <string> body_mode;
    in-out property <string> raw_body_subtype;
    in-out property <string> request_body;
    in-out property <[KeyValueTableRow]> body_field_rows;
    in-out property <string> form_file_field;
    in-out property <string> form_file_path;
    in-out property <string> graphql_variables;
    in-out property <string> pre_request_script;
    in-out property <string> request_tests;
    in-out property <[TestAssertionRow]> test_assertion_rows;
    in-out property <string> realtime_mode;
    in-out property <string> realtime_message;
    in-out property <string> websocket_message_mode;
    in-out property <string> websocket_protocols;
    in-out property <string> websocket_event_history;
    in-out property <string> sse_max_events;
    in-out property <string> sse_last_event_id;
    in-out property <bool> sse_streaming;
    in-out property <string> sse_event_history;
    in-out property <string> grpc_endpoint;
    in-out property <string> grpc_method;
    in-out property <string> grpc_metadata;
    in-out property <string> grpc_message;
    in-out property <string> grpc_method_catalog;
    in property <bool> busy;
    callback open_websocket();
    callback run_websocket();
    callback close_websocket();
    callback copy_websocket_events();
    callback clear_websocket_events();
    callback run_sse();
    callback open_sse_stream();
    callback close_sse_stream();
    callback copy_sse_events();
    callback clear_sse_events();
    callback add_query_param();
    callback paste_query_params();
    callback import_query_params(string);
    callback update_query_param_row(int, string, string);
    callback delete_query_param_row(int);
    callback add_header();
    callback paste_headers();
    callback import_headers(string);
    callback update_header_row(int, string, string);
    callback delete_header_row(int);
    callback copy_headers();
    callback auth_mode_changed(string);
    callback update_basic_auth(string, string);
    callback add_auth_key();
    callback update_auth_key_row(int, string, string);
    callback delete_auth_key_row(int);
    callback body_mode_changed(string);
    callback add_body_field();
    callback add_body_file_field(string, string);
    callback update_body_field_row(int, string, string);
    callback delete_body_field_row(int);
    callback add_test_assertion();
    callback add_test_assertion_template(string);
    callback add_custom_test_assertion(string, string, string);
    callback update_test_assertion_row(int, string, string, string);
    callback cycle_test_assertion_kind(int, string);
    callback delete_test_assertion_row(int);
    callback apply_graphql_template(string);
    callback apply_header_preset(string);
    callback build_grpc_draft();
    property <string> active_tab: "body";

    horizontal-stretch: 1;
    vertical-stretch: 1;
    background: Theme.surface_container_lowest;

    VerticalLayout {
        padding: 0px;
        spacing: 0px;

        Rectangle {
            height: 44px;
            horizontal-stretch: 1;
            background: Theme.surface_container_low;

            HorizontalLayout {
                padding-left: 20px;
                padding-right: 20px;
                spacing: 12px;
                alignment: center;

                for item in [
                    { mode: "params", label: "Params" },
                    { mode: "headers", label: "Headers" },
                    { mode: "body", label: "Body" },
                    { mode: "auth", label: "Auth" },
                    { mode: "realtime", label: "Realtime" },
                    { mode: "scripts", label: "Scripts" },
                ]: WorkspaceTab {
                    mode: item.mode;
                    label: item.label;
                    selected: root.active_tab == item.mode;
                    picked(mode) => {
                        root.active_tab = mode;
                    }
                }
            }
        }

        Rectangle {
            height: 1px;
            background: Theme.outline_variant;
        }

        if root.active_tab == "body": Rectangle {
            height: 44px;
            horizontal-stretch: 1;
            background: Theme.surface_container_lowest;

            HorizontalLayout {
                padding-left: 8px;
                padding-right: 8px;
                spacing: 6px;
                alignment: center;

                for item in [
                    { mode: "none", label: "none" },
                    { mode: "form", label: "form-data" },
                    { mode: "urlenc", label: "urlenc" },
                    { mode: "raw", label: "raw" },
                    { mode: "graphql", label: "graphql" },
                    { mode: "binary", label: "binary" },
                ]: BodyModeButton {
                    mode: item.mode;
                    label: item.label;
                    button_width: item.mode == "form" ? 72px : item.mode == "graphql" ? 64px : item.mode == "urlenc" || item.mode == "binary" ? 58px : 46px;
                    selected: root.body_mode == item.mode;
                    enabled: !root.busy;
                    picked(mode) => {
                        root.body_mode = mode;
                        root.body_mode_changed(mode);
                    }
                }

                Rectangle {
                    horizontal-stretch: 1;
                }

                if root.body_mode == "raw": HorizontalLayout {
                    height: 34px;
                    spacing: 4px;

                    for item in [
                        { subtype: "json", label: "JSON" },
                        { subtype: "text", label: "Text" },
                        { subtype: "xml", label: "XML" },
                    ]: BodyModeButton {
                        mode: item.subtype;
                        label: item.label;
                        button_width: 46px;
                        selected: root.raw_body_subtype == item.subtype;
                        enabled: !root.busy;
                        picked(subtype) => {
                            root.raw_body_subtype = subtype;
                        }
                    }
                }

                if root.body_mode == "graphql": ActionButton {
                    text: "Query";
                    button_width: 50px;
                    enabled: !root.busy;
                    clicked => {
                        root.apply_graphql_template("query");
                    }
                }

                if root.body_mode == "graphql": ActionButton {
                    text: "Mutation";
                    button_width: 68px;
                    enabled: !root.busy;
                    clicked => {
                        root.apply_graphql_template("mutation");
                    }
                }

                if root.body_mode == "graphql": ActionButton {
                    text: "Intro";
                    button_width: 52px;
                    enabled: !root.busy;
                    clicked => {
                        root.apply_graphql_template("introspection");
                    }
                }
            }
        }

        Rectangle {
            height: 1px;
            background: Theme.outline_variant;
        }

        Rectangle {
            vertical-stretch: 1;
            horizontal-stretch: 1;
            background: Theme.surface_container_lowest;

            if root.active_tab == "params": KeyValueTablePanel {
                x: 16px;
                y: 16px;
                width: parent.width - 32px;
                height: parent.height - 32px;
                rows <=> root.query_param_rows;
                title: "Query Parameters";
                key_header: "Param";
                value_header: "Value";
                helper: "Stored as key=value lines for transport compatibility.";
                busy: root.busy;
                show_paste: true;
                show_import: true;
                import_path <=> root.query_param_import_path;
                add_row => {
                    root.add_query_param();
                }
                paste_rows => {
                    root.paste_query_params();
                }
                import_rows(path) => {
                    root.import_query_params(path);
                }
                update_row(row_id, key, value) => {
                    root.update_query_param_row(row_id, key, value);
                }
                delete_row(row_id) => {
                    root.delete_query_param_row(row_id);
                }
            }

            if root.active_tab == "headers": HeaderEditorPanel {
                x: 16px;
                y: 16px;
                width: parent.width - 32px;
                height: parent.height - 32px;
                request_headers <=> root.request_headers;
                header_rows <=> root.header_rows;
                header_import_path <=> root.header_import_path;
                busy: root.busy;
                apply_header_preset(preset) => {
                    root.apply_header_preset(preset);
                }
                add_header => {
                    root.add_header();
                }
                paste_headers => {
                    root.paste_headers();
                }
                import_headers(path) => {
                    root.import_headers(path);
                }
                update_header_row(row_id, key, value) => {
                    root.update_header_row(row_id, key, value);
                }
                delete_header_row(row_id) => {
                    root.delete_header_row(row_id);
                }
                copy_headers => {
                    root.copy_headers();
                }
            }

            if root.active_tab == "body" && root.body_mode == "graphql": HorizontalLayout {
                x: 16px;
                y: 16px;
                width: parent.width - 32px;
                height: parent.height - 32px;
                spacing: 12px;

                LabeledEditor {
                    label: "GraphQL Query";
                    text <=> root.request_body;
                }

                LabeledEditor {
                    label: "Variables";
                    text <=> root.graphql_variables;
                }
            }

            if root.active_tab == "body" && root.body_mode == "form": KeyValueTablePanel {
                x: 16px;
                y: 16px;
                width: parent.width - 32px;
                height: parent.height - 32px;
                rows <=> root.body_field_rows;
                title: "Form Data";
                key_header: "Field";
                value_header: "Value";
                helper: "Values are stored as key=value lines. Prefix file values with @path.";
                busy: root.busy;
                show_file_attach: true;
                file_field <=> root.form_file_field;
                file_path <=> root.form_file_path;
                add_row => {
                    root.add_body_field();
                }
                add_file_row(field, path) => {
                    root.add_body_file_field(field, path);
                }
                update_row(row_id, key, value) => {
                    root.update_body_field_row(row_id, key, value);
                }
                delete_row(row_id) => {
                    root.delete_body_field_row(row_id);
                }
            }

            if root.active_tab == "body" && root.body_mode == "urlenc": KeyValueTablePanel {
                x: 16px;
                y: 16px;
                width: parent.width - 32px;
                height: parent.height - 32px;
                rows <=> root.body_field_rows;
                title: "URL Encoded";
                key_header: "Field";
                value_header: "Value";
                helper: "Stored as key=value lines for transport compatibility.";
                busy: root.busy;
                add_row => {
                    root.add_body_field();
                }
                update_row(row_id, key, value) => {
                    root.update_body_field_row(row_id, key, value);
                }
                delete_row(row_id) => {
                    root.delete_body_field_row(row_id);
                }
            }

            if root.active_tab == "body" && root.body_mode == "binary": Rectangle {
                x: 16px;
                y: 16px;
                width: parent.width - 32px;
                height: parent.height - 32px;
                background: transparent;

                VerticalLayout {
                    padding: 0px;
                    spacing: 10px;

                    UiText {
                        text: "Binary File";
                        height: 20px;
                        horizontal-stretch: 1;
                        color: Theme.on_surface_variant;
                        font-size: 12px;
                        font-weight: 800;
                        vertical-alignment: center;
                        overflow: elide;
                    }

                    TextField {
                        text <=> root.request_body;
                        placeholder: "/absolute/path/to/body.bin";
                        mono: true;
                        enabled: !root.busy;
                    }

                    DataPanel {
                        title: "Binary Upload";
                        body: "The file at this path is streamed as the request body. Common file extensions set Content-Type automatically; a request header override wins.";
                    }
                }
            }

            if root.active_tab == "body" && root.body_mode == "none": DataPanel {
                x: 16px;
                y: 16px;
                width: parent.width - 32px;
                height: parent.height - 32px;
                title: "No Body";
                body: "This request will be sent without a body.";
            }

            if root.active_tab == "body" && root.body_mode == "raw": CodePane {
                width: parent.width;
                height: parent.height;
                text <=> root.request_body;
                read_only: false;
            }

            if root.active_tab == "auth": AuthEditorPanel {
                x: 16px;
                y: 16px;
                width: parent.width - 32px;
                height: parent.height - 32px;
                auth_mode <=> root.auth_mode;
                auth_config <=> root.auth_config;
                auth_basic_username <=> root.auth_basic_username;
                auth_basic_password <=> root.auth_basic_password;
                auth_key_rows <=> root.auth_key_rows;
                busy: root.busy;
                auth_mode_changed(mode) => {
                    root.auth_mode_changed(mode);
                }
                update_basic_auth(username, password) => {
                    root.update_basic_auth(username, password);
                }
                add_auth_key => {
                    root.add_auth_key();
                }
                update_auth_key_row(row_id, key, value) => {
                    root.update_auth_key_row(row_id, key, value);
                }
                delete_auth_key_row(row_id) => {
                    root.delete_auth_key_row(row_id);
                }
            }

            if root.active_tab == "realtime": RealtimeEditorPanel {
                x: 16px;
                y: 16px;
                width: parent.width - 32px;
                height: parent.height - 32px;
                realtime_mode <=> root.realtime_mode;
                realtime_message <=> root.realtime_message;
                websocket_message_mode <=> root.websocket_message_mode;
                websocket_protocols <=> root.websocket_protocols;
                websocket_event_history <=> root.websocket_event_history;
                sse_max_events <=> root.sse_max_events;
                sse_last_event_id <=> root.sse_last_event_id;
                sse_streaming <=> root.sse_streaming;
                sse_event_history <=> root.sse_event_history;
                grpc_endpoint <=> root.grpc_endpoint;
                grpc_method <=> root.grpc_method;
                grpc_metadata <=> root.grpc_metadata;
                grpc_message <=> root.grpc_message;
                grpc_method_catalog <=> root.grpc_method_catalog;
                busy: root.busy;
                open_websocket => {
                    root.open_websocket();
                }
                run_websocket => {
                    root.run_websocket();
                }
                close_websocket => {
                    root.close_websocket();
                }
                copy_websocket_events => {
                    root.copy_websocket_events();
                }
                clear_websocket_events => {
                    root.clear_websocket_events();
                }
                run_sse => {
                    root.run_sse();
                }
                open_sse_stream => {
                    root.open_sse_stream();
                }
                close_sse_stream => {
                    root.close_sse_stream();
                }
                copy_sse_events => {
                    root.copy_sse_events();
                }
                clear_sse_events => {
                    root.clear_sse_events();
                }
                build_grpc_draft => {
                    root.build_grpc_draft();
                }
            }

            if root.active_tab == "scripts": HorizontalLayout {
                x: 16px;
                y: 16px;
                width: parent.width - 32px;
                height: parent.height - 32px;
                spacing: 12px;

                LabeledEditor {
                    label: "Pre-request";
                    text <=> root.pre_request_script;
                }

                TestAssertionEditorPanel {
                    rows <=> root.test_assertion_rows;
                    busy: root.busy;
                    add_row => {
                        root.add_test_assertion();
                    }
                    add_template_row(template) => {
                        root.add_test_assertion_template(template);
                    }
                    add_custom_row(kind, target, expected) => {
                        root.add_custom_test_assertion(kind, target, expected);
                    }
                    update_row(row_id, kind, target, expected) => {
                        root.update_test_assertion_row(row_id, kind, target, expected);
                    }
                    cycle_kind_row(row_id, kind) => {
                        root.cycle_test_assertion_kind(row_id, kind);
                    }
                    delete_row(row_id) => {
                        root.delete_test_assertion_row(row_id);
                    }
                }
            }
        }
    }
}

component ResponsePanel inherits Rectangle {
    in-out property <string> response_body;
    in-out property <string> response_raw_body;
    in-out property <string> response_headers;
    in-out property <string> response_cookies;
    in-out property <string> folded_response_body;
    in-out property <string> folded_response_raw_body;
    in-out property <string> folded_response_headers;
    in-out property <string> folded_response_cookies;
    in-out property <string> codegen_language;
    in-out property <string> codegen_output;
    in-out property <string> codegen_path;
    in-out property <[RunnerRow]> runner_rows;
    in-out property <string> runner_summary;
    in-out property <string> runner_delay_ms;
    in-out property <string> runner_report_path;
    in-out property <string> runner_report_format;
    in-out property <bool> runner_stop_on_failure;
    in-out property <bool> runner_active;
    in property <string> response_status;
    in property <string> response_meta;
    in property <string> response_time;
    in property <string> response_size;
    in property <string> response_tone;
    in property <bool> busy;
    callback generate_code();
    callback save_codegen(string);
    callback run_collection();
    callback cancel_collection_run();
    callback save_runner_report(string);
    callback copy_response(string, string, int, int);
    callback format_response(string);
    callback summarize_graphql_schema(string, string);
    property <string> active_tab: "pretty";
    property <bool> pretty_response_folded: false;
    property <bool> raw_response_folded: false;
    property <bool> headers_response_folded: false;
    property <bool> cookies_response_folded: false;
    property <int> pretty_selection_anchor: 0;
    property <int> pretty_selection_cursor: 0;
    property <int> raw_selection_anchor: 0;
    property <int> raw_selection_cursor: 0;
    property <int> headers_selection_anchor: 0;
    property <int> headers_selection_cursor: 0;
    property <int> cookies_selection_anchor: 0;
    property <int> cookies_selection_cursor: 0;
    property <bool> active_response_folded: root.active_tab == "pretty" ? root.pretty_response_folded : root.active_tab == "raw" ? root.raw_response_folded : root.active_tab == "headers" ? root.headers_response_folded : root.cookies_response_folded;
    property <bool> all_responses_folded: root.pretty_response_folded && root.raw_response_folded && root.headers_response_folded && root.cookies_response_folded;
    property <bool> any_response_folded: root.pretty_response_folded || root.raw_response_folded || root.headers_response_folded || root.cookies_response_folded;
    property <string> active_response_text: root.active_tab == "pretty" ? root.response_body : root.active_tab == "raw" ? root.response_raw_body : root.active_tab == "headers" ? root.response_headers : root.response_cookies;
    property <string> active_response_display_text: root.active_response_folded ? (root.active_tab == "pretty" ? root.folded_response_body : root.active_tab == "raw" ? root.folded_response_raw_body : root.active_tab == "headers" ? root.folded_response_headers : root.folded_response_cookies) : root.active_response_text;
    property <int> active_response_selection_anchor: root.active_tab == "pretty" ? root.pretty_selection_anchor : root.active_tab == "raw" ? root.raw_selection_anchor : root.active_tab == "headers" ? root.headers_selection_anchor : root.cookies_selection_anchor;
    property <int> active_response_selection_cursor: root.active_tab == "pretty" ? root.pretty_selection_cursor : root.active_tab == "raw" ? root.raw_selection_cursor : root.active_tab == "headers" ? root.headers_selection_cursor : root.cookies_selection_cursor;
    property <bool> response_ready: root.response_status != "Idle" || root.response_headers != "" || root.response_time != "" || root.response_size != "" || root.response_raw_body != root.response_body;

    function set_response_selection(tab: string, anchor: int, cursor: int) {
        if (tab == "pretty") {
            root.pretty_selection_anchor = anchor;
            root.pretty_selection_cursor = cursor;
        } else if (tab == "raw") {
            root.raw_selection_anchor = anchor;
            root.raw_selection_cursor = cursor;
        } else if (tab == "headers") {
            root.headers_selection_anchor = anchor;
            root.headers_selection_cursor = cursor;
        } else if (tab == "cookies") {
            root.cookies_selection_anchor = anchor;
            root.cookies_selection_cursor = cursor;
        }
    }

    function clear_response_selection(tab: string) {
        root.set_response_selection(tab, 0, 0);
    }

    function clear_all_response_selections() {
        root.clear_response_selection("pretty");
        root.clear_response_selection("raw");
        root.clear_response_selection("headers");
        root.clear_response_selection("cookies");
    }

    changed response_body => {
        root.clear_response_selection("pretty");
    }

    changed response_raw_body => {
        root.clear_response_selection("raw");
    }

    changed response_headers => {
        root.clear_response_selection("headers");
    }

    changed response_cookies => {
        root.clear_response_selection("cookies");
    }

    changed folded_response_body => {
        root.clear_response_selection("pretty");
    }

    changed folded_response_raw_body => {
        root.clear_response_selection("raw");
    }

    changed folded_response_headers => {
        root.clear_response_selection("headers");
    }

    changed folded_response_cookies => {
        root.clear_response_selection("cookies");
    }

    width: 400px;
    vertical-stretch: 1;
    background: Theme.surface_container_lowest;

    VerticalLayout {
        padding: 0px;
        spacing: 0px;

        Rectangle {
            height: 112px;
            horizontal-stretch: 1;
            background: Theme.surface_container_low;

            UiText {
                x: 20px;
                y: 14px;
                text: "Response";
                width: 180px;
                height: 30px;
                color: Theme.on_surface;
                font-size: 24px;
                font-weight: 800;
                overflow: elide;
                vertical-alignment: center;
            }

            Rectangle {
                x: parent.width - 148px;
                y: 15px;
                width: 128px;
                height: 30px;
                border-radius: 4px;
                border-width: 1px;
                border-color: root.response_tone == "error" ? Theme.error : #00a572;
                background: transparent;

                UiText {
                    x: 7px;
                    text: root.response_status;
                    width: parent.width - 14px;
                    height: parent.height;
                    color: root.response_tone == "error" ? Theme.error : #00a572;
                    font-family: "JetBrains Mono";
                    font-size: 13px;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                    overflow: elide;
                }
            }

            UiText {
                x: 20px;
                y: 60px;
                text: "TIME";
                width: 80px;
                height: 18px;
                color: Theme.on_surface_variant;
                font-size: 11px;
                font-weight: 800;
                vertical-alignment: center;
                overflow: elide;
            }

            UiText {
                x: 150px;
                y: 60px;
                text: "SIZE";
                width: 80px;
                height: 18px;
                color: Theme.on_surface_variant;
                font-size: 11px;
                font-weight: 800;
                vertical-alignment: center;
                overflow: elide;
            }

            UiText {
                x: 20px;
                y: 80px;
                text: root.response_time == "" ? "--" : root.response_time;
                width: 116px;
                height: 20px;
                color: Theme.on_surface;
                font-family: "JetBrains Mono";
                font-size: 13px;
                vertical-alignment: center;
                overflow: elide;
            }

            UiText {
                x: 150px;
                y: 80px;
                text: root.response_size == "" ? "--" : root.response_size;
                width: parent.width - 170px;
                height: 22px;
                color: Theme.on_surface;
                font-family: "JetBrains Mono";
                font-size: 13px;
                vertical-alignment: center;
                overflow: elide;
            }
        }

        Rectangle {
            height: 1px;
            background: Theme.outline_variant;
        }

        Rectangle {
            height: 44px;
            horizontal-stretch: 1;
            background: Theme.surface_container_low;

            HorizontalLayout {
                padding-left: 12px;
                padding-right: 12px;
                spacing: 8px;
                alignment: center;

                for item in [
                    { mode: "pretty", label: "Pretty" },
                    { mode: "raw", label: "Raw" },
                    { mode: "headers", label: "Headers" },
                    { mode: "cookies", label: "Cookies" },
                ]: ResponseTab {
                    mode: item.mode;
                    label: item.label;
                    selected: root.active_tab == item.mode;
                    picked(mode) => {
                        root.active_tab = mode;
                        root.clear_response_selection(mode);
                    }
                }
            }
        }

        Rectangle {
            height: 1px;
            background: Theme.outline_variant;
        }

        Rectangle {
            height: 36px;
            horizontal-stretch: 1;
            background: Theme.surface_container;

            HorizontalLayout {
                padding-left: 8px;
                padding-right: 8px;
                spacing: 6px;
                alignment: center;

                Rectangle {
                    horizontal-stretch: 1;
                }

                ActionButton {
                    text: "Schema";
                    button_width: 64px;
                    enabled: !root.busy && root.active_response_text != "" && (root.active_tab == "pretty" || root.active_tab == "raw");
                    clicked => {
                        root.summarize_graphql_schema(root.active_tab, root.active_response_text);
                        root.active_tab = "pretty";
                    }
                }

                ActionButton {
                    text: "Format";
                    button_width: 62px;
                    enabled: !root.busy && (root.active_tab == "pretty" || root.active_tab == "raw");
                    clicked => {
                        root.format_response(root.active_tab);
                    }
                }

                ActionButton {
                    text: "Copy";
                    button_width: 52px;
                    enabled: root.active_response_display_text != "";
                    clicked => {
                        root.copy_response(root.active_tab, root.active_response_display_text, root.active_response_selection_anchor, root.active_response_selection_cursor);
                    }
                }

                ActionButton {
                    text: root.active_response_folded ? "Open" : "Fold";
                    button_width: 52px;
                    clicked => {
                        root.pretty_response_folded = root.active_tab == "pretty" ? !root.pretty_response_folded : root.pretty_response_folded;
                        root.raw_response_folded = root.active_tab == "raw" ? !root.raw_response_folded : root.raw_response_folded;
                        root.headers_response_folded = root.active_tab == "headers" ? !root.headers_response_folded : root.headers_response_folded;
                        root.cookies_response_folded = root.active_tab == "cookies" ? !root.cookies_response_folded : root.cookies_response_folded;
                        root.clear_response_selection(root.active_tab);
                    }
                }

                ActionButton {
                    text: "Fold All";
                    button_width: 62px;
                    enabled: !root.all_responses_folded;
                    clicked => {
                        root.pretty_response_folded = true;
                        root.raw_response_folded = true;
                        root.headers_response_folded = true;
                        root.cookies_response_folded = true;
                        root.clear_all_response_selections();
                    }
                }

                ActionButton {
                    text: "Open All";
                    button_width: 66px;
                    enabled: root.any_response_folded;
                    clicked => {
                        root.pretty_response_folded = false;
                        root.raw_response_folded = false;
                        root.headers_response_folded = false;
                        root.cookies_response_folded = false;
                        root.clear_all_response_selections();
                    }
                }
            }
        }

        Rectangle {
            height: 1px;
            background: Theme.outline_variant;
        }

        Rectangle {
            vertical-stretch: 1;
            horizontal-stretch: 1;
            background: Theme.surface_container_lowest;

            if root.active_response_folded && root.active_tab == "pretty": CodePane {
                width: parent.width;
                height: parent.height;
                text <=> root.folded_response_body;
                read_only: true;
                selection_changed(anchor, cursor) => {
                    root.set_response_selection("pretty", anchor, cursor);
                }
            }

            if root.active_response_folded && root.active_tab == "raw": CodePane {
                width: parent.width;
                height: parent.height;
                text <=> root.folded_response_raw_body;
                read_only: true;
                selection_changed(anchor, cursor) => {
                    root.set_response_selection("raw", anchor, cursor);
                }
            }

            if root.active_response_folded && root.active_tab == "headers": CodePane {
                width: parent.width;
                height: parent.height;
                text <=> root.folded_response_headers;
                read_only: true;
                selection_changed(anchor, cursor) => {
                    root.set_response_selection("headers", anchor, cursor);
                }
            }

            if root.active_response_folded && root.active_tab == "cookies": CodePane {
                width: parent.width;
                height: parent.height;
                text <=> root.folded_response_cookies;
                read_only: true;
                selection_changed(anchor, cursor) => {
                    root.set_response_selection("cookies", anchor, cursor);
                }
            }

            if !root.active_response_folded && !root.response_ready && (root.active_tab == "pretty" || root.active_tab == "raw"): UiText {
                text: root.active_tab == "raw" ? root.response_raw_body : root.response_body;
                width: parent.width - 32px;
                height: parent.height;
                x: 16px;
                color: Theme.outline;
                font-size: 12px;
                horizontal-alignment: center;
                vertical-alignment: center;
                overflow: elide;
            }

            if !root.active_response_folded && root.response_ready && root.active_tab == "pretty": CodePane {
                width: parent.width;
                height: parent.height;
                text <=> root.response_body;
                read_only: true;
                selection_changed(anchor, cursor) => {
                    root.set_response_selection("pretty", anchor, cursor);
                }
            }

            if !root.active_response_folded && root.response_ready && root.active_tab == "raw": CodePane {
                width: parent.width;
                height: parent.height;
                text <=> root.response_raw_body;
                read_only: true;
                selection_changed(anchor, cursor) => {
                    root.set_response_selection("raw", anchor, cursor);
                }
            }

            if !root.active_response_folded && root.active_tab == "headers": CodePane {
                width: parent.width;
                height: parent.height;
                text <=> root.response_headers;
                read_only: true;
                selection_changed(anchor, cursor) => {
                    root.set_response_selection("headers", anchor, cursor);
                }
            }

            if !root.active_response_folded && root.active_tab == "cookies" && root.response_cookies == "No cookies": UiText {
                text: root.response_cookies;
                width: parent.width;
                height: parent.height;
                color: Theme.outline;
                font-size: 12px;
                horizontal-alignment: center;
                vertical-alignment: center;
                overflow: elide;
            }

            if !root.active_response_folded && root.active_tab == "cookies" && root.response_cookies != "No cookies": CodePane {
                width: parent.width;
                height: parent.height;
                text <=> root.response_cookies;
                read_only: true;
                selection_changed(anchor, cursor) => {
                    root.set_response_selection("cookies", anchor, cursor);
                }
            }
        }
    }
}

component DashboardPage inherits Rectangle {
    in property <int> route_count;
    in property <int> history_count;
    in property <int> mock_count;
    in property <string> runner_summary;
    in property <bool> server_running;
    in property <string> server_status;
    in property <string> response_status;
    callback open_page(int);

    horizontal-stretch: 1;
    vertical-stretch: 1;
    background: Theme.background;

    HorizontalLayout {
        padding: 20px;
        spacing: 20px;

        Rectangle {
            horizontal-stretch: 1;
            vertical-stretch: 1;
            background: transparent;

            VerticalLayout {
                padding: 0px;
                spacing: 18px;

                PageTitle {
                    title: "System Overview";
                    subtitle: "Real-time metrics for the local API workspace.";
                }

                HorizontalLayout {
                    height: 104px;
                    spacing: 16px;

                    MetricCard {
                        label: "ROUTES";
                        value: root.route_count + "";
                        detail: "Imported endpoints";
                    }

                    MetricCard {
                        label: "HISTORY";
                        value: root.history_count + "";
                        detail: "Local requests";
                    }

                    MetricCard {
                        label: "MOCK LOGS";
                        value: root.mock_count + "";
                        detail: root.server_running ? root.server_status : "Mock stopped";
                    }
                }

                DataPanel {
                    title: "Traffic Volume";
                    body: "▂▃▅▇█▇▅▃▂▃▅▇█\n\n" + (root.response_status == "" ? "No response yet" : root.response_status);
                }

                DataPanel {
                    title: "Top Endpoints";
                    body: root.route_count == 0 ? "Import an OpenAPI document to populate endpoint metrics." : "Endpoint metrics will follow imported route traffic.";
                }
            }
        }

        Rectangle {
            width: 320px;
            vertical-stretch: 1;
            background: Theme.surface_container_low;
            border-radius: 8px;
            border-width: 1px;
            border-color: Theme.outline_variant;

            VerticalLayout {
                padding: 16px;
                spacing: 14px;

                UiText {
                    text: "QUICK ACTIONS";
                    height: 20px;
                    horizontal-stretch: 1;
                    color: Theme.on_surface_variant;
                    font-size: 12px;
                    font-weight: 800;
                    vertical-alignment: center;
                    overflow: elide;
                }

                ActionButton {
                    text: "Requests";
                    primary: true;
                    button_width: 288px;
                    clicked => {
                        root.open_page(1);
                    }
                }

                ActionButton {
                    text: "Mocks";
                    button_width: 288px;
                    clicked => {
                        root.open_page(2);
                    }
                }

                ActionButton {
                    text: "Runner";
                    button_width: 288px;
                    clicked => {
                        root.open_page(3);
                    }
                }

                Rectangle {
                    height: 1px;
                    horizontal-stretch: 1;
                    background: Theme.outline_variant;
                }

                DataPanel {
                    title: "Live Activity";
                    body: root.runner_summary == "" ? "No collection run results yet." : root.runner_summary;
                }
            }
        }
    }
}

component MockRouteLine inherits Rectangle {
    in property <string> method;
    in property <string> path;
    in property <bool> selected;
    callback picked();

    height: 46px;
    horizontal-stretch: 1;
    border-radius: 6px;
    border-width: 0px;
    background: root.selected ? Theme.surface_variant : touch.has-hover ? Theme.surface_container_high : transparent;

    touch := TouchArea {
        mouse-cursor: pointer;
        clicked => {
            root.picked();
        }
    }

    Rectangle {
        width: 2px;
        height: parent.height - 10px;
        y: 5px;
        background: root.selected ? Theme.primary : transparent;
    }

    MethodChip {
        x: 10px;
        y: 12px;
        method: root.method;
    }

    UiText {
        x: 82px;
        text: root.path;
        width: parent.width - 108px;
        height: parent.height;
        font-family: "JetBrains Mono";
        font-size: 12px;
        color: root.selected ? Theme.on_surface : Theme.on_surface_variant;
        vertical-alignment: center;
        overflow: elide;
    }

    StatusDot {
        x: parent.width - 18px;
        y: 19px;
        tone: root.selected ? "active" : "inactive";
    }
}

component MockConfigField inherits Rectangle {
    in property <string> label;
    in property <string> value;

    width: 150px;
    height: 52px;
    background: transparent;

    UiText {
        y: 2px;
        text: root.label;
        width: parent.width;
        height: 16px;
        color: Theme.on_surface_variant;
        font-size: 11px;
        font-weight: 800;
        vertical-alignment: center;
        overflow: elide;
    }

    UiText {
        y: 22px;
        text: root.value;
        width: parent.width;
        height: 28px;
        color: Theme.on_surface;
        font-family: "JetBrains Mono";
        font-size: 12px;
        vertical-alignment: center;
        overflow: elide;
    }
}

component MockRuleLine inherits Rectangle {
    in property <int> row_id;
    in property <string> source;
    in property <string> name;
    in property <string> value;
    in property <string> body_preview;
    in property <bool> selected;
    callback picked(int);

    height: 54px;
    horizontal-stretch: 1;
    border-radius: 6px;
    border-width: 1px;
    border-color: root.selected ? Theme.primary : Theme.outline_variant;
    background: root.selected ? Theme.surface_variant : touch.has-hover ? Theme.surface_container_high : Theme.surface;

    touch := TouchArea {
        mouse-cursor: pointer;
        clicked => {
            root.picked(root.row_id);
        }
    }

    UiText {
        x: 12px;
        y: 7px;
        text: root.source;
        width: 48px;
        height: 18px;
        color: root.selected ? Theme.primary : Theme.on_surface_variant;
        font-family: "JetBrains Mono";
        font-size: 11px;
        font-weight: 800;
        vertical-alignment: center;
        overflow: elide;
    }

    UiText {
        x: 66px;
        y: 7px;
        text: root.name + "=" + root.value;
        width: parent.width - 78px;
        height: 18px;
        color: Theme.on_surface;
        font-family: "JetBrains Mono";
        font-size: 12px;
        font-weight: 700;
        vertical-alignment: center;
        overflow: elide;
    }

    UiText {
        x: 12px;
        y: 29px;
        width: parent.width - 24px;
        height: 18px;
        text: root.body_preview;
        color: Theme.on_surface_variant;
        font-size: 12px;
        vertical-alignment: center;
        overflow: elide;
    }
}

component MockManagerPage inherits Rectangle {
    in-out property <[RouteRow]> routes;
    in-out property <[MockLogRow]> mock_logs;
    in-out property <[MockRuleRow]> mock_rule_rows;
    in-out property <int> selected_route;
    in-out property <int> selected_mock_rule;
    in-out property <string> mock_log_filter;
    in-out property <string> mock_log_path;
    in property <string> selected_mock_method;
    in property <string> selected_mock_path;
    in property <string> selected_mock_summary;
    in-out property <string> selected_mock_body;
    in-out property <string> selected_mock_rule_source;
    in-out property <string> selected_mock_rule_name;
    in-out property <string> selected_mock_rule_value;
    in-out property <string> selected_mock_rule_body;
    in property <bool> busy;
    in property <bool> server_running;
    in property <string> server_status;
    callback select_route(int);
    callback toggle_server();
    callback save_mock_response(string);
    callback select_mock_rule(int);
    callback add_mock_rule(string);
    callback save_mock_rule(int, string, string, string, string);
    callback delete_mock_rule(int);
    callback filter_mock_logs(string);
    callback save_mock_logs(string);
    callback clear_mock_logs();

    horizontal-stretch: 1;
    vertical-stretch: 1;
    background: Theme.background;

    HorizontalLayout {
        spacing: 0px;

        Rectangle {
            width: 288px;
            vertical-stretch: 1;
            background: Theme.surface;

            VerticalLayout {
                padding: 0px;
                spacing: 0px;

                Rectangle {
                    height: 56px;
                    horizontal-stretch: 1;
                    background: Theme.surface_container_lowest;

                    UiText {
                        x: 16px;
                        text: "ENDPOINTS";
                        width: parent.width - 56px;
                        height: parent.height;
                        color: Theme.on_surface;
                        font-size: 12px;
                        font-weight: 800;
                        vertical-alignment: center;
                        overflow: elide;
                    }

                }

                ListView {
                    horizontal-stretch: 1;
                    vertical-stretch: 1;
                    vertical-scrollbar-policy: ScrollBarPolicy.as-needed;
                    horizontal-scrollbar-policy: ScrollBarPolicy.as-needed;

                    for route[i] in root.routes: MockRouteLine {
                        method: route.method;
                        path: route.path;
                        selected: root.selected_route == i;
                        picked => {
                            root.selected_route = i;
                            root.select_route(i);
                        }
                    }
                }
            }
        }

        Rectangle {
            width: 1px;
            background: Theme.outline_variant;
        }

        Rectangle {
            horizontal-stretch: 1;
            vertical-stretch: 1;
            background: Theme.surface;

            VerticalLayout {
                padding: 0px;
                spacing: 0px;

                Rectangle {
                    height: 76px;
                    horizontal-stretch: 1;
                    background: Theme.surface_container_lowest;

                    MethodChip {
                        x: 18px;
                        y: 18px;
                        method: root.selected_mock_method == "" ? "GET" : root.selected_mock_method;
                    }

                    UiText {
                        x: 90px;
                        y: 14px;
                        text: root.selected_mock_path == "" ? "Select an endpoint" : root.selected_mock_path;
                        width: parent.width - 338px;
                        height: 24px;
                        color: Theme.on_surface;
                        font-family: "JetBrains Mono";
                        font-size: 15px;
                        font-weight: 800;
                        vertical-alignment: center;
                        overflow: elide;
                    }

                    UiText {
                        x: 90px;
                        y: 40px;
                        text: root.selected_mock_summary == "" ? (root.routes.length == 0 ? "Import routes to configure mock responses." : "Generated OpenAPI mock response preview.") : root.selected_mock_summary;
                        width: parent.width - 338px;
                        height: 18px;
                        color: Theme.on_surface_variant;
                        font-size: 12px;
                        vertical-alignment: center;
                        overflow: elide;
                    }

                    UiText {
                        x: parent.width - 232px;
                        y: 15px;
                        text: "Mock Server Status:";
                        width: 122px;
                        height: 22px;
                        color: Theme.on_surface_variant;
                        font-size: 12px;
                        vertical-alignment: center;
                        overflow: elide;
                    }

                    ActionButton {
                        x: parent.width - 108px;
                        y: 14px;
                        text: root.server_running ? "Running" : "Start";
                        button_width: 90px;
                        primary: !root.server_running;
                        warning: root.server_running;
                        enabled: !root.busy && (root.server_running || root.routes.length > 0);
                        clicked => {
                            root.toggle_server();
                        }
                    }

                    UiText {
                        x: parent.width - 232px;
                        y: 42px;
                        text: root.server_running ? root.server_status : "Stopped";
                        width: 214px;
                        height: 18px;
                        color: root.server_running ? Theme.secondary : Theme.outline;
                        font-family: "JetBrains Mono";
                        font-size: 11px;
                        horizontal-alignment: right;
                        vertical-alignment: center;
                        overflow: elide;
                    }
                }

                Rectangle {
                    height: 1px;
                    horizontal-stretch: 1;
                    background: Theme.outline_variant;
                }

                HorizontalLayout {
                    height: 76px;
                    padding-left: 18px;
                    padding-right: 18px;
                    spacing: 24px;
                    alignment: center;

                    MockConfigField {
                        label: "Status Code";
                        value: root.selected_mock_path == "" ? "--" : "200 OK";
                    }

                    MockConfigField {
                        label: "Delay";
                        value: "0 ms";
                    }

                    MockConfigField {
                        label: "Response Body";
                        value: root.selected_mock_path == "" ? "--" : "OpenAPI mock";
                    }

                    Rectangle {
                        horizontal-stretch: 1;
                    }
                }

                Rectangle {
                    height: 1px;
                    horizontal-stretch: 1;
                    background: Theme.outline_variant;
                }

                Rectangle {
                    height: 46px;
                    horizontal-stretch: 1;
                    background: Theme.surface_container_lowest;

                    UiText {
                        x: 18px;
                        text: "Response Body";
                        width: 150px;
                        height: parent.height;
                        color: Theme.primary;
                        font-size: 13px;
                        font-weight: 800;
                        vertical-alignment: center;
                        overflow: elide;
                    }

                    UiText {
                        x: 172px;
                        text: "Headers generated by mock server";
                        width: parent.width - 266px;
                        height: parent.height;
                        color: Theme.on_surface_variant;
                        font-size: 12px;
                        vertical-alignment: center;
                        overflow: elide;
                    }

                    ActionButton {
                        x: parent.width - 82px;
                        y: 6px;
                        text: "Save";
                        button_width: 64px;
                        enabled: !root.busy && root.selected_mock_path != "";
                        clicked => {
                            root.save_mock_response(root.selected_mock_body);
                        }
                    }
                }

                Rectangle {
                    horizontal-stretch: 1;
                    vertical-stretch: 1;
                    background: Theme.surface_container_lowest;

                    if root.selected_mock_body == "": UiText {
                        x: 18px;
                        width: parent.width - 36px;
                        height: parent.height;
                        text: root.routes.length == 0 ? "Import an OpenAPI document to generate mock route responses." : "Select an endpoint to preview its generated mock response.";
                        color: Theme.outline;
                        font-size: 12px;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                        overflow: elide;
                    }

                    if root.selected_mock_body != "": CodePane {
                        x: 0px;
                        y: 0px;
                        width: parent.width;
                        height: parent.height;
                        text <=> root.selected_mock_body;
                        read_only: false;
                    }
                }
            }
        }

        Rectangle {
            width: 360px;
            vertical-stretch: 1;
            background: Theme.surface_container_lowest;

            VerticalLayout {
                padding: 0px;
                spacing: 0px;

                Rectangle {
                    height: 430px;
                    horizontal-stretch: 1;
                    background: Theme.surface_container_low;

                    VerticalLayout {
                        padding: 14px;
                        spacing: 10px;

                        HorizontalLayout {
                            height: 30px;
                            spacing: 8px;
                            alignment: center;

                            UiText {
                                text: "ROUTING RULES";
                                height: parent.height;
                                horizontal-stretch: 1;
                                color: Theme.on_surface;
                                font-size: 12px;
                                font-weight: 800;
                                vertical-alignment: center;
                                overflow: elide;
                            }

                            ActionButton {
                                text: "+H";
                                button_width: 42px;
                                enabled: !root.busy && root.selected_mock_path != "";
                                clicked => {
                                    root.add_mock_rule("header");
                                }
                            }

                            ActionButton {
                                text: "+Q";
                                button_width: 42px;
                                enabled: !root.busy && root.selected_mock_path != "";
                                clicked => {
                                    root.add_mock_rule("query");
                                }
                            }
                        }

                        Rectangle {
                            height: 112px;
                            horizontal-stretch: 1;
                            background: Theme.surface_container_lowest;
                            border-radius: 6px;
                            border-width: 1px;
                            border-color: Theme.outline_variant;
                            clip: true;

                            if root.mock_rule_rows.length == 0: UiText {
                                x: 12px;
                                width: parent.width - 24px;
                                height: parent.height;
                                text: root.selected_mock_path == "" ? "Select an endpoint to add conditional responses." : "No conditional rules for this endpoint.";
                                color: Theme.outline;
                                font-size: 12px;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                                overflow: elide;
                            }

                            if root.mock_rule_rows.length != 0: ListView {
                                width: parent.width;
                                height: parent.height;
                                vertical-scrollbar-policy: ScrollBarPolicy.as-needed;
                                horizontal-scrollbar-policy: ScrollBarPolicy.as-needed;

                                for rule in root.mock_rule_rows: MockRuleLine {
                                    row_id: rule.row_id;
                                    source: rule.source;
                                    name: rule.name;
                                    value: rule.value;
                                    body_preview: rule.body_preview;
                                    selected: root.selected_mock_rule == rule.row_id;
                                    picked(row_id) => {
                                        root.selected_mock_rule = row_id;
                                        root.select_mock_rule(row_id);
                                    }
                                }
                            }
                        }

                        HorizontalLayout {
                            height: 28px;
                            spacing: 8px;

                            BodyModeButton {
                                mode: "header";
                                label: "Header";
                                button_width: 74px;
                                selected: root.selected_mock_rule_source == "header";
                                enabled: !root.busy && root.selected_mock_rule >= 0;
                                picked(mode) => {
                                    root.selected_mock_rule_source = mode;
                                }
                            }

                            BodyModeButton {
                                mode: "query";
                                label: "Query";
                                button_width: 66px;
                                selected: root.selected_mock_rule_source == "query";
                                enabled: !root.busy && root.selected_mock_rule >= 0;
                                picked(mode) => {
                                    root.selected_mock_rule_source = mode;
                                }
                            }

                            Rectangle {
                                horizontal-stretch: 1;
                            }

                            ActionButton {
                                text: "Del";
                                button_width: 48px;
                                warning: true;
                                enabled: !root.busy && root.selected_mock_rule >= 0;
                                clicked => {
                                    root.delete_mock_rule(root.selected_mock_rule);
                                }
                            }
                        }

                        HorizontalLayout {
                            height: 34px;
                            spacing: 8px;

                            TextField {
                                text <=> root.selected_mock_rule_name;
                                placeholder: root.selected_mock_rule_source == "query" ? "query key" : "header name";
                                mono: true;
                                enabled: !root.busy && root.selected_mock_rule >= 0;
                            }

                            TextField {
                                text <=> root.selected_mock_rule_value;
                                placeholder: "match value";
                                mono: true;
                                enabled: !root.busy && root.selected_mock_rule >= 0;
                            }
                        }

                        Rectangle {
                            horizontal-stretch: 1;
                            vertical-stretch: 1;
                            background: Theme.surface_container_lowest;
                            border-radius: 6px;
                            border-width: 1px;
                            border-color: Theme.outline_variant;
                            clip: true;

                            if root.selected_mock_rule < 0: UiText {
                                x: 12px;
                                width: parent.width - 24px;
                                height: parent.height;
                                text: "Select or add a rule to edit its JSON response.";
                                color: Theme.outline;
                                font-size: 12px;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                                overflow: elide;
                            }

                            if root.selected_mock_rule >= 0: CodePane {
                                width: parent.width;
                                height: parent.height;
                                text <=> root.selected_mock_rule_body;
                                read_only: false;
                            }
                        }

                        ActionButton {
                            text: "Save Rule";
                            button_width: 332px;
                            enabled: !root.busy && root.selected_mock_rule >= 0 && root.selected_mock_rule_name != "" && root.selected_mock_rule_value != "" && root.selected_mock_rule_body != "";
                            clicked => {
                                root.save_mock_rule(root.selected_mock_rule, root.selected_mock_rule_source, root.selected_mock_rule_name, root.selected_mock_rule_value, root.selected_mock_rule_body);
                            }
                        }
                    }
                }

                Rectangle {
                    height: 1px;
                    horizontal-stretch: 1;
                    background: Theme.outline_variant;
                }

                Rectangle {
                    vertical-stretch: 1;
                    horizontal-stretch: 1;
                    background: Theme.surface_container_lowest;

                    VerticalLayout {
                        padding: 14px;
                        spacing: 10px;

                        HorizontalLayout {
                            height: 34px;
                            spacing: 8px;
                            alignment: center;

                            UiText {
                                text: "LIVE TRAFFIC";
                                height: parent.height;
                                horizontal-stretch: 1;
                                color: Theme.on_surface;
                                font-size: 12px;
                                font-weight: 800;
                                vertical-alignment: center;
                                overflow: elide;
                            }

                            ActionButton {
                                text: "Clear";
                                button_width: 62px;
                                warning: true;
                                enabled: !root.busy && root.mock_logs.length > 0;
                                clicked => {
                                    root.clear_mock_logs();
                                }
                            }
                        }

                        TextField {
                            text <=> root.mock_log_filter;
                            placeholder: "Filter traffic";
                            mono: true;
                            enabled: !root.busy;
                            edited => {
                                root.filter_mock_logs(root.mock_log_filter);
                            }
                        }

                        if root.mock_logs.length == 0: DataPanel {
                            title: "No requests";
                            body: "Incoming mock traffic appears here.";
                        }

                        if root.mock_logs.length != 0: ListView {
                            horizontal-stretch: 1;
                            vertical-stretch: 1;
                            vertical-scrollbar-policy: ScrollBarPolicy.as-needed;
                            horizontal-scrollbar-policy: ScrollBarPolicy.as-needed;

                            for log in root.mock_logs: MockLogLine {
                                method: log.method;
                                path: log.path;
                                status: log.status;
                            }
                        }

                        HorizontalLayout {
                            height: 34px;
                            spacing: 8px;

                            TextField {
                                text <=> root.mock_log_path;
                                placeholder: "mock-logs.json";
                                mono: true;
                                enabled: !root.busy;
                            }

                            ActionButton {
                                text: "Save";
                                button_width: 62px;
                                enabled: !root.busy && root.mock_logs.length > 0;
                                clicked => {
                                    root.save_mock_logs(root.mock_log_path);
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}

component EnvironmentNavRow inherits Rectangle {
    in property <string> mode;
    in property <string> label;
    in property <string> detail;
    in property <string> tone: "inactive";
    in property <bool> selected: false;
    callback picked(string);

    height: 52px;
    horizontal-stretch: 1;
    border-radius: 6px;
    border-width: root.selected ? 1px : 0px;
    border-color: Theme.outline_variant;
    background: root.selected ? Theme.surface_variant : nav_touch.has-hover ? Theme.surface_container_high : transparent;

    nav_touch := TouchArea {
        mouse-cursor: pointer;
        clicked => {
            root.picked(root.mode);
        }
    }

    StatusDot {
        x: 14px;
        y: 18px;
        tone: root.selected ? "active" : root.tone;
    }

    UiText {
        x: 32px;
        y: 7px;
        text: root.label;
        width: parent.width - 44px;
        height: 20px;
        color: root.selected ? Theme.on_surface : Theme.on_surface_variant;
        font-size: 14px;
        font-weight: root.selected ? 800 : 600;
        vertical-alignment: center;
        overflow: elide;
    }

    UiText {
        x: 32px;
        y: 28px;
        text: root.detail;
        width: parent.width - 44px;
        height: 16px;
        color: Theme.outline;
        font-size: 11px;
        vertical-alignment: center;
        overflow: elide;
    }
}

component VariableScopePill inherits Rectangle {
    in property <string> scope;

    width: 46px;
    height: 22px;
    border-radius: 4px;
    border-width: 1px;
    border-color: root.scope == "global" ? Theme.primary : Theme.secondary;
    background: root.scope == "global" ? #25264a : #123627;

    UiText {
        text: root.scope == "global" ? "Glb" : "Env";
        width: parent.width;
        height: parent.height;
        color: root.scope == "global" ? Theme.primary : Theme.secondary;
        font-family: "JetBrains Mono";
        font-size: 11px;
        font-weight: 800;
        horizontal-alignment: center;
        vertical-alignment: center;
        overflow: elide;
    }
}

component EnvironmentVariableRow inherits Rectangle {
    in property <int> row_id;
    in property <string> scope;
    in-out property <string> name;
    in-out property <string> initial_value;
    in-out property <string> current_value;
    in property <bool> enabled: true;
    callback edited(int, string, string, string);
    callback delete_requested(int, string);

    height: 48px;
    horizontal-stretch: 1;
    border-radius: 6px;
    border-width: 1px;
    border-color: Theme.outline_variant;
    background: row_touch.has-hover ? Theme.surface_container_high : Theme.surface_container_low;

    row_touch := TouchArea {}

    TextField {
        x: 10px;
        y: 6px;
        width: 142px;
        height: 34px;
        text <=> root.name;
        placeholder: "VARIABLE";
        mono: true;
        enabled: root.enabled;
        edited => {
            root.edited(root.row_id, root.scope, root.name, root.current_value);
        }
    }

    TextField {
        x: 164px;
        y: 6px;
        width: 170px;
        height: 34px;
        text <=> root.initial_value;
        placeholder: "Initial";
        mono: true;
        enabled: root.enabled;
        edited => {
            root.current_value = root.initial_value;
            root.edited(root.row_id, root.scope, root.name, root.initial_value);
        }
    }

    TextField {
        x: 346px;
        y: 6px;
        width: parent.width - 472px;
        height: 34px;
        text <=> root.current_value;
        placeholder: "Current";
        mono: true;
        enabled: root.enabled;
        edited => {
            root.initial_value = root.current_value;
            root.edited(root.row_id, root.scope, root.name, root.current_value);
        }
    }

    VariableScopePill {
        x: parent.width - 112px;
        y: 13px;
        scope: root.scope;
    }

    ActionButton {
        x: parent.width - 54px;
        y: 7px;
        text: "Del";
        button_width: 44px;
        warning: true;
        enabled: root.enabled;
        clicked => {
            root.delete_requested(root.row_id, root.scope);
        }
    }
}

component EnvironmentVariableTable inherits Rectangle {
    in-out property <[VariableTableRow]> variable_rows;
    in-out property <string> environment_name;
    in-out property <string> environment_draft_name;
    in property <bool> busy;
    callback environment_name_changed(string);
    callback add_environment(string);
    callback rename_environment(string, string);
    callback delete_environment(string);
    callback update_variable_row(int, string, string, string);
    callback add_variable(string);
    callback delete_variable_row(int, string);

    property <string> environment_label: root.environment_name == "test" ? "Staging" : root.environment_name == "prod" ? "Production" : root.environment_name == "dev" ? "Development" : root.environment_name == "local" ? "Local" : root.environment_name == "" ? "No Environment" : root.environment_name;

    horizontal-stretch: 1;
    vertical-stretch: 1;
    background: Theme.surface;

    VerticalLayout {
        padding: 0px;
        spacing: 0px;

        Rectangle {
            height: 88px;
            horizontal-stretch: 1;
            background: Theme.surface;

            HorizontalLayout {
                padding-left: 18px;
                padding-right: 18px;
                spacing: 12px;
                alignment: center;

                Rectangle {
                    horizontal-stretch: 1;
                    height: 58px;
                    background: transparent;

                    UiText {
                        x: 0px;
                        y: 2px;
                        text: root.environment_label + " Variables";
                        width: parent.width;
                        height: 30px;
                        color: Theme.on_surface;
                        font-size: 22px;
                        font-weight: 800;
                        vertical-alignment: center;
                        overflow: elide;
                    }

                    UiText {
                        x: 0px;
                        y: 34px;
                        text: "Variable / Initial Value / Current Value / Scope";
                        width: parent.width;
                        height: 18px;
                        color: Theme.on_surface_variant;
                        font-size: 12px;
                        vertical-alignment: center;
                        overflow: elide;
                    }
                }

                TextField {
                    width: 132px;
                    height: 34px;
                    text <=> root.environment_draft_name;
                    placeholder: "env name";
                    mono: true;
                    enabled: !root.busy;
                    accepted => {
                        root.environment_name_changed(root.environment_draft_name);
                    }
                }

                ActionButton {
                    text: "Use";
                    button_width: 48px;
                    enabled: !root.busy && root.environment_draft_name != "";
                    clicked => {
                        root.environment_name_changed(root.environment_draft_name);
                    }
                }

                ActionButton {
                    text: "Add";
                    button_width: 48px;
                    enabled: !root.busy && root.environment_draft_name != "";
                    clicked => {
                        root.add_environment(root.environment_draft_name);
                    }
                }

                ActionButton {
                    text: "Ren";
                    button_width: 48px;
                    enabled: !root.busy && root.environment_name != "" && root.environment_draft_name != "" && root.environment_draft_name != root.environment_name;
                    clicked => {
                        root.rename_environment(root.environment_name, root.environment_draft_name);
                    }
                }

                ActionButton {
                    text: "Del";
                    button_width: 48px;
                    warning: true;
                    enabled: !root.busy && root.environment_name != "";
                    clicked => {
                        root.delete_environment(root.environment_name);
                    }
                }

                ActionButton {
                    text: "+ Global";
                    button_width: 86px;
                    enabled: !root.busy;
                    clicked => {
                        root.add_variable("global");
                    }
                }

                ActionButton {
                    text: "+ Env";
                    button_width: 70px;
                    primary: true;
                    enabled: !root.busy && root.environment_name != "";
                    clicked => {
                        root.add_variable("environment");
                    }
                }
            }
        }

        Rectangle {
            height: 1px;
            horizontal-stretch: 1;
            background: Theme.outline_variant;
        }

        Rectangle {
            height: 34px;
            horizontal-stretch: 1;
            background: Theme.surface_container_lowest;

            UiText {
                x: 28px;
                text: "Variable";
                width: 126px;
                height: parent.height;
                color: Theme.on_surface_variant;
                font-size: 11px;
                font-weight: 800;
                vertical-alignment: center;
                overflow: elide;
            }

            UiText {
                x: 182px;
                text: "Initial Value";
                width: 150px;
                height: parent.height;
                color: Theme.on_surface_variant;
                font-size: 11px;
                font-weight: 800;
                vertical-alignment: center;
                overflow: elide;
            }

            UiText {
                x: 364px;
                text: "Current Value";
                width: parent.width - 494px;
                height: parent.height;
                color: Theme.on_surface_variant;
                font-size: 11px;
                font-weight: 800;
                vertical-alignment: center;
                overflow: elide;
            }

            UiText {
                x: parent.width - 112px;
                text: "Scope";
                width: 46px;
                height: parent.height;
                color: Theme.on_surface_variant;
                font-size: 11px;
                font-weight: 800;
                horizontal-alignment: center;
                vertical-alignment: center;
                overflow: elide;
            }
        }

        Rectangle {
            horizontal-stretch: 1;
            vertical-stretch: 1;
            background: Theme.surface;

            if root.variable_rows.length == 0: UiText {
                x: 18px;
                y: 16px;
                text: "No variables yet";
                width: parent.width - 36px;
                height: 28px;
                color: Theme.outline;
                font-size: 13px;
                vertical-alignment: center;
                overflow: elide;
            }

            if root.variable_rows.length != 0: ListView {
                x: 18px;
                y: 16px;
                width: parent.width - 36px;
                height: parent.height - 32px;
                vertical-scrollbar-policy: ScrollBarPolicy.as-needed;
                horizontal-scrollbar-policy: ScrollBarPolicy.as-needed;

                for row in root.variable_rows: EnvironmentVariableRow {
                    row_id: row.row_id;
                    scope: row.scope;
                    name: row.name;
                    initial_value: row.initial_value;
                    current_value: row.current_value;
                    enabled: !root.busy;
                    edited(row_id, scope, name, value) => {
                        root.update_variable_row(row_id, scope, name, value);
                    }
                    delete_requested(row_id, scope) => {
                        root.delete_variable_row(row_id, scope);
                    }
                }
            }
        }
    }
}

component VariableDetailsPanel inherits Rectangle {
    in property <string> preview;

    width: 288px;
    vertical-stretch: 1;
    background: Theme.surface_container_low;

    VerticalLayout {
        padding: 16px;
