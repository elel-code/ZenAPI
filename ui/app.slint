component HeaderEditorPanel inherits Rectangle {
    in-out property <string> request_headers;
    in-out property <[KeyValueTableRow]> header_rows;
    in property <bool> busy;
    callback apply_header_preset(string);
    callback add_header();
    callback update_header_row(int, string, string);
    callback delete_header_row(int);

    horizontal-stretch: 1;
    vertical-stretch: 1;
    background: transparent;

    VerticalLayout {
        padding: 0px;
        spacing: 6px;

        HorizontalLayout {
            height: 22px;
            spacing: 6px;
            alignment: center;

            UiText {
                text: "Headers";
                horizontal-stretch: 1;
                height: parent.height;
                color: Theme.on_surface_variant;
                font-size: 12px;
                font-weight: 800;
                vertical-alignment: center;
                overflow: elide;
            }

            ActionButton {
                text: "Accept";
                button_width: 58px;
                enabled: !root.busy;
                clicked => {
                    root.apply_header_preset("accept-json");
                }
            }

            ActionButton {
                text: "Content";
                button_width: 64px;
                enabled: !root.busy;
                clicked => {
                    root.apply_header_preset("content-json");
                }
            }

            ActionButton {
                text: "Bearer";
                button_width: 60px;
                enabled: !root.busy;
                clicked => {
                    root.apply_header_preset("bearer-token");
                }
            }
        }

        KeyValueTablePanel {
            rows <=> root.header_rows;
            title: "";
            key_header: "Header";
            value_header: "Value";
            helper: "Stored as Header=value lines; presets update common headers.";
            busy: root.busy;
            add_row => {
                root.add_header();
            }
            update_row(row_id, key, value) => {
                root.update_header_row(row_id, key, value);
            }
            delete_row(row_id) => {
                root.delete_header_row(row_id);
            }
        }
    }
}

component SidebarProfile inherits Rectangle {
    height: 58px;
    horizontal-stretch: 1;
