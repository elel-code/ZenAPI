import { Theme } from "theme.slint";
import { DataPanel, UiText } from "widgets.slint";

component SettingsPageTitle inherits Rectangle {
    in property <string> title;
    in property <string> subtitle;

    height: 62px;
    horizontal-stretch: 1;
    background: transparent;

    UiText {
        text: root.title;
        x: 0px;
        y: 0px;
        width: parent.width;
        height: 34px;
        color: Theme.on_surface;
        font-size: 26px;
        font-weight: 800;
        vertical-alignment: center;
        overflow: elide;
    }

    UiText {
        text: root.subtitle;
        x: 0px;
        y: 36px;
        width: parent.width;
        height: 22px;
        color: Theme.on_surface_variant;
        font-size: 13px;
        vertical-alignment: center;
        overflow: elide;
    }
}

export component SettingsPage inherits Rectangle {
    in property <string> spec_label;
    in property <bool> spec_loaded;
    in property <string> file_path;
    in property <string> collection_name;
    in property <string> collection_path;
    in property <int> route_count;
    in property <int> history_count;

    horizontal-stretch: 1;
    vertical-stretch: 1;
    background: Theme.background;

    HorizontalLayout {
        spacing: 0px;

        Rectangle {
            horizontal-stretch: 1;
            vertical-stretch: 1;
            background: Theme.surface;

            VerticalLayout {
                padding: 28px;
                spacing: 18px;

                SettingsPageTitle {
                    title: "Project Settings";
                    subtitle: "Local workspace configuration and persistence state.";
                }

                DataPanel {
                    title: "Workspace";
                    body: "Spec: " + (root.spec_loaded ? root.spec_label : "None") + "\nRoutes imported: " + root.route_count + "\nHistory entries: " + root.history_count;
                }

                HorizontalLayout {
                    height: 150px;
                    spacing: 16px;

                    DataPanel {
                        title: "OpenAPI Source";
                        body: root.file_path == "" ? "No OpenAPI file path selected." : root.file_path;
                    }

                    DataPanel {
                        title: "Collection File";
                        body: root.collection_path == "" ? "No collection file path selected." : root.collection_path;
                    }
                }

                DataPanel {
                    title: "Local Storage";
                    body: "The Slint app currently stores history locally and keeps environment profiles session-scoped. Remote project visibility, ownership transfer, and destructive account controls are not implemented.";
                }
            }
        }

        Rectangle {
            width: 1px;
            background: Theme.outline_variant;
        }

        Rectangle {
            width: 320px;
            vertical-stretch: 1;
            background: Theme.surface_container_lowest;

            VerticalLayout {
                padding: 16px;
                spacing: 12px;

                UiText {
                    text: "CURRENT STATE";
                    height: 22px;
                    horizontal-stretch: 1;
                    color: Theme.on_surface;
                    font-size: 13px;
                    font-weight: 800;
                    vertical-alignment: center;
                    overflow: elide;
                }

                DataPanel {
                    title: "Collection";
                    body: root.collection_name == "" ? "None" : root.collection_name;
                }

                DataPanel {
                    title: "Files";
                    body: "OpenAPI: " + (root.file_path == "" ? "not selected" : root.file_path) + "\nCollection: " + (root.collection_path == "" ? "not selected" : root.collection_path);
                }

                DataPanel {
                    title: "Missing Backend";
                    body: "Audit trails, project membership, remote visibility, and ownership controls need real persistence before controls are exposed.";
                }
            }
        }
    }
}
