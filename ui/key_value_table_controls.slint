import { Theme } from "theme.slint";
import { TextField } from "text_field.slint";
import { ActionButton } from "action_button.slint";
import { UiText } from "widgets.slint";

export component KeyValueTableControls inherits Rectangle {
    in property <string> title;
    in property <bool> busy: false;
    in property <bool> show_paste: false;
    in property <bool> show_import: false;
    in-out property <string> import_path;
    in property <bool> show_file_attach: false;
    in-out property <string> file_field;
    in-out property <string> file_path;
    callback add_row();
    callback paste_rows();
    callback import_rows(string);
    callback pick_import_file();
    callback add_file_row(string, string);
    callback pick_file();

    height: 28px + (root.show_import ? 42px : 0px) + (root.show_file_attach ? 42px : 0px);
    horizontal-stretch: 1;
    background: transparent;

    VerticalLayout {
        padding: 0px;
        spacing: 8px;

        HorizontalLayout {
            height: 28px;
            spacing: 8px;
            alignment: center;

            UiText {
                text: root.title;
                horizontal-stretch: 1;
                height: parent.height;
                color: Theme.on_surface_variant;
                font-size: 12px;
                font-weight: 800;
                vertical-alignment: center;
                overflow: elide;
            }

            ActionButton {
                text: "+";
                button_width: 34px;
                enabled: !root.busy;
                clicked => {
                    root.add_row();
                }
            }

            if root.show_paste: ActionButton {
                text: "Paste";
                button_width: 58px;
                enabled: !root.busy;
                clicked => {
                    root.paste_rows();
                }
            }
        }

        if root.show_import: HorizontalLayout {
            height: 34px;
            spacing: 8px;

            TextField {
                text <=> root.import_path;
                placeholder: "key-value file path";
                mono: true;
                enabled: !root.busy;
            }

            ActionButton {
                text: "Open";
                button_width: 54px;
                enabled: !root.busy;
                clicked => {
                    root.pick_import_file();
                }
            }

            ActionButton {
                text: "Import";
                button_width: 68px;
                enabled: !root.busy && root.import_path != "";
                clicked => {
                    root.import_rows(root.import_path);
                }
            }
        }

        if root.show_file_attach: HorizontalLayout {
            height: 34px;
            spacing: 8px;

            TextField {
                text <=> root.file_field;
                placeholder: "file field";
                mono: true;
                enabled: !root.busy;
            }

            TextField {
                text <=> root.file_path;
                placeholder: "/absolute/path/to/file";
                mono: true;
                enabled: !root.busy;
            }

            ActionButton {
                text: "Pick";
                button_width: 50px;
                enabled: !root.busy;
                clicked => {
                    root.pick_file();
                }
            }

            ActionButton {
                text: "Add File";
                button_width: 76px;
                enabled: !root.busy && root.file_field != "" && root.file_path != "";
                clicked => {
                    root.add_file_row(root.file_field, root.file_path);
                }
            }
        }
    }
}
