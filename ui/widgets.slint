import { ScrollView } from "std-widgets.slint";
import { Theme } from "theme.slint";

export component UiText inherits Text {
    font-family: "Inter";
    font-size: 13px;
    font-weight: 500;
    color: Theme.on_surface;
    letter-spacing: 0px;
}

export global MethodStyle {
    public pure function text_color(method: string) -> color {
        return method == "GET" ? #60a5fa : method == "POST" ? #4ade80 : method == "PUT" ? #facc15 : method == "PATCH" ? #facc15 : method == "DELETE" ? #f87171 : Theme.outline;
    }

    public pure function background(method: string) -> color {
        return method == "GET" ? #1d3d66 : method == "POST" ? #17452c : method == "PUT" ? #4a3b12 : method == "PATCH" ? #4a3b12 : method == "DELETE" ? #4f1d22 : #242430;
    }

    public pure function border(method: string) -> color {
        return method == "GET" ? #3b82f6 : method == "POST" ? #22c55e : method == "PUT" ? #eab308 : method == "PATCH" ? #eab308 : method == "DELETE" ? #ef4444 : Theme.outline_variant;
    }
}

export global ToneStyle {
    public pure function color(tone: string) -> color {
        return tone == "error" ? Theme.error : tone == "busy" ? Theme.tertiary : tone == "success" ? Theme.secondary : Theme.on_surface_variant;
    }
}

export global ButtonStyle {
    public pure function border_color(enabled: bool, primary: bool, warning: bool) -> color {
        return !enabled ? Theme.outline_variant : warning ? Theme.tertiary : primary ? Theme.primary_container : Theme.outline_variant;
    }

    public pure function background_color(enabled: bool, primary: bool, warning: bool, pressed: bool, hovered: bool) -> color {
        return !enabled ? Theme.surface_container_low : warning ? (pressed ? #9b520f : hovered ? #c96b18 : #7a430d) : primary ? (pressed ? #3d3fba : hovered ? #5557df : Theme.inverse_primary) : (pressed ? Theme.surface_container_highest : hovered ? Theme.surface_container_high : Theme.surface_container);
    }

    public pure function text_color(enabled: bool, primary: bool, warning: bool) -> color {
        return !enabled ? Theme.outline : primary ? Theme.on_surface : warning ? Theme.on_surface : Theme.on_surface;
    }
}

export component MethodChip inherits Rectangle {
    in property <string> method;

    width: 62px;
    height: 22px;
    border-radius: 4px;
    border-width: 1px;
    border-color: MethodStyle.border(root.method);
    background: MethodStyle.background(root.method);

    UiText {
        text: root.method;
        width: parent.width;
        height: parent.height;
        font-family: "JetBrains Mono";
        font-size: 12px;
        font-weight: 800;
        color: MethodStyle.text_color(root.method);
        horizontal-alignment: center;
        vertical-alignment: center;
        overflow: elide;
    }
}

export component StatusDot inherits Rectangle {
    in property <string> tone: "inactive";

    width: 8px;
    height: 8px;
    border-radius: 4px;
    background: root.tone == "active" ? Theme.secondary : root.tone == "error" ? Theme.error : Theme.outline_variant;
}

export component ActionButton inherits Rectangle {
    in property <string> text;
    in property <bool> enabled: true;
    in property <bool> primary: false;
    in property <bool> warning: false;
    in property <length> button_width: 96px;
    callback clicked();

    width: root.button_width;
    height: 34px;
    border-radius: 8px;
    border-width: 1px;
    border-color: ButtonStyle.border_color(root.enabled, root.primary, root.warning);
    background: ButtonStyle.background_color(root.enabled, root.primary, root.warning, touch.pressed, touch.has-hover);
    opacity: root.enabled ? 1 : 0.62;

    touch := TouchArea {
        enabled: root.enabled;
        mouse-cursor: root.enabled ? pointer : default;
        clicked => {
            root.clicked();
        }
    }

    UiText {
        text: root.text;
        width: parent.width;
        height: parent.height;
        color: ButtonStyle.text_color(root.enabled, root.primary, root.warning);
        font-size: 13px;
        font-weight: 700;
        horizontal-alignment: center;
        vertical-alignment: center;
        overflow: elide;
    }
}

export component RouteListItem inherits Rectangle {
    in property <string> method;
    in property <string> path;
    in property <string> summary;
    in property <bool> selected;
    callback picked();

    height: 44px;
    horizontal-stretch: 1;
    border-radius: 6px;
    background: root.selected ? Theme.surface_variant : touch.has-hover ? Theme.surface_container_high : Theme.surface_container_low;

    touch := TouchArea {
        mouse-cursor: pointer;
        clicked => {
            root.picked();
        }
    }

    Rectangle {
        x: 0px;
        y: 5px;
        width: 2px;
        height: 34px;
        background: Theme.primary;
        visible: root.selected;
    }

    MethodChip {
        x: 10px;
        y: 11px;
        method: root.method;
    }

    UiText {
        x: 82px;
        y: 5px;
        text: root.path;
        width: parent.width - 92px;
        height: 19px;
        font-family: "JetBrains Mono";
        font-size: 12px;
        font-weight: 700;
        color: Theme.on_surface;
        overflow: elide;
        vertical-alignment: center;
    }

    UiText {
        x: 82px;
        y: 24px;
        text: root.summary;
        width: parent.width - 92px;
        height: 15px;
        font-size: 11px;
        color: Theme.on_surface_variant;
        visible: root.summary != "";
        overflow: elide;
        vertical-alignment: center;
    }
}

export component HistoryListItem inherits Rectangle {
    in property <int> entry_id;
    in property <string> method;
    in property <string> url;
    in property <string> status;
    in property <bool> enabled: true;
    callback picked(int);
    callback delete_requested(int);

    height: 52px;
    horizontal-stretch: 1;
    border-radius: 6px;
    background: touch.has-hover ? Theme.surface_container_high : Theme.surface_container_low;

    touch := TouchArea {
        mouse-cursor: pointer;
        clicked => {
            root.picked(root.entry_id);
        }
    }

    MethodChip {
        x: 10px;
        y: 8px;
        method: root.method;
    }

    UiText {
        x: 82px;
        y: 6px;
        text: root.url;
        width: parent.width - 142px;
        height: 20px;
        font-family: "JetBrains Mono";
        font-size: 12px;
        font-weight: 700;
        color: Theme.on_surface;
        overflow: elide;
        vertical-alignment: center;
    }

    UiText {
        x: 82px;
        y: 28px;
        text: root.status;
        width: parent.width - 142px;
        height: 16px;
        font-family: "JetBrains Mono";
        font-size: 11px;
        color: Theme.on_surface_variant;
        overflow: elide;
        vertical-alignment: center;
    }

    ActionButton {
        x: parent.width - 52px;
        y: 9px;
        text: "Del";
        button_width: 42px;
        warning: true;
        enabled: root.enabled;
        clicked => {
            root.delete_requested(root.entry_id);
        }
    }
}

export component CollectionListItem inherits Rectangle {
    in property <int> entry_id;
    in property <string> method;
    in property <string> name;
    in property <string> url;
    in property <bool> enabled: true;
    callback picked(int);
    callback duplicate_requested(int);
    callback delete_requested(int);

    height: 54px;
    horizontal-stretch: 1;
    border-radius: 6px;
    background: touch.has-hover ? Theme.surface_container_high : Theme.surface_container_low;

    touch := TouchArea {
        mouse-cursor: pointer;
        clicked => {
            root.picked(root.entry_id);
        }
    }

    MethodChip {
        x: 10px;
        y: 9px;
        method: root.method;
    }

    UiText {
        x: 82px;
        y: 6px;
        text: root.name;
        width: parent.width - 186px;
        height: 20px;
        font-size: 12px;
        font-weight: 700;
        color: Theme.on_surface;
        overflow: elide;
        vertical-alignment: center;
    }

    UiText {
        x: 82px;
        y: 29px;
        text: root.url;
        width: parent.width - 186px;
        height: 16px;
        font-family: "JetBrains Mono";
        font-size: 11px;
        color: Theme.on_surface_variant;
        overflow: elide;
        vertical-alignment: center;
    }

    ActionButton {
        x: parent.width - 96px;
        y: 10px;
        text: "Dup";
        button_width: 40px;
        enabled: root.enabled;
        clicked => {
            root.duplicate_requested(root.entry_id);
        }
    }

    ActionButton {
        x: parent.width - 50px;
        y: 10px;
        text: "Del";
        button_width: 40px;
        warning: true;
