export component MockLogItem inherits Rectangle {
    in property <string> method;
    in property <string> path;
    in property <string> status;

    height: 34px;
    horizontal-stretch: 1;
    border-radius: 6px;
    background: Theme.surface_container_low;

    MethodChip {
        x: 8px;
        y: 6px;
        method: root.method;
    }

    UiText {
        x: 78px;
        y: 4px;
        text: root.path;
        width: parent.width - 126px;
        height: 26px;
        font-family: "JetBrains Mono";
        font-size: 11px;
        font-weight: 700;
        color: Theme.on_surface;
        overflow: elide;
        vertical-alignment: center;
    }

    UiText {
        x: parent.width - 40px;
        y: 4px;
        text: root.status;
        width: 32px;
        height: 26px;
        font-family: "JetBrains Mono";
        font-size: 11px;
        font-weight: 800;
        color: root.status == "200" || root.status == "204" ? Theme.secondary : Theme.error;
        horizontal-alignment: right;
        overflow: elide;
        vertical-alignment: center;
    }
}

