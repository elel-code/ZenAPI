import { ListView } from "std-widgets.slint";
import { Theme } from "theme.slint";
import { VariableTableRow } from "types.slint";
import { UiText } from "widgets.slint";
import { EnvironmentVariableRow } from "environment_variable_row.slint";
import { EnvironmentVariableToolbar } from "environment_variable_toolbar.slint";

export component EnvironmentVariableTable inherits Rectangle {
    in-out property <[VariableTableRow]> variable_rows;
    in-out property <string> environment_name;
    in-out property <string> environment_draft_name;
    in property <bool> busy;
    callback environment_name_changed(string);
    callback add_environment(string);
    callback rename_environment(string, string);
    callback delete_environment(string);
    callback update_variable_row(int, string, string, string);
    callback add_variable(string);
    callback delete_variable_row(int, string);

    property <string> environment_label: root.environment_name == "test" ? "Staging" : root.environment_name == "prod" ? "Production" : root.environment_name == "dev" ? "Development" : root.environment_name == "local" ? "Local" : root.environment_name == "" ? "No Environment" : root.environment_name;

    horizontal-stretch: 1;
    vertical-stretch: 1;
    background: Theme.surface;

    VerticalLayout {
        padding: 0px;
        spacing: 0px;

        EnvironmentVariableToolbar {
            environment_label: root.environment_label;
            environment_name <=> root.environment_name;
            environment_draft_name <=> root.environment_draft_name;
            busy: root.busy;
            environment_name_changed(name) => {
                root.environment_name_changed(name);
            }
            add_environment(name) => {
                root.add_environment(name);
            }
            rename_environment(old_name, new_name) => {
                root.rename_environment(old_name, new_name);
            }
            delete_environment(name) => {
                root.delete_environment(name);
            }
            add_variable(scope) => {
                root.add_variable(scope);
            }
        }

        Rectangle {
            height: 1px;
            horizontal-stretch: 1;
            background: Theme.outline_variant;
        }

        Rectangle {
            height: 34px;
            horizontal-stretch: 1;
            background: Theme.surface_container_lowest;

            UiText {
                x: 28px;
                text: "Variable";
                width: 126px;
                height: parent.height;
                color: Theme.on_surface_variant;
                font-size: 11px;
                font-weight: 800;
                vertical-alignment: center;
                overflow: elide;
            }

            UiText {
                x: 182px;
                text: "Initial Value";
                width: 150px;
                height: parent.height;
                color: Theme.on_surface_variant;
                font-size: 11px;
                font-weight: 800;
                vertical-alignment: center;
                overflow: elide;
            }

            UiText {
                x: 364px;
                text: "Current Value";
                width: parent.width - 494px;
                height: parent.height;
                color: Theme.on_surface_variant;
                font-size: 11px;
                font-weight: 800;
                vertical-alignment: center;
                overflow: elide;
            }

            UiText {
                x: parent.width - 112px;
                text: "Scope";
                width: 46px;
                height: parent.height;
                color: Theme.on_surface_variant;
                font-size: 11px;
                font-weight: 800;
                horizontal-alignment: center;
                vertical-alignment: center;
                overflow: elide;
            }
        }

        Rectangle {
            horizontal-stretch: 1;
            vertical-stretch: 1;
            background: Theme.surface;

            if root.variable_rows.length == 0: UiText {
                x: 18px;
                y: 16px;
                text: "No variables yet";
                width: parent.width - 36px;
                height: 28px;
                color: Theme.outline;
                font-size: 13px;
                vertical-alignment: center;
                overflow: elide;
            }

            if root.variable_rows.length != 0: ListView {
                x: 18px;
                y: 16px;
                width: parent.width - 36px;
                height: parent.height - 32px;
                vertical-scrollbar-policy: ScrollBarPolicy.as-needed;
                horizontal-scrollbar-policy: ScrollBarPolicy.as-needed;

                for row in root.variable_rows: EnvironmentVariableRow {
                    row_id: row.row_id;
                    scope: row.scope;
                    name: row.name;
                    initial_value: row.initial_value;
                    current_value: row.current_value;
                    enabled: !root.busy;
                    edited(row_id, scope, name, value) => {
                        root.update_variable_row(row_id, scope, name, value);
                    }
                    delete_requested(row_id, scope) => {
                        root.delete_variable_row(row_id, scope);
                    }
                }
            }
        }
    }
}
