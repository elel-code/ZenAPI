import { ResponsePanel } from "response_panel.slint";
import { RunnerRow } from "types.slint";

export component RequestBuilderResponseHost inherits ResponsePanel {
    in-out property <string> workspace_response_body;
    in-out property <string> workspace_response_raw_body;
    in-out property <string> workspace_response_headers;
    in-out property <string> workspace_response_cookies;
    in-out property <string> workspace_folded_response_body;
    in-out property <string> workspace_folded_response_raw_body;
    in-out property <string> workspace_folded_response_headers;
    in-out property <string> workspace_folded_response_cookies;
    in-out property <string> workspace_codegen_language;
    in-out property <string> workspace_codegen_output;
    in-out property <string> workspace_codegen_path;
    in-out property <[RunnerRow]> workspace_runner_rows;
    in-out property <string> workspace_runner_summary;
    in-out property <string> workspace_runner_delay_ms;
    in-out property <string> workspace_runner_report_path;
    in-out property <string> workspace_runner_report_format;
    in-out property <bool> workspace_runner_stop_on_failure;
    in-out property <bool> workspace_runner_active;
    in property <string> workspace_response_status;
    in property <string> workspace_response_meta;
    in property <string> workspace_response_time;
    in property <string> workspace_response_size;
    in property <string> workspace_response_tone;
    in property <bool> workspace_busy;
    callback workspace_generate_code();
    callback workspace_save_codegen(string);
    callback workspace_pick_codegen_path();
    callback workspace_run_collection();
    callback workspace_cancel_collection_run();
    callback workspace_save_runner_report(string);
    callback workspace_pick_runner_report_path();
    callback workspace_copy_response(string, string, int, int);
    callback workspace_format_response(string);
    callback workspace_summarize_graphql_schema(string, string);

    response_body <=> root.workspace_response_body;
    response_raw_body <=> root.workspace_response_raw_body;
    response_headers <=> root.workspace_response_headers;
    response_cookies <=> root.workspace_response_cookies;
    folded_response_body <=> root.workspace_folded_response_body;
    folded_response_raw_body <=> root.workspace_folded_response_raw_body;
    folded_response_headers <=> root.workspace_folded_response_headers;
    folded_response_cookies <=> root.workspace_folded_response_cookies;
    codegen_language <=> root.workspace_codegen_language;
    codegen_output <=> root.workspace_codegen_output;
    codegen_path <=> root.workspace_codegen_path;
    runner_rows <=> root.workspace_runner_rows;
    runner_summary <=> root.workspace_runner_summary;
    runner_delay_ms <=> root.workspace_runner_delay_ms;
    runner_report_path <=> root.workspace_runner_report_path;
    runner_report_format <=> root.workspace_runner_report_format;
    runner_stop_on_failure <=> root.workspace_runner_stop_on_failure;
    runner_active <=> root.workspace_runner_active;
    response_status: root.workspace_response_status;
    response_meta: root.workspace_response_meta;
    response_time: root.workspace_response_time;
    response_size: root.workspace_response_size;
    response_tone: root.workspace_response_tone;
    busy: root.workspace_busy;
    generate_code => {
        root.workspace_generate_code();
    }
    save_codegen(path) => {
        root.workspace_save_codegen(path);
    }
    pick_codegen_path => {
        root.workspace_pick_codegen_path();
    }
    run_collection => {
        root.workspace_run_collection();
    }
    cancel_collection_run => {
        root.workspace_cancel_collection_run();
    }
    save_runner_report(path) => {
        root.workspace_save_runner_report(path);
    }
    pick_runner_report_path => {
        root.workspace_pick_runner_report_path();
    }
    copy_response(tab, text, anchor, cursor) => {
        root.workspace_copy_response(tab, text, anchor, cursor);
    }
    format_response(tab) => {
        root.workspace_format_response(tab);
    }
    summarize_graphql_schema(tab, text) => {
        root.workspace_summarize_graphql_schema(tab, text);
    }
}
