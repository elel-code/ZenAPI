import { ListView } from "std-widgets.slint";
import { DataPanel, MockLogLine } from "cards.slint";
import { Theme } from "theme.slint";
import { TextField } from "text_field.slint";
import { MockLogRow } from "types.slint";
import { ActionButton } from "action_button.slint";
import { UiText } from "widgets.slint";

export component MockManagerTrafficPanel inherits Rectangle {
    in property <[MockLogRow]> mock_logs;
    in-out property <string> mock_log_filter;
    in-out property <string> mock_log_path;
    in property <bool> busy;
    callback filter_mock_logs(string);
    callback save_mock_logs(string);
    callback pick_mock_log_path();
    callback clear_mock_logs();

    vertical-stretch: 1;
    horizontal-stretch: 1;
    background: Theme.surface_container_lowest;

    VerticalLayout {
        padding: 14px;
        spacing: 10px;

        HorizontalLayout {
            height: 34px;
            spacing: 8px;
            alignment: center;

            UiText {
                text: "LIVE TRAFFIC";
                height: parent.height;
                horizontal-stretch: 1;
                color: Theme.on_surface;
                font-size: 12px;
                font-weight: 800;
                vertical-alignment: center;
                overflow: elide;
            }

            ActionButton {
                text: "Clear";
                button_width: 62px;
                warning: true;
                enabled: !root.busy && root.mock_logs.length > 0;
                clicked => {
                    root.clear_mock_logs();
                }
            }
        }

        TextField {
            text <=> root.mock_log_filter;
            placeholder: "Filter traffic";
            mono: true;
            enabled: !root.busy;
            edited => {
                root.filter_mock_logs(root.mock_log_filter);
            }
        }

        if root.mock_logs.length == 0: DataPanel {
            title: "No requests";
            body: "Incoming mock traffic appears here.";
        }

        if root.mock_logs.length != 0: ListView {
            horizontal-stretch: 1;
            vertical-stretch: 1;
            vertical-scrollbar-policy: ScrollBarPolicy.as-needed;
            horizontal-scrollbar-policy: ScrollBarPolicy.as-needed;

            for log in root.mock_logs: MockLogLine {
                method: log.method;
                path: log.path;
                status: log.status;
            }
        }

        HorizontalLayout {
            height: 34px;
            spacing: 8px;

            TextField {
                text <=> root.mock_log_path;
                placeholder: "mock-logs.json";
                mono: true;
                enabled: !root.busy;
            }

            ActionButton {
                text: "Open";
                button_width: 58px;
                enabled: !root.busy;
                clicked => {
                    root.pick_mock_log_path();
                }
            }

            ActionButton {
                text: "Save";
                button_width: 62px;
                enabled: !root.busy && root.mock_logs.length > 0;
                clicked => {
                    root.save_mock_logs(root.mock_log_path);
                }
            }
        }
    }
}
