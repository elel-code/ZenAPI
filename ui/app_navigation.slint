import { ScrollView } from "std-widgets.slint";
import { Theme } from "theme.slint";
import { UiText } from "widgets.slint";
import { SidebarProfile } from "sidebar.slint";

component AppNavItem inherits Rectangle {
    in property <int> page_index;
    in property <string> label;
    in property <string> glyph;
    in property <bool> selected;
    callback picked(int);

    height: 36px;
    horizontal-stretch: 1;
    border-radius: 8px;
    background: root.selected ? Theme.primary_container : touch.has-hover ? Theme.surface_variant : transparent;

    touch := TouchArea {
        mouse-cursor: pointer;
        clicked => {
            root.picked(root.page_index);
        }
    }

    UiText {
        x: 12px;
        text: root.glyph;
        width: 22px;
        height: parent.height;
        color: root.selected ? Theme.on_primary_container : Theme.on_surface_variant;
        font-size: 16px;
        font-weight: 800;
        horizontal-alignment: center;
        vertical-alignment: center;
        overflow: elide;
    }

    UiText {
        x: 46px;
        text: root.label;
        width: parent.width - 58px;
        height: parent.height;
        color: root.selected ? Theme.on_primary_container : Theme.on_surface_variant;
        font-size: 13px;
        font-weight: root.selected ? 800 : 600;
        vertical-alignment: center;
        overflow: elide;
    }
}

export component AppNavigation inherits Rectangle {
    in-out property <int> active_page_index;
    in property <string> spec_label;
    in property <bool> spec_loaded;
    callback open_page(int);

    width: 240px;
    vertical-stretch: 1;
    background: Theme.surface_container_low;

    nav_scroll := ScrollView {
        width: parent.width;
        height: parent.height;
        viewport-width: self.visible-width;
        viewport-height: max(self.visible-height, 650px);
        vertical-scrollbar-policy: ScrollBarPolicy.as-needed;
        horizontal-scrollbar-policy: ScrollBarPolicy.as-needed;

        Rectangle {
            width: nav_scroll.visible-width;
            height: max(nav_scroll.visible-height, 650px);
            background: transparent;

            VerticalLayout {
                padding: 16px;
                spacing: 12px;

                SidebarProfile {
                    title: root.spec_loaded ? root.spec_label : "Workspace";
                    subtitle: root.spec_loaded ? "OpenAPI imported" : "No OpenAPI loaded";
                }

                Rectangle {
                    height: 1px;
                    horizontal-stretch: 1;
                    background: Theme.outline_variant;
                }

                for item in [
                    { page_index: 0, label: "Dashboard", glyph: "D" },
                    { page_index: 1, label: "Requests", glyph: "R" },
                    { page_index: 2, label: "Mocks", glyph: "M" },
                    { page_index: 3, label: "Test Runner", glyph: "T" },
                    { page_index: 4, label: "Environments", glyph: "E" },
                    { page_index: 5, label: "Traffic Analytics", glyph: "A" },
                ]: AppNavItem {
                    page_index: item.page_index;
                    label: item.label;
                    glyph: item.glyph;
                    selected: root.active_page_index == item.page_index;
                    picked(page_index) => {
                        root.open_page(page_index);
                    }
                }

                Rectangle {
                    height: 1px;
                    horizontal-stretch: 1;
                    background: Theme.outline_variant;
                }

                for item in [
                    { page_index: 6, label: "API Docs", glyph: "D" },
                    { page_index: 7, label: "API Keys", glyph: "K" },
                    { page_index: 8, label: "Team Members", glyph: "T" },
                    { page_index: 9, label: "Project Settings", glyph: "S" },
                    { page_index: 10, label: "Codegen", glyph: "C" },
                ]: AppNavItem {
                    page_index: item.page_index;
                    label: item.label;
                    glyph: item.glyph;
                    selected: root.active_page_index == item.page_index;
                    picked(page_index) => {
                        root.open_page(page_index);
                    }
                }

                Rectangle {
                    vertical-stretch: 1;
                }
            }
        }
    }
}

component BottomNavItem inherits Rectangle {
    in property <int> page_index;
    in property <string> label;
    in property <string> glyph;
    in property <bool> selected;
    callback picked(int);

    horizontal-stretch: 1;
    height: 56px;
    background: touch.has-hover ? Theme.surface_container_high : transparent;

    touch := TouchArea {
        mouse-cursor: pointer;
        clicked => {
            root.picked(root.page_index);
        }
    }

    Rectangle {
        x: (parent.width - 44px) / 2;
        y: 6px;
        width: 44px;
        height: 22px;
        border-radius: 8px;
        background: root.selected ? Theme.primary_container : transparent;
    }

    UiText {
        x: 0px;
        y: 6px;
        text: root.glyph;
        width: parent.width;
        height: 22px;
        color: root.selected ? Theme.on_primary_container : Theme.on_surface_variant;
        font-size: 13px;
        font-weight: 800;
        horizontal-alignment: center;
        vertical-alignment: center;
        overflow: elide;
    }

    UiText {
        x: 0px;
        y: 31px;
        text: root.label;
        width: parent.width;
        height: 18px;
        color: root.selected ? Theme.primary : Theme.on_surface_variant;
        font-size: 11px;
        font-weight: root.selected ? 800 : 600;
        horizontal-alignment: center;
        vertical-alignment: center;
        overflow: elide;
    }
}

export component BottomNavigation inherits Rectangle {
    in-out property <int> active_page_index;
    callback open_page(int);

    height: 56px;
    horizontal-stretch: 1;
    background: Theme.surface_container;

    Rectangle {
        width: parent.width;
        height: 1px;
        background: Theme.outline_variant;
    }

    HorizontalLayout {
        padding: 0px;
        spacing: 0px;

        for item in [
            { page_index: 0, label: "Dashboard", glyph: "D" },
            { page_index: 1, label: "Requests", glyph: "R" },
            { page_index: 2, label: "Mocks", glyph: "M" },
            { page_index: 6, label: "Docs", glyph: "A" },
        ]: BottomNavItem {
            page_index: item.page_index;
            label: item.label;
            glyph: item.glyph;
            selected: root.active_page_index == item.page_index;
            picked(page_index) => {
                root.open_page(page_index);
            }
        }
    }
}
