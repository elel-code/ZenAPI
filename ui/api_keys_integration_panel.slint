import { ActionButton } from "action_button.slint";
import { ReadOnlyCodeBlock } from "editors.slint";
import { Theme } from "theme.slint";
import { UiText } from "widgets.slint";

export component ApiKeysIntegrationPanel inherits Rectangle {
    in property <bool> has_auth;
    in property <string> curl_hint;
    in property <string> integration_hint;
    callback copy_api_key_integration(string, string);

    width: 320px;
    vertical-stretch: 1;
    background: Theme.surface_container_lowest;

    VerticalLayout {
        padding: 16px;
        spacing: 12px;

        UiText {
            text: "INTEGRATION";
            height: 22px;
            horizontal-stretch: 1;
            color: Theme.on_surface;
            font-size: 13px;
            font-weight: 800;
            vertical-alignment: center;
            overflow: elide;
        }

        UiText {
            text: root.has_auth ? "Equivalent request auth mapping." : "No auth headers or query values will be generated.";
            height: 36px;
            horizontal-stretch: 1;
            color: Theme.on_surface_variant;
            font-size: 12px;
            vertical-alignment: top;
            overflow: elide;
        }

        ReadOnlyCodeBlock {
            text: root.curl_hint;
        }

        ReadOnlyCodeBlock {
            text: root.integration_hint;
        }

        HorizontalLayout {
            height: 34px;
            spacing: 10px;

            ActionButton {
                text: "Copy cURL";
                button_width: 116px;
                primary: true;
                clicked => {
                    root.copy_api_key_integration("curl", root.curl_hint);
                }
            }

            ActionButton {
                text: "Copy Auth";
                button_width: 116px;
                enabled: root.has_auth;
                clicked => {
                    root.copy_api_key_integration("auth", root.integration_hint);
                }
            }
        }
    }
}
