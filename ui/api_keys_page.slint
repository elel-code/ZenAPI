import { Theme } from "theme.slint";
import { ApiKeysDetailPanel } from "api_keys_detail_panel.slint";
import { ApiKeysIntegrationPanel } from "api_keys_integration_panel.slint";
import { ApiKeysListPanel } from "api_keys_list_panel.slint";

export component ApiKeysPage inherits Rectangle {
    in property <string> auth_mode;
    in property <string> auth_config;
    in property <string> auth_basic_username;
    in property <int> auth_key_row_count;
    in property <string> url;

    property <bool> has_auth: root.auth_mode != "none" && (root.auth_config != "" || root.auth_key_row_count > 0 || root.auth_basic_username != "");
    property <string> mode_title: root.auth_mode == "bearer" ? "Bearer Token" : root.auth_mode == "oauth2" ? "OAuth2 Access Token" : root.auth_mode == "jwt" ? "JWT Bearer" : root.auth_mode == "basic" ? "Basic Auth" : root.auth_mode == "api-header" ? "API Key Header" : root.auth_mode == "api-query" ? "API Key Query" : "No Auth";
    property <string> mode_summary: root.auth_mode == "api-header" ? root.auth_key_row_count + " header row(s) configured" : root.auth_mode == "api-query" ? root.auth_key_row_count + " query row(s) configured" : root.auth_mode == "basic" ? (root.auth_basic_username == "" ? "Username/password not configured" : "Username configured; password hidden") : root.has_auth ? "Credential value configured; secret hidden" : "No request auth configured";
    property <string> target_url: root.url == "" ? "<request-url>" : root.url;
    property <string> integration_hint: root.auth_mode == "bearer" ? "Authorization: Bearer <configured-token>" : root.auth_mode == "oauth2" ? "Authorization: Bearer <configured-access-token>" : root.auth_mode == "jwt" ? "Authorization: Bearer <configured-jwt>" : root.auth_mode == "basic" ? "Authorization: Basic <base64-credentials>" : root.auth_mode == "api-header" ? "Configured API key rows are merged into request headers." : root.auth_mode == "api-query" ? "Configured API key rows are merged into request query parameters." : "Requests are sent without generated authorization credentials.";
    property <string> curl_hint: root.auth_mode == "bearer" || root.auth_mode == "oauth2" || root.auth_mode == "jwt" ? "curl \"" + root.target_url + "\" \\\n  -H \"" + root.integration_hint + "\"" : root.auth_mode == "basic" ? "curl \"" + root.target_url + "\" \\\n  -H \"Authorization: Basic <base64-credentials>\"" : root.auth_mode == "api-header" ? "curl \"" + root.target_url + "\" \\\n  -H \"<configured-header>: <configured-value>\"" : root.auth_mode == "api-query" ? "curl \"" + root.target_url + "?<configured-key>=<configured-value>\"" : "curl \"" + root.target_url + "\"";

    horizontal-stretch: 1;
    vertical-stretch: 1;
    background: Theme.background;

    HorizontalLayout {
        spacing: 0px;

        ApiKeysListPanel {
            auth_mode: root.auth_mode;
            auth_basic_username: root.auth_basic_username;
            auth_key_row_count: root.auth_key_row_count;
            has_auth: root.has_auth;
            mode_title: root.mode_title;
            mode_summary: root.mode_summary;
        }

        Rectangle {
            width: 1px;
            background: Theme.outline_variant;
        }

        ApiKeysDetailPanel {
            has_auth: root.has_auth;
            mode_title: root.mode_title;
            mode_summary: root.mode_summary;
            integration_hint: root.integration_hint;
            target_url: root.target_url;
        }

        ApiKeysIntegrationPanel {
            has_auth: root.has_auth;
            curl_hint: root.curl_hint;
            integration_hint: root.integration_hint;
        }
    }
}
