import { Theme } from "theme.slint";
import { ActionButton } from "action_button.slint";
import { TextField } from "text_field.slint";
import { UiText } from "widgets.slint";

export component SidebarOpenApiPanel inherits Rectangle {
    in-out property <string> file_path;
    in property <bool> busy;
    callback import_openapi(string);
    callback pick_openapi_file();

    height: 72px;
    horizontal-stretch: 1;
    background: transparent;

    VerticalLayout {
        padding: 0px;
        spacing: 8px;

        UiText {
            text: "OPENAPI";
            height: 18px;
            horizontal-stretch: 1;
            color: Theme.on_surface_variant;
            font-size: 12px;
            font-weight: 800;
            vertical-alignment: center;
            overflow: elide;
        }

        HorizontalLayout {
            height: 36px;
            spacing: 8px;
            alignment: center;

            TextField {
                text <=> root.file_path;
                placeholder: "spec path";
                mono: true;
                enabled: !root.busy;
                horizontal-stretch: 1;
                accepted => {
                    if !root.busy && root.file_path != "" {
                        root.import_openapi(root.file_path);
                    }
                }
            }

            ActionButton {
                text: "Open";
                enabled: !root.busy;
                button_width: 54px;
                clicked => {
                    root.pick_openapi_file();
                }
            }

            ActionButton {
                text: "Import";
                primary: true;
                enabled: !root.busy && root.file_path != "";
                button_width: 66px;
                clicked => {
                    root.import_openapi(root.file_path);
                }
            }
        }
    }
}
