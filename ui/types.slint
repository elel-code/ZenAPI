export struct RouteRow {
    method: string,
    path: string,
    summary: string,
}

export struct CollectionRow {
    id: int,
    method: string,
    name: string,
    url: string,
    is_folder: bool,
    folder_path: string,
}

export struct RunnerRow {
    method: string,
    name: string,
    status: string,
    detail: string,
    tone: string,
}

export struct MockLogRow {
    method: string,
    path: string,
    status: string,
}

export struct MockRuleRow {
    row_id: int,
    source: string,
    name: string,
    value: string,
    body_preview: string,
}

export struct VariableTableRow {
    row_id: int,
    scope: string,
    name: string,
    initial_value: string,
    current_value: string,
}

export struct EnvironmentRow {
    name: string,
    label: string,
    detail: string,
    tone: string,
}
