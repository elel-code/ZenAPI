export struct RouteRow {
    method: string,
    path: string,
    summary: string,
}

export struct MockLogRow {
    method: string,
    path: string,
    status: string,
}

export struct VariableTableRow {
    row_id: int,
    scope: string,
    name: string,
    initial_value: string,
    current_value: string,
}

export struct EnvironmentRow {
