import { CollectionRow, HistoryRow, RouteRow } from "types.slint";
import { Sidebar } from "sidebar.slint";

export component RequestSidebarPane inherits Sidebar {
    in-out property <[RouteRow]> workspace_routes;
    in-out property <[CollectionRow]> workspace_collection_rows;
    in-out property <[HistoryRow]> workspace_history_rows;
    in-out property <int> workspace_selected_route;
    in-out property <int> workspace_selected_collection_request;
    in-out property <string> workspace_selected_collection_folder;
    in-out property <string> workspace_collection_move_target_label;
    in-out property <string> workspace_collection_request_name;
    in-out property <string> workspace_collection_folder_name;
    in-out property <string> workspace_collection_name;
    in-out property <string> workspace_collection_path;
    in-out property <string> workspace_history_filter;
    in-out property <string> workspace_file_path;
    in property <string> workspace_collection_status;
    in property <string> workspace_spec_label;
    in property <bool> workspace_spec_loaded;
    in property <int> workspace_total_route_count;
    in property <bool> workspace_busy;

    callback workspace_import_openapi(string);
    callback workspace_pick_openapi_file();
    callback workspace_select_route(int);
    callback workspace_select_collection_request(int);
    callback workspace_rename_collection_request(int, string);
    callback workspace_duplicate_collection_request(int);
    callback workspace_delete_collection_request(int);
    callback workspace_move_collection_request(int, string);
    callback workspace_import_collection(string);
    callback workspace_add_collection_folder(string);
    callback workspace_rename_collection_folder(string, string);
    callback workspace_delete_collection_folder(string);
    callback workspace_save_current_request();
    callback workspace_save_collection(string);
    callback workspace_export_postman_collection(string);
    callback workspace_pick_collection_import_file();
    callback workspace_pick_collection_save_path();
    callback workspace_pick_postman_collection_path();
    callback workspace_select_history(int);
    callback workspace_filter_history(string);
    callback workspace_delete_history(int);
    callback workspace_clear_history();

    routes <=> root.workspace_routes;
    collection_rows <=> root.workspace_collection_rows;
    history_rows <=> root.workspace_history_rows;
    selected_route <=> root.workspace_selected_route;
    selected_collection_request <=> root.workspace_selected_collection_request;
    selected_collection_folder <=> root.workspace_selected_collection_folder;
    collection_move_target_label <=> root.workspace_collection_move_target_label;
    collection_request_name <=> root.workspace_collection_request_name;
    collection_folder_name <=> root.workspace_collection_folder_name;
    collection_name <=> root.workspace_collection_name;
    collection_path <=> root.workspace_collection_path;
    history_filter <=> root.workspace_history_filter;
    collection_status: root.workspace_collection_status;
    file_path <=> root.workspace_file_path;
    spec_label: root.workspace_spec_label;
    spec_loaded: root.workspace_spec_loaded;
    total_route_count: root.workspace_total_route_count;
    busy: root.workspace_busy;
    import_openapi(path) => {
        root.workspace_import_openapi(path);
    }
    pick_openapi_file => {
        root.workspace_pick_openapi_file();
    }
    select_route(index) => {
        root.workspace_select_route(index);
    }
    select_collection_request(id) => {
        root.workspace_select_collection_request(id);
    }
    rename_collection_request(id, name) => {
        root.workspace_rename_collection_request(id, name);
    }
    duplicate_collection_request(id) => {
        root.workspace_duplicate_collection_request(id);
    }
    delete_collection_request(id) => {
        root.workspace_delete_collection_request(id);
    }
    move_collection_request(id, folder_path) => {
        root.workspace_move_collection_request(id, folder_path);
    }
    import_collection(path) => {
        root.workspace_import_collection(path);
    }
    add_collection_folder(name) => {
        root.workspace_add_collection_folder(name);
    }
    rename_collection_folder(folder_path, name) => {
        root.workspace_rename_collection_folder(folder_path, name);
    }
    delete_collection_folder(folder_path) => {
        root.workspace_delete_collection_folder(folder_path);
    }
    save_current_request => {
        root.workspace_save_current_request();
    }
    save_collection(path) => {
        root.workspace_save_collection(path);
    }
    export_postman_collection(path) => {
        root.workspace_export_postman_collection(path);
    }
    pick_collection_import_file => {
        root.workspace_pick_collection_import_file();
    }
    pick_collection_save_path => {
        root.workspace_pick_collection_save_path();
    }
    pick_postman_collection_path => {
        root.workspace_pick_postman_collection_path();
    }
    select_history(id) => {
        root.workspace_select_history(id);
    }
    filter_history(query) => {
        root.workspace_filter_history(query);
    }
    delete_history(id) => {
        root.workspace_delete_history(id);
    }
    clear_history => {
        root.workspace_clear_history();
    }
}
