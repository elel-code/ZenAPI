import { Theme } from "theme.slint";
import { ActionButton, BodyModeButton, CodePane, DataPanel, LabeledEditor, TextField, UiText } from "widgets.slint";

export component RealtimeEditorPanel inherits Rectangle {
    in-out property <string> realtime_mode;
    in-out property <string> realtime_message;
    in-out property <string> websocket_message_mode;
    in-out property <string> websocket_protocols;
    in-out property <string> websocket_event_history;
    in-out property <string> sse_max_events;
    in-out property <string> sse_last_event_id;
    in-out property <bool> sse_streaming;
    in-out property <string> sse_event_history;
    in-out property <string> grpc_endpoint;
    in-out property <string> grpc_method;
    in-out property <string> grpc_metadata;
    in-out property <string> grpc_message;
    in-out property <string> grpc_method_catalog;
    in-out property <string> grpc_descriptor_path;
    in-out property <string> grpc_protoc_path;
    in-out property <bool> grpc_streaming;
    in property <bool> busy;
    callback open_websocket();
    callback run_websocket();
    callback close_websocket();
    callback copy_websocket_events();
    callback clear_websocket_events();
    callback run_sse();
    callback open_sse_stream();
    callback close_sse_stream();
    callback copy_sse_events();
    callback clear_sse_events();
    callback invoke_grpc_unary();
    callback invoke_grpc_server_streaming();
    callback stop_grpc_stream();
    callback build_grpc_draft();
    callback pick_grpc_descriptor_file();
    callback load_grpc_descriptor_set(string);
    callback load_grpc_proto_file(string, string);
    callback load_grpc_reflection();

    horizontal-stretch: 1;
    vertical-stretch: 1;
    background: transparent;

    VerticalLayout {
        padding: 0px;
        spacing: 12px;

        HorizontalLayout {
            height: 30px;
            spacing: 8px;
            alignment: center;

            for item in [
                { mode: "ws", label: "WebSocket", width: 104px },
                { mode: "sse", label: "SSE", width: 68px },
                { mode: "grpc", label: "gRPC", width: 72px },
            ]: BodyModeButton {
                mode: item.mode;
                label: item.label;
                button_width: item.width;
                selected: root.realtime_mode == item.mode;
                enabled: !root.busy;
                picked(mode) => {
                    root.realtime_mode = mode;
                }
            }

            Rectangle {
                horizontal-stretch: 1;
            }
        }

        if root.realtime_mode == "ws": HorizontalLayout {
            spacing: 12px;
            vertical-stretch: 1;

            Rectangle {
                horizontal-stretch: 1;
                vertical-stretch: 1;
                background: transparent;

                VerticalLayout {
                    padding: 0px;
                    spacing: 10px;

                    HorizontalLayout {
                        height: 34px;
                        spacing: 8px;
                        alignment: center;

                        BodyModeButton {
                            mode: "text";
                            label: "Text";
                            button_width: 58px;
                            selected: root.websocket_message_mode == "text";
                            enabled: !root.busy;
                            picked(mode) => {
                                root.websocket_message_mode = mode;
                            }
                        }

                        BodyModeButton {
                            mode: "binary";
                            label: "Binary";
                            button_width: 72px;
                            selected: root.websocket_message_mode == "binary";
                            enabled: !root.busy;
                            picked(mode) => {
                                root.websocket_message_mode = mode;
                            }
                        }

                        TextField {
                            text <=> root.websocket_protocols;
                            placeholder: "subprotocols: chat, superchat";
                            mono: true;
                            enabled: !root.busy;
                        }
                    }

                    LabeledEditor {
                        label: root.websocket_message_mode == "binary" ? "WebSocket Binary Bytes" : "WebSocket Message";
                        text <=> root.realtime_message;
                    }

                    if root.websocket_event_history == "": DataPanel {
                        height: 132px;
                        title: "WebSocket History";
                        body: "Open a session or send a one-shot message to capture sent and received frames here.";
                    }

                    if root.websocket_event_history != "": CodePane {
                        height: 180px;
                        text: root.websocket_event_history;
                        read_only: true;
                    }
                }
            }

            Rectangle {
                width: 190px;
                vertical-stretch: 1;
                background: Theme.surface_container;
                border-radius: 8px;
                border-width: 1px;
                border-color: Theme.outline_variant;

                VerticalLayout {
                    padding: 14px;
                    spacing: 10px;

                    UiText {
                        text: "SESSION";
                        height: 20px;
                        horizontal-stretch: 1;
                        color: Theme.on_surface_variant;
                        font-size: 12px;
                        font-weight: 800;
                        vertical-alignment: center;
                        overflow: elide;
                    }

                    ActionButton {
                        text: "Open";
                        button_width: 162px;
                        enabled: !root.busy;
                        clicked => {
                            root.open_websocket();
                        }
                    }

                    ActionButton {
                        text: "Send";
                        button_width: 162px;
                        primary: true;
                        enabled: !root.busy;
                        clicked => {
                            root.run_websocket();
                        }
                    }

                    ActionButton {
                        text: "End";
                        button_width: 162px;
                        warning: true;
                        enabled: !root.busy;
                        clicked => {
                            root.close_websocket();
                        }
                    }

                    ActionButton {
                        text: "Copy";
                        button_width: 162px;
                        enabled: root.websocket_event_history != "";
                        clicked => {
                            root.copy_websocket_events();
                        }
                    }

                    ActionButton {
                        text: "Clear";
                        button_width: 162px;
                        warning: true;
                        enabled: root.websocket_event_history != "";
                        clicked => {
                            root.clear_websocket_events();
                        }
                    }

                    UiText {
                        text: root.websocket_message_mode == "binary" ? "Binary mode sends hex bytes over an open session." : "Open uses request headers and subprotocols.";
                        horizontal-stretch: 1;
                        vertical-stretch: 1;
                        color: Theme.outline;
                        font-size: 12px;
                        vertical-alignment: top;
                        overflow: elide;
                    }
                }
            }
        }

        if root.realtime_mode == "sse": HorizontalLayout {
            spacing: 12px;
            vertical-stretch: 1;

            Rectangle {
                horizontal-stretch: 1;
                vertical-stretch: 1;
                background: transparent;

                VerticalLayout {
                    padding: 0px;
                    spacing: 10px;

                    TextField {
                        text <=> root.sse_max_events;
                        placeholder: "Preview event count";
                        mono: true;
                        enabled: !root.busy && !root.sse_streaming;
                    }

                    TextField {
                        text <=> root.sse_last_event_id;
                        placeholder: "Last-Event-ID";
                        mono: true;
                        enabled: !root.busy;
                    }

                    if root.sse_event_history == "": DataPanel {
                        title: root.sse_streaming ? "SSE Streaming" : "SSE Preview";
                        body: "Uses the request URL and request headers.\nLast-Event-ID is updated from incoming events when available.";
                    }

                    if root.sse_event_history != "": CodePane {
                        text: root.sse_event_history;
                        read_only: true;
                    }
                }
            }

            Rectangle {
                width: 190px;
                vertical-stretch: 1;
                background: Theme.surface_container;
                border-radius: 8px;
                border-width: 1px;
                border-color: Theme.outline_variant;

                VerticalLayout {
                    padding: 14px;
                    spacing: 10px;

                    UiText {
                        text: "EVENT STREAM";
                        height: 20px;
                        horizontal-stretch: 1;
                        color: Theme.on_surface_variant;
                        font-size: 12px;
                        font-weight: 800;
                        vertical-alignment: center;
                        overflow: elide;
                    }

                    ActionButton {
                        text: "Once";
                        button_width: 162px;
                        enabled: !root.busy && !root.sse_streaming;
                        clicked => {
                            root.run_sse();
                        }
                    }

                    ActionButton {
                        text: "Stream";
                        button_width: 162px;
                        primary: true;
                        enabled: !root.busy && !root.sse_streaming;
                        clicked => {
                            root.open_sse_stream();
                        }
                    }

                    ActionButton {
                        text: "Stop";
                        button_width: 162px;
                        warning: true;
                        enabled: root.sse_streaming;
                        clicked => {
                            root.close_sse_stream();
                        }
                    }

                    ActionButton {
                        text: "Copy";
                        button_width: 162px;
                        enabled: root.sse_event_history != "";
                        clicked => {
                            root.copy_sse_events();
                        }
                    }

                    ActionButton {
                        text: "Clear";
                        button_width: 162px;
                        warning: true;
                        enabled: !root.sse_streaming && root.sse_event_history != "";
                        clicked => {
                            root.clear_sse_events();
                        }
                    }
                }
            }
        }

        if root.realtime_mode == "grpc": HorizontalLayout {
            spacing: 12px;
            vertical-stretch: 1;

            Rectangle {
                horizontal-stretch: 1;
                vertical-stretch: 1;
                background: transparent;

                VerticalLayout {
                    padding: 0px;
                    spacing: 10px;

                    HorizontalLayout {
                        height: 36px;
                        spacing: 10px;

                        TextField {
                            text <=> root.grpc_endpoint;
                            placeholder: "http://localhost:50051";
                            mono: true;
                            enabled: !root.busy;
                        }

                        TextField {
                            text <=> root.grpc_method;
                            placeholder: "package.Service/Method";
                            mono: true;
                            enabled: !root.busy;
                        }
                    }

                    HorizontalLayout {
                        spacing: 12px;
                        vertical-stretch: 1;

                        LabeledEditor {
                            label: "Metadata";
                            text <=> root.grpc_metadata;
                        }

                        LabeledEditor {
                            label: "Message";
                            text <=> root.grpc_message;
                        }
                    }

                    LabeledEditor {
                        label: "Method Catalog";
                        text <=> root.grpc_method_catalog;
                        height: 92px;
                    }

                    HorizontalLayout {
                        height: 34px;
                        spacing: 8px;

                        TextField {
                            text <=> root.grpc_descriptor_path;
                            placeholder: "/absolute/path/to/schema.protoset or schema.proto";
                            mono: true;
                            enabled: !root.busy;
                            horizontal-stretch: 1;
                            accepted => {
                                if !root.busy && root.grpc_descriptor_path != "" {
                                    root.load_grpc_descriptor_set(root.grpc_descriptor_path);
                                }
                            }
                        }

                        ActionButton {
                            text: "Open";
                            button_width: 54px;
                            enabled: !root.busy && !root.grpc_streaming;
                            clicked => {
                                root.pick_grpc_descriptor_file();
                            }
                        }

                        ActionButton {
                            text: "Set";
                            button_width: 46px;
                            enabled: !root.busy && !root.grpc_streaming && root.grpc_descriptor_path != "";
                            clicked => {
                                root.load_grpc_descriptor_set(root.grpc_descriptor_path);
                            }
                        }

                        ActionButton {
                            text: "Proto";
                            button_width: 58px;
                            enabled: !root.busy && !root.grpc_streaming && root.grpc_descriptor_path != "";
                            clicked => {
                                root.load_grpc_proto_file(root.grpc_descriptor_path, root.grpc_protoc_path);
                            }
                        }
                    }

                    HorizontalLayout {
                        height: 34px;
                        spacing: 8px;

                        TextField {
                            text <=> root.grpc_protoc_path;
                            placeholder: "protoc";
                            mono: true;
                            enabled: !root.busy;
                            horizontal-stretch: 1;
                            accepted => {
                                if !root.busy && root.grpc_descriptor_path != "" {
                                    root.load_grpc_proto_file(root.grpc_descriptor_path, root.grpc_protoc_path);
                                }
                            }
                        }
                    }
                }
            }

            Rectangle {
                width: 190px;
                vertical-stretch: 1;
                background: Theme.surface_container;
                border-radius: 8px;
                border-width: 1px;
                border-color: Theme.outline_variant;

                VerticalLayout {
                    padding: 14px;
                    spacing: 10px;

                    UiText {
                        text: "REQUEST";
                        height: 20px;
                        horizontal-stretch: 1;
                        color: Theme.on_surface_variant;
                        font-size: 12px;
                        font-weight: 800;
                        vertical-alignment: center;
                        overflow: elide;
                    }

                    ActionButton {
                        text: "Invoke";
                        button_width: 162px;
                        primary: true;
                        enabled: !root.busy && !root.grpc_streaming && root.grpc_endpoint != "" && root.grpc_method != "";
                        clicked => {
                            root.invoke_grpc_unary();
                        }
                    }

                    ActionButton {
                        text: "Stream";
                        button_width: 162px;
                        enabled: !root.busy && !root.grpc_streaming && root.grpc_endpoint != "" && root.grpc_method != "";
                        clicked => {
                            root.invoke_grpc_server_streaming();
                        }
                    }

                    ActionButton {
                        text: "Stop";
                        button_width: 162px;
                        warning: true;
                        enabled: root.grpc_streaming;
                        clicked => {
                            root.stop_grpc_stream();
                        }
                    }

                    ActionButton {
                        text: "Build";
                        button_width: 162px;
                        enabled: !root.busy && !root.grpc_streaming;
                        clicked => {
                            root.build_grpc_draft();
                        }
                    }

                    ActionButton {
                        text: "Reflect";
                        button_width: 162px;
                        enabled: !root.busy && !root.grpc_streaming && root.grpc_endpoint != "";
                        clicked => {
                            root.load_grpc_reflection();
                        }
                    }

                    Rectangle {
                        horizontal-stretch: 1;
                        vertical-stretch: 1;
                        background: transparent;
                    }
                }
            }
        }
    }
}
